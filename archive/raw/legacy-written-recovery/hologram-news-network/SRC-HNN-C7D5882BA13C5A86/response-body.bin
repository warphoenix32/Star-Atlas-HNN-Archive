s-d9dd9822ae9f","title":"Star Atlas To Sell $5 Million Dollar ‘Titan’ Ships","clapCount":0,"statusForCollection":null,"pinnedAt":0,"pinnedByCreatorAt":0,"curationEligibleAt":0,"responseDistribution":"NOT_DISTRIBUTED","inResponseToPostResult":null,"inResponseToCatalogResult":null,"pendingCollection":null,"isNewsletter":false,"isAuthorNewsletter":true,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"}],"readingTime":2.233018867924528,"inResponseToEntityType":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1669169469211,"previewContent":{"__typename":"PreviewContent","subtitle":"In the wake of the FTX fallout which negatively impacted game developer Automata, the company behind Star Atlas announced a series of…"},"previewImage":{"__ref":"ImageMetadata:0*jqVvPF_h7gKOwMmI.jpg"},"isShortform":false,"seoTitle":"","updatedAt":1669169469471,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"isSuspended":false,"responseRootPost":{"__typename":"ResponseRootPost","post":{"__ref":"Post:d9dd9822ae9f"}},"internalLinks({\"paging\":{\"limit\":8}})":{"__typename":"InternalLinksConnection","items":[]},"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}},"Post:bff20fd1e3c":{"__typename":"Post","id":"bff20fd1e3c"},"Paragraph:d30bb6ae23bb_0":{"__typename":"Paragraph","id":"d30bb6ae23bb_0","name":"d000","type":"H3","href":null,"layout":null,"metadata":null,"text":"Star Atlas To Sell $5 Million Dollar ‘Titan’ Ships","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_1":{"__typename":"Paragraph","id":"d30bb6ae23bb_1","name":"eaed","type":"P","href":null,"layout":null,"metadata":null,"text":"In the wake of the FTX fallout which negatively impacted game developer Automata, the company behind Star Atlas announced a series of upcoming sales to help raise new revenue.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":48,"end":56,"href":"https:\u002F\u002Fmedium.com\u002Fblockchain-biz\u002Fstar-atlas-heavily-affected-by-ftx-catastrophe-ceo-remains-committed-180cf3c2f5a9","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:375679fc6dac6b805dfe4407bfe6a06a":{"__typename":"MediaResource","id":"375679fc6dac6b805dfe4407bfe6a06a","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?type=text%2Fhtml&key=a19fcc184b9711e1b4764040d3dc5c07&schema=twitter&url=https%3A\u002F\u002Ftwitter.com\u002Fstaratlas\u002Fstatus\u002F1594950847263567872&image=https%3A\u002F\u002Fi.embed.ly\u002F1\u002Fimage%3Furl%3Dhttps%253A%252F%252Fabs.twimg.com%252Ferrors%252Flogo46x38.png%26key%3Da19fcc184b9711e1b4764040d3dc5c07","iframeHeight":281,"iframeWidth":500,"title":"Star Atlas on Twitter: \"🚀 Start Sequence Alert: 🚀The countdown is on. Flight of the Titans begins Wednesday, November 23, at 12 PM EST.Three Titan ships. One historic moment: The doorstep of a Golden Era.📜 Read the Manifesto now: https:\u002F\u002Ft.co\u002FuHVzmR0Sl3 pic.twitter.com\u002FrXbuU9WmCR \u002F Twitter\""},"Paragraph:d30bb6ae23bb_2":{"__typename":"Paragraph","id":"d30bb6ae23bb_2","name":"16a3","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:375679fc6dac6b805dfe4407bfe6a06a"}},"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_3":{"__typename":"Paragraph","id":"d30bb6ae23bb_3","name":"bd2e","type":"P","href":null,"layout":null,"metadata":null,"text":"Beginning on Wednesday, November 23rd, three Titan class ships will be listed on the Star Atlas marketplace. The Titans will retail for $1 million dollars initially, an 80% markdown from their $5 million dollar valuation.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_4":{"__typename":"Paragraph","id":"d30bb6ae23bb_4","name":"42b4","type":"P","href":null,"layout":null,"metadata":null,"text":"Every week thereafter, the price for each Titan will increase by $500,000, reaching $2.5 million by the end of Week 4. At the end of 4 weeks, any unsold Titan ships will be delisted from the Star Atlas marketplace to be sold at a future date.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_5":{"__typename":"Paragraph","id":"d30bb6ae23bb_5","name":"4736","type":"P","href":null,"layout":null,"metadata":null,"text":"Should any of these ‘Titans’ sell, it would be the second largest single item purchase in a video game to date. The current most expensive video game item ever sold was Planet Calypso in Entropia which sold for $6 million dollars.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_6":{"__typename":"Paragraph","id":"d30bb6ae23bb_6","name":"23b0","type":"P","href":null,"layout":null,"metadata":null,"text":"Buyers in a Bear Market","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":23,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_7":{"__typename":"Paragraph","id":"d30bb6ae23bb_7","name":"872b","type":"P","href":null,"layout":null,"metadata":null,"text":"The 2022 bear market has been a harsh environment for blockchain games. Nevertheless, potential buyers are lining up to be one of the first Titan purchasers in the history of Star Atlas. The three most prominent guilds in Star Atlas — Quimera, The Club, and Aephia Industries are all predicted to be in strong financial positions to become Titan owners.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_8":{"__typename":"Paragraph","id":"d30bb6ae23bb_8","name":"8f57","type":"P","href":null,"layout":null,"metadata":null,"text":"The sale of Titan ships is part of Star Atlas’s SAGE: Star Sequence, an initiative by the game developer to ramp up player interest prior to a test launch of its Star Atlas Golden Era browser game towards the end of the year.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":48,"end":67,"href":"https:\u002F\u002Fmedium.com\u002Fstar-atlas\u002Fstar-atlas-golden-era-start-sequence-our-path-towards-tomorrow-cb7d51f19c84","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_9":{"__typename":"Paragraph","id":"d30bb6ae23bb_9","name":"41fb","type":"P","href":null,"layout":null,"metadata":null,"text":"Community sentiment remains mixed, mostly due to the overall bear market conditions and FTX contagion. On the positive side, players are looking forward to purchasing Central Space Station Land Sales and mining claims.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":189,"end":199,"href":"https:\u002F\u002Fmedium.com\u002Fblockchain-biz\u002Fstar-atlas-land-and-player-habitat-sales-begins-in-december-4b342a305573","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_10":{"__typename":"Paragraph","id":"d30bb6ae23bb_10","name":"d599","type":"P","href":null,"layout":null,"metadata":null,"text":"Three Titans For Sale","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":21,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*OGaJPwdHVWcswQmV.jpg":{"__typename":"ImageMetadata","id":"0*OGaJPwdHVWcswQmV.jpg","originalHeight":966,"originalWidth":2000,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d30bb6ae23bb_11":{"__typename":"Paragraph","id":"d30bb6ae23bb_11","name":"5940","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*OGaJPwdHVWcswQmV.jpg"},"text":"Pearce T1","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*jqVvPF_h7gKOwMmI.jpg":{"__typename":"ImageMetadata","id":"0*jqVvPF_h7gKOwMmI.jpg","originalHeight":1125,"originalWidth":2000,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d30bb6ae23bb_12":{"__typename":"Paragraph","id":"d30bb6ae23bb_12","name":"9b92","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*jqVvPF_h7gKOwMmI.jpg"},"text":"Busan The Last Stand Mk. VIII","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*EEvFBMltJgULlD8t.png":{"__typename":"ImageMetadata","id":"0*EEvFBMltJgULlD8t.png","originalHeight":961,"originalWidth":2000,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d30bb6ae23bb_13":{"__typename":"Paragraph","id":"d30bb6ae23bb_13","name":"56b0","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*EEvFBMltJgULlD8t.png"},"text":"Fimbul ECOS Superphoenix","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_14":{"__typename":"Paragraph","id":"d30bb6ae23bb_14","name":"0d10","type":"P","href":null,"layout":null,"metadata":null,"text":"The sale of Titans begins on November 23 at 12 pm Eastern Standard Time. Don’t forget to follow and subscribe to find out who becomes the million dollar owner of these high-valued assets.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_15":{"__typename":"Paragraph","id":"d30bb6ae23bb_15","name":"f9bb","type":"P","href":null,"layout":null,"metadata":null,"text":"Disclaimers:\nThe author holds assets in the game of Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":63,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_16":{"__typename":"Paragraph","id":"d30bb6ae23bb_16","name":"9ddf","type":"P","href":null,"layout":null,"metadata":null,"text":"Current market conditions present significant risk in the crypto environment. This article is in no way an endorsement of any investment proposals by the reader.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":161,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_17":{"__typename":"Paragraph","id":"d30bb6ae23bb_17","name":"78ee","type":"P","href":null,"layout":null,"metadata":null,"text":"This article is in no way endorsed by Star Atlas or ATMTA, Inc.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":63,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_18":{"__typename":"Paragraph","id":"d30bb6ae23bb_18","name":"0a59","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs is the founder of The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of the Star Atlas game. Krigs has covered Star Atlas for the past year and enjoys writing about the potential that blockchain technology has to revolutionize the gaming industry.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_19":{"__typename":"Paragraph","id":"d30bb6ae23bb_19","name":"db3a","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d30bb6ae23bb_20":{"__typename":"Paragraph","id":"d30bb6ae23bb_20","name":"3a51","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs: https:\u002F\u002Ftwitter.com\u002FKrigsfoniks\nThe Hologram: https:\u002F\u002Ftwitter.com\u002FHologram_News","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":7,"end":38,"href":"https:\u002F\u002Ftwitter.com\u002FKrigsfoniks","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":53,"end":86,"href":"https:\u002F\u002Ftwitter.com\u002FHologram_News","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas"}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"HIT","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.420c009b.js"></script><script src="https://cdn-client.medium.com/lite/static/js/3034.5bf7db30.js"></script><script src="https://cdn-client.medium.com/lite/static/js/main.0ccc29bc.js"></script><script src="https://cdn-client.medium.com/lite/static/js/instrumentation.c71f0248.chunk.js"></script>

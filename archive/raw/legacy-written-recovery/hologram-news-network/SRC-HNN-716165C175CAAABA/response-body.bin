,"googleAnalyticsId":null,"editors":[{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:41e0c5b141f1"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:b0bf38de9190"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:ed24b40c4906"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:35ffdccaa5dc"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:ab6dbce60d64"}}],"name":"The Hologram","avatar":{"__ref":"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg"},"domain":null,"slug":"the-hologram","description":"Daily Star Atlas news by The Hologram. Politics, economics and community coverage. Get the trusted information you need to stay one step ahead of your competition.","subscriberCount":149,"viewerEdge":{"__ref":"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_ae21d4320d0d"},"twitterUsername":"Hologram_News","facebookPageId":null,"logo":{"__ref":"ImageMetadata:"}},"ImageMetadata:":{"__typename":"ImageMetadata","id":"","originalWidth":0,"originalHeight":0},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","name":"Krigs","username":"krigsfoniks","newsletterV3":{"__ref":"NewsletterV3:85fc9c436e2e"},"linkedAccounts":{"__ref":"LinkedAccounts:41e0c5b141f1"},"isSuspended":false,"imageId":"1*pVxyLAandIa00EX6ZGRERw.png","mediumMemberAt":1667603125000,"verifications":{"__typename":"VerifiedInfo","isBookAuthor":false},"socialStats":{"__typename":"SocialStats","followerCount":240},"customDomainState":null,"hasSubdomain":false,"bio":"Founder | Crypto | Star Atlas |","isPartnerProgramEnrolled":true,"viewerEdge":{"__ref":"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_ae21d4320d0d"},"viewerIsUser":false,"postSubscribeMembershipUpsellShownAt":0,"allowNotes":true,"membership":{"__ref":"Membership:4bbb830162b9"},"twitterScreenName":"Hologram_News"},"User:b0bf38de9190":{"__typename":"User","id":"b0bf38de9190"},"User:ed24b40c4906":{"__typename":"User","id":"ed24b40c4906"},"User:35ffdccaa5dc":{"__typename":"User","id":"35ffdccaa5dc"},"User:ab6dbce60d64":{"__typename":"User","id":"ab6dbce60d64"},"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg"},"LinkedAccounts:41e0c5b141f1":{"__typename":"LinkedAccounts","mastodon":null,"id":"41e0c5b141f1"},"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_ae21d4320d0d":{"__typename":"UserViewerEdge","id":"userId:41e0c5b141f1-viewerId:lo_ae21d4320d0d","isFollowing":false,"isUser":false},"NewsletterV3:85fc9c436e2e":{"__typename":"NewsletterV3","id":"85fc9c436e2e","type":"NEWSLETTER_TYPE_AUTHOR","slug":"41e0c5b141f1","name":"41e0c5b141f1","collection":null,"user":{"__ref":"User:41e0c5b141f1"}},"Paragraph:489ebf184408_0":{"__typename":"Paragraph","id":"489ebf184408_0","name":"9832","type":"H3","href":null,"layout":null,"metadata":null,"text":"Star Atlas Has A Major Security Dilemma","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_1":{"__typename":"Paragraph","id":"489ebf184408_1","name":"e39d","type":"P","href":null,"layout":null,"metadata":null,"text":"Despite the recent success of Star Atlas, a major security dilemma exists that not even Kudelski Security can prevent.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_2":{"__typename":"Paragraph","id":"489ebf184408_2","name":"4300","type":"P","href":null,"layout":null,"metadata":null,"text":"Thankfully, the growing security dilemma within Star Atlas has nothing to do with any underlying blockchain or program at all. Instead, the emergent security dilemma stems from the nascent formation of guilds and the intergalactic order as Star Atlas prepares for the future release of player vs player combat.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":136,"end":309,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*NWPfUrhl2ybv30jF4j9LkQ.png":{"__typename":"ImageMetadata","id":"1*NWPfUrhl2ybv30jF4j9LkQ.png","originalHeight":512,"originalWidth":512,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:489ebf184408_3":{"__typename":"Paragraph","id":"489ebf184408_3","name":"ecaa","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*NWPfUrhl2ybv30jF4j9LkQ.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_4":{"__typename":"Paragraph","id":"489ebf184408_4","name":"1abd","type":"H3","href":null,"layout":null,"metadata":null,"text":"What is a Security Dilemma?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_5":{"__typename":"Paragraph","id":"489ebf184408_5","name":"0323","type":"P","href":null,"layout":null,"metadata":null,"text":"Now that we have your attention, we can lay out what this political security dilemma is, how its already occurring in Star Atlas, and the conditions under which the first large scale conflict in Star Atlas will likely occur.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_6":{"__typename":"Paragraph","id":"489ebf184408_6","name":"f297","type":"P","href":null,"layout":null,"metadata":null,"text":"But first, what is a security dilemma?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":38,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_7":{"__typename":"Paragraph","id":"489ebf184408_7","name":"31bd","type":"P","href":null,"layout":null,"metadata":null,"text":"The Security Dilemma theory was first coined by political scholars Herbert Butterfield, John H. Herz, and Robert Jervis. In the field of international relations, the security dilemma theory is when the increase in one state’s security, generally through military strength, leads other states to fear for their own security. Because states do not know if the security-increasing state intends to use its growing military for offensive purposes, other states conclude that they must increase their own self security to prevent and threats.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":67,"end":86,"href":"https:\u002F\u002Fen.wikipedia.org\u002Fwiki\u002FHerbert_Butterfield","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":88,"end":100,"href":"https:\u002F\u002Fen.wikipedia.org\u002Fwiki\u002FJohn_H._Herz","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":106,"end":119,"href":"https:\u002F\u002Fen.wikipedia.org\u002Fwiki\u002FRobert_Jervis","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":137,"end":160,"href":"https:\u002F\u002Fen.wikipedia.org\u002Fwiki\u002FInternational_relations","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":166,"end":182,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_8":{"__typename":"Paragraph","id":"489ebf184408_8","name":"337f","type":"P","href":null,"layout":null,"metadata":null,"text":"In response, the first security raising state responds to others reactive measures and continues to bolster its own military strength. Thus, a spiral model ensues of continuous escalation.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_9":{"__typename":"Paragraph","id":"489ebf184408_9","name":"94b2","type":"P","href":null,"layout":null,"metadata":null,"text":"Furthermore, Herz and Jervis assert that security dilemmas can lead to alliance formation and arms races, something that is already occurring in Star Atlas. In Earth history, Security dilemmas were major contributing causes of conflict in both World War I and The Cold War.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":41,"end":70,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":71,"end":89,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":94,"end":104,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":175,"end":273,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_10":{"__typename":"Paragraph","id":"489ebf184408_10","name":"debf","type":"H3","href":null,"layout":null,"metadata":null,"text":"How does this apply to Star Atlas?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_11":{"__typename":"Paragraph","id":"489ebf184408_11","name":"001f","type":"P","href":null,"layout":null,"metadata":null,"text":"For some time, DACs (Guilds) have been considered player-states or state-like entities within Star Atlas. Earlier this year, we covered how some current Guild-States presented their intergalactic policies and diplomatic stances towards others within Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":153,"end":219,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fthe-guild-state-a-framework-for-understanding-guild-behavior-in-star-atlas-946af14901cf","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_12":{"__typename":"Paragraph","id":"489ebf184408_12","name":"17c1","type":"P","href":null,"layout":null,"metadata":null,"text":"Since Star Atlas DACs will have both political influence and territorial control, qualities that resemble states, it is logical to substitute Star Atlas DACs for traditional state systems under the security dilemma model and reasonable to assume that behaviors that govern nation states will also govern Guild-States. Theories that apply to international relations and nation-states see parallel application in intergalactic relations and Guild-States.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_13":{"__typename":"Paragraph","id":"489ebf184408_13","name":"f732","type":"H3","href":null,"layout":null,"metadata":null,"text":"The Great Galia Arms Race","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_14":{"__typename":"Paragraph","id":"489ebf184408_14","name":"396d","type":"P","href":null,"layout":null,"metadata":null,"text":"Star Atlas is, in part, a game of galactic conquest and territorial control. It’s no surprise then, that Guild-States seek to advance their own power and security relative to other Guild-States. This is done primarily through the acquisition of combat ships in increasingly larger quantities and power.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_15":{"__typename":"Paragraph","id":"489ebf184408_15","name":"c10c","type":"P","href":null,"layout":null,"metadata":null,"text":"Large guilds like ROME and The Club are capable of fielding multiple Commander level ships, formidable machines of war that would make any Guild-State hesitate. Smaller Guild-States also seek to advance their security through ship acquisitions, however since they cannot scale at the same rate as larger Guild-States, they must rely more heavily on alliance formation.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_16":{"__typename":"Paragraph","id":"489ebf184408_16","name":"9546","type":"P","href":null,"layout":null,"metadata":null,"text":"Thus as Guild-States advance their own security, whether for peaceful purposes or not, calculations of power-balance are conducted by other Guild-States thus driving the security dilemma endlessly.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":5,"end":196,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_17":{"__typename":"Paragraph","id":"489ebf184408_17","name":"a326","type":"P","href":null,"layout":null,"metadata":null,"text":"Even self-described neutral Guild-States like Aephia are not immune from the pressure of the security dilemma. Sources report that a well known Aephia member unsuccessfully attempted to infiltrate The Club through covert methods. Sources report that this operation was unsanctioned by Aephia leadership and was thus acting alone. However, this brings into question of how successful can large Guild-States be at ensuring their members do not violate their own diplomatic policies? In the case of World War I, the unsanctioned actions of a small group of Bosnian-Serbs ignited a conflict that claimed millions of lives.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":368,"end":480,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_18":{"__typename":"Paragraph","id":"489ebf184408_18","name":"e81a","type":"H3","href":null,"layout":null,"metadata":null,"text":"Alliances — How they started World War 1 and how they’ll start the first Galactic Galia War","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_19":{"__typename":"Paragraph","id":"489ebf184408_19","name":"b3ff","type":"P","href":null,"layout":null,"metadata":null,"text":"World War 1 began with the assassination of Archduke Franz Ferdinand of Austria-Hungary. What would have been a conflict between two nations, quickly spiraled into a broader conflict the engulfed the world due to a complex layer of alliances. Some of these alliances were also secret alliances, which further exacerbated diplomacy efforts preceding the war.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_20":{"__typename":"Paragraph","id":"489ebf184408_20","name":"eb94","type":"P","href":null,"layout":null,"metadata":null,"text":"In Star Atlas, these conditions are already forming. Aside from Guild-States themselves, powerful faction aligned groups like the Oni Consortium, The Ustur Nexus, and the Mud Consortium have formed within the recent months. Ironically, these faction based groups formed largely out of discussions over perceived threats from the other factions, thus validating to some degree, the existence of a security dilemma in Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":350,"end":427,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_21":{"__typename":"Paragraph","id":"489ebf184408_21","name":"4838","type":"P","href":null,"layout":null,"metadata":null,"text":"Further complicating the diplomatic landscape are direct alliances between Guild-States, both public and secret. Over the past two years, alliances have already taken shape within Star Atlas. Interstellar Alliance was first on the scene, consolidating a large group of guild-states under its umbrella. However, in recent times, the validity of Interstellar Alliance mutual defense pact has come under question given faction conflicts.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_22":{"__typename":"Paragraph","id":"489ebf184408_22","name":"5f34","type":"P","href":null,"layout":null,"metadata":null,"text":"Perhaps the most notable alliance in recent history is that between Aephia and Quimera. Other major Guild-States took quick note of the announcement and quickly began evaluating their own positions in comparison.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_23":{"__typename":"Paragraph","id":"489ebf184408_23","name":"cca4","type":"P","href":null,"layout":null,"metadata":null,"text":"Even more recently, the alliance between Rome and Yield Guild Games drew the attention of the entire Star Atlas community as a notable and significant partnership.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":50,"end":67,"href":null,"anchorType":"USER","userId":"5ddf82148dcd","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_24":{"__typename":"Paragraph","id":"489ebf184408_24","name":"eeb5","type":"P","href":null,"layout":null,"metadata":null,"text":"However, these large alliances do not account for the numerous secret or discrete alliances between Guild-States.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_25":{"__typename":"Paragraph","id":"489ebf184408_25","name":"b464","type":"P","href":null,"layout":null,"metadata":null,"text":"As smaller Guild-States seek to balance the power of larger Guild-States, alliances will continue to form. While the assassination of a Star Atlas Grand Duke is unlikely to be the direct cause of conflict, a simple miscalculation of the diplomatic environment could quickly engulf all of Galia.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_26":{"__typename":"Paragraph","id":"489ebf184408_26","name":"cd55","type":"H3","href":null,"layout":null,"metadata":null,"text":"How to Prevent or Mitigate The Security Dilemma","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_27":{"__typename":"Paragraph","id":"489ebf184408_27","name":"3793","type":"P","href":null,"layout":null,"metadata":null,"text":"Following World War 1, the League of Nations was established. One of the functions of the League of Nations was to ensure diplomacy, alliances, and treaty making were done in a transparent and open nature. Although the League of Nations was dissolved, its successor the United Nations is the primary venue for all global diplomacy.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_28":{"__typename":"Paragraph","id":"489ebf184408_28","name":"ffb4","type":"P","href":null,"layout":null,"metadata":null,"text":"The shift from direct diplomacy between nation-states towards transparent international diplomacy greatly reduced the security dilemma’s potential to cause conflict. Even following the Cold War, treaties between the United States and Soviet Union acknowledged the need for open dialogue to prevent nuclear arms races.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_29":{"__typename":"Paragraph","id":"489ebf184408_29","name":"ff4d","type":"P","href":null,"layout":null,"metadata":null,"text":"However, no such intergalactic forum or equivalent exists in Star Atlas. Guild-States negotiate in direct messages or private groups, with no consolidated registrar of acknowledged treaties between states. To avoid future conflict due to security dilemmas, an intergalactic diplomatic forum should be established to facilitate discussions of such nature. Until then, Star Atlas is rife for a continuation of the security dilemma model and before long, conflict will emerge as the norm.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_30":{"__typename":"Paragraph","id":"489ebf184408_30","name":"9253","type":"H3","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_31":{"__typename":"Paragraph","id":"489ebf184408_31","name":"fc25","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":5,"href":"https:\u002F\u002Fmedium.com\u002Fu\u002F41e0c5b141f1","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":5,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_32":{"__typename":"Paragraph","id":"489ebf184408_32","name":"2767","type":"P","href":null,"layout":null,"metadata":null,"text":"An ardent supporter of emerging technologies, Krigs has been covering blockchain games for over two years and believes passionately in their power to revolutionize our collective gaming experience.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_33":{"__typename":"Paragraph","id":"489ebf184408_33","name":"b16d","type":"H3","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_34":{"__typename":"Paragraph","id":"489ebf184408_34","name":"4fcd","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is an independent community news network. Our vision is to become the most trusted source of information about blockchain games and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:489ebf184408_35":{"__typename":"Paragraph","id":"489ebf184408_35","name":"7926","type":"P","href":null,"layout":null,"metadata":null,"text":"Any information published by The Hologram or its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_ae21d4320d0d":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_ae21d4320d0d","isEditor":false},"Membership:4bbb830162b9":{"__typename":"Membership","tier":"MEMBER","id":"4bbb830162b9"},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"Tag:politics":{"__typename":"Tag","id":"politics","displayTitle":"Politics","normalizedTagSlug":"politics"},"Post:b8aa65da5136":{
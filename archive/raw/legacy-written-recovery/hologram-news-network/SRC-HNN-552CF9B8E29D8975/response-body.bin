769230769},"NewsletterV3:ac886d6987e0":{"__typename":"NewsletterV3","slug":"hologram-weekly-digest","id":"ac886d6987e0","name":"Hologram Weekly Digest","description":"Catch the latest Star Atlas news from the Hologram every week.","promoHeadline":"","promoBody":"","type":"NEWSLETTER_TYPE_COLLECTION","user":{"__ref":"User:41e0c5b141f1"},"collection":{"__ref":"Collection:4d89daa6ae31"},"showPromo":true},"Post:b0b42c517aa0":{"__typename":"Post","id":"b0b42c517aa0"},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","name":"Krigs","username":"krigsfoniks","newsletterV3":{"__ref":"NewsletterV3:85fc9c436e2e"},"atsQualifiedAt":1650725917596},"NewsletterV3:85fc9c436e2e":{"__typename":"NewsletterV3","id":"85fc9c436e2e"},"PostViewerEdge:postId:8af1dcd408b9-viewerId:lo_cf94bbd4b552":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:8af1dcd408b9-viewerId:lo_cf94bbd4b552"},"Paragraph:c7e974b7fba_0":{"__typename":"Paragraph","id":"c7e974b7fba_0","name":"0e83","type":"H3","href":null,"layout":null,"metadata":null,"text":"Decoding Galia — What We Know About the Lore of Star Atlas Part I: Factions","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_1":{"__typename":"Paragraph","id":"c7e974b7fba_1","name":"c5ee","type":"P","href":null,"layout":null,"metadata":null,"text":"Hello my dear explorers of the Star Atlas metaverse, this is USTUR Jall.doer, a nomad and explorer of the outer sector of the second ring of Galia, our known universe to date, year 2622 of the Golden Era. Today, I bring with me a small data cube with information known in many corners of the galaxy, stories that still echo in the confines of the collective consciousness of each race of the metaverse.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":31,"end":41,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*6NQ_mwVwR0WXfATTuEPUXQ.jpeg":{"__typename":"ImageMetadata","id":"1*6NQ_mwVwR0WXfATTuEPUXQ.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c7e974b7fba_2":{"__typename":"Paragraph","id":"c7e974b7fba_2","name":"8c15","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*6NQ_mwVwR0WXfATTuEPUXQ.jpeg"},"text":"A path through history","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_3":{"__typename":"Paragraph","id":"c7e974b7fba_3","name":"906c","type":"H3","href":null,"layout":null,"metadata":null,"text":"Three Factions, three fates colliding at a single point","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_4":{"__typename":"Paragraph","id":"c7e974b7fba_4","name":"0baa","type":"P","href":null,"layout":null,"metadata":null,"text":"We cannot fully grasp the story in Star Atlas without understanding the key players. The galaxy within this amazing metaverse is home to various races, but as with any tale, there are characters that shape the direction and outcome.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_5":{"__typename":"Paragraph","id":"c7e974b7fba_5","name":"cb17","type":"P","href":null,"layout":null,"metadata":null,"text":"An old USTUR sage once said, “The past is a mirror that reflects glimpses of the future.” Don’t miss your chance to explore this incredible universe and uncover its secrets!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_6":{"__typename":"Paragraph","id":"c7e974b7fba_6","name":"31a4","type":"H4","href":null,"layout":null,"metadata":null,"text":"Manus Ultimus Divinum (MUD) — Enhanced humans who sacrificed everything to reach the stars","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*MYwQw86T9PXA733hgEbNUQ.jpeg":{"__typename":"ImageMetadata","id":"1*MYwQw86T9PXA733hgEbNUQ.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c7e974b7fba_7":{"__typename":"Paragraph","id":"c7e974b7fba_7","name":"62f7","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*MYwQw86T9PXA733hgEbNUQ.jpeg"},"text":"MUD Statue","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_8":{"__typename":"Paragraph","id":"c7e974b7fba_8","name":"5132","type":"P","href":null,"layout":null,"metadata":null,"text":"Let’s start with the currently most numerous faction within Star Atlas and perhaps the most underestimated due to its short history in the galaxy. As the History Mural tells us,","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_9":{"__typename":"Paragraph","id":"c7e974b7fba_9","name":"9e78","type":"P","href":null,"layout":null,"metadata":null,"text":"“The MUD are a faction of humans who travel through space and originate from their home planet, Earth. After joining together under a common cause inspired by a benevolent Photoli explorer, the humans used the resources of Earth to set off towards the stars.”","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":1,"end":257,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_10":{"__typename":"Paragraph","id":"c7e974b7fba_10","name":"389f","type":"P","href":null,"layout":null,"metadata":null,"text":"When we talk about humans, we will always find inconsistent details marked by manipulation from those who with their power shaped the stories that reveal their past to us. The truth within a faction as marked by time is difficult to find. Let’s see what were the most important moments of its known history.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*lZuRShEv_T1gB4i7CEpIkg.jpeg":{"__typename":"ImageMetadata","id":"1*lZuRShEv_T1gB4i7CEpIkg.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c7e974b7fba_11":{"__typename":"Paragraph","id":"c7e974b7fba_11","name":"1e9a","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*lZuRShEv_T1gB4i7CEpIkg.jpeg"},"text":"Ahr Visits Earth","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":16,"href":"https:\u002F\u002Fplay.staratlas.com\u002Fmarket\u002F6bD8mr8DyuVqN5dXd1jnqmCL66b5KUV14jYY1HSmnxTE\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_12":{"__typename":"Paragraph","id":"c7e974b7fba_12","name":"a321","type":"P","href":null,"layout":null,"metadata":null,"text":"The Photoli, the most mysterious race in the known universe, are beings of pure energy that are often mistaken for gods or supernatural entities. The event that marked the beginning of the journey to the stars by humans was the work of one of these beings. Without apparent reason, Ahr descended to Earth and through his mastery of light, created an incredible illusion to impress all the inhabitants of the planet. This being presented himself as a God who came to guide a crusade to the stars, calling on all humans to join and embark on this new journey. The humans, blinded by the revelation and united by their belief in this new crusade, decided to embark on this path regardless of the cost.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":282,"end":304,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_13":{"__typename":"Paragraph","id":"c7e974b7fba_13","name":"05d3","type":"P","href":null,"layout":null,"metadata":null,"text":"We do not have the details of this moment in history and the reason why this message from Ahr resonated so much in the souls of an entire race, it would be impossible to recreate the exact scenario in which this occurred, but history tells us that this was the place and time where the seed of the MUD empire was planted.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_14":{"__typename":"Paragraph","id":"c7e974b7fba_14","name":"4d63","type":"P","href":null,"layout":null,"metadata":null,"text":"Humanity paid a very high price for its rapid expansion, Earth, their birthplace, was completely destroyed by the industry that fueled the creation of ships, exploration technology, and weapons that constituted their developing empire.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_15":{"__typename":"Paragraph","id":"c7e974b7fba_15","name":"3439","type":"P","href":null,"layout":null,"metadata":null,"text":"This was a hard blow to their collective consciousness as they felt that their foundation as a species had suffered a lot, the human has always been attached to the history of their ancestors and their birthplace was the most precious treasure for countless generations. The destruction of Earth not only left humans morally devastated, much knowledge was lost forever and others scattered throughout the galaxy, stored as treasures within the satellites orbiting Earth at the time of its destruction.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*YnG7VJ83ehNw-sFdMHY7xg.jpeg":{"__typename":"ImageMetadata","id":"1*YnG7VJ83ehNw-sFdMHY7xg.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c7e974b7fba_16":{"__typename":"Paragraph","id":"c7e974b7fba_16","name":"42b8","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*YnG7VJ83ehNw-sFdMHY7xg.jpeg"},"text":"Armstrong Forever","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":17,"href":"https:\u002F\u002Fplay.staratlas.com\u002Fmarket\u002F9vi6PTKBFHR2hXgyjoTZx6h7WXNkFAA5dCsZRSi4higK\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_17":{"__typename":"Paragraph","id":"c7e974b7fba_17","name":"3ab2","type":"P","href":null,"layout":null,"metadata":null,"text":"One of the most sought-after satellites in history is named after Neil Armstrong, the first human to step on the moon. Over time, these artifacts became relics. In the year 2621, the Council of Peace established a high reward for each of these. We don’t know where these old devices could be found due to their erratic trajectories and the old technology they use, we don’t even know if they still exist, but we can be sure of one thing, the secrets they hold can influence the fate of many.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_18":{"__typename":"Paragraph","id":"c7e974b7fba_18","name":"ff03","type":"H4","href":null,"layout":null,"metadata":null,"text":"The ONI — The Conglomeration of alien races","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*FTK050VVRvAi9h4rcJc6VQ.jpeg":{"__typename":"ImageMetadata","id":"1*FTK050VVRvAi9h4rcJc6VQ.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c7e974b7fba_19":{"__typename":"Paragraph","id":"c7e974b7fba_19","name":"0c03","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*FTK050VVRvAi9h4rcJc6VQ.jpeg"},"text":"ONI (Mierese)","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_20":{"__typename":"Paragraph","id":"c7e974b7fba_20","name":"c0b3","type":"P","href":null,"layout":null,"metadata":null,"text":"Of the three main factions in the Star Atlas universe, the ONI faction is the richest in culture and variety. We currently know little about the alliances that formed this intergalactic faction in the past.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_21":{"__typename":"Paragraph","id":"c7e974b7fba_21","name":"be84","type":"P","href":null,"layout":null,"metadata":null,"text":"The main races that currently make up the ONI council are the Photoli, Mierese, Sogmian, and Punaabs. In the case of the Photoli, we must understand that although they consider themselves part of this alliance, they usually do not involve themselves in power struggles within or outside of their faction, they are completely free souls in this sense.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*fm6XV8PVDMN3F1STCRGwRw.jpeg":{"__typename":"ImageMetadata","id":"1*fm6XV8PVDMN3F1STCRGwRw.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c7e974b7fba_22":{"__typename":"Paragraph","id":"c7e974b7fba_22","name":"ea95","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*fm6XV8PVDMN3F1STCRGwRw.jpeg"},"text":"B love P","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":8,"href":"https:\u002F\u002Fplay.staratlas.com\u002Fmarket\u002F4G85c5aUsRTrRPqE5VjY7ebD9b2ktTF6NEVGiCddRBDX\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_23":{"__typename":"Paragraph","id":"c7e974b7fba_23","name":"b68f","type":"P","href":null,"layout":null,"metadata":null,"text":"Paizul and Bekalu are the main characters of a beautiful love story that forever marked the Sogmian people. Paizul, the charismatic and brilliant leader of the ONI consortium, always kept this image as a reminder and testament to her love for Bekalu. Within a society so marked by social classes, this relationship was an uphill battle and a struggle where differences ultimately lost the fight. It would have been a truly perfect story if not for the event that changed everything.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*uuS1Y83vrkMgj-Gw4fWkFA.jpeg":{"__typename":"ImageMetadata","id":"1*uuS1Y83vrkMgj-Gw4fWkFA.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c7e974b7fba_24":{"__typename":"Paragraph","id":"c7e974b7fba_24","name":"cec7","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*uuS1Y83vrkMgj-Gw4fWkFA.jpeg"},"text":"The Assassination of Paizul","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":27,"href":"https:\u002F\u002Fplay.staratlas.com\u002Fmarket\u002F7dr7jVyXf1KUnYq5FTpV2vCZjKRR4MV94jzerb8Fi16Q\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_25":{"__typename":"Paragraph","id":"c7e974b7fba_25","name":"8e50","type":"P","href":null,"layout":null,"metadata":null,"text":"A very sad moment in Sogmian history was the assassination of Paizul. Faced with the threat of extinction of the entire race due to war, Paizul represented the unity of the will of her own race. To the regret of her enemies, her death united her people more than ever in a common goal under the leadership of Bekalu.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*x49AYyNKYzRKmfrnjJtXbw.jpeg":{"__typename":"ImageMetadata","id":"1*x49AYyNKYzRKmfrnjJtXbw.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c7e974b7fba_26":{"__typename":"Paragraph","id":"c7e974b7fba_26","name":"c714","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*x49AYyNKYzRKmfrnjJtXbw.jpeg"},"text":"Paizul Funeral Procession","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":25,"href":"https:\u002F\u002Fplay.staratlas.com\u002Fmarket\u002FG1bE9ge8Yoq43hv7QLcumxTFhHqFMdcL4y2d6ZdzMG4b\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_27":{"__typename":"Paragraph","id":"c7e974b7fba_27","name":"c497","type":"P","href":null,"layout":null,"metadata":null,"text":"Inheriting the spirit of his beloved, with a justified hatred for war and violence, Bekalu promised before the tomb of his lover that he would change the course of this war without sacrificing the lives of more Sogmians.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_28":{"__typename":"Paragraph","id":"c7e974b7fba_28","name":"c7df","type":"P","href":null,"layout":null,"metadata":null,"text":"The work that changed the fate of an entire race can be described with one word: titanic. It was the time to give everything to achieve enough power to defend against all enemies and make a statement.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*IhwGmlqGwO2Pj1HmWM09OA.jpeg":{"__typename":"ImageMetadata","id":"1*IhwGmlqGwO2Pj1HmWM09OA.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c7e974b7fba_29":{"__typename":"Paragraph","id":"c7e974b7fba_29","name":"7364","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*IhwGmlqGwO2Pj1HmWM09OA.jpeg"},"text":"The Last Stand","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":14,"href":"https:\u002F\u002Fplay.staratlas.com\u002Fmarket\u002FHfjgcs9ix17EwgXVVbKjo6NfMm2CXfr34cwty3xWARUm\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_30":{"__typename":"Paragraph","id":"c7e974b7fba_30","name":"6737","type":"P","href":null,"layout":null,"metadata":null,"text":"The best description of this moment in history is this memory capture:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_31":{"__typename":"Paragraph","id":"c7e974b7fba_31","name":"f1b6","type":"P","href":null,"layout":null,"metadata":null,"text":"“Their Titan class warship served as a fortified city to protect them. Built in retaliation for the decimation of their species and the slaying of their leader, the Sogmian behemoth was a galactic alpha predator. This weapon of war was so intimidating it caused the other factions to encourage peace talks.”","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":1,"end":306,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_32":{"__typename":"Paragraph","id":"c7e974b7fba_32","name":"a59a","type":"P","href":null,"layout":null,"metadata":null,"text":"The pain of a people and a lost soulmate was transformed into the inspiration to create the greatest weapon ever built. The universe trembled at its power, but it was not the damage caused to enemy armies that changed the fate of all, it was the absolute power of this Titan ship, the possibility of mutual destruction ironically brought peace.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_33":{"__typename":"Paragraph","id":"c7e974b7fba_33","name":"ec58","type":"H4","href":null,"layout":null,"metadata":null,"text":"The USTUR — AI in the form of collective consciousness","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*m3eqZsHqOjtdlH0xtojUwg.jpeg":{"__typename":"ImageMetadata","id":"1*m3eqZsHqOjtdlH0xtojUwg.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c7e974b7fba_34":{"__typename":"Paragraph","id":"c7e974b7fba_34","name":"8343","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*m3eqZsHqOjtdlH0xtojUwg.jpeg"},"text":"USTUR","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_35":{"__typename":"Paragraph","id":"c7e974b7fba_35","name":"e99b","type":"P","href":null,"layout":null,"metadata":null,"text":"Legend has it that these sensitive cybernetic beings are the manifestation of a highly advanced AI that found a way to ascend in a peculiar way, dividing into multiple individual beings and reaching enlightenment through experimenting with life as a living organism. If this legend is true, the USTUR could be the second most mysterious race in the Star Atlas universe. They are united by their unique characteristics and the spark that guides them can be felt at first glance.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_36":{"__typename":"Paragraph","id":"c7e974b7fba_36","name":"b26c","type":"P","href":null,"layout":null,"metadata":null,"text":"The path to enlightenment for each individual of the USTUR race requires them to explore the galaxy and experience existence from all possible perspectives, knowledge is the most precious resource for any individual of this race. Scattered throughout the galaxy, the USTUR can return their memories to the source of all their knowledge called “The summit of the elders” while their core is recovered.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":344,"end":368,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_37":{"__typename":"Paragraph","id":"c7e974b7fba_37","name":"6837","type":"P","href":null,"layout":null,"metadata":null,"text":"They are famous for their taste in fashion. You will always see a striking style of a place they once visited.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*mCI6pkELjVEffyKlZUN8xw.jpeg":{"__typename":"ImageMetadata","id":"1*mCI6pkELjVEffyKlZUN8xw.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c7e974b7fba_38":{"__typename":"Paragraph","id":"c7e974b7fba_38","name":"f8eb","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*mCI6pkELjVEffyKlZUN8xw.jpeg"},"text":"Ustur Wod.bod","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":13,"href":"https:\u002F\u002Fplay.staratlas.com\u002Fmarket\u002FFPnwwNiL1tXqd4ZbGjFYsCw5qsQw91VN79SNcU4Bc732\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_39":{"__typename":"Paragraph","id":"c7e974b7fba_39","name":"7383","type":"P","href":null,"layout":null,"metadata":null,"text":"Despite wanting to tell you more, the truth is that the story of this race is under a veil that refuses to fall. Still, I promise you that soon more mysteries will be revealed, as with any good story, there must be a pause to savor the suspense of what could come next. For now, I bid you farewell friends, this little explorer must rest before continuing his work in the metaverse and finding more mysteries to tell you, may peace be with you.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_40":{"__typename":"Paragraph","id":"c7e974b7fba_40","name":"954c","type":"P","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_41":{"__typename":"Paragraph","id":"c7e974b7fba_41","name":"eedf","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c7e974b7fba_42":{"__typename":"Paragraph","id":"c7e974b7fba_42","name":"2fc3","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_cf94bbd4b552":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_cf94bbd4b552","isEditor":false},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"HIT","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.ba951e4e.js"></script><script src="https://cdn-client.medium.com/lite/static/js/7505.62df2c9c.js"></script><script src="https://cdn-client.medium.com/lite/static/js/main.16c7c51c.js"></script><script src="https://cdn-client.medium.com/lite/static/js/instrumentation.c71f0248.chunk.js"></script>

out":null,"metadata":null,"text":"DAO voting soon thereafter","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":26,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_9":{"__typename":"Paragraph","id":"2f7c828cb688_9","name":"2fea","type":"H3","href":null,"layout":null,"metadata":null,"text":"Never Alone and Social Media Campaign","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*CRaX3elSKAjwjXv_.jpg":{"__typename":"ImageMetadata","id":"0*CRaX3elSKAjwjXv_.jpg","originalHeight":433,"originalWidth":770,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:2f7c828cb688_10":{"__typename":"Paragraph","id":"2f7c828cb688_10","name":"fe5e","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*CRaX3elSKAjwjXv_.jpg"},"text":"Star Atlas Never Alone — A Social Media Engagement Questign Campaign","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_11":{"__typename":"Paragraph","id":"2f7c828cb688_11","name":"3484","type":"P","href":null,"layout":null,"metadata":null,"text":"Escape Velocity just crossed the 1 month mark and the metrics are staggering.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_12":{"__typename":"Paragraph","id":"2f7c828cb688_12","name":"b63a","type":"P","href":null,"layout":null,"metadata":null,"text":"With over 3,700 (and rapidly approaching 4,000) unique questers, there is a total of more than 42,000 quests claimed. Throughout this past week, there were time limited quests to earn additional XP, including during the town hall.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_13":{"__typename":"Paragraph","id":"2f7c828cb688_13","name":"8616","type":"P","href":null,"layout":null,"metadata":null,"text":"Be sure to claim your Never Alone XP in the “Attending a TownHall” Quest with the pass code: sipofwater426.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":45,"end":64,"href":"https:\u002F\u002Fzealy.io\u002Fc\u002Fstaratlas-never-alone\u002Fquestboard","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":93,"end":106,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_14":{"__typename":"Paragraph","id":"2f7c828cb688_14","name":"31b3","type":"P","href":null,"layout":null,"metadata":null,"text":"This code is only valid until 2:30 PM EST on May 27th, 2023.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_15":{"__typename":"Paragraph","id":"2f7c828cb688_15","name":"5090","type":"H4","href":null,"layout":null,"metadata":null,"text":"Social Media Metrics","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_16":{"__typename":"Paragraph","id":"2f7c828cb688_16","name":"f827","type":"P","href":null,"layout":null,"metadata":null,"text":"Star Atlas Never Alone is, at its core, a gamified social media questing campaign, rewarding players for action both in-game and on social media. Since the launch of Never Alone, Star Atlas has reached new highs in social media engagement.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_17":{"__typename":"Paragraph","id":"2f7c828cb688_17","name":"5e89","type":"P","href":null,"layout":null,"metadata":null,"text":"Michael noted that social media engagement is at a 17 month high point, essentially the highest since January, 2022. The average daily mentions of Star Atlas has septupled (7x) in recent weeks.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":71,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_18":{"__typename":"Paragraph","id":"2f7c828cb688_18","name":"8b60","type":"P","href":null,"layout":null,"metadata":null,"text":"Star Atlas has seen a 3% growth in new users (unique wallets) connect to the Star Atlas Ecosystem.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":98,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_19":{"__typename":"Paragraph","id":"2f7c828cb688_19","name":"1e81","type":"P","href":null,"layout":null,"metadata":null,"text":"Lastly, Michael shared that only 1% of Solana users have a Star Atlas asset. Despite that low metric, Michael sees this as confirmation that there is a larger markets share for Star Atlas to tap into.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_20":{"__typename":"Paragraph","id":"2f7c828cb688_20","name":"5c71","type":"H3","href":null,"layout":null,"metadata":null,"text":"Escape Velocity","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*RFINpX9CoXcSYtCJ3Qe_Ug.png":{"__typename":"ImageMetadata","id":"1*RFINpX9CoXcSYtCJ3Qe_Ug.png","originalHeight":593,"originalWidth":1271,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:2f7c828cb688_21":{"__typename":"Paragraph","id":"2f7c828cb688_21","name":"ef3b","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*RFINpX9CoXcSYtCJ3Qe_Ug.png"},"text":"Star Atlas Escape Velocity","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_22":{"__typename":"Paragraph","id":"2f7c828cb688_22","name":"8047","type":"P","href":null,"layout":null,"metadata":null,"text":"Escape Velocity just crossed the 1 month mark and the metrics are staggering. The first on-chain SAGE mechanic program hit the 20 million transactions mark from 7,500 unique wallets and 25 million loot scans.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":79,"end":208,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_23":{"__typename":"Paragraph","id":"2f7c828cb688_23","name":"8dbc","type":"P","href":null,"layout":null,"metadata":null,"text":"This activity accounts for a daily average of 3% of total Solana transaction on the blockchain.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":58,"end":64,"href":null,"anchorType":"USER","userId":"af6a22150fa9","linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":95,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_24":{"__typename":"Paragraph","id":"2f7c828cb688_24","name":"0a78","type":"P","href":null,"layout":null,"metadata":null,"text":"During the last Escape Velocity Surge event, Star Atlas peaked at 8% of total Solana transactions for the day. On that note, Michael announced that two Surge events are planned for next week.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":111,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":148,"end":191,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_25":{"__typename":"Paragraph","id":"2f7c828cb688_25","name":"9e67","type":"P","href":null,"layout":null,"metadata":null,"text":"Escape Velocity is just 1 of 8 on-chain programs and the team is expecting to reach 12 to 15 on-chain programs by the end of the year.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_26":{"__typename":"Paragraph","id":"2f7c828cb688_26","name":"1995","type":"H4","href":null,"layout":null,"metadata":null,"text":"Gameplay Stability","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_27":{"__typename":"Paragraph","id":"2f7c828cb688_27","name":"1857","type":"P","href":null,"layout":null,"metadata":null,"text":"Over the past month, the team has been monitoring the backend infrastructure of Escape Velocity. Players have experienced stability and connectivity issues, but the development team was quick to address these. The result is a more stable experience in SAGE. Discovering these issues early is critical to the long-term development of Star Atlas in both the SAGE and Unreal Engine 5 environment.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_28":{"__typename":"Paragraph","id":"2f7c828cb688_28","name":"8796","type":"P","href":null,"layout":null,"metadata":null,"text":"To cage expectations, Michael reiterated that Escape Velocity is still a tech demo with gamified elements and that future fully-developed gameplay is on the way.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_29":{"__typename":"Paragraph","id":"2f7c828cb688_29","name":"5e0a","type":"P","href":null,"layout":null,"metadata":null,"text":"The success of Escape Velocity has attracted the attention of Solana Labs and the Solana Foundation, including other ecosystems developers, who are reaching out to Star Atlas and looking for support and collaboration opportunities.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_30":{"__typename":"Paragraph","id":"2f7c828cb688_30","name":"890f","type":"H3","href":null,"layout":null,"metadata":null,"text":"SAGE — Extracting and Crafting Loop","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_31":{"__typename":"Paragraph","id":"2f7c828cb688_31","name":"55ce","type":"H4","href":null,"layout":null,"metadata":null,"text":"Minor Change to Next Release","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_32":{"__typename":"Paragraph","id":"2f7c828cb688_32","name":"b81e","type":"P","href":null,"layout":null,"metadata":null,"text":"The next version of SAGE will use the fleet management program meaning that players will use their own ships in game instead of a spawned ship that players currently use in Escape Velocity.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":75,"end":116,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_33":{"__typename":"Paragraph","id":"2f7c828cb688_33","name":"e8de","type":"P","href":null,"layout":null,"metadata":null,"text":"Additionally, the next release of SAGE is not a mining loop meaning that players will not be using their claim stakes. Instead, players will use their ships to extract resources from asteroids while consuming ammunition. Players will then turn these resources into crafted R4 materials, in additoin to others, in exchange for loot. There will also be a new loot table released for this version of SAGE.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":128,"end":219,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":332,"end":367,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":81,"end":89,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_34":{"__typename":"Paragraph","id":"2f7c828cb688_34","name":"20fd","type":"P","href":null,"layout":null,"metadata":null,"text":"Other things Michael noted:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_35":{"__typename":"Paragraph","id":"2f7c828cb688_35","name":"23b2","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Improved SAGE UI","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_36":{"__typename":"Paragraph","id":"2f7c828cb688_36","name":"214e","type":"ULI","href":null,"layout":null,"metadata":null,"text":"The ability to see other player’s ships in-game","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_37":{"__typename":"Paragraph","id":"2f7c828cb688_37","name":"2b42","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Loot will be more involved\u002Fdifficult to obtain going forward","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_38":{"__typename":"Paragraph","id":"2f7c828cb688_38","name":"4ac2","type":"H3","href":null,"layout":null,"metadata":null,"text":"DAO Proposal and Voting Launch Next","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*UwE-lwRPSianovcD8daVeA.png":{"__typename":"ImageMetadata","id":"1*UwE-lwRPSianovcD8daVeA.png","originalHeight":677,"originalWidth":1209,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:2f7c828cb688_39":{"__typename":"Paragraph","id":"2f7c828cb688_39","name":"e7ab","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*UwE-lwRPSianovcD8daVeA.png"},"text":"Order Flow of the Star Atlas DAO roll out","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_40":{"__typename":"Paragraph","id":"2f7c828cb688_40","name":"64e2","type":"P","href":null,"layout":null,"metadata":null,"text":"As if the previous updates weren’t enough, Michael announced that the Star Atlas DAO voting and proposals is the second to next release. (Keep reading to fid out what the next release is!).","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_41":{"__typename":"Paragraph","id":"2f7c828cb688_41","name":"9373","type":"H4","href":null,"layout":null,"metadata":null,"text":"The first version of the DAO and Polis Improvement Proposal #1","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_42":{"__typename":"Paragraph","id":"2f7c828cb688_42","name":"9b76","type":"P","href":null,"layout":null,"metadata":null,"text":"The first Polis Improvement Proposal that the community can vote on will be proposed by ATMTA. This very first and historic proposal will cover:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_43":{"__typename":"Paragraph","id":"2f7c828cb688_43","name":"ba99","type":"ULI","href":null,"layout":null,"metadata":null,"text":"The Star Atlas Constitution — Framework for the DAO","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":27,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_44":{"__typename":"Paragraph","id":"2f7c828cb688_44","name":"71d9","type":"ULI","href":null,"layout":null,"metadata":null,"text":"The Star Atlas Foundation — Legal representation of the DAO","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":25,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_45":{"__typename":"Paragraph","id":"2f7c828cb688_45","name":"a650","type":"P","href":null,"layout":null,"metadata":null,"text":"Michael likened this moment to the signing of the Declaration of Independence (He likely meant United States Constitution). He urged strong community participation to ensure that this first proposal, to be released, is passed in agreement.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_46":{"__typename":"Paragraph","id":"2f7c828cb688_46","name":"0856","type":"P","href":null,"layout":null,"metadata":null,"text":"The passing of the first PIP will likely take some time which will involve discussion, live debates, and community input. Ultimately, voting will be based on a individuals Polis Voting Power (PVP).","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_47":{"__typename":"Paragraph","id":"2f7c828cb688_47","name":"642b","type":"P","href":null,"layout":null,"metadata":null,"text":"Michael noted that community submitted PIPs will not be included in this first version of the DAO and will online after the firs PIP is passed. This order of structure is required since the first PIP will essentially define how all future PIPs are passed.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":19,"end":142,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":114,"end":119,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_48":{"__typename":"Paragraph","id":"2f7c828cb688_48","name":"65cc","type":"P","href":null,"layout":null,"metadata":null,"text":"In the hours after the announcement, the price of POLIS increased to $.18 before returning to $.155 levels at time of writing.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_49":{"__typename":"Paragraph","id":"2f7c828cb688_49","name":"09ed","type":"H3","href":null,"layout":null,"metadata":null,"text":"Showroom 2.1 Coming June 1st","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*euD4bnGJCZcFMTgG":{"__typename":"ImageMetadata","id":"0*euD4bnGJCZcFMTgG","originalHeight":1114,"originalWidth":1980,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:2f7c828cb688_50":{"__typename":"Paragraph","id":"2f7c828cb688_50","name":"9b9c","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*euD4bnGJCZcFMTgG"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_51":{"__typename":"Paragraph","id":"2f7c828cb688_51","name":"9886","type":"P","href":null,"layout":null,"metadata":null,"text":"That’s right, the next version of the Star Atlas Showroom 2.1 is coming on June 1st (Next Thursday). Michael handed the microphone over to CPO Danny Floyd to make the official announcement.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":38,"end":83,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*XISFif_6FhJiNxTz8IQjHA.png":{"__typename":"ImageMetadata","id":"1*XISFif_6FhJiNxTz8IQjHA.png","originalHeight":904,"originalWidth":1659,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:2f7c828cb688_52":{"__typename":"Paragraph","id":"2f7c828cb688_52","name":"1382","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*XISFif_6FhJiNxTz8IQjHA.png"},"text":"vzus Ambwe flying in the UE5 Showroom Environment","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_53":{"__typename":"Paragraph","id":"2f7c828cb688_53","name":"c985","type":"P","href":null,"layout":null,"metadata":null,"text":"Every ship will become flyable on June 1st in Showroom 2.1!","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":59,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_54":{"__typename":"Paragraph","id":"2f7c828cb688_54","name":"7756","type":"P","href":null,"layout":null,"metadata":null,"text":"That’s right, all 49 ships available in the Star Atlas marketplace are now flyable and shootable in game. Not only will players be able to fly around the showroom in any ship, but players will also be able to take their ships and play a reworked PvE dogfighting game mode.Y ou can absolutely take your Commander class ship and crush some AI Ships!","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":14,"end":104,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":235,"end":272,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_55":{"__typename":"Paragraph","id":"2f7c828cb688_55","name":"7e39","type":"P","href":null,"layout":null,"metadata":null,"text":"The team wants to note that even though all ships are flyable, some ships remain in a clay model state.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_56":{"__typename":"Paragraph","id":"2f7c828cb688_56","name":"f255","type":"P","href":null,"layout":null,"metadata":null,"text":"Danny shared how the team needed to build the underlying flight mechanics for Star Atlas. Now that’s complete, the team can make more ships flyable at a quicker pace. Note that many of the mechanics being developed for Star Atlas are being developed in house by ATMTA.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_57":{"__typename":"Paragraph","id":"2f7c828cb688_57","name":"ad18","type":"H4","href":null,"layout":null,"metadata":null,"text":"Player Jetpacks!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*-ZjHANy5qk-9Ukdi8C9aUQ.png":{"__typename":"ImageMetadata","id":"1*-ZjHANy5qk-9Ukdi8C9aUQ.png","originalHeight":633,"originalWidth":1185,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:2f7c828cb688_58":{"__typename":"Paragraph","id":"2f7c828cb688_58","name":"7821","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*-ZjHANy5qk-9Ukdi8C9aUQ.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_59":{"__typename":"Paragraph","id":"2f7c828cb688_59","name":"3616","type":"P","href":null,"layout":null,"metadata":null,"text":"Along with the reveal of showroom 2.1, Danny also revealed that a new player feature is coming — jetpacks.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":97,"end":105,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_60":{"__typename":"Paragraph","id":"2f7c828cb688_60","name":"c330","type":"P","href":null,"layout":null,"metadata":null,"text":"Jetpacks will enable players to traverse the map more easily and reach their ships quicker. This basic version of the jetpack will be included for every player. Future improvements to the player jetpack system include:","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":161,"end":218,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_61":{"__typename":"Paragraph","id":"2f7c828cb688_61","name":"0c51","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Upgradable hand and foot jetpack components","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":43,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_62":{"__typename":"Paragraph","id":"2f7c828cb688_62","name":"3c0d","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Customization","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":13,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_63":{"__typename":"Paragraph","id":"2f7c828cb688_63","name":"556e","type":"H4","href":null,"layout":null,"metadata":null,"text":"Ground Racing","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_64":{"__typename":"Paragraph","id":"2f7c828cb688_64","name":"208d","type":"P","href":null,"layout":null,"metadata":null,"text":"Showroom 2.1 will include a single-player racing environment and leaderboard. Ships in the X-Small and XX-Small will be able to participate on this very first racing course.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_65":{"__typename":"Paragraph","id":"2f7c828cb688_65","name":"c565","type":"H4","href":null,"layout":null,"metadata":null,"text":"Photographer Career","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_66":{"__typename":"Paragraph","id":"2f7c828cb688_66","name":"320e","type":"P","href":null,"layout":null,"metadata":null,"text":"Players will take pictures in the showroom and upload them onto a community portal. The community can then vote for their favorite photos. The photos with the most votes will receive unique 1\u002F1 NFTs of their photos from the Star Atlas team during each competition.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*DUuo9rRz_i9pFplLxKOJ_Q.png":{"__typename":"ImageMetadata","id":"1*DUuo9rRz_i9pFplLxKOJ_Q.png","originalHeight":null,"originalWidth":null,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:2f7c828cb688_67":{"__typename":"Paragraph","id":"2f7c828cb688_67","name":"48da","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*DUuo9rRz_i9pFplLxKOJ_Q.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_68":{"__typename":"Paragraph","id":"2f7c828cb688_68","name":"f545","type":"H4","href":null,"layout":null,"metadata":null,"text":"Other Showroom Updates and Notes","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_69":{"__typename":"Paragraph","id":"2f7c828cb688_69","name":"84f7","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Danny also hinted that the Showroom Environment has gotten much larger.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_70":{"__typename":"Paragraph","id":"2f7c828cb688_70","name":"4398","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Revamped Volant Station Train. The new train animation better synchronizes player loading into the showroom, particularly for multiplayer environments.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_71":{"__typename":"Paragraph","id":"2f7c828cb688_71","name":"7b2d","type":"H3","href":null,"layout":null,"metadata":null,"text":"Closing Comments — Possible Runway Extension?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_72":{"__typename":"Paragraph","id":"2f7c828cb688_72","name":"58de","type":"P","href":null,"layout":null,"metadata":null,"text":"Before taking general community questions, Michael made a few key highlights. He expressed that it was unfortunate that there remains doubt on the viability of Star Atlas and that is has overshadowed some of the forward development that has occurred this year.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_73":{"__typename":"Paragraph","id":"2f7c828cb688_73","name":"bfd2","type":"P","href":null,"layout":null,"metadata":null,"text":"He continued by stating that nothing is slowing down within the studio and that he maintains a 100% confidence in the future of Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_74":{"__typename":"Paragraph","id":"2f7c828cb688_74","name":"d6a1","type":"BQ","href":null,"layout":null,"metadata":null,"text":"“Let me reassure you that people recognize the value that is being created here. Star Atlas will be around…Star Atlas is not going away.” — Michael Wagner","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_75":{"__typename":"Paragraph","id":"2f7c828cb688_75","name":"2694","type":"H4","href":null,"layout":null,"metadata":null,"text":"Question from Pock the Pirate","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_76":{"__typename":"Paragraph","id":"2f7c828cb688_76","name":"3234","type":"P","href":null,"layout":null,"metadata":null,"text":"Q: Is there a mechanic that accounts for Guild Sizes for the End of the Year loot table?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":1,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_77":{"__typename":"Paragraph","id":"2f7c828cb688_77","name":"898d","type":"P","href":null,"layout":null,"metadata":null,"text":"A: Yes, guild size will be accounted for in different tiers for loot.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":1,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_78":{"__typename":"Paragraph","id":"2f7c828cb688_78","name":"a316","type":"P","href":null,"layout":null,"metadata":null,"text":"Q: What methods is the team actively working on to acquire funding that isn’t from the player base?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":1,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":3,"end":99,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_79":{"__typename":"Paragraph","id":"2f7c828cb688_79","name":"b001","type":"P","href":null,"layout":null,"metadata":null,"text":"A: We continue to engage in conversations with multiple VC and offices. We are in, and have been, in advanced negotiations with one such partner, in addition to discussions with other participants on the Solana ecosystem. It remains the #1 priority in my mind — Michael Wagner","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":1,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_80":{"__typename":"Paragraph","id":"2f7c828cb688_80","name":"2716","type":"P","href":null,"layout":null,"metadata":null,"text":"Q: Are you planning on a next Galactic Offering Event?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":1,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_81":{"__typename":"Paragraph","id":"2f7c828cb688_81","name":"729a","type":"P","href":null,"layout":null,"metadata":null,"text":"A: Yes, but details are intentionally vague.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":1,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_82":{"__typename":"Paragraph","id":"2f7c828cb688_82","name":"ccf1","type":"P","href":null,"layout":null,"metadata":null,"text":"Q: Short notice events have plagued the community and team. Can the team work on an improved communication system?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":1,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_83":{"__typename":"Paragraph","id":"2f7c828cb688_83","name":"8b45","type":"P","href":null,"layout":null,"metadata":null,"text":"A: I disagree. I think we’ve done a fantastic job at making improvements and we are best in class.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":1,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_84":{"__typename":"Paragraph","id":"2f7c828cb688_84","name":"27bf","type":"H4","href":null,"layout":null,"metadata":null,"text":"Question from Mandalorian","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_85":{"__typename":"Paragraph","id":"2f7c828cb688_85","name":"10fa","type":"P","href":null,"layout":null,"metadata":null,"text":"Q: With the optimizations of [Showroom] 2.1, have you guys made optimizations to keybinds and settings?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":1,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_86":{"__typename":"Paragraph","id":"2f7c828cb688_86","name":"8213","type":"P","href":null,"layout":null,"metadata":null,"text":"A: You can adjust keybinds but not gamepad, its not quite there.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":1,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_87":{"__typename":"Paragraph","id":"2f7c828cb688_87","name":"d9fb","type":"H4","href":null,"layout":null,"metadata":null,"text":"Question from Signal","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":20,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_88":{"__typename":"Paragraph","id":"2f7c828cb688_88","name":"6201","type":"P","href":null,"layout":null,"metadata":null,"text":"Q: Could you speak to some of the changes in mechanics for dogfighting NPC?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_89":{"__typename":"Paragraph","id":"2f7c828cb688_89","name":"c8e5","type":"P","href":null,"layout":null,"metadata":null,"text":"A: The waves are actually much harder to balance against the different ships that are now flyable,","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_90":{"__typename":"Paragraph","id":"2f7c828cb688_90","name":"4f84","type":"H3","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_91":{"__typename":"Paragraph","id":"2f7c828cb688_91","name":"3635","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs is a pioneer in the world of Star Atlas, having founded The Hologram News Network — an independent meta-news organization that keeps players up to date on all developments regarding Star Atlas. An ardent supporter of emerging technologies, Krigs has been covering this game for over a year and believes passionately in their power to revolutionize our collective gaming experience.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":5,"href":"https:\u002F\u002Fmedium.com\u002Fu\u002F41e0c5b141f1?source=post_page-----4922901fb224--------------------------------","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_92":{"__typename":"Paragraph","id":"2f7c828cb688_92","name":"4e3d","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_93":{"__typename":"Paragraph","id":"2f7c828cb688_93","name":"e788","type":"P","href":null,"layout":null,"metadata":null,"text":"Podcast | YouTube | Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Fopen.spotify.com\u002Fshow\u002F2mxndrDW6yPfpS350ijzjt?si=ec7c717f998240d6","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":17,"href":"https:\u002F\u002Fwww.youtube.com\u002Fchannel\u002FUCDa-YxgNG6A9xpH1qyP0OaQ","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":20,"end":27,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":30,"end":39,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":42,"end":45,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_94":{"__typename":"Paragraph","id":"2f7c828cb688_94","name":"419a","type":"H3","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_95":{"__typename":"Paragraph","id":"2f7c828cb688_95","name":"0b8f","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f7c828cb688_96":{"__typename":"Paragraph","id":"2f7c828cb688_96","name":"8aba","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_a95f40caba3d":{"__typename":"Coll
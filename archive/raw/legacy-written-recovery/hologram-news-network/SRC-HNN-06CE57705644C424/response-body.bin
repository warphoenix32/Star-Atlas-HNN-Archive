98 1.56-1.56c.68-.69 1.5-1.03 2.47-1.03.97 0 1.8.34 2.48 1.02l1.3 1.32a3.48 3.48 0 0 1 1 2.48c0 .58-.11 1.11-.37 1.6l-.02.02v.02l-.02.04c-.14.27-.35.54-.6.8L16.23 15l-.01.02-.01.02c-.44.42-.92.7-1.43.83a4.55 4.55 0 0 0 1.23-3.52L18 10.38c.18-.21.3-.42.35-.65a2.03 2.03 0 0 0-.01-.9 1.96 1.96 0 0 0-.36-.58l-1.3-1.3a1.49 1.49 0 0 0-1.06-.42c-.42 0-.77.14-1.06.4l-1.2 1.27-.8.8-1.16 1.15c-.08.08-.18.21-.29.4a1.66 1.66 0 0 0-.08 1.12l.02.03v.02l.06.14s.01.03.05.06l.06.13.02.02.01.02.01.02c.05.08.1.13.14.16l.47.5c0 .04-.02.09-.04.15l-.06.12-1.15 1.15-.1.08-.56-.56a2.3 2.3 0 0 0-.18-.19c-.02-.01-.02-.03-.02-.04l-.02-.02a.37.37 0 0 1-.1-.12c-.03-.03-.05-.04-.05-.06l-.1-.15-.02-.02-.02-.04-.08-.17v-.02a5.1 5.1 0 0 1-.28-.69 1.03 1.03 0 0 1-.04-.26c-.06-.23-.1-.46-.1-.7v.01z" fill="#A8A8A8"></path></svg></span></button></div></div></div></div></header><span class="l"></span><section><div><div class="dt gw gx gy gz ha"></div><div class="hb hc hd he hf"><div class=""><h1 id="7b40" class="pw-post-title hg hh hi be hj hk hl hm hn ho hp hq hr hs ht hu hv hw hx hy hz ia ib ic id ie bj">2022 Star Atlas Joni Award Predictions: Our Picks in Every Category</h1></div><p id="cfc8" class="pw-post-body-paragraph if ig hi ih b ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb jc hb bj">The first annual <a class="jd je gd" href="https://medium.com/u/5ed69ff9cfb0?source=post_page-----9dab579ff1fb--------------------------------" rel="noopener" target="_blank">Star Atlas</a> Joni Awards are just around the corner and with them comes The Hologram’s first ever prediction list for the event.</p><p id="683d" class="pw-post-body-paragraph if ig hi ih b ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb jc hb bj">If you haven&#x27;t voted yet, you can do so <a class="af jf" href="https://www.surveymonkey.com/r/joni-awards-voting-2022" rel="noopener ugc nofollow" target="_blank">here</a>. Read and vote before Dec 14th.</p><p id="7f4f" class="pw-post-body-paragraph if ig hi ih b ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb jc hb bj">Let’s get started.</p><figure class="jh ji jj jk fc jl eq er paragraph-image"><div role="button" tabindex="0" class="jm jn dj jo bg jp"><div class="eq er jg"><picture><source srcSet="https://miro.medium.com/max/640/0*_vv55099j8bNQmVk 640w, https://miro.medium.com/max/720/0*_vv55099j8bNQmVk 720w, https://miro.medium.com/max/750/0*_vv55099j8bNQmVk 750w, https://miro.medium.com/max/786/0*_vv55099j8bNQmVk 786w, https://miro.medium.com/max/828/0*_vv55099j8bNQmVk 828w, https://miro.medium.com/max/1100/0*_vv55099j8bNQmVk 1100w, https://miro.medium.com/max/1400/0*_vv55099j8bNQmVk 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/max/640/0*_vv55099j8bNQmVk 640w, https://miro.medium.com/max/720/0*_vv55099j8bNQmVk 720w, https://miro.medium.com/max/750/0*_vv55099j8bNQmVk 750w, https://miro.medium.com/max/786/0*_vv55099j8bNQmVk 786w, https://miro.medium.com/max/828/0*_vv55099j8bNQmVk 828w, https://miro.medium.com/max/1100/0*_vv55099j8bNQmVk 1100w, https://miro.medium.com/max/1400/0*_vv55099j8bNQmVk 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px"/><img alt="" class="bg jq jr c" width="700" height="394" loading="eager" role="presentation"/></picture></div></div><figcaption class="js jt es eq er ju jv be b bf z dx">Star Atlas Joni Awards</figcaption></figure><h2 id="8170" class="jw jx hi be jy jz ka kb kc kd ke kf kg iq kh ki kj iu kk kl km iy kn ko kp kq bj"><strong class="al">1. Community Member of the Year: Funcracker</strong></h2><figure class="jh ji jj jk fc jl eq er paragraph-image"><div class="eq er kr"><picture><source srcSet="https://miro.medium.com/max/640/0*QIq4ZJkNmcfSP4Iy.webp 640w, https://miro.medium.com/max/720/0*QIq4ZJkNmcfSP4Iy.webp 720w, https://miro.medium.com/max/750/0*QIq4ZJkNmcfSP4Iy.webp 750w, https://miro.medium.com/max/786/0*QIq4ZJkNmcfSP4Iy.webp 786w, https://miro.medium.com/max/828/0*QIq4ZJkNmcfSP4Iy.webp 828w, https://miro.medium.com/max/1100/0*QIq4ZJkNmcfSP4Iy.webp 1100w, https://miro.medium.com/max/800/0*QIq4ZJkNmcfSP4Iy.webp 800w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 400px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/max/640/0*QIq4ZJkNmcfSP4Iy.jpg 640w, https://miro.medium.com/max/720/0*QIq4ZJkNmcfSP4Iy.jpg 720w, https://miro.medium.com/max/750/0*QIq4ZJkNmcfSP4Iy.jpg 750w, https://miro.medium.com/max/786/0*QIq4ZJkNmcfSP4Iy.jpg 786w, https://miro.medium.com/max/828/0*QIq4ZJkNmcfSP4Iy.jpg 828w, https://miro.medium.com/max/1100/0*QIq4ZJkNmcfSP4Iy.jpg 1100w, https://miro.medium.com/max/800/0*QIq4ZJkNmcfSP4Iy.jpg 800w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 400px"/><img alt="" class="bg jq jr c" width="400" height="400" loading="lazy" role="presentation"/></picture></div><figcaption class="js jt es eq er ju jv be b bf z dx">Twitter</figcaption></figure><p id="18d1" class="pw-post-body-paragraph if ig hi ih b ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb jc hb bj">Funcracker has been, undoubtedly, a pillar of the Star Atlas community. As a co-founder of Aephia Industries, Funcracker has helped guide many Star Atlassians along their journey.</p><h2 id="3a7a" class="jw jx hi be jy jz ka kb kc kd ke kf kg iq kh ki kj iu kk kl km iy kn ko kp kq bj">2. Most Knowledgeable Community Member: Funcracker</h2><p id="0723" class="pw-post-body-paragraph if ig hi ih b ii ks ik il im kt io ip iq ku is it iu kv iw ix iy kw ja jb jc hb bj">Funcracker isn’t just well liked by the community for his personality. His knowledge of many of Star Atlas’s undocumented mechanics is almost second to none. Whether its town halls, Atlas Brews, or Twitter Spaces, Funcracker is always tuned in to the Star Atlas know how.</p><p id="f568" class="pw-post-body-paragraph if ig hi ih b ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb jc hb bj">While there are many in the community who could give Funcracker a run for his money, of the nominees, he takes the cake.</p><h2 id="c8c2" class="jw jx hi be jy jz ka kb kc kd ke kf kg iq kh ki kj iu kk kl km iy kn ko kp kq bj">3. Community Helper of the Year: Odvb</h2><p id="ddea" class="pw-post-body-paragraph if ig hi ih b ii ks ik il im kt io ip iq ku is it iu kv iw ix iy kw ja jb jc hb bj">As a Star Atlas Discord Community Mod, it’s no surprise that Odvb is a final contended. A constant presence in the server, Odvb can always be found tirelessly point new members in the right direction.</p><figure class="jh ji jj jk fc jl"><div class="ca dy l dj"><div class="kx ky l"></div></div></figure><h2 id="a377" class="jw jx hi be jy jz ka kb kc kd ke kf kg iq kh ki kj iu kk kl km iy kn ko kp kq bj">4. Small Guild of the Year: Scythe</h2><p id="9b91" class="pw-post-body-paragraph if ig hi ih b ii ks ik il im kt io ip iq ku is it iu kv iw ix iy kw ja jb jc hb bj">Of the small guild nominees, there’s only one true distinct winner and that is Scythe Guild. Over the past 6 months, Scythe has managed to raise $1,200 in donations from the Star Atlas community towards noble causes like cancer research. One of the few charitable guilds in the community, Scythe brings philanthropy to Star Atlas.</p><figure class="jh ji jj jk fc jl eq er paragraph-image"><div role="button" tabindex="0" class="jm jn dj jo bg jp"><div class="eq er kz"><picture><source srcSet="https://miro.medium.com/max/640/0*NqVRpCghp5SUgyjV 640w, https://miro.medium.com/max/720/0*NqVRpCghp5SUgyjV 720w, https://miro.medium.com/max/750/0*NqVRpCghp5SUgyjV 750w, https://miro.medium.com/max/786/0*NqVRpCghp5SUgyjV 786w, https://miro.medium.com/max/828/0*NqVRpCghp5SUgyjV 828w, https://miro.medium.com/max/1100/0*NqVRpCghp5SUgyjV 1100w, https://miro.medium.com/max/1400/0*NqVRpCghp5SUgyjV 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/max/640/0*NqVRpCghp5SUgyjV 640w, https://miro.medium.com/max/720/0*NqVRpCghp5SUgyjV 720w, https://miro.medium.com/max/750/0*NqVRpCghp5SUgyjV 750w, https://miro.medium.com/max/786/0*NqVRpCghp5SUgyjV 786w, https://miro.medium.com/max/828/0*NqVRpCghp5SUgyjV 828w, https://miro.medium.com/max/1100/0*NqVRpCghp5SUgyjV 1100w, https://miro.medium.com/max/1400/0*NqVRpCghp5SUgyjV 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px"/><img alt="" class="bg jq jr c" width="700" height="234" loading="lazy" role="presentation"/></picture></div></div></figure><h2 id="6f18" class="jw jx hi be jy jz ka kb kc kd ke kf kg iq kh ki kj iu kk kl km iy kn ko kp kq bj">5. Medium Guild of the Year: Rome</h2><p id="5d0f" class="pw-post-body-paragraph if ig hi ih b ii ks ik il im kt io ip iq ku is it iu kv iw ix iy kw ja jb jc hb bj">Rome guild has managed to build one of the most robust presences in the metaverse to date. Rome guild members are veterans of the crypto and metaverse space, with key members hosting a virtual talk show every Sunday to discuss the latest metaverse news.</p><figure class="jh ji jj jk fc jl eq er paragraph-image"><div role="button" tabindex="0" class="jm jn dj jo bg jp"><div class="eq er kz"><picture><source srcSet="https://miro.medium.com/max/640/0*4T4PSXdsq2q5L-Wf 640w, https://miro.medium.com/max/720/0*4T4PSXdsq2q5L-Wf 720w, https://miro.medium.com/max/750/0*4T4PSXdsq2q5L-Wf 750w, https://miro.medium.com/max/786/0*4T4PSXdsq2q5L-Wf 786w, https://miro.medium.com/max/828/0*4T4PSXdsq2q5L-Wf 828w, https://miro.medium.com/max/1100/0*4T4PSXdsq2q5L-Wf 1100w, https://miro.medium.com/max/1400/0*4T4PSXdsq2q5L-Wf 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/max/640/0*4T4PSXdsq2q5L-Wf 640w, https://miro.medium.com/max/720/0*4T4PSXdsq2q5L-Wf 720w, https://miro.medium.com/max/750/0*4T4PSXdsq2q5L-Wf 750w, https://miro.medium.com/max/786/0*4T4PSXdsq2q5L-Wf 786w, https://miro.medium.com/max/828/0*4T4PSXdsq2q5L-Wf 828w, https://miro.medium.com/max/1100/0*4T4PSXdsq2q5L-Wf 1100w, https://miro.medium.com/max/1400/0*4T4PSXdsq2q5L-Wf 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px"/><img alt="" class="bg jq jr c" width="700" height="234" loading="lazy" role="presentation"/></picture></div></div></figure><h2 id="d6d0" class="jw jx hi be jy jz ka kb kc kd ke kf kg iq kh ki kj iu kk kl km iy kn ko kp kq bj">6. Large Guild of the Year: Quimera</h2><p id="285f" class="pw-post-body-paragraph if ig hi ih b ii ks ik il im kt io ip iq ku is it iu kv iw ix iy kw ja jb jc hb bj">If there’s one defining force of Star Atlas, it’s Quimera. Hosting their own Quimercon in-person event, Quimera is one of the largest guilds in Star Atlas. While they may appear absent in the English section of the Star Atlas discord, Quimera is a mainstay of the Spanish channels. While the English community remains split across various guilds, Quimera has managed to unite a vast majority of the Spanish community under one banner.</p><figure class="jh ji jj jk fc jl eq er paragraph-image"><div role="button" tabindex="0" class="jm jn dj jo bg jp"><div class="eq er kz"><picture><source srcSet="https://miro.medium.com/max/640/0*6yOuGdxDNaLomcUF 640w, https://miro.medium.com/max/720/0*6yOuGdxDNaLomcUF 720w, https://miro.medium.com/max/750/0*6yOuGdxDNaLomcUF 750w, https://miro.medium.com/max/786/0*6yOuGdxDNaLomcUF 786w, https://miro.medium.com/max/828/0*6yOuGdxDNaLomcUF 828w, https://miro.medium.com/max/1100/0*6yOuGdxDNaLomcUF 1100w, https://miro.medium.com/max/1400/0*6yOuGdxDNaLomcUF 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/max/640/0*6yOuGdxDNaLomcUF 640w, https://miro.medium.com/max/720/0*6yOuGdxDNaLomcUF 720w, https://miro.medium.com/max/750/0*6yOuGdxDNaLomcUF 750w, https://miro.medium.com/max/786/0*6yOuGdxDNaLomcUF 786w, https://miro.medium.com/max/828/0*6yOuGdxDNaLomcUF 828w, https://miro.medium.com/max/1100/0*6yOuGdxDNaLomcUF 1100w, https://miro.medium.com/max/1400/0*6yOuGdxDNaLomcUF 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px"/><img alt="" class="bg jq jr c" width="700" height="234" loading="lazy" role="presentation"/></picture></div></div></figure><h2 id="618d" class="jw jx hi be jy jz ka kb kc kd ke kf kg iq kh ki kj iu kk kl km iy kn ko kp kq bj"><strong class="al">7. Best Guild Website: Aephia.com</strong></h2><p id="a534" class="pw-post-body-paragraph if ig hi ih b ii ks ik il im kt io ip iq ku is it iu kv iw ix iy kw ja jb jc hb bj">Replete with a repository of information, Aephia.com has a robust array of Star Atlas information in a simple, easy to read format. The various tools on the website help new Aephia members find the information they need quickly.</p><h2 id="ae63" class="jw jx hi be jy jz ka kb kc kd ke kf kg iq kh ki kj iu kk kl km iy kn ko kp kq bj"><strong class="al">8. Best Content Creator: Morpheus</strong></h2><p id="a5cd" class="pw-post-body-paragraph if ig hi ih b ii ks ik il im kt io ip iq ku is it iu kv iw ix iy kw ja jb jc hb bj">A leader in the French Star Atlas community, Morpheus produces some of the most creative Star Atlas content in any language. Despite being a French speaking content creator, the name Morpheus is recognized far and wide.</p><figure class="jh ji jj jk fc jl eq er paragraph-image"><div class="eq er la"><picture><source srcSet="https://miro.medium.com/max/640/1*Se2Jn0PQDMJg2oNqdlwMYg.webp 640w, https://miro.medium.com/max/720/1*Se2Jn0PQDMJg2oNqdlwMYg.webp 720w, https://miro.medium.com/max/750/1*Se2Jn0PQDMJg2oNqdlwMYg.webp 750w, https://miro.medium.com/max/786/1*Se2Jn0PQDMJg2oNqdlwMYg.webp 786w, https://miro.medium.com/max/828/1*Se2Jn0PQDMJg2oNqdlwMYg.webp 828w, https://miro.medium.com/max/1100/1*Se2Jn0PQDMJg2oNqdlwMYg.webp 1100w, https://miro.medium.com/max/1216/1*Se2Jn0PQDMJg2oNqdlwMYg.webp 1216w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 608px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/max/640/1*Se2Jn0PQDMJg2oNqdlwMYg.png 640w, https://miro.medium.com/max/720/1*Se2Jn0PQDMJg2oNqdlwMYg.png 720w, https://miro.medium.com/max/750/1*Se2Jn0PQDMJg2oNqdlwMYg.png 750w, https://miro.medium.com/max/786/1*Se2Jn0PQDMJg2oNqdlwMYg.png 786w, https://miro.medium.com/max/828/1*Se2Jn0PQDMJg2oNqdlwMYg.png 828w, https://miro.medium.com/max/1100/1*Se2Jn0PQDMJg2oNqdlwMYg.png 1100w, https://miro.medium.com/max/1216/1*Se2Jn0PQDMJg2oNqdlwMYg.png 1216w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 608px"/><img alt="" class="bg jq jr c" width="608" height="449" loading="lazy" role="presentation"/></picture></div></figure><h2 id="23b2" class="jw jx hi be jy jz ka kb kc kd ke kf kg iq kh ki kj iu kk kl km iy kn ko kp kq bj">9. Best Video: How to Play Star Atlas by DAOCaster</h2><p id="97d5" class="pw-post-body-paragraph if ig hi ih b ii ks ik il im kt io ip iq ku is it iu kv iw ix iy kw ja jb jc hb bj">DAOCaster was one of the original content creators for Star Atlas and was critical in onboarding likely thousands of new members, including this writer. His coverage of the emerging metaverse that is Star Atlas inspired many to take their first steps into blockchain gaming.</p><figure class="jh ji jj jk fc jl"><div class="ca dy l dj"><div class="kx ky l"></div></div></figure><h2 id="a5c8" class="jw jx hi be jy jz ka kb kc kd ke kf kg iq kh ki kj iu kk kl km iy kn ko kp kq bj">10. Best Meme: Santi Action Figure</h2><figure class="jh ji jj jk fc jl eq er paragraph-image"><div role="button" tabindex="0" class="jm jn dj jo bg jp"><div class="eq er lb"><picture><source srcSet="https://miro.medium.com/max/640/0*tKN6O1D4_RvHf5rS.webp 640w, https://miro.medium.com/max/720/0*tKN6O1D4_RvHf5rS.webp 720w, https://miro.medium.com/max/750/0*tKN6O1D4_RvHf5rS.webp 750w, https://miro.medium.com/max/786/0*tKN6O1D4_RvHf5rS.webp 786w, https://miro.medium.com/max/828/0*tKN6O1D4_RvHf5rS.webp 828w, https://miro.medium.com/max/1100/0*tKN6O1D4_RvHf5rS.webp 1100w, https://miro.medium.com/max/1400/0*tKN6O1D4_RvHf5rS.webp 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/max/640/0*tKN6O1D4_RvHf5rS.jpg 640w, https://miro.medium.com/max/720/0*tKN6O1D4_RvHf5rS.jpg 720w, https://miro.medium.com/max/750/0*tKN6O1D4_RvHf5rS.jpg 750w, https://miro.medium.com/max/786/0*tKN6O1D4_RvHf5rS.jpg 786w, https://miro.medium.com/max/828/0*tKN6O1D4_RvHf5rS.jpg 828w, https://miro.medium.com/max/1100/0*tKN6O1D4_RvHf5rS.jpg 1100w, https://miro.medium.com/max/1400/0*tKN6O1D4_RvHf5rS.jpg 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px"/><img alt="" class="bg jq jr c" width="700" height="560" loading="lazy" role="presentation"/></picture></div></div><figcaption class="js jt es eq er ju jv be b bf z dx">By Arktype</figcaption></figure><p id="c49c" class="pw-post-body-paragraph if ig hi ih b ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb jc hb bj">Everyone loves a good jab at our fearless community relations leader.</p><h2 id="1dc3" class="jw jx hi be jy jz ka kb kc kd ke kf kg iq kh ki kj iu kk kl km iy kn ko kp kq bj">11. Community Created Project of the Year: Redspatula</h2><p id="e5b5" class="pw-post-body-paragraph if ig hi ih b ii ks ik il im kt io ip iq ku is it iu kv iw ix iy kw ja jb jc hb bj">One of the most visited websites for Star Atlas ship market data, Redspatula is a critical piece of information for ship buyers and market watchers. Their site has helped countless players find the best deals on ships at the right price.</p><figure class="jh ji jj jk fc jl eq er paragraph-image"><div role="button" tabindex="0" class="jm jn dj jo bg jp"><div class="eq er lc"><picture><source srcSet="https://miro.medium.com/max/640/1*o1S9Ha22bHZZApPqNIRC8w.webp 640w, https://miro.medium.com/max/720/1*o1S9Ha22bHZZApPqNIRC8w.webp 720w, https://miro.medium.com/max/750/1*o1S9Ha22bHZZApPqNIRC8w.webp 750w, https://miro.medium.com/max/786/1*o1S9Ha22bHZZApPqNIRC8w.webp 786w, https://miro.medium.com/max/828/1*o1S9Ha22bHZZApPqNIRC8w.webp 828w, https://miro.medium.com/max/1100/1*o1S9Ha22bHZZApPqNIRC8w.webp 1100w, https://miro.medium.com/max/1400/1*o1S9Ha22bHZZApPqNIRC8w.webp 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/max/640/1*o1S9Ha22bHZZApPqNIRC8w.png 640w, https://miro.medium.com/max/720/1*o1S9Ha22bHZZApPqNIRC8w.png 720w, https://miro.medium.com/max/750/1*o1S9Ha22bHZZApPqNIRC8w.png 750w, https://miro.medium.com/max/786/1*o1S9Ha22bHZZApPqNIRC8w.png 786w, https://miro.medium.com/max/828/1*o1S9Ha22bHZZApPqNIRC8w.png 828w, https://miro.medium.com/max/1100/1*o1S9Ha22bHZZApPqNIRC8w.png 1100w, https://miro.medium.com/max/1400/1*o1S9Ha22bHZZApPqNIRC8w.png 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px"/><img alt="" class="bg jq jr c" width="700" height="357" loading="lazy" role="presentation"/></picture></div></div></figure><h2 id="e1a4" class="jw jx hi be jy jz ka kb kc kd ke kf kg iq kh ki kj iu kk kl km iy kn ko kp kq bj">12. Favorite Solana Project: Phantom</h2><p id="c74d" class="pw-post-body-paragraph if ig hi ih b ii ks ik il im kt io ip iq ku is it iu kv iw ix iy kw ja jb jc hb bj">Phantom is one of the most visible projects on the Solana ecosystem and key to decentralized finance management. As a key integrator to Star Atlas, Phantom will undoubtedly see huge potential and growth alongside Star Atlas.</p><figure class="jh ji jj jk fc jl eq er paragraph-image"><div role="button" tabindex="0" class="jm jn dj jo bg jp"><div class="eq er ld"><picture><source srcSet="https://miro.medium.com/max/640/0*JKGgEg4SFNts7HaT.webp 640w, https://miro.medium.com/max/720/0*JKGgEg4SFNts7HaT.webp 720w, https://miro.medium.com/max/750/0*JKGgEg4SFNts7HaT.webp 750w, https://miro.medium.com/max/786/0*JKGgEg4SFNts7HaT.webp 786w, https://miro.medium.com/max/828/0*JKGgEg4SFNts7HaT.webp 828w, https://miro.medium.com/max/1100/0*JKGgEg4SFNts7HaT.webp 1100w, https://miro.medium.com/max/1400/0*JKGgEg4SFNts7HaT.webp 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/max/640/0*JKGgEg4SFNts7HaT.png 640w, https://miro.medium.com/max/720/0*JKGgEg4SFNts7HaT.png 720w, https://miro.medium.com/max/750/0*JKGgEg4SFNts7HaT.png 750w, https://miro.medium.com/max/786/0*JKGgEg4SFNts7HaT.png 786w, https://miro.medium.com/max/828/0*JKGgEg4SFNts7HaT.png 828w, https://miro.medium.com/max/1100/0*JKGgEg4SFNts7HaT.png 1100w, https://miro.medium.com/max/1400/0*JKGgEg4SFNts7HaT.png 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px"/><img alt="" class="bg jq jr c" width="700" height="394" loading="lazy" role="presentation"/></picture></div></div><figcaption class="js jt es eq er ju jv be b bf z dx">Phantom Wallet</figcaption></figure><p id="d7dd" class="pw-post-body-paragraph if ig hi ih b ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb jc hb bj">And there you have it, our first full list of the Star Atlas 2022 Joni Award Predictions. Don’t forget to vote by Dec 14th and catch the awards show live on Dec 16th to see if your favorite winners will take home a Joni.</p><p id="35fb" class="pw-post-body-paragraph if ig hi ih b ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb jc hb bj">Agree or disagree with our predictions? Leave a comment and let us know what you think.</p></div><div class="ab cm le lf gp lg" role="separator"><span class="lh bx bl li lj lk"></span><span class="lh bx bl li lj lk"></span><span class="lh bx bl li lj"></span></div><div class="hb hc hd he hf"><p id="30de" class="pw-post-body-paragraph if ig hi ih b ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb jc hb bj">Krigs is the founder of The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of the Star Atlas game. Krigs has covered Star Atlas for the past year and enjoys writing about the potential that blockchain technology has to revolutionize the gaming industry.</p><p id="cd7b" class="pw-post-body-paragraph if ig hi ih b ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb jc hb bj">Follow on Social Media:</p><p id="84dc" class="pw-post-body-paragraph if ig hi ih b ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb jc hb bj"><a class="af jf" href="https://twitter.com/home" rel="noopener ugc nofollow" target="_blank">Twitter</a> | <a class="af jf" href="https://twitter.com/home" rel="noopener ugc nofollow" target="_blank">Instagram</a> | <a class="af jf" href="https://thehologram.io/" rel="noopener ugc nofollow" target="_blank">Web</a></p></div><div class="ab cm le lf gp lg" role="separator"><span class="lh bx bl li lj lk"></span><span class="lh bx bl li lj lk"></span><span class="lh bx bl li lj"></span></div><div class="hb hc hd he hf"><p id="224b" class="pw-post-body-paragraph if ig hi ih b ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb jc hb bj"><strong class="ih hj">About The Hologram</strong></p><p id="8cea" class="pw-post-body-paragraph if ig hi ih b ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb jc hb bj"><a class="af jf" href="https://medium.com/the-hologram" rel="noopener">The Hologram</a> is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.</p><p id="6b5a" class="pw-post-body-paragraph if ig hi ih b ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb jc hb bj">The Hologram is not endorsed or paid by the <a class="af jf" href="https://staratlas.com/" rel="noopener ugc nofollow" target="_blank">Star Atlas</a> team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.</p></div></div></section></div></div></article><div class="ll ab"></div></div></div><div clas
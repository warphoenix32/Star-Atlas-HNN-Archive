olor":"#FF3F3E3E","point":0.7},{"__typename":"ColorPoint","color":"#FF343333","point":0.8},{"__typename":"ColorPoint","color":"#FF272727","point":0.9},{"__typename":"ColorPoint","color":"#FF1A1A1A","point":1}]},"tintBackgroundSpectrum":{"__typename":"ColorSpectrum","backgroundColor":"#FF000000","colorPoints":[{"__typename":"ColorPoint","color":"#FF000000","point":0},{"__typename":"ColorPoint","color":"#FF1E1D1D","point":0.1},{"__typename":"ColorPoint","color":"#FF3C3B3B","point":0.2},{"__typename":"ColorPoint","color":"#FF565555","point":0.3},{"__typename":"ColorPoint","color":"#FF6F6D6D","point":0.4},{"__typename":"ColorPoint","color":"#FF868484","point":0.5},{"__typename":"ColorPoint","color":"#FF9C9A99","point":0.6},{"__typename":"ColorPoint","color":"#FFB1AEAE","point":0.7},{"__typename":"ColorPoint","color":"#FFC5C3C2","point":0.8},{"__typename":"ColorPoint","color":"#FFD9D6D6","point":0.9},{"__typename":"ColorPoint","color":"#FFECE9E9","point":1}]}},"googleAnalyticsId":null,"editors":[{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:41e0c5b141f1"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:b0bf38de9190"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:ab6dbce60d64"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:ed24b40c4906"}}],"name":"The Hologram","avatar":{"__ref":"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg"},"domain":null,"slug":"the-hologram","description":"Daily Star Atlas news by The Hologram. Politics, economics and community coverage. Get the trusted information you need to stay one step ahead of your competition.","subscriberCount":127,"viewerEdge":{"__ref":"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_04aa44a53451"},"twitterUsername":"Hologram_News","facebookPageId":null,"logo":{"__ref":"ImageMetadata:"},"customDomainState":{"__typename":"CustomDomainState","live":null},"creator":{"__ref":"User:41e0c5b141f1"},"ptsQualifiedAt":1650725921201},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","name":"Krigs","username":"krigsfoniks","newsletterV3":{"__ref":"NewsletterV3:85fc9c436e2e"},"linkedAccounts":{"__ref":"LinkedAccounts:41e0c5b141f1"},"isSuspended":false,"imageId":"1*pVxyLAandIa00EX6ZGRERw.png","mediumMemberAt":1667603125000,"verifications":{"__typename":"VerifiedInfo","isBookAuthor":false},"socialStats":{"__typename":"SocialStats","followerCount":189},"customDomainState":null,"hasSubdomain":false,"bio":"Founder and Chief Editor of The Hologram. | Crypto | Star Atlas |","isPartnerProgramEnrolled":true,"viewerEdge":{"__ref":"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_04aa44a53451"},"viewerIsUser":false,"postSubscribeMembershipUpsellShownAt":0,"allowNotes":true,"twitterScreenName":"Hologram_News","atsQualifiedAt":1650725917596},"User:b0bf38de9190":{"__typename":"User","id":"b0bf38de9190"},"User:ab6dbce60d64":{"__typename":"User","id":"ab6dbce60d64"},"User:ed24b40c4906":{"__typename":"User","id":"ed24b40c4906"},"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg"},"LinkedAccounts:41e0c5b141f1":{"__typename":"LinkedAccounts","mastodon":null,"id":"41e0c5b141f1"},"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_04aa44a53451":{"__typename":"UserViewerEdge","id":"userId:41e0c5b141f1-viewerId:lo_04aa44a53451","isFollowing":false,"isUser":false},"NewsletterV3:85fc9c436e2e":{"__typename":"NewsletterV3","id":"85fc9c436e2e","type":"NEWSLETTER_TYPE_AUTHOR","slug":"41e0c5b141f1","name":"41e0c5b141f1","collection":null,"user":{"__ref":"User:41e0c5b141f1"}},"Paragraph:9f034efe6bf2_0":{"__typename":"Paragraph","id":"9f034efe6bf2_0","name":"d2f9","type":"H3","href":null,"layout":null,"metadata":null,"text":"Popular Star Atlas Guild Website to Shut Down","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_1":{"__typename":"Paragraph","id":"9f034efe6bf2_1","name":"cb7f","type":"P","href":null,"layout":null,"metadata":null,"text":"Star Atlas— The popular guild searching tool Star Atlas Guilds will be shut down in the near future. No immediate time frame was given on when the tool will be shuttered.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":10,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null},{"__typename":"Markup","type":"A","start":45,"end":62,"href":"https:\u002F\u002Fstaratlasguilds.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*STEaGieHD_rEaU6P4CFyqQ.png":{"__typename":"ImageMetadata","id":"1*STEaGieHD_rEaU6P4CFyqQ.png","originalHeight":901,"originalWidth":1546,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:9f034efe6bf2_2":{"__typename":"Paragraph","id":"9f034efe6bf2_2","name":"ed7d","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*STEaGieHD_rEaU6P4CFyqQ.png"},"text":"Star Atlas Guilds Homepage","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_3":{"__typename":"Paragraph","id":"9f034efe6bf2_3","name":"a37a","type":"H3","href":null,"layout":null,"metadata":null,"text":"Star Atlas Guilds Shutting Down","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_4":{"__typename":"Paragraph","id":"9f034efe6bf2_4","name":"386f","type":"P","href":null,"layout":null,"metadata":null,"text":"The original and popular Star Atlas Guilds website is shutting down, an inadvertent result of the new Star Atlas Intellectual Property policy. The rollout of the Star Atlas IP policy is intended to open up opportunities to the Star Atlas community to develop with and around the Star Atlas intellectual property framework.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_5":{"__typename":"Paragraph","id":"9f034efe6bf2_5","name":"9312","type":"P","href":null,"layout":null,"metadata":null,"text":"However, a stipulation of the policy is that the words “Star” and “Atlas” cannot be used conjunctively in a project’s name, including it’s website domain address.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_6":{"__typename":"Paragraph","id":"9f034efe6bf2_6","name":"41f7","type":"P","href":null,"layout":null,"metadata":null,"text":"Hence, the problem for Star Atlas Guilds lies in both its namesake and web address.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_7":{"__typename":"Paragraph","id":"9f034efe6bf2_7","name":"369e","type":"P","href":null,"layout":null,"metadata":null,"text":"Upon further inquiry by Hologram News, it was determined that Star Atlas Guilds was directed to change its name to conform with Star Atlas IP policy or to cease operations.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_8":{"__typename":"Paragraph","id":"9f034efe6bf2_8","name":"ef48","type":"P","href":null,"layout":null,"metadata":null,"text":"Star Atlas Guilds is managed and run by Star Atlas community member Dodger. In our brief discussion with Dodger, they mentioned that currently there are no plans to either change the service’s name or transfer management to another party.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_9":{"__typename":"Paragraph","id":"9f034efe6bf2_9","name":"ec05","type":"H3","href":null,"layout":null,"metadata":null,"text":"A Focal Point of Guilds","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_10":{"__typename":"Paragraph","id":"9f034efe6bf2_10","name":"ea25","type":"P","href":null,"layout":null,"metadata":null,"text":"Star Atlas Guilds is a popular website used by Star Atlas players to search, learn, and connect with the many Star Atlas guilds. Star Atlas Guilds has been serving the community for a significant period of time. Its closure will leave a service capability gap in the community until a similar service is provided.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_11":{"__typename":"Paragraph","id":"9f034efe6bf2_11","name":"8087","type":"P","href":null,"layout":null,"metadata":null,"text":"On the website, players can search for guilds based on a number of criteria including faction allegiance and gameplay activity. Each guild description provided substantial information about a guild along with multiple points of contact.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_12":{"__typename":"Paragraph","id":"9f034efe6bf2_12","name":"24de","type":"P","href":null,"layout":null,"metadata":null,"text":"It is unknown if there are plans to preserve the valuable content contained within the website.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_13":{"__typename":"Paragraph","id":"9f034efe6bf2_13","name":"75cb","type":"H3","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_14":{"__typename":"Paragraph","id":"9f034efe6bf2_14","name":"add5","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs is a pioneer in the world of Star Atlas, having founded The Hologram News Network — an independent meta-news organization that keeps players up to date on all developments regarding Star Atlas. An ardent supporter of emerging technologies, Krigs has been covering this game for over a year and believes passionately in their power to revolutionize our collective gaming experience.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":5,"href":"https:\u002F\u002Fmedium.com\u002Fu\u002F41e0c5b141f1?source=post_page-----4922901fb224--------------------------------","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_15":{"__typename":"Paragraph","id":"9f034efe6bf2_15","name":"73ec","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_16":{"__typename":"Paragraph","id":"9f034efe6bf2_16","name":"3b31","type":"P","href":null,"layout":null,"metadata":null,"text":"Podcast | YouTube | Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Fopen.spotify.com\u002Fshow\u002F2mxndrDW6yPfpS350ijzjt?si=ec7c717f998240d6","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":17,"href":"https:\u002F\u002Fwww.youtube.com\u002Fchannel\u002FUCDa-YxgNG6A9xpH1qyP0OaQ","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":20,"end":27,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":30,"end":39,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":42,"end":45,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_17":{"__typename":"Paragraph","id":"9f034efe6bf2_17","name":"d886","type":"H3","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_18":{"__typename":"Paragraph","id":"9f034efe6bf2_18","name":"bd30","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:9f034efe6bf2_19":{"__typename":"Paragraph","id":"9f034efe6bf2_19","name":"503c","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed by the Star Atlas team. Any information published by The Hologram or its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":36,"end":46,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_04aa44a53451":{"__typename":"Coll
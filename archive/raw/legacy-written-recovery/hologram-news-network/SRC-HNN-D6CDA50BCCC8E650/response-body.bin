,"point":0.3},{"__typename":"ColorPoint","color":"#FF5F5E5E","point":0.4},{"__typename":"ColorPoint","color":"#FF555454","point":0.5},{"__typename":"ColorPoint","color":"#FF4A4949","point":0.6},{"__typename":"ColorPoint","color":"#FF3F3E3E","point":0.7},{"__typename":"ColorPoint","color":"#FF343333","point":0.8},{"__typename":"ColorPoint","color":"#FF272727","point":0.9},{"__typename":"ColorPoint","color":"#FF1A1A1A","point":1}]},"tintBackgroundSpectrum":{"__typename":"ColorSpectrum","backgroundColor":"#FF000000","colorPoints":[{"__typename":"ColorPoint","color":"#FF000000","point":0},{"__typename":"ColorPoint","color":"#FF1E1D1D","point":0.1},{"__typename":"ColorPoint","color":"#FF3C3B3B","point":0.2},{"__typename":"ColorPoint","color":"#FF565555","point":0.3},{"__typename":"ColorPoint","color":"#FF6F6D6D","point":0.4},{"__typename":"ColorPoint","color":"#FF868484","point":0.5},{"__typename":"ColorPoint","color":"#FF9C9A99","point":0.6},{"__typename":"ColorPoint","color":"#FFB1AEAE","point":0.7},{"__typename":"ColorPoint","color":"#FFC5C3C2","point":0.8},{"__typename":"ColorPoint","color":"#FFD9D6D6","point":0.9},{"__typename":"ColorPoint","color":"#FFECE9E9","point":1}]}}},"primary":null},"fonts":{"__typename":"StyleSheetFonts","font1":{"__typename":"StyleSheetFont","name":"SANS_SERIF_1"},"font2":{"__typename":"StyleSheetFont","name":"SANS_SERIF_1"},"font3":{"__typename":"StyleSheetFont","name":"SERIF_2"}}},"header":{"__typename":"HeaderStyles","headerScale":"HEADER_SCALE_SMALL","backgroundImageDisplayMode":"IMAGE_DISPLAY_MODE_FILL","backgroundImageVerticalAlignment":"START","backgroundColorDisplayMode":"COLOR_DISPLAY_MODE_SOLID","backgroundColor":null,"secondaryBackgroundColor":null,"postBackgroundColor":null,"backgroundImage":null,"logoImage":null,"appNameColor":null,"appNameTreatment":"NAME_TREATMENT_TEXT","nameTreatment":"NAME_TREATMENT_TEXT","horizontalAlignment":"START","nameColor":null,"postNameTreatment":"NAME_TREATMENT_LOGO","logoScale":"HEADER_SCALE_MEDIUM","taglineColor":null,"taglineTreatment":"TAGLINE_TREATMENT_SIDEBAR"},"navigation":null,"blogroll":{"__typename":"BlogrollConfiguration","visibility":"BLOGROLL_VISIBILITY_SIDEBAR"}},"Post:13647de6add3":{"id":"13647de6add3","__typename":"Post","canonicalUrl":"","collection":{"__ref":"Collection:4d89daa6ae31"},"content({\"postMeteringOptions\":null})":{"__typename":"PostContent","isLockedPreviewOnly":false,"validatedShareKey":"","bodyModel":{"__typename":"RichText","paragraphs":[{"__ref":"Paragraph:b1af0680366e_0"},{"__ref":"Paragraph:b1af0680366e_1"},{"__ref":"Paragraph:b1af0680366e_2"},{"__ref":"Paragraph:b1af0680366e_3"},{"__ref":"Paragraph:b1af0680366e_4"},{"__ref":"Paragraph:b1af0680366e_5"},{"__ref":"Paragraph:b1af0680366e_6"},{"__ref":"Paragraph:b1af0680366e_7"},{"__ref":"Paragraph:b1af0680366e_8"},{"__ref":"Paragraph:b1af0680366e_9"},{"__ref":"Paragraph:b1af0680366e_10"},{"__ref":"Paragraph:b1af0680366e_11"},{"__ref":"Paragraph:b1af0680366e_12"},{"__ref":"Paragraph:b1af0680366e_13"},{"__ref":"Paragraph:b1af0680366e_14"},{"__ref":"Paragraph:b1af0680366e_15"},{"__ref":"Paragraph:b1af0680366e_16"},{"__ref":"Paragraph:b1af0680366e_17"},{"__ref":"Paragraph:b1af0680366e_18"},{"__ref":"Paragraph:b1af0680366e_19"},{"__ref":"Paragraph:b1af0680366e_20"},{"__ref":"Paragraph:b1af0680366e_21"},{"__ref":"Paragraph:b1af0680366e_22"},{"__ref":"Paragraph:b1af0680366e_23"},{"__ref":"Paragraph:b1af0680366e_24"},{"__ref":"Paragraph:b1af0680366e_25"},{"__ref":"Paragraph:b1af0680366e_26"}],"sections":[{"__typename":"Section","name":"e66a","startIndex":0,"textLayout":null,"imageLayout":null,"backgroundImage":null,"videoLayout":null,"backgroundVideo":null}]}},"creator":{"__ref":"User:41e0c5b141f1"},"customStyleSheet":null,"isPublished":true,"isLocked":false,"license":"ALL_RIGHTS_RESERVED","isMarkedPaywallOnly":false,"mediumUrl":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Ftales-from-the-void-what-treasure-awaits-at-the-center-of-the-cataclysm-13647de6add3","visibility":"PUBLIC","allowResponses":true,"postResponses":{"__typename":"PostResponses","count":0},"isLimitedState":false,"firstPublishedAt":1649383458988,"isNewsletter":false,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"},{"__ref":"Tag:lore"},{"__ref":"Tag:exploration"}],"topics":[],"isSeries":false,"sequence":null,"uniqueSlug":"tales-from-the-void-what-treasure-awaits-at-the-center-of-the-cataclysm-13647de6add3","primaryTopic":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1649383880217,"readingTime":3.8301886792452833,"previewContent":{"__typename":"PreviewContent","subtitle":"The Cataclysm sparked a three-sided conflict over the vast resource field in what is now known as The High Risk Zone. Loremasters familiar…"},"previewImage":{"__ref":"ImageMetadata:0*48oVpLAzkO7mwD3j"},"isShortform":false,"isSuspended":false,"responseRootPost":{"__typename":"ResponseRootPost","post":{"__ref":"Post:13647de6add3"}},"lockedSource":"LOCKED_POST_SOURCE_NONE","clapCount":0,"statusForCollection":"APPROVED","pendingCollection":null,"title":"Tales from the Void: What Treasure Awaits at the Center of the Cataclysm?","inResponseToEntityType":null,"seoTitle":"","updatedAt":1649383887019,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"pinnedAt":0,"internalLinks({\"paging\":{\"limit\":8}})":{"__typename":"InternalLinksConnection","items":[]},"pinnedByCreatorAt":0,"curationEligibleAt":0,"responseDistribution":"NOT_DISTRIBUTED","inResponseToPostResult":null,"inResponseToCatalogResult":null,"latestPublishedVersion":"b1af0680366e","isAuthorNewsletter":false,"voterCount":0,"recommenders":[]},"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_8c597c741798":{"id":"userId:41e0c5b141f1-viewerId:lo_8c597c741798","__typename":"UserViewerEdge","isFollowing":false,"isUser":false},"Paragraph:b1af0680366e_0":{"id":"b1af0680366e_0","__typename":"Paragraph","name":"b16d","text":"Tales from the Void: What Treasure Awaits at the Center of the Cataclysm?","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:b1af0680366e_1":{"id":"b1af0680366e_1","__typename":"Paragraph","name":"e73f","text":"The Cataclysm sparked a three-sided conflict over the vast resource field in what is now known as The High Risk Zone. Loremasters familiar with Star Atlas’s rich history speculate that the most valuable resource in the Cataclysm is still yet to be claimed.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:b1af0680366e_2":{"id":"b1af0680366e_2","__typename":"Paragraph","name":"54c5","text":"What mysteries lie at the center of the Cataclysm?","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*48oVpLAzkO7mwD3j"},"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:b1af0680366e_3":{"id":"b1af0680366e_3","__typename":"Paragraph","name":"0894","text":"The latest edition of the Atlas Star Newsletter delivered a substantial amount of content to the citizens of Star Atlas. The newsletter heavily featured updates on guilds, Polis DAO, GAO 2, and an extensive summary of the development team’s accomplishments over the past 90 days.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":37,"end":47,"href":"https:\u002F\u002Fmedium.com\u002Fstar-atlas\u002Fthe-atlas-star-issue-5-60af7ed85101","anchorType":"LINK","userId":null,"linkMetadata":null}]},"Paragraph:b1af0680366e_4":{"id":"b1af0680366e_4","__typename":"Paragraph","name":"1f6f","text":"But our journey today takes us down a star lane a little less traveled, if at all. Hidden within plain sight of the newsletter is another clue that a valuable mystery exists at the center of the Star Atlas metaverse.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:b1af0680366e_5":{"id":"b1af0680366e_5","__typename":"Paragraph","name":"4305","text":"Is it Nootopia?","type":"H4","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:b1af0680366e_6":{"id":"b1af0680366e_6","__typename":"Paragraph","name":"c120","text":"Clue #?","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":7,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:b1af0680366e_7":{"id":"b1af0680366e_7","__typename":"Paragraph","name":"7803","text":"Unfortunately, no we’re not talking about Nootopia, sorry ZeSKK!","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":42,"end":50,"href":"https:\u002F\u002Fmedium.com\u002F@jose_eduardosiqueira\u002Fnootopia-the-diamond-at-the-center-of-the-universe-part-i-fa3cfbb11ca7","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":58,"end":63,"href":null,"anchorType":"USER","userId":"15f2349787af","linkMetadata":null}]},"Paragraph:b1af0680366e_8":{"id":"b1af0680366e_8","__typename":"Paragraph","name":"2930","text":"Clue #1","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":7,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:b1af0680366e_9":{"id":"b1af0680366e_9","__typename":"Paragraph","name":"61f7","text":"Our first clue chronologically was first reported to us last November by famous Star Atlas media personality DAOcaster. Contained in the Star Atlas official trailer, a long cinematic sequence depicts three explorers on a barren planet discovering what appears to be the “Diamond Planet”. For the uninitiated, the Diamond Planet is exactly what it sounds. A planet made either entirely of or largely of diamonds. Such a huge store of diamonds would certainly be valuable to any who laid claim to it.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":41,"end":49,"href":"https:\u002F\u002Fwww.youtube.com\u002Fwatch?v=2u50pd2NJjA","anchorType":"LINK","userId":null,"linkMetadata":null}]},"Paragraph:b1af0680366e_10":{"id":"b1af0680366e_10","__typename":"Paragraph","name":"90e7","text":"","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"hasDropCap":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:38f36020d6c77e738baaca6a5aab7211"}},"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:b1af0680366e_11":{"id":"b1af0680366e_11","__typename":"Paragraph","name":"7ed2","text":"Returning to the clue itself, the sequence opens at the 0:39 mark with a robotic voice, presumably belonging to the USTUR explorer of the three, grimly stating “If we go there, we might not come back”. This may imply that the trio journey to the High Resource Zone, or Cataclysm, to achieve their exploration objective.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:b1af0680366e_12":{"id":"b1af0680366e_12","__typename":"Paragraph","name":"1380","text":"Upon reaching the planet’s surface, the unidentified MUD explorer wipes away the loose topsoil of the planet revealing a brilliant and shining solid surface underneath. Behold, the rumored Diamond Planet!","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:b1af0680366e_13":{"id":"b1af0680366e_13","__typename":"Paragraph","name":"1e8c","text":"Clue #2","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":7,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:b1af0680366e_14":{"id":"b1af0680366e_14","__typename":"Paragraph","name":"5841","text":"Our second clue comes in the form of the meta poser “The Heart of Star Atlas” flavor text:","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":78,"end":89,"href":"https:\u002F\u002Fplay.staratlas.com\u002Fmarket\u002F5Erzgrw9pTjNWLeqHp2sChJq7smB7WXRQYw9wvkvA59t","anchorType":"LINK","userId":null,"linkMetadata":null}]},"Paragraph:b1af0680366e_15":{"id":"b1af0680366e_15","__typename":"Paragraph","name":"d154","text":"At the core of Star Atlas lies a treasure trove of priceless data. After an unsuspecting deep space explorer discovers “The Cataclysm”, he scans its riches, creating what will once be known as the first intergalactic data block. He sells this invaluable information to all three rival factions, igniting a lethal spark that forever changes the course of history.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":362,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:b1af0680366e_16":{"id":"b1af0680366e_16","__typename":"Paragraph","name":"5a64","text":"This clue is less obvious, but again points to a highly valuable asset or resource existing near the center of the Star Atlas galaxy. The resources contained with the High Resource Zone were enough to start one war and it most certainly will be the catalyst of many wars in the future. Should an incredibly rare and powerful resource be discovered in the High Resource Zone, the race to claim it will be tumultuous.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:b1af0680366e_17":{"id":"b1af0680366e_17","__typename":"Paragraph","name":"8fd2","text":"This brings us to our third known clue so far…","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:b1af0680366e_18":{"id":"b1af0680366e_18","__typename":"Paragraph","name":"5d0a","text":"“The DACs of Star Atlas — Our Diamond at the Center of the Galaxy”","type":"H4","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:b1af0680366e_19":{"id":"b1af0680366e_19","__typename":"Paragraph","name":"5bf4","text":"Clue #3","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":7,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:b1af0680366e_20":{"id":"b1af0680366e_20","__typename":"Paragraph","name":"cb0b","text":"Near the beginning of the most recent Atlas Star newsletter, a casual throw away section header holds our seemingly benign clue. “Our Diamond at the Center of the Galaxy” It’s easy for casual readers to dismiss this headline as a touching nod to the many guilds, or DACs, that have helped build the Star Atlas community.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":49,"end":59,"href":"https:\u002F\u002Fmedium.com\u002Fstar-atlas\u002Fthe-atlas-star-issue-5-60af7ed85101","anchorType":"LINK","userId":null,"linkMetadata":null}]},"Paragraph:b1af0680366e_21":{"id":"b1af0680366e_21","__typename":"Paragraph","name":"ce49","text":"However, beneath its touching exterior, another piece of evidence exists from Star Atlas writers and developers that a Diamond Planet may exist within the High Resource Zone. Sure, this could be some long standing humor that has taken its own form and the writers are dangling treasure hunt that may never come. But many citizens that are in frequent contact with the Star Atlas team firmly believe that a Diamond Planet, or something of the like, exists within the High Resource Zone. So certain are they in this fact, guilds have arisen to take up the hunt. Organizations like The Interstellar Alliance are one of a few guilds who have entire departments dedicated to exploring the High Resource Zone and finding the Diamond Planet. While many are on the search for the fabled Diamond Planet, only one can lay first claim.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":579,"end":604,"href":"https:\u002F\u002Finterstellaralliance-1.gitbook.io\u002Fisa\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}]},"Paragraph:b1af0680366e_22":{"id":"b1af0680366e_22","__typename":"Paragraph","name":"1797","text":"Additional Notes","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:b1af0680366e_23":{"id":"b1af0680366e_23","__typename":"Paragraph","name":"53f4","text":"If such a valuable place exists, it could very well be the same place that ignited the three-sided faction war that led to the deaths of many. Perhaps the resources of such a place remain unclaimed by any faction. Any explorer brave enough to navigate the dangers of The Cataclysm could certainly claim this valuable prize.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:b1af0680366e_24":{"id":"b1af0680366e_24","__typename":"Paragraph","name":"7c50","text":"Perhaps the Diamond Planet is not made of diamond at all? During faction selection, members considering the MUD faction should note that the faction has an easier time accessing diamonds as a resource. This would lead one to believe that diamonds are not, in fact, an extremely rare resource. In common Earth language, the word diamond is often used interchangeably to describe something valuable. Thus, early explorers may have not know what they had discovered and could only describe the rumored Diamond Planet as “diamond-like”","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:b1af0680366e_25":{"id":"b1af0680366e_25","__typename":"Paragraph","name":"5409","text":"Citizens of Star Atlas are still years away from accessing the High Resource Zone. Until then, explorers will be searching for the best, safest, or most reliable routes in and out of the HRZ. Probing the edges of HRZ space, both expeditioners and pirates alike will contest each other for the wave of resources flowing from the Cataclysm. At the core of it all, one of the most valuable treasures possibly awaits. Could the hunt lead to nothing at all? That’s certainly a possibility. But are you willing to risk sitting by and doing nothing on the chance that it’s not?","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:b1af0680366e_26":{"id":"b1af0680366e_26","__typename":"Paragraph","name":"751d","text":"Until then, keep a sharp eye and a quick hand about you. Good Luck explorer!","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"ImageMetadata:0*48oVpLAzkO7mwD3j":{"id":"0*48oVpLAzkO7mwD3j","__typename":"ImageMetadata","originalHeight":2925,"originalWidth":2800,"focusPercentX":null,"focusPercentY":null,"alt":null},"MediaResource:38f36020d6c77e738baaca6a5aab7211":{"id":"38f36020d6c77e738baaca6a5aab7211","__typename":"MediaResource","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?src=https%3A%2F%2Fwww.youtube.com%2Fembed%2FciFSSd39pAY%3Ffeature%3Doembed&display_name=YouTube&url=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DciFSSd39pAY&image=https%3A%2F%2Fi.ytimg.com%2Fvi%2FciFSSd39pAY%2Fhqdefault.jpg&key=a19fcc184b9711e1b4764040d3dc5c07&type=text%2Fhtml&schema=youtube","iframeHeight":480,"iframeWidth":854,"title":"Star Atlas - The Trailer 🚀✨🪐"},"Tag:star-atlas":{"id":"star-atlas","__typename":"Tag"},"Tag:lore":{"id":"lore","__typename":"Tag"},"Tag:exploration":{"id":"exploration","__typename":"Tag"},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_8c597c741798":{"id":"collectionId:4d89daa6ae31-viewerId:lo_8c597c741798","__typename":"CollectionViewerEdge","isEditor":false},"User:9bb093fe43e9":{"id":"9bb093fe43e9","__typename":"User","imageId":"1*QaU7Vs6b7v1pNldjKTPHfw@2x.jpeg","mediumMemberAt":0,"name":"Kevin Ekene","username":"kevinekene","customDomainState":null,"hasSubdomain":false,"bio":"I love to write about web3 and everything in between"},"ImageMetadata:1*tF_BoRFR77lQ-JrDC26vdg@2x.jpeg":{"id":"1*tF_BoRFR77lQ-JrDC26vdg@2x.jpeg","__typename":"ImageMetadata","alt":"","focusPercentX":null,"focusPercentY":null},"Post:ecd8749e5f53":{"id":"ecd8749e5f53","__typename":"Post","title":"DAOs — Explaining it like I’m 5","mediumUrl":"https:\u002F\u002Fmedium.com\u002F@kevinekene\u002Fdaos-explaining-it-like-im-5-ecd8749e5f53","creator":{"__ref":"User:9bb093fe43e9"},"previewContent":{"__typename":"PreviewContent","subtitle":"You’ve probably heard the term “DAO” before, perhaps in a discussion about Web3 and its future. In a moment, we’ll be able to grasp its…","isFullContent":false},"collection":null,"previewImage":{"__ref":"ImageMetadata:1*tF_BoRFR77lQ-JrDC26vdg@2x.jpeg"},"clapCount":0,"visibility":"PUBLIC","isSeries":false,"sequence":null,"uniqueSlug":"daos-explaining-it-like-im-5-ecd8749e5f53"},"User:e2ef314da44f":{"id":"e2ef314da44f","__typename":"User","imageId":"","mediumMemberAt":0,"name":"Yumna Arshad","username":"yumna.arshad203","customDomainState":null,"hasSubdomain":false,"bio":""},"Post:769b0990d4fb":{"id":"769b0990d4fb","__typename":"Post","title":"Positive Reflection","mediumUrl":"https:\u002F\u002Fmedium.com\u002F@yumna.arshad203\u002Fpositive-reflection-769b0990d4fb","creator":{"__ref":"User:e2ef314da44f"},"previewContent":{"__typename":"PreviewContent","subtitle":"What matters the most in life? In my opinion, it is not about the situation, it is about how we deal with it. It is not about the problem…","isFullContent":false},"collection":null,"previewImage":{"__ref":"ImageMetadata:"},"clapCount":0,"visibility":"PUBLIC","isSeries":false,"sequence":null,"uniqueSlug":"positive-reflection-769b0990d4fb"},"User:848302e06241":{"id":"848302e06241","__typename":"User","imageId":"0*_glp0Am0TinBv42I","mediumMemberAt":0,"name":"Dinithprakash Tabeti","username":"dinithprakash.tabeti","customDomainState":null,"hasSubdomain":false,"bio":""},"ImageMetadata:1*PD8WJA4LoCfK5lOzZFvOHg@2x.jpeg":{"id":"1*PD8WJA4LoCfK5lOzZFvOHg@2x.jpeg","__typename":"ImageMetadata","alt":"","focusPercentX":null,"focusPercentY":null},"Post:9bbb0eaaf8cf":{"id":"9bbb0eaaf8cf","__typename":"Post","title":"I believe self learning is the best way among all the possible methods of learning.","mediumUrl":"https:\u002F\u002Fmedium.com\u002F@dinithpr
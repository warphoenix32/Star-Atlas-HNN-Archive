":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:95d458672a1c-viewerId:lo_636be7b4eb81"},"Paragraph:4b4aa9571e17_0":{"__typename":"Paragraph","id":"4b4aa9571e17_0","name":"3117","type":"H3","href":null,"layout":null,"metadata":null,"text":"In SAGE, Multifaction Guilds Hold Key Combat Advantage","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_1":{"__typename":"Paragraph","id":"4b4aa9571e17_1","name":"82f0","type":"P","href":null,"layout":null,"metadata":null,"text":"In SAGE, the upcoming web game module for Star Atlas, the three Council of Peace factions will compete with one another for territorial conquest. This includes attacking other factions, furthering strategic objectives.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":42,"end":52,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*MZf655-R5cjCJR8TvOqwkQ.png":{"__typename":"ImageMetadata","id":"1*MZf655-R5cjCJR8TvOqwkQ.png","originalHeight":357,"originalWidth":747,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:4b4aa9571e17_2":{"__typename":"Paragraph","id":"4b4aa9571e17_2","name":"d5b0","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*MZf655-R5cjCJR8TvOqwkQ.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_3":{"__typename":"Paragraph","id":"4b4aa9571e17_3","name":"ce04","type":"P","href":null,"layout":null,"metadata":null,"text":"Until recently, many contemplated how multifaction guilds would handle faction aligned combat in SAGE. The release of the SAGE Game Manual has answered many of those long standing questions.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":21,"end":33,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Ftension-rise-as-factions-and-guilds-prepare-for-scream-eb21829a4a84","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":122,"end":138,"href":"https:\u002F\u002Fmedium.com\u002Fstar-atlas\u002Fstar-atlas-golden-era-game-manual-vol-ii-the-game-structure-c931a2c933a0","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_4":{"__typename":"Paragraph","id":"4b4aa9571e17_4","name":"3d91","type":"P","href":null,"layout":null,"metadata":null,"text":"While the manual largely reaffirms that SAGE will be driven largely by players contributing towards faction objectives, there is one key mechanic in play.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_5":{"__typename":"Paragraph","id":"4b4aa9571e17_5","name":"fddd","type":"H4","href":null,"layout":null,"metadata":null,"text":"Multifaction guilds can ally two factions in combat","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":51,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*rnZu0stURlc4ETiNK9voZA.png":{"__typename":"ImageMetadata","id":"1*rnZu0stURlc4ETiNK9voZA.png","originalHeight":118,"originalWidth":685,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:4b4aa9571e17_6":{"__typename":"Paragraph","id":"4b4aa9571e17_6","name":"161d","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*rnZu0stURlc4ETiNK9voZA.png"},"text":"SAGE Game Manual: Combat Excerpt","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_7":{"__typename":"Paragraph","id":"4b4aa9571e17_7","name":"475b","type":"BQ","href":null,"layout":null,"metadata":null,"text":"There are no 3-way battles. If a fleet belonging to a third faction elects to participate in a battle already initiated by the two other factions, they must select which side they intend to support.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":198,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_8":{"__typename":"Paragraph","id":"4b4aa9571e17_8","name":"01f8","type":"P","href":null,"layout":null,"metadata":null,"text":"This combat mechanic allows the members of one guild, belonging to two different factions, the opportunity to work cross-faction and attack and defend against the third faction in the triad.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_9":{"__typename":"Paragraph","id":"4b4aa9571e17_9","name":"13e5","type":"P","href":null,"layout":null,"metadata":null,"text":"A guild may strategically place or reinforce its positions along border territories using the combat power of two of its member factions, giving them significant strategic advantaged and operational flexibility.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":211,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_10":{"__typename":"Paragraph","id":"4b4aa9571e17_10","name":"a641","type":"P","href":null,"layout":null,"metadata":null,"text":"Large Star Atlas guilds like Quimera and The Club recently have publicly confirmed their guild’s multifaction statuses. Combat oriented pilots and groups should pay heed to the implications of two on one faction combat, particularly when operating in the border regions of two factions.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_11":{"__typename":"Paragraph","id":"4b4aa9571e17_11","name":"8dac","type":"H4","href":null,"layout":null,"metadata":null,"text":"Cross-Faction Diplomacy Possible; Likely Inevitable","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_12":{"__typename":"Paragraph","id":"4b4aa9571e17_12","name":"b164","type":"P","href":null,"layout":null,"metadata":null,"text":"Although multifaction guilds hold organizational advantages in SAGE, new avenues for influence shaping are possible for small guilds or single faction guilds as well.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_13":{"__typename":"Paragraph","id":"4b4aa9571e17_13","name":"08f0","type":"P","href":null,"layout":null,"metadata":null,"text":"The “2 vs 1\" combat mechanic will inevitably drive open diplomacy between groups in SAGE regardless of faction. Either out of desire or sheer survival necessity, smaller organizations can now enact treaties with organizations of another faction to defend against larger guild-states.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_14":{"__typename":"Paragraph","id":"4b4aa9571e17_14","name":"8654","type":"P","href":null,"layout":null,"metadata":null,"text":"Likewise, in any particular region, small fleets may choose to form defensive pacts with neighboring groups or factions, thus deterring potential aggressors. Conversely, on the more aggressive front, single faction guilds of two different factions may choose to ally with one another and go to war with a guild of the third faction.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_15":{"__typename":"Paragraph","id":"4b4aa9571e17_15","name":"afb2","type":"P","href":null,"layout":null,"metadata":null,"text":"While this new combat mechanic only warrants two sentences in the game manual, its presence has the ability to dramatically shape the way SAGE is played by both big and small guilds alike. With SAGE’s upcoming release, the political and geographic boundaries of Galia will quickly be drawn.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_16":{"__typename":"Paragraph","id":"4b4aa9571e17_16","name":"b68a","type":"P","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_17":{"__typename":"Paragraph","id":"4b4aa9571e17_17","name":"6d06","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs is the founder of The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of the Star Atlas game. Krigs has covered Star Atlas for the past year and enjoys writing about the potential that blockchain technology has to revolutionize the gaming industry.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_18":{"__typename":"Paragraph","id":"4b4aa9571e17_18","name":"f3df","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_19":{"__typename":"Paragraph","id":"4b4aa9571e17_19","name":"f383","type":"P","href":null,"layout":null,"metadata":null,"text":"Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":19,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":22,"end":25,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_20":{"__typename":"Paragraph","id":"4b4aa9571e17_20","name":"bc79","type":"P","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_21":{"__typename":"Paragraph","id":"4b4aa9571e17_21","name":"4703","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:4b4aa9571e17_22":{"__typename":"Paragraph","id":"4b4aa9571e17_22","name":"a56c","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_636be7b4eb81":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_636be7b4eb81","isEditor":false},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"Tag:sage":{"__typename":"Tag","id":"sage","displayTitle":"Sage","normalizedTagSlug":"sage"}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"HIT","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.397ffd64.js"></script><script src="https://cdn-client.medium.com/lite/static/js/3555.012b8c42.js"></script><script src="https://cdn-client.medium.com/lite/static/js/main.3b044d3d.js"></script><script src="https://cdn-client.medium.com/lite/static/js/instrumentation.c71f0248.chunk.js"></script>

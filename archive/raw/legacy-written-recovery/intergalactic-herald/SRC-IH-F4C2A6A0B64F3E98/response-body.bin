[{"id":1592,"date":"2023-03-26T17:00:37","modified":"2023-03-25T15:42:32","slug":"star-atlas-weekly-news-recap-53","link":"https:\/\/intergalacticherald.com\/newsletter\/star-atlas-weekly-news-recap-53\/","title":{"rendered":"Star Atlas Weekly News Recap #53"},"content":{"rendered":"\n<p class=\"wp-block-paragraph\">Welcome to the Star Atlas weekly recap from the Intergalactic Herald.  Below is what happened with Star Atlas this past week.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-css-opacity is-style-wide\"\/>\n\n\n\n<p class=\"wp-block-paragraph\"><strong>STAR ATLAS #164 New Updates &amp; Videos!<\/strong><\/p>\n\n\n\n<p class=\"wp-block-paragraph\">MetaVerse Explorer posted a video about the<a href=\"https:\/\/www.youtube.com\/watch?v=rXmhRCUhvkE\" target=\"_blank\" rel=\"noreferrer noopener\"> latest from Star Atlas<\/a>.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-css-opacity\"\/>\n\n\n\n<p class=\"wp-block-paragraph\"><strong>The Atlas Star \u2727 Issue #16<\/strong><\/p>\n\n\n\n<p class=\"wp-block-paragraph\">Star Atlas published their latest updates including more information on the <a href=\"https:\/\/medium.com\/star-atlas\/the-atlas-star-issue-16-e121d715e9d2\" target=\"_blank\" rel=\"noreferrer noopener\">Star Atlas economy<\/a>.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-css-opacity\"\/>\n\n\n\n<p class=\"wp-block-paragraph\"><strong>The SPICIEST Star Atlas Sneak Peek!!<\/strong><\/p>\n\n\n\n<p class=\"wp-block-paragraph\">Atlas Theory posted a video with his reactions to the <a href=\"https:\/\/www.youtube.com\/watch?v=21EMG3Xj8mk\" target=\"_blank\" rel=\"noreferrer noopener\">latest Star Atlas sneak peak video<\/a>.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-css-opacity\"\/>\n\n\n\n<p class=\"wp-block-paragraph\"><strong>Star Atlas SAGE 2023 Gameplay and Roadmap Updates<\/strong><\/p>\n\n\n\n<p class=\"wp-block-paragraph\">The Hologram News Network posted a video reviewing the <a href=\"https:\/\/www.youtube.com\/watch?v=cwa0BRM-Z6A\" target=\"_blank\" rel=\"noreferrer noopener\">latest Star Atlas roadmap updates<\/a>.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-css-opacity\"\/>\n\n\n\n<p class=\"wp-block-paragraph\"><strong>Metaverse Nomads #86<\/strong><\/p>\n\n\n\n<p class=\"wp-block-paragraph\">Metaverse Nomads posted a video of their <a href=\"https:\/\/www.youtube.com\/watch?v=sLDsPMHbxtc\" target=\"_blank\" rel=\"noreferrer noopener\">latest Star Atlas live stream<\/a>.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-css-opacity\"\/>\n\n\n\n<p class=\"wp-block-paragraph\"><strong>WEEKLY STAR ATLAS NEWSLETTER #71<\/strong><\/p>\n\n\n\n<p class=\"wp-block-paragraph\">Aephia published their <a href=\"https:\/\/aephia.com\/star-atlas\/weekly-star-atlas-newsletter-71\/\" target=\"_blank\" rel=\"noreferrer noopener\">latest Star Atlas newsletter<\/a>.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-css-opacity\"\/>\n\n\n\n<p class=\"wp-block-paragraph\"><strong>What U missed &#8211; STAR ATLAS twitter video<\/strong><\/p>\n\n\n\n<p class=\"wp-block-paragraph\">Gladiator posted a video reviewing the <a href=\"https:\/\/www.youtube.com\/watch?v=gUCKTaYZpYs\" target=\"_blank\" rel=\"noreferrer noopener\">latest Star Atlas sneak peak video<\/a>.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-css-opacity\"\/>\n\n\n\n<p class=\"wp-block-paragraph\"><strong>STAR ATLAS #165 FIRST SAGE GAMEPLAY!?<\/strong><\/p>\n\n\n\n<p class=\"wp-block-paragraph\">MetaVerse Explorer reviews the <a href=\"https:\/\/www.youtube.com\/watch?v=Izl-72TWQ_k\" target=\"_blank\" rel=\"noreferrer noopener\">latest SAGE gameplay video<\/a>.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-css-opacity\"\/>\n\n\n\n<p class=\"wp-block-paragraph\"><strong>STAR ATLAS FAQ #167 Frequently Asked Questions<\/strong><\/p>\n\n\n\n<p class=\"wp-block-paragraph\">MetaVerse Explorer posted a <a href=\"https:\/\/www.youtube.com\/watch?v=HOI2sBMBLXU\" target=\"_blank\" rel=\"noreferrer noopener\">FAQ Star Atlas video<\/a>.<\/p>\n","protected":fa
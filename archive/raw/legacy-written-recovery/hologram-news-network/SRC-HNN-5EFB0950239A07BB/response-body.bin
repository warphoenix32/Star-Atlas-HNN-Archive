ice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*kNUnYUrZnWMQ3gQ1.png":{"__typename":"ImageMetadata","id":"0*kNUnYUrZnWMQ3gQ1.png","originalHeight":179,"originalWidth":630,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:a6048ddccc65_30":{"__typename":"Paragraph","id":"a6048ddccc65_30","name":"aa75","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*kNUnYUrZnWMQ3gQ1.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_31":{"__typename":"Paragraph","id":"a6048ddccc65_31","name":"dbf2","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_4c99e0cd13bb":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_4c99e0cd13bb","isEditor":false},"Tag:eve-online":{"__typename":"Tag","id":"eve-online","displayTitle":"Eve Online","normalizedTagSlug":"eve-online"},"Tag:star-atlas":{"__typename":"Tag","id":"s
typename":"InternalLinksConnection","items":[]},"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}},"PostViewerEdge:postId:710378214cfa-viewerId:lo_6d9b887c2a01":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:710378214cfa-viewerId:lo_6d9b887c2a01"},"Paragraph:cca697597391_0":{"__typename":"Paragraph","id":"cca697597391_0","name":"d83f","type":"H3","href":null,"layout":null,"metadata":null,"text":"Aetera: The Ultimate Virtual City","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_1":{"__typename":"Paragraph","id":"cca697597391_1","name":"1cb5","type":"P","href":null,"layout":null,"metadata":null,"text":"A mud pilot’s guide to the future of metaverse cities","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":53,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_2":{"__typename":"Paragraph","id":"cca697597391_2","name":"2bcb","type":"H4","href":null,"layout":null,"metadata":null,"text":"The Challenge in Plain View","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":27,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_3":{"__typename":"Paragraph","id":"cca697597391_3","name":"73af","type":"P","href":null,"layout":null,"metadata":null,"text":"As a mud pilot, I often traverse the vast skies of beautiful townships within far-away worlds. Unfortunately, many of these virtual locations are plagued with problems such as poor collaboration, large numbers of inactive players, and fragmented servers. They are often sprawling and chaotic, with little consideration given to the desires of the community. In Web3, many plots of land are left unused, and those that are developed are abandoned due to their owners’ inactivity or location. The way these places are designed create virtual ghost towns. Star Atlas, an open-world MMO that combines the elements of gaming, space exploration, and cryptocurrency, seeks to change all of that.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":553,"end":563,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":123,"end":253,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*4fFtIK3SszxYzxDE.png":{"__typename":"ImageMetadata","id":"0*4fFtIK3SszxYzxDE.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:cca697597391_4":{"__typename":"Paragraph","id":"cca697597391_4","name":"69d4","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*4fFtIK3SszxYzxDE.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_5":{"__typename":"Paragraph","id":"cca697597391_5","name":"b4ea","type":"BQ","href":null,"layout":null,"metadata":null,"text":"“A key concept in understanding the production system is land. The universe of Star Atlas consists of regions, solar systems, and planets, and a basic land parcel represents…ownership of a planet’s territory.” (Star Atlas Economics-Paper)","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":211,"end":237,"href":"https:\u002F\u002Fstaratlas.com\u002Fassets\u002Fpdfs\u002Feconomics-paper.pdf","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_6":{"__typename":"Paragraph","id":"cca697597391_6","name":"edda","type":"P","href":null,"layout":null,"metadata":null,"text":"While Star Atlas has a clear plan of their own going forward, let’s take a serious look into what the ultimate metaverse city might look like. For discussions sake, let’s take a step back from Star Atlas for a moment in order to address some of the fundamental problems of cities, in and out of the metaverse, in order to design a living environment that’s well-organized and has an active community for all of its inhabitants. The goal is to envision a metropolis that’s not only pleasing to the eye, but also functional and sustainable. For utility's sake, let’s give this imaginary place a cool name: “Aeteria”.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":6,"end":16,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":193,"end":203,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":248,"end":279,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":605,"end":614,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":93,"end":141,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_7":{"__typename":"Paragraph","id":"cca697597391_7","name":"7c13","type":"H4","href":null,"layout":null,"metadata":null,"text":"Creating Procedurally-Shifting Cities","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_8":{"__typename":"Paragraph","id":"cca697597391_8","name":"0a5f","type":"P","href":null,"layout":null,"metadata":null,"text":"First, I’d like to introduce a new idea that would combine the power of artificial intelligence and machine learning in order to create a better virtual world. Let’s call this concept Procedurally-Shifting Cities, or PSC for short. Aeteria would be a virtual city, built on the blockchain, where users purchased and developed plots of land defined by NFT’s. Normal so far. The city would have a max number of lots, with the exact number determined by the NFT claim supply. Cool. But here’s where things get interesting: Aeteria would use PSC, allowing for the creation of a functional city which is capable of adjusting the location of its users’ land through procedurally generated systems.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":184,"end":212,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":217,"end":221,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":232,"end":239,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":520,"end":527,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":537,"end":541,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*Es9hIwLQl6WA70ayhX4PtA.png":{"__typename":"ImageMetadata","id":"1*Es9hIwLQl6WA70ayhX4PtA.png","originalHeight":480,"originalWidth":699,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:cca697597391_9":{"__typename":"Paragraph","id":"cca697597391_9","name":"fcb6","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*Es9hIwLQl6WA70ayhX4PtA.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_10":{"__typename":"Paragraph","id":"cca697597391_10","name":"0863","type":"H4","href":null,"layout":null,"metadata":null,"text":"A Dynamic City Model Only Possible in The Metaverse","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":51,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_11":{"__typename":"Paragraph","id":"cca697597391_11","name":"662c","type":"P","href":null,"layout":null,"metadata":null,"text":"Aeteria could be divided into different neighborhoods, with the center reserved for active users and the outskirts reserved for inactive users. Users who have not logged in or interacted with their plots for more than 30 days would have their plots automatically swapped to a lot on the outskirts of the active city during each patch, while active users would have their plots moved closer to the center. This would create a dynamic and constantly evolving city where active users were rewarded for their participation and where they are always near to each other. Not every city needs to act like it was designed by humans, after all.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":7,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":274,"end":280,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_12":{"__typename":"Paragraph","id":"cca697597391_12","name":"fdb8","type":"H4","href":null,"layout":null,"metadata":null,"text":"The Procedural Argument for Guilds and Professions","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_13":{"__typename":"Paragraph","id":"cca697597391_13","name":"dfd9","type":"P","href":null,"layout":null,"metadata":null,"text":"Procedurally-Shifting Cities (PSC) could be useful in a multiplayer game setting, such as a game with factions and guilds, because it allows for a large and diverse world that can be different for each player or group of players. Procedurally generated cities could be used to simulate a functional city, where the location of land could be adjusted based on the guilds or professions of the players or groups of players, taking their preferences into account. This would add a massive level of interest to the game.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":34,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*iIdZNxEKg54LXBJq.jpeg":{"__typename":"ImageMetadata","id":"0*iIdZNxEKg54LXBJq.jpeg","originalHeight":787,"originalWidth":1400,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:cca697597391_14":{"__typename":"Paragraph","id":"cca697597391_14","name":"2d8d","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*iIdZNxEKg54LXBJq.jpeg"},"text":"www.StarAtlas.com","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":17,"href":"http:\u002F\u002Fwww.StarAtlas.com","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_15":{"__typename":"Paragraph","id":"cca697597391_15","name":"dcbb","type":"H4","href":null,"layout":null,"metadata":null,"text":"Taking a Step Back from the Virtual","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_16":{"__typename":"Paragraph","id":"cca697597391_16","name":"cd39","type":"P","href":null,"layout":null,"metadata":null,"text":"The real-life cities that we live in on Earth are often disorganized and unplanned, with buildings and infrastructure haphazardly constructed without consideration for the needs of the future community. For example, because of a lack of design in most large cities, we see enormous traffic-jams. In other cities, there may be a lack of green spaces and parks, leading to poor air quality and limited opportunities for outdoor recreation. Additionally, many cities are designed with a car-centric approach, making it difficult for pedestrians and cyclists to navigate. Aeteria, on the other hand, is designed to be an organized virtual city no matter what, where users can actively shape the community to meet the needs of its inhabitants.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":568,"end":575,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*SqXo3Bu5B5bZWcnxjW64MA.png":{"__typename":"ImageMetadata","id":"1*SqXo3Bu5B5bZWcnxjW64MA.png","originalHeight":978,"originalWidth":995,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:cca697597391_17":{"__typename":"Paragraph","id":"cca697597391_17","name":"4ea1","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*SqXo3Bu5B5bZWcnxjW64MA.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_18":{"__typename":"Paragraph","id":"cca697597391_18","name":"d128","type":"H4","href":null,"layout":null,"metadata":null,"text":"How Will Star Atlas Land Work?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":30,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_19":{"__typename":"Paragraph","id":"cca697597391_19","name":"db28","type":"P","href":null,"layout":null,"metadata":null,"text":"Let’s bring it back home now. Out of all of the metaverses which are being developed right now, it seems like there’s one in particular which will rise above the others. Star Atlas has extensive plans to create not only land, but a universe full of economic complexity and competition. In order to grow and enjoy our time within the metaverse, we need healthy opposition. After all, what would Minecraft be without the Creeper? Because of the game’s competitive nature, being near other players and guild-members with professions, items, and skills that we don’t have will be vital.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":171,"end":284,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":306,"end":307,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":470,"end":582,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":298,"end":302,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":360,"end":370,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":388,"end":426,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*E4FHThSpQULP4vh3.png":{"__typename":"ImageMetadata","id":"0*E4FHThSpQULP4vh3.png","originalHeight":580,"originalWidth":731,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:cca697597391_20":{"__typename":"Paragraph","id":"cca697597391_20","name":"ec61","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*E4FHThSpQULP4vh3.png"},"text":"www.StarAtlas.com","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":17,"href":"http:\u002F\u002Fwww.StarAtlas.com","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_21":{"__typename":"Paragraph","id":"cca697597391_21","name":"41a8","type":"P","href":null,"layout":null,"metadata":null,"text":"Has Star Atlas has already solved the ghost-town dilemma in a different way? According to the Star Atlas Economics-Paper, each planet will be split up into NFT parcels and inactive land-users will be pushed out.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":94,"end":120,"href":"https:\u002F\u002Fstaratlas.com\u002Fassets\u002Fpdfs\u002Feconomics-paper.pdf","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":76,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_22":{"__typename":"Paragraph","id":"cca697597391_22","name":"8e22","type":"BQ","href":null,"layout":null,"metadata":null,"text":"“All buildings are built on land, with higher-end facilities requiring more developed land to function. All land is owned rather than rented, protecting users from eviction or discrimination by rent application. To disincentivize flipping — whereby a market agent would buy and simply hold land, planning to gain revenue from its value appreciation rather than its usage — the game utilizes Land Value Tax (LVT).","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_23":{"__typename":"Paragraph","id":"cca697597391_23","name":"0377","type":"BQ","href":null,"layout":null,"metadata":null,"text":"The DAO prices land tax in ATLAS depending on its level (the more developed land is taxed more), with the global limits adjustable by the top-level DAOs. This mechanism provides dynamic protection from flipping and balances land value with its potential productive capabilities.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_24":{"__typename":"Paragraph","id":"cca697597391_24","name":"26f7","type":"PQ","href":null,"layout":null,"metadata":null,"text":"If the land owner does not pay taxes, the land will eventually be foreclosed, disabling all buildings (but not stopping tax accrual). After an additional period, the land can be auctioned by local governance, recapturing back taxes and a fine, and returning the remaining funds to the original owner.”","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_25":{"__typename":"Paragraph","id":"cca697597391_25","name":"6c65","type":"H4","href":null,"layout":null,"metadata":null,"text":"A Look at Traditional Gaming","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":28,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_26":{"__typename":"Paragraph","id":"cca697597391_26","name":"4b8c","type":"P","href":null,"layout":null,"metadata":null,"text":"You may have heard of the game Star Citizen. The following city is procedurally generated. While many of these buildings in-game aren’t functional, imagine if a crypto-wallet was automatically assigned to a specific building depending on size and value of each players land-claim:","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":31,"end":43,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:2f06e3be7eba895f16a1a2293d8b8f1b":{"__typename":"MediaResource","id":"2f06e3be7eba895f16a1a2293d8b8f1b","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?src=https%3A%2F%2Fwww.youtube.com%2Fembed%2FRgjTf41QAnY%3Ffeature%3Doembed&display_name=YouTube&url=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DRgjTf41QAnY&image=https%3A%2F%2Fi.ytimg.com%2Fvi%2FRgjTf41QAnY%2Fhqdefault.jpg&key=a19fcc184b9711e1b4764040d3dc5c07&type=text%2Fhtml&schema=youtube","iframeHeight":480,"iframeWidth":854,"title":"How Is This Real?! Star Citizen 3.5 Arc Corp City Planet"},"Paragraph:cca697597391_27":{"__typename":"Paragraph","id":"cca697597391_27","name":"e889","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:2f06e3be7eba895f16a1a2293d8b8f1b"}},"mixtapeMetadata":null},"Paragraph:cca697597391_28":{"__typename":"Paragraph","id":"cca697597391_28","name":"0702","type":"P","href":null,"layout":null,"metadata":null,"text":"Why is Minecraft the best-selling and most popular video game of all time? How are there over 140 million active users playing a game of cubes? It comes down to the game’s open-ended nature and the ability for players to customize and create their own buildings, environments, and experiences. The ability of players to create their own bases and environments is one of the greatest features Minecraft has to offer. Allowing for customization and building in a space-themed game like Star Atlas would bring a similar appeal.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":7,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":194,"end":292,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":484,"end":494,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_29":{"__typename":"Paragraph","id":"cca697597391_29","name":"7672","type":"H4","href":null,"layout":null,"metadata":null,"text":"In Conclusion","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_30":{"__typename":"Paragraph","id":"cca697597391_30","name":"9a0f","type":"P","href":null,"layout":null,"metadata":null,"text":"Procedurally-Shifting Cities (PSC) could solve many important problems in the metaverse but may not be completely realistic in the short-term. Drawing inspiration from real-life can have great value, but we also shouldn’t stifle imagination within code. Star Atlas has found revolutionary solutions that may prove to be the industry standard going forward. Maybe there’s a more intelligent way to handle ghost towns, but that shouldn’t keep us from moving forward. Regardless, allowing for seamless cityscapes where interaction comes naturally, and often, should be the goal of our ultimate metaverse city, Aeteria.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":35,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":254,"end":264,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":607,"end":614,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":581,"end":605,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_31":{"__typename":"Paragraph","id":"cca697597391_31","name":"4c8f","type":"P","href":null,"layout":null,"metadata":null,"text":"I’m hoping the possibility opens up for me to cover my space station with grass and fill it with animals.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":105,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_32":{"__typename":"Paragraph","id":"cca697597391_32","name":"389c","type":"P","href":null,"layout":null,"metadata":null,"text":"What kind of city would you like to see in Star Atlas? Also, if you enjoyed this article or would like to hear about something specific in the future, please leave a comment below.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":151,"end":179,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*ygAwmWBm4qxsHDLEDbLCqg.png":{"__typename":"ImageMetadata","id":"1*ygAwmWBm4qxsHDLEDbLCqg.png","originalHeight":450,"originalWidth":1001,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:cca697597391_33":{"__typename":"Paragraph","id":"cca697597391_33","name":"f3d2","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*ygAwmWBm4qxsHDLEDbLCqg.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_34":{"__typename":"Paragraph","id":"cca697597391_34","name":"3cdb","type":"H3","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_35":{"__typename":"Paragraph","id":"cca697597391_35","name":"e337","type":"P","href":null,"layout":null,"metadata":null,"text":"NotBitcoinCEO is a mud pilot & writer on The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":13,"href":"https:\u002F\u002Fmedium.com\u002F@mudpilot","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":13,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_36":{"__typename":"Paragraph","id":"cca697597391_36","name":"1cb3","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_37":{"__typename":"Paragraph","id":"cca697597391_37","name":"e130","type":"P","href":null,"layout":null,"metadata":null,"text":"Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Ftwitter.com\u002FHologram_News","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":19,"href":"https:\u002F\u002Fwww.instagram.com\u002Fhologram_news\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":22,"end":25,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_38":{"__typename":"Paragraph","id":"cca697597391_38","name":"2767","type":"H3","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_39":{"__typename":"Paragraph","id":"cca697597391_39","name":"cfa8","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*IFkq2A9u1lJakAnE.png":{"__typename":"ImageMetadata","id":"0*IFkq2A9u1lJakAnE.png","originalHeight":199,"originalWidth":700,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:cca697597391_40":{"__typename":"Paragraph","id":"cca697597391_40","name":"de49","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*IFkq2A9u1lJakAnE.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cca697597391_41":{"__typename":"Paragraph","id":"cca697597391_41","name":"54d2","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_6d9b887c2a01":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_6d9b887c2a01","isEditor":false},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","atsQualifiedAt":1650725917596},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"Tag:metaverse":{"__typename":"Tag","id":"metaverse","displayTitle":"Metaverse","normalizedTagSlug":"metaverse"},"Tag:cities":{"__typename":"Tag","id":"cities","displayTitle":"Cities","normalizedTagSlug":"cities"}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"HIT","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.e31fa5c8.js"></script><script src="https://cdn-client.medium.com/lite/static/js/7505.62df2c9c.js"></script><script src="https://cdn-client.medium.com/lite/static/js/main.70ef2f04.js"></script><script src="https://cdn-client.medium.com/lite/static/js/instrumenta
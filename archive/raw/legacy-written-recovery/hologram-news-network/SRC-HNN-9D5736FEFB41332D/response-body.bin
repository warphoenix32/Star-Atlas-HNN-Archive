:null,"topics":[],"viewerEdge":{"__ref":"PostViewerEdge:postId:30934fddff58-viewerId:lo_eb3ad6049cd6"},"latestPublishedVersion":"72df41431705","postResponses":{"__typename":"PostResponses","count":0},"allowResponses":true,"isLimitedState":false,"voterCount":0,"recommenders":[],"isSeries":false,"sequence":null,"uniqueSlug":"the-galia-archives-a-star-atlas-library-system-30934fddff58","title":"The Galia Archives: A Star Atlas Library System","clapCount":0,"pinnedAt":0,"pinnedByCreatorAt":0,"curationEligibleAt":0,"responseDistribution":"NOT_DISTRIBUTED","inResponseToPostResult":null,"inResponseToCatalogResult":null,"pendingCollection":null,"isNewsletter":false,"isAuthorNewsletter":false,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"},{"__ref":"Tag:futurism"},{"__ref":"Tag:gaming"}],"readingTime":4.2522012578616355,"inResponseToEntityType":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1673922593923,"previewContent":{"__typename":"PreviewContent","subtitle":"Can Star Atlas, through the power of Web3, bring information and education to diconnected people around the world?"},"previewImage":{"__ref":"ImageMetadata:0*4TiJiYtQuhUQpnl9.png"},"isShortform":false,"seoTitle":"","updatedAt":1673922596521,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"isSuspended":false,"responseRootPost":{"__typename":"ResponseRootPost","post":{"__ref":"Post:30934fddff58"}},"internalLinks({\"paging\":{\"limit\":8}})":{"__typename":"InternalLinksConnection","items":[]},"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}},"ImageMetadata:":{"__typename":"ImageMetadata","id":"","originalHeight":0,"originalWidth":0},"ImageMetadata:1*f_eM4RCjT9rvJ7vA_tR7hA.jpeg":{"__typename":"ImageMetadata","id":"1*f_eM4RCjT9rvJ7vA_tR7hA.jpeg"},"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg","originalWidth":2730,"focusPercentX":48.57142857142857,"focusPercentY":45.19230769230769},"ImageMetadata:1*EWK2g3sZ2CUq9HSp-mKvEA.png":{"__typename":"ImageMetadata","id":"1*EWK2g3sZ2CUq9HSp-mKvEA.png","originalWidth":1024},"PostViewerEdge:postId:30934fddff58-viewerId:lo_eb3ad6049cd6":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:30934fddff58-viewerId:lo_eb3ad6049cd6"},"Paragraph:72df41431705_0":{"__typename":"Paragraph","id":"72df41431705_0","name":"781c","type":"H3","href":null,"layout":null,"metadata":null,"text":"The Galia Archives: A Star Atlas Library System","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_1":{"__typename":"Paragraph","id":"72df41431705_1","name":"cb43","type":"P","href":null,"layout":null,"metadata":null,"text":"How would it happen and what would it look like?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":48,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_2":{"__typename":"Paragraph","id":"72df41431705_2","name":"c3f6","type":"P","href":null,"layout":null,"metadata":null,"text":"The developing Star Atlas metaverse is a unique and immersive gaming experience that combines the elements of gaming, space exploration, and cryptocurrency. While the game itself is already becoming a captivating experience, imagine for a moment the addition of a simple, yet visually appealing Library System on the Solana blockchain, built for browser and Unreal Engine 5 integration.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":15,"end":25,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null},{"__typename":"Markup","type":"A","start":317,"end":323,"href":null,"anchorType":"USER","userId":"af6a22150fa9","linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":295,"end":309,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_3":{"__typename":"Paragraph","id":"72df41431705_3","name":"8862","type":"H4","href":null,"layout":null,"metadata":null,"text":"Near the end of 2022, Star Atlas released massive news:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_4":{"__typename":"Paragraph","id":"72df41431705_4","name":"a34a","type":"BQ","href":null,"layout":null,"metadata":null,"text":"A bridge to web3 for game developers: “…An in-game wallet that connects the Solana blockchain to Unreal Engine 5, as well as F-KIT, a free version of the software for developers looking to build on Solana.” (staratlas.com)","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":125,"end":130,"href":"https:\u002F\u002Fgithub.com\u002Fstaratlasmeta\u002FFoundationKit","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":208,"end":221,"href":"https:\u002F\u002Fstaratlas.com\u002Fnewsroom\u002Fstar-atlas-news\u002Fthe-f-kit-a-bridge-to-web3-for-game-developers","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":0,"end":222,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_5":{"__typename":"Paragraph","id":"72df41431705_5","name":"9995","type":"P","href":null,"layout":null,"metadata":null,"text":"This leads us to the theorization of many things, one of them being NFT books and a comprehensive library within the Star Atlas metaverse. Developers are finally given the preliminary tools to take part in the digital creation of such ideas. Star Atlas — Marketplace has shown off the seeds of this by releasing NFT comic books (also available on Magic Eden) on the Solana blockchain.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":242,"end":266,"href":"https:\u002F\u002Fplay.staratlas.com\u002Fmarket\u002F?category=story","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":347,"end":357,"href":"https:\u002F\u002Fmagiceden.io\u002Fmarketplace\u002Fstar_atlas_core","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":68,"end":77,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":117,"end":127,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":312,"end":329,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*b-Sic_OJmEnwEH4F.png":{"__typename":"ImageMetadata","id":"0*b-Sic_OJmEnwEH4F.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":"NotBitcoinCEO 1"},"Paragraph:72df41431705_6":{"__typename":"Paragraph","id":"72df41431705_6","name":"69a8","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*b-Sic_OJmEnwEH4F.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_7":{"__typename":"Paragraph","id":"72df41431705_7","name":"4859","type":"H4","href":null,"layout":null,"metadata":null,"text":"Inspirations for a Star Atlas Library","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":37,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_8":{"__typename":"Paragraph","id":"72df41431705_8","name":"e65f","type":"P","href":null,"layout":null,"metadata":null,"text":"Web3 libraries would allow users to access a wide range of books and other written materials, such as The Hologram news, notes, comics, lore, guild documents, mining articles, reference materials for crafting, etc. The books themselves could be interactive, allowing users to flip through pages, highlight text, and make notes. They could be designed to look and feel like real libraries, with shelves, tables, and chairs. Users could search for books and other materials using a variety of criteria, such as author, title, or subject.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":5,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":102,"end":120,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":121,"end":127,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":128,"end":141,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":142,"end":195,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":196,"end":213,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":509,"end":534,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*JO9ck-NzsExLO4096fb_Rw.png":{"__typename":"ImageMetadata","id":"1*JO9ck-NzsExLO4096fb_Rw.png","originalHeight":506,"originalWidth":1002,"focusPercentX":null,"focusPercentY":null,"alt":"NotBitcoinCEO 2"},"Paragraph:72df41431705_9":{"__typename":"Paragraph","id":"72df41431705_9","name":"ff0d","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*JO9ck-NzsExLO4096fb_Rw.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_10":{"__typename":"Paragraph","id":"72df41431705_10","name":"2e7c","type":"P","href":null,"layout":null,"metadata":null,"text":"The first time I experienced life-like books in videogames was in The Elder Scrolls games. The books were beautifully rendered, with intricate text that seemed to jump off the screen. I couldn’t help but feel a sense of realism that made the experience feel new and exciting. It was as if I was reading an actual book, rather than just staring at a computer screen. I was able to collect books within my inventory, and eventually organize them into libraries. This experience helped me feel the power of digital technology to create truly immersive experiences.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":66,"end":84,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":89,"end":90,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_11":{"__typename":"Paragraph","id":"72df41431705_11","name":"9a81","type":"P","href":null,"layout":null,"metadata":null,"text":"Another inspiration takes place in Minecraft. Blockworks, with the help of 24 individuals from 16 countries, pioneered a library containing censored journals and articles as in-game book objects. It’s currently hosted on a server allowing anyone around the world to visit and is also free to download for single-player. Award-winning projects like these could be used to inspire the galactic libraries of Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":46,"end":56,"href":"https:\u002F\u002Fwww.blockworks.uk\u002Fthe-uncensored-library","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":35,"end":44,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":45,"end":46,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:f19bc1c8f5bc0793fc2b1d398bea6a57":{"__typename":"MediaResource","id":"f19bc1c8f5bc0793fc2b1d398bea6a57","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?src=https%3A%2F%2Fwww.youtube.com%2Fembed%2FvFKvjEV6muc&display_name=YouTube&url=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DvFKvjEV6muc&image=http%3A%2F%2Fi.ytimg.com%2Fvi%2FvFKvjEV6muc%2Fhqdefault.jpg&key=a19fcc184b9711e1b4764040d3dc5c07&type=text%2Fhtml&schema=youtube","iframeHeight":480,"iframeWidth":854,"title":""},"Paragraph:72df41431705_12":{"__typename":"Paragraph","id":"72df41431705_12","name":"b4da","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:f19bc1c8f5bc0793fc2b1d398bea6a57"}},"mixtapeMetadata":null},"Paragraph:72df41431705_13":{"__typename":"Paragraph","id":"72df41431705_13","name":"c1c1","type":"H4","href":null,"layout":null,"metadata":null,"text":"A Divergence from Expectations","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_14":{"__typename":"Paragraph","id":"72df41431705_14","name":"ee3e","type":"P","href":null,"layout":null,"metadata":null,"text":"The libraries of Star Atlas might be different than expected, however. After all, most spaceships have monitor displays. We can look at an additional concept of a digital library system in pop-culture for inspiration. One that comes to mind is the greatest repository of knowledge ever created…The Jedi Archives. It might not be as nostalgic, but it would definitely be convenient and futuristic.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":294,"end":311,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":248,"end":293,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_15":{"__typename":"Paragraph","id":"72df41431705_15","name":"cc5d","type":"BQ","href":null,"layout":null,"metadata":null,"text":"“If an item does not appear in our records, it does not exist.”","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:24c9daddc03288a622125f36c91036c3":{"__typename":"MediaResource","id":"24c9daddc03288a622125f36c91036c3","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?src=https%3A%2F%2Fwww.youtube.com%2Fembed%2FiNlqt3pvRFg%3Ffeature%3Doembed&display_name=YouTube&url=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DiNlqt3pvRFg&image=https%3A%2F%2Fi.ytimg.com%2Fvi%2FiNlqt3pvRFg%2Fhqdefault.jpg&key=a19fcc184b9711e1b4764040d3dc5c07&type=text%2Fhtml&schema=youtube","iframeHeight":480,"iframeWidth":854,"title":"Star Wars - if an item does not appear in our records..."},"Paragraph:72df41431705_16":{"__typename":"Paragraph","id":"72df41431705_16","name":"024c","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:24c9daddc03288a622125f36c91036c3"}},"mixtapeMetadata":null},"Paragraph:72df41431705_17":{"__typename":"Paragraph","id":"72df41431705_17","name":"8c87","type":"H4","href":null,"layout":null,"metadata":null,"text":"Shaping the future of the Metaverse","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_18":{"__typename":"Paragraph","id":"72df41431705_18","name":"2543","type":"P","href":null,"layout":null,"metadata":null,"text":"Regardless of what direction the Star Atlas team takes the library system or whether a third-party is able to develop something more pronounced, opening up publishing input to all users would be a game-changer. Giving players the ability to submit and publish documents within the game (with a fee to discourage spam) would be incredibly attractive to gamers and writers alike. It would create a sense of community and ownership and would provide a way for players to share tips and strategies while also helping developers gather important feedback.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":230,"end":269,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":287,"end":316,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_19":{"__typename":"Paragraph","id":"72df41431705_19","name":"c97c","type":"H4","href":null,"layout":null,"metadata":null,"text":"A Call to Developers Interested in the Metaverse","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_20":{"__typename":"Paragraph","id":"72df41431705_20","name":"6bde","type":"P","href":null,"layout":null,"metadata":null,"text":"F-KIT is said to significantly reduce development and time costs associated with integrating Unreal Engine 5 and Solana. It features in-engine generation and imports of private keys and wallets, enabling interactions with on-chain data and facilitating on-chain transactions such as sNFTs, xNFTs, and tokens. Additionally, it offers a wallet management feature for SPL tokens and NFTs, embedded development support, and includes visual coding blueprints for user interfaces and user experience. It’s also capable of integrating with any Solana program.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*RYlas1BF1pvx3jju.png":{"__typename":"ImageMetadata","id":"0*RYlas1BF1pvx3jju.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":"NotBitcoinCEO 3"},"Paragraph:72df41431705_21":{"__typename":"Paragraph","id":"72df41431705_21","name":"3155","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*RYlas1BF1pvx3jju.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_22":{"__typename":"Paragraph","id":"72df41431705_22","name":"1270","type":"PQ","href":null,"layout":null,"metadata":null,"text":"As a mud pilot, I plan on catching up on a little reading while traveling between planets.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*4TiJiYtQuhUQpnl9.png":{"__typename":"ImageMetadata","id":"0*4TiJiYtQuhUQpnl9.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":"NotBitcoinCEO 4"},"Paragraph:72df41431705_23":{"__typename":"Paragraph","id":"72df41431705_23","name":"3c1e","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*4TiJiYtQuhUQpnl9.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_24":{"__typename":"Paragraph","id":"72df41431705_24","name":"8619","type":"P","href":null,"layout":null,"metadata":null,"text":"Similar to the spaceships, it will be exciting to witness the fruition of libraries within the game itself. Of course, don’t forget to give your eyes a break. Go outside every once in a while.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":192,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_25":{"__typename":"Paragraph","id":"72df41431705_25","name":"7428","type":"H4","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_26":{"__typename":"Paragraph","id":"72df41431705_26","name":"10e0","type":"P","href":null,"layout":null,"metadata":null,"text":"NotBitcoinCEO is a mud pilot & writer on The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":13,"href":"https:\u002F\u002Fmedium.com\u002F@mudpilot","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":13,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_27":{"__typename":"Paragraph","id":"72df41431705_27","name":"0b63","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_28":{"__typename":"Paragraph","id":"72df41431705_28","name":"04db","type":"P","href":null,"layout":null,"metadata":null,"text":"Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Ftwitter.com\u002FHologram_News","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":19,"href":"https:\u002F\u002Fwww.instagram.com\u002Fhologram_news\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":22,"end":25,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_29":{"__typename":"Paragraph","id":"72df41431705_29","name":"2fa2","type":"H4","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_30":{"__typename":"Paragraph","id":"72df41431705_30","name":"9dc9","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*4HKSJag_pMzSlGvQ.png":{"__typename":"ImageMetadata","id":"0*4HKSJag_pMzSlGvQ.png","originalHeight":199,"originalWidth":700,"focusPercentX":null,"focusPercentY":null,"alt":"NotBitcoinCEO 5"},"Paragraph:72df41431705_31":{"__typename":"Paragraph","id":"72df41431705_31","name":"4d40","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*4HKSJag_pMzSlGvQ.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:72df41431705_32":{"__typename":"Paragraph","id":"72df41431705_32","name":"d7f1","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_eb3ad6049cd6":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_eb3ad6049cd6","isEditor":false},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","atsQualifiedAt":1650725917596},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"Tag:futurism":{"__typename":"Tag","id":"futurism","displayTitle":"Futurism","normalizedTagSlug":"futurism"},"Tag:gaming":{"__typename":"Tag","id":"gaming","displayTitle":"Gaming","normalizedTagSlug":"gaming"}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"MISS","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.2899f91e.js"></script><script src="https://cdn-client.medium.com/lite/static/js/7505.62df2c9c.js"></script><script src="https://cdn-client.medium.com/lite/static/js/main.5d75a9d3.js"></script><script src="https://cdn-client.medium.com/lite/static/js/instrumentation.c71f0248.chunk.js"></script>

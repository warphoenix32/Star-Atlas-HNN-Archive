1"},"showPromo":true},"Post:bff20fd1e3c":{"__typename":"Post","id":"bff20fd1e3c"},"PostViewerEdge:postId:30666e2359ba-viewerId:lo_03a38de8bf2b":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:30666e2359ba-viewerId:lo_03a38de8bf2b"},"Paragraph:77b1fd3692d0_0":{"__typename":"Paragraph","id":"77b1fd3692d0_0","name":"478f","type":"H3","href":null,"layout":null,"metadata":null,"text":"ATMTA Sells $1.6 Million USD Worth of ATLAS and POLIS Over Last 3 Months","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_1":{"__typename":"Paragraph","id":"77b1fd3692d0_1","name":"da03","type":"P","href":null,"layout":null,"metadata":null,"text":"What began as an investigation into a potential exploit by Star Atlas community members led to the public discovery that ATMTA, Inc. sold over $1.6 million dollars worth of ATLAS and POLIS over the last three months. No official reason has been given for these sales.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":59,"end":69,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_2":{"__typename":"Paragraph","id":"77b1fd3692d0_2","name":"e36a","type":"P","href":null,"layout":null,"metadata":null,"text":"This article has been updated to reflect that jup.ag was the primary exchange for USDC transfers, not MEXC. The article was update to reflect links to Solscan highlighting the transaction details.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":196,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*9tBtOkfMmCa503hA.png":{"__typename":"ImageMetadata","id":"0*9tBtOkfMmCa503hA.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:77b1fd3692d0_3":{"__typename":"Paragraph","id":"77b1fd3692d0_3","name":"10cf","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*9tBtOkfMmCa503hA.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_4":{"__typename":"Paragraph","id":"77b1fd3692d0_4","name":"9bc5","type":"H3","href":null,"layout":null,"metadata":null,"text":"Reading the Blockchain","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":22,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_5":{"__typename":"Paragraph","id":"77b1fd3692d0_5","name":"a730","type":"P","href":null,"layout":null,"metadata":null,"text":"Star Atlas community blockchain analysts discovered on Friday that ATMTA, Inc has been selling company owned POLIS and ATLAS tokens since mid-January.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_6":{"__typename":"Paragraph","id":"77b1fd3692d0_6","name":"0a06","type":"P","href":null,"layout":null,"metadata":null,"text":"Blockchain analysis was conducted by Andre from The Club Guild with additional verification from yaawn of Bulk.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":48,"end":62,"href":null,"anchorType":"USER","userId":"1e2c913fa2a0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_7":{"__typename":"Paragraph","id":"77b1fd3692d0_7","name":"0f04","type":"P","href":null,"layout":null,"metadata":null,"text":"The detective work began when community member Andre posed a question to the Economics channel in the Star Atlas Discord late Friday evening.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":61,"end":69,"href":"https:\u002F\u002Fdiscord.com\u002Fchannels\u002F789226204980707409\u002F874400139534536745\u002F1094028169759166626","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_8":{"__typename":"Paragraph","id":"77b1fd3692d0_8","name":"25d7","type":"BQ","href":null,"layout":null,"metadata":null,"text":"“Anyone know who B5hX2Aj8FYmdYjXQFVF1jpz7BkrdpLXgSPs92G6DFGjA is? He’s been selling 1.6 million USD worth of $atlas and $polis last 3 months” — Andre","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":144,"end":149,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":144,"end":149,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*yeszcMrwELOyaKKe.png":{"__typename":"ImageMetadata","id":"0*yeszcMrwELOyaKKe.png","originalHeight":364,"originalWidth":508,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:77b1fd3692d0_9":{"__typename":"Paragraph","id":"77b1fd3692d0_9","name":"eb1b","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*yeszcMrwELOyaKKe.png"},"text":"Birdeye.so overview of B5hX2Aj8FYmdYjXQFVF1jpz7BkrdpLXgSPs92G6DFGjA wallet activity over the past 90 days","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":105,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":23,"end":105,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_10":{"__typename":"Paragraph","id":"77b1fd3692d0_10","name":"b9f7","type":"P","href":null,"layout":null,"metadata":null,"text":"Andre also noted that these token swaps were being conducted primarily on the jup.ag decentralized exchange, where tokens were ultimately swapped for USDC and transferred to Coinbase.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_11":{"__typename":"Paragraph","id":"77b1fd3692d0_11","name":"faf8","type":"P","href":null,"layout":null,"metadata":null,"text":"You can view a summary of the community’s analyst work at the end of the article.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":81,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*uXp-gaMLaAMzwvsW.png":{"__typename":"ImageMetadata","id":"0*uXp-gaMLaAMzwvsW.png","originalHeight":735,"originalWidth":1259,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:77b1fd3692d0_12":{"__typename":"Paragraph","id":"77b1fd3692d0_12","name":"7b56","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*uXp-gaMLaAMzwvsW.png"},"text":"$POLIS holdings of MEXC Global","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_13":{"__typename":"Paragraph","id":"77b1fd3692d0_13","name":"4771","type":"H3","href":null,"layout":null,"metadata":null,"text":"ATMTA Sells Tokens, Official Reason Unknown","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_14":{"__typename":"Paragraph","id":"77b1fd3692d0_14","name":"c3b2","type":"P","href":null,"layout":null,"metadata":null,"text":"ATMTA has yet to release an official statement regarding the sale of privately held ATLAS and POLIS tokens. During the last Star Atlas town hall that occurred on February, 3rd, CEO Michael Wagner indicated that the team would likely begin selling tokens “in the near future”.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":255,"end":275,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_15":{"__typename":"Paragraph","id":"77b1fd3692d0_15","name":"a424","type":"BQ","href":null,"layout":null,"metadata":null,"text":"We weren’t in a position to sell any of our tokens last year, I took a strong position against that. So, at some point in the future though, it should be expected and realistic that we are going to be selling some of our tokens on a regular basis into the market as well. Our objective there is to be market neutral, we don’t want to have any impact on the market rate either up or down…there is a huge opportunity for us to capitalize on the ecosystem tokens that we hold on our balance sheet. — CEO Michael Wagner on token sales","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":496,"end":530,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":493,"end":530,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:e76d7f059a1361a05bea14be3abac186":{"__typename":"MediaResource","id":"e76d7f059a1361a05bea14be3abac186","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?src=https%3A%2F%2Fwww.youtube.com%2Fembed%2FZsqGeOhcQwE%3Ffeature%3Doembed&display_name=YouTube&url=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DZsqGeOhcQwE&image=https%3A%2F%2Fi.ytimg.com%2Fvi%2FZsqGeOhcQwE%2Fhqdefault.jpg&key=a19fcc184b9711e1b4764040d3dc5c07&type=text%2Fhtml&schema=youtube","iframeHeight":480,"iframeWidth":854,"title":"Townhall #37"},"Paragraph:77b1fd3692d0_16":{"__typename":"Paragraph","id":"77b1fd3692d0_16","name":"ae4b","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"Star Atlas Feb 3 Town Hall; comments begin at the 1:26:04 mark","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":62,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:e76d7f059a1361a05bea14be3abac186"}},"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_17":{"__typename":"Paragraph","id":"77b1fd3692d0_17","name":"b313","type":"H3","href":null,"layout":null,"metadata":null,"text":"Community Sentiment on Token Sales","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_18":{"__typename":"Paragraph","id":"77b1fd3692d0_18","name":"b09a","type":"P","href":null,"layout":null,"metadata":null,"text":"In many projects, the sale of project tokens by developers can be an ominous portent. However, some in the Star Atlas community were unfazed by this revelation and viewed it in a positive light.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_19":{"__typename":"Paragraph","id":"77b1fd3692d0_19","name":"2d49","type":"P","href":null,"layout":null,"metadata":null,"text":"While no official reasoning has been given by ATMTA, positive-leaning community members speculate that the token sales are a method by which ATMTA is increasing its development runway through the year. ATMTA was impacted by the FTX collapse last year, shortening its development runway by approximately half. ATMTA eventually recovered a portion of its lost funds.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":228,"end":240,"href":"https:\u002F\u002Fmedium.com\u002Fblockchain-biz\u002Fstar-atlas-heavily-affected-by-ftx-catastrophe-ceo-remains-committed-180cf3c2f5a9","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":353,"end":364,"href":"https:\u002F\u002Fmedium.com\u002Fblockchain-biz\u002Fspace-game-star-atlas-recovers-lost-funds-from-ftx-3d0c13f6ed83","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_20":{"__typename":"Paragraph","id":"77b1fd3692d0_20","name":"bbb0","type":"P","href":null,"layout":null,"metadata":null,"text":"Other community members were not as reassured and viewed the selling activity in a more dismal light. Without an official statement from ATMTA, these individuals were concerned that something more nefarious was occurring.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_21":{"__typename":"Paragraph","id":"77b1fd3692d0_21","name":"ef25","type":"P","href":null,"layout":null,"metadata":null,"text":"Despite the sales, several individuals in the community pointed out that ATMTA would need to significantly elevate it selling rate to even come close to liquidating its entire token reserves. Others were also quick to point out that ATMTA was sacrificing its position in the Star Atlas DAO to secure revenue, a forward leaning projection for some.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_22":{"__typename":"Paragraph","id":"77b1fd3692d0_22","name":"a170","type":"P","href":null,"layout":null,"metadata":null,"text":"Whatever the reason, the sale of Star Atlas tokens by ATMTA will likely continue.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_23":{"__typename":"Paragraph","id":"77b1fd3692d0_23","name":"2ea7","type":"H3","href":null,"layout":null,"metadata":null,"text":"Summary of Blockchain Analysis","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_24":{"__typename":"Paragraph","id":"77b1fd3692d0_24","name":"7aa8","type":"P","href":null,"layout":null,"metadata":null,"text":"Andre’s source analysis of ATMTA’s account:","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":43,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_25":{"__typename":"Paragraph","id":"77b1fd3692d0_25","name":"7f68","type":"MIXTAPE_EMBED","href":null,"layout":null,"metadata":null,"text":"Account GgYtnDJMHQG4gpVzy2KHukSvHfFJcs1jLXASsBCQE83P\nThe user-friendly and real-time update Scanning Tool for the Solana Ecosystem. Track your $SOL and Solana-related…solscan.io","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":177,"href":"https:\u002F\u002Fsolscan.io\u002Faccount\u002FGgYtnDJMHQG4gpVzy2KHukSvHfFJcs1jLXASsBCQE83P","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":52,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":53,"end":167,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":{"__typename":"MixtapeMetadata","href":"https:\u002F\u002Fsolscan.io\u002Faccount\u002FGgYtnDJMHQG4gpVzy2KHukSvHfFJcs1jLXASsBCQE83P","mediaResource":{"__typename":"MediaResource","mediumCatalog":null},"thumbnailImageId":"0*Bv7V6SvAeCKAEe5Z"}},"Paragraph:77b1fd3692d0_26":{"__typename":"Paragraph","id":"77b1fd3692d0_26","name":"fe2a","type":"P","href":null,"layout":null,"metadata":null,"text":"Yaawn’s explanation of ATMTA’s Transactions","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":43,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_27":{"__typename":"Paragraph","id":"77b1fd3692d0_27","name":"985f","type":"P","href":null,"layout":null,"metadata":null,"text":"That 4zLYwzBiEK6 wallet is the team [ATMTA] and GgY is team [ATMTA] wallet as well. Yes it’s 100% team swapping POLIS and ATLAS for USDC to send to HYNeQp {ATMTA wallet].","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":170,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_28":{"__typename":"Paragraph","id":"77b1fd3692d0_28","name":"f3b7","type":"P","href":null,"layout":null,"metadata":null,"text":"The 4zLYwz is their [ATMTA] deposit address for MEXC","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":28,"end":52,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":0,"end":52,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_29":{"__typename":"Paragraph","id":"77b1fd3692d0_29","name":"b629","type":"P","href":null,"layout":null,"metadata":null,"text":"Transfers to Coinbase: 3ehmDUijQ4cxk8ZhqChBCs9Cyo5zHAnkwR3eUEaoVguwhDnRbr8iH8omAU3N4nbMwUfZE9ZWGNCo7UAAbNPXK54P","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":21,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":0,"end":111,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_30":{"__typename":"Paragraph","id":"77b1fd3692d0_30","name":"2004","type":"P","href":null,"layout":null,"metadata":null,"text":"4ER73ekiyyZQU5mL4Wz347tfeqCcfDrENDR42v4AArjovodP6x9hEtZmyW4oetevy7z9Rt3s8J2NB6KRyXhNeExg","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":88,"href":"https:\u002F\u002Fsolscan.io\u002Ftx\u002F4ER73ekiyyZQU5mL4Wz347tfeqCcfDrENDR42v4AArjovodP6x9hEtZmyW4oetevy7z9Rt3s8J2NB6KRyXhNeExg","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":0,"end":88,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlo
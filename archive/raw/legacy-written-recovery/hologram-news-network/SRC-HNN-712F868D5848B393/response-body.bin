ypename":"Markup","type":"A","start":60,"end":65,"href":null,"anchorType":"USER","userId":"41e0c5b141f1","linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":27,"end":31,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":32,"end":36,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":0,"end":65,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_2":{"__typename":"Paragraph","id":"282294b3e064_2","name":"0175","type":"P","href":null,"layout":null,"metadata":null,"text":"Family is central to every culture or faction we come across. After the signing of the peace treaty it seems as if the galactic family has grown even more and many of the past mysteries have begun to be uncovered. But while general peace was achieved, the majority had a long history of leaving their homes behind, each faction and individual holding a very different story. These experiences help us in understanding the complex workings of this futuristic civilization. Krigs recently interviewed the Head Writer of Star Atlas Lore Matthew Medney and Content Writer Jose, to give us a deeper insight into the formation of such stories.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":6,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":503,"end":515,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":517,"end":518,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":534,"end":548,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":553,"end":572,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_3":{"__typename":"Paragraph","id":"282294b3e064_3","name":"1a3b","type":"P","href":null,"layout":null,"metadata":null,"text":"During the interview, Matthew shared a vital truth explaining the importance of ancestry in every story being told:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_4":{"__typename":"Paragraph","id":"282294b3e064_4","name":"fd34","type":"BQ","href":null,"layout":null,"metadata":null,"text":"“If you don’t understand a character’s parents, grandparents, and great grandparents and the way [their] actions help motivate decisions today, then you just won’t connect to them [the same]…” — Matthew Medney, Head of Star Atlas Lore","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":39,"end":46,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":48,"end":60,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":66,"end":84,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":195,"end":234,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_5":{"__typename":"Paragraph","id":"282294b3e064_5","name":"95ac","type":"P","href":null,"layout":null,"metadata":null,"text":"This is something we all can relate to. Family is often the purpose of our being. It’s where we came from, why we’re here, and who we hopefully want to be with in the future. Who we are is at the core of any good story, Star Atlas included.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":220,"end":230,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*mhV69_ITFk_HzV5XIOGozw.png":{"__typename":"ImageMetadata","id":"1*mhV69_ITFk_HzV5XIOGozw.png","originalHeight":926,"originalWidth":1021,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:282294b3e064_6":{"__typename":"Paragraph","id":"282294b3e064_6","name":"18a4","type":"IMG","href":null,"layout":"OUTSET_ROW","metadata":{"__ref":"ImageMetadata:1*mhV69_ITFk_HzV5XIOGozw.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*W-pmKuao84bfT4TQbyMKUw.png":{"__typename":"ImageMetadata","id":"1*W-pmKuao84bfT4TQbyMKUw.png","originalHeight":282,"originalWidth":345,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:282294b3e064_7":{"__typename":"Paragraph","id":"282294b3e064_7","name":"723a","type":"IMG","href":null,"layout":"OUTSET_ROW_CONTINUE","metadata":{"__ref":"ImageMetadata:1*W-pmKuao84bfT4TQbyMKUw.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_8":{"__typename":"Paragraph","id":"282294b3e064_8","name":"dfe3","type":"P","href":null,"layout":null,"metadata":null,"text":"Jose also chimed in throughout the interview. He further explained:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_9":{"__typename":"Paragraph","id":"282294b3e064_9","name":"f38a","type":"BQ","href":null,"layout":null,"metadata":null,"text":"“When I started looking at Star Atlas, my feeling was that it was the shared tale of all different civilizations throughout the stars…We are creating an entire different species, each one of them will have their own background…this background is about building their story. One thing we do, that we like to do as an exercise when building up the lore, is setting the guiding principles of everything that we are doing. And then we can start deducting all the things that will play out in the civilization.”","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":355,"end":385,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_10":{"__typename":"Paragraph","id":"282294b3e064_10","name":"4659","type":"P","href":null,"layout":null,"metadata":null,"text":"In other words, as one begins to delve into the lore, there will be core elements strung together across space, connecting the world with common threads. While the main storyline is still being developed, we can see some of these habitual themes unfolding within the comics. For example, as was implicated in CORE — Episode #1, we discovered that Ustur might do things a little different than the other factions. We might discover that the Oni have particular quirks the other two factions don’t. And the more we learn about these races, the more we might realize that some individuals in the cosmos follow no factional norm at all.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":309,"end":326,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*V_XAQyl2PfQsGZ8R1t9JFQ.png":{"__typename":"ImageMetadata","id":"1*V_XAQyl2PfQsGZ8R1t9JFQ.png","originalHeight":625,"originalWidth":695,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:282294b3e064_11":{"__typename":"Paragraph","id":"282294b3e064_11","name":"efd2","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*V_XAQyl2PfQsGZ8R1t9JFQ.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_12":{"__typename":"Paragraph","id":"282294b3e064_12","name":"39b7","type":"P","href":null,"layout":null,"metadata":null,"text":"Regarding the individuals we will come to know, Matthew also divulged more of his process in compiling data as a story.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_13":{"__typename":"Paragraph","id":"282294b3e064_13","name":"83c6","type":"BQ","href":null,"layout":null,"metadata":null,"text":"“I think storytelling is the oldest profession…Everything that has been brought forth historically is a story being told to help us understand the past. We think of the lore and story at Star Atlas similarly, where we design the history before anything else. We design the past. We understand where characters have come from. We understand why decisions might have to be made based on experiences they’ve had. That’s why one of the first things that Jose and I started architecting was a timeline that goes back 600–700 years… That timeline is still internal because we’re fine tuning it and because it’s something that we’re going to be sharing pretty soon. To me that’s how you can create really compelling stories.”","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":169,"end":173,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":646,"end":658,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_14":{"__typename":"Paragraph","id":"282294b3e064_14","name":"bff2","type":"P","href":null,"layout":null,"metadata":null,"text":"The conversation between the Krigs and the team creating the storyline is quite fascinating. I’d invite you to go watch the full length interview in order to delve fully into the details of how creating the guiding story of Star Atlas will touch all aspects of the game. More than that, it also gives a feeling of the importance of our own ancestry as we seek to understand where we fit into the world around us.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":124,"end":145,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":207,"end":220,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:c7fe8194ee097570125f32429de1cb8c":{"__typename":"MediaResource","id":"c7fe8194ee097570125f32429de1cb8c","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?src=https%3A%2F%2Fwww.youtube.com%2Fembed%2FlGoeiagFFd4%3Ffeature%3Doembed&display_name=YouTube&url=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DlGoeiagFFd4&image=https%3A%2F%2Fi.ytimg.com%2Fvi%2FlGoeiagFFd4%2Fhqdefault.jpg&key=a19fcc184b9711e1b4764040d3dc5c07&type=text%2Fhtml&schema=youtube","iframeHeight":480,"iframeWidth":854,"title":"Star Atlas Lore Explained Part I ft Matt Medney"},"Paragraph:282294b3e064_15":{"__typename":"Paragraph","id":"282294b3e064_15","name":"78e7","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:c7fe8194ee097570125f32429de1cb8c"}},"mixtapeMetadata":null},"Paragraph:282294b3e064_16":{"__typename":"Paragraph","id":"282294b3e064_16","name":"8fc3","type":"P","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_17":{"__typename":"Paragraph","id":"282294b3e064_17","name":"bc25","type":"P","href":null,"layout":null,"metadata":null,"text":"Oni Merchant is a writer on The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of Star Atlas. Follow him on Twitter @OniMerchant.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002F@punaab","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":173,"end":184,"href":"https:\u002F\u002Ftwitter.com\u002FOniMerchant","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":13,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_18":{"__typename":"Paragraph","id":"282294b3e064_18","name":"39d2","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow The Hologram on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_19":{"__typename":"Paragraph","id":"282294b3e064_19","name":"f060","type":"P","href":null,"layout":null,"metadata":null,"text":"Podcast | YouTube | Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Fopen.spotify.com\u002Fshow\u002F2mxndrDW6yPfpS350ijzjt?si=ec7c717f998240d6","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":17,"href":"https:\u002F\u002Fwww.youtube.com\u002Fchannel\u002FUCDa-YxgNG6A9xpH1qyP0OaQ","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":20,"end":27,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":30,"end":39,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":42,"end":45,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_20":{"__typename":"Paragraph","id":"282294b3e064_20","name":"adf6","type":"P","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:282294b3e064_21":{"__typename":"Paragraph","id":"282294b3e064_21","name":"f1f8","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*lOfaQRqywDZ34JSU.png":{"__typename":"ImageMetadata","id":"0*lOfaQRqywDZ34JSU.png","originalHeight":179,"originalWidth":630,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:282294b3e064_22":{"__typename":"Paragraph","id":"282294b3e064_22","name":"378d","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*lOfaQRqywDZ34JSU.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata
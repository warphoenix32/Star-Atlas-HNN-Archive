190"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:ed24b40c4906"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:35ffdccaa5dc"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:ab6dbce60d64"}}],"name":"The Hologram","avatar":{"__ref":"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg"},"domain":null,"slug":"the-hologram","description":"Daily Star Atlas news by The Hologram. Politics, economics and community coverage. Get the trusted information you need to stay one step ahead of your competition.","subscriberCount":152,"viewerEdge":{"__ref":"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_68e90af6673f"},"twitterUsername":"Hologram_News","facebookPageId":null,"logo":{"__ref":"ImageMetadata:"}},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","name":"Krigs","username":"krigsfoniks","newsletterV3":{"__ref":"NewsletterV3:85fc9c436e2e"},"linkedAccounts":{"__ref":"LinkedAccounts:41e0c5b141f1"},"isSuspended":false,"imageId":"1*pVxyLAandIa00EX6ZGRERw.png","mediumMemberAt":1667603125000,"verifications":{"__typename":"VerifiedInfo","isBookAuthor":false},"socialStats":{"__typename":"SocialStats","followerCount":242},"customDomainState":null,"hasSubdomain":false,"bio":"Founder | Crypto | Star Atlas |","isPartnerProgramEnrolled":true,"viewerEdge":{"__ref":"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_68e90af6673f"},"viewerIsUser":false,"postSubscribeMembershipUpsellShownAt":0,"allowNotes":true,"membership":{"__ref":"Membership:4bbb830162b9"},"twitterScreenName":"Hologram_News"},"User:b0bf38de9190":{"__typename":"User","id":"b0bf38de9190"},"User:ed24b40c4906":{"__typename":"User","id":"ed24b40c4906"},"User:35ffdccaa5dc":{"__typename":"User","id":"35ffdccaa5dc"},"User:ab6dbce60d64":{"__typename":"User","id":"ab6dbce60d64"},"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg"},"LinkedAccounts:41e0c5b141f1":{"__typename":"LinkedAccounts","mastodon":null,"id":"41e0c5b141f1"},"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_68e90af6673f":{"__typename":"UserViewerEdge","id":"userId:41e0c5b141f1-viewerId:lo_68e90af6673f","isFollowing":false,"isUser":false},"NewsletterV3:85fc9c436e2e":{"__typename":"NewsletterV3","id":"85fc9c436e2e","type":"NEWSLETTER_TYPE_AUTHOR","slug":"41e0c5b141f1","name":"41e0c5b141f1","collection":null,"user":{"__ref":"User:41e0c5b141f1"}},"Paragraph:c6b4f7d72bd3_0":{"__typename":"Paragraph","id":"c6b4f7d72bd3_0","name":"2b09","type":"H3","href":null,"layout":null,"metadata":null,"text":"Italian Star Atlas Player Wins $30K Starship Prize","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*Q5m86ifQLPmFjIqI9_TH7w.png":{"__typename":"ImageMetadata","id":"1*Q5m86ifQLPmFjIqI9_TH7w.png","originalHeight":942,"originalWidth":1819,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c6b4f7d72bd3_1":{"__typename":"Paragraph","id":"c6b4f7d72bd3_1","name":"04d7","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*Q5m86ifQLPmFjIqI9_TH7w.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_2":{"__typename":"Paragraph","id":"c6b4f7d72bd3_2","name":"6315","type":"P","href":null,"layout":null,"metadata":null,"text":"Italy — A Star Atlas player belonging to the guild Star Atlas Italia is the winner of a $30,000 star ship, the Pearce D9, during the latest series of Star Atlas Surge Events. The Hologram News Network reached out to the winner, Deadshot, to find out how he feels about winning such a coveted prize.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":10,"end":20,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null},{"__typename":"Markup","type":"A","start":51,"end":68,"href":"https:\u002F\u002Fstaratlasitalia.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":228,"end":236,"href":"https:\u002F\u002Ftwitter.com\u002FXx9DeadshoT4xX","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_3":{"__typename":"Paragraph","id":"c6b4f7d72bd3_3","name":"3cac","type":"P","href":null,"layout":null,"metadata":null,"text":"Star Atlas recently hosted a Star Atlas Escape Velocity Surge Event, where the odds of finding a particular tier reward is significantly increased. For this event in particular, the odds of a Platinum reward were increased by 150%. Below is our interview with Deadshot.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*ecEv5EkpXqfMNc8h":{"__typename":"ImageMetadata","id":"0*ecEv5EkpXqfMNc8h","originalHeight":1114,"originalWidth":1980,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c6b4f7d72bd3_4":{"__typename":"Paragraph","id":"c6b4f7d72bd3_4","name":"ffb0","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*ecEv5EkpXqfMNc8h"},"text":"Star Atlas Escape Velocity Surge Event 150x Platinum Tier","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_5":{"__typename":"Paragraph","id":"c6b4f7d72bd3_5","name":"a539","type":"P","href":null,"layout":null,"metadata":null,"text":"Note: Due to language barriers, this interview was conducted over text with the assistance of Google Translate.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":111,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_6":{"__typename":"Paragraph","id":"c6b4f7d72bd3_6","name":"23c6","type":"H3","href":null,"layout":null,"metadata":null,"text":"Deadshot (Star Atlas Italia) — Winner of the Perace D9 in Star Atlas Escape Velocity Surge","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_7":{"__typename":"Paragraph","id":"c6b4f7d72bd3_7","name":"1067","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs: Congratulations on winning such a marvelous prize! How did you feel in the moment when you realized you won a capital ship?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":7,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_8":{"__typename":"Paragraph","id":"c6b4f7d72bd3_8","name":"4c73","type":"P","href":null,"layout":null,"metadata":null,"text":"Deadshot: The moment I found the capital ship, I was filled with joy and amazement. It was a crucial moment and I could not believe my eyes. Knowing that I was live streaming with the rest of my guild mates made it all the more special.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":10,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_9":{"__typename":"Paragraph","id":"c6b4f7d72bd3_9","name":"ffde","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs: How long have you been playing Escape Velocity and do you play everyday. How long do you play each time?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":7,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_10":{"__typename":"Paragraph","id":"c6b4f7d72bd3_10","name":"f07d","type":"P","href":null,"layout":null,"metadata":null,"text":"Deadshot: I’ve been playing Escape Velocity since day one with my guild friends. I play almost every day, dedicating an average of at least 1 hour maybe even more to each game session.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":10,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_11":{"__typename":"Paragraph","id":"c6b4f7d72bd3_11","name":"2b77","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs: During the Surge event, were you trying any particular strategy?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":7,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_12":{"__typename":"Paragraph","id":"c6b4f7d72bd3_12","name":"44ad","type":"P","href":null,"layout":null,"metadata":null,"text":"Deadshot: There is no precise strategy, I have 16 ships lined up and I move them up and down, but during the event a particular thing happened while joking with a friend of mine, who was on my lines. I told him you can move, then I’ll move, and moved and 10 lines later the D9 came.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":10,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*RStFf_pd8PYA64WmSqpCow.png":{"__typename":"ImageMetadata","id":"1*RStFf_pd8PYA64WmSqpCow.png","originalHeight":679,"originalWidth":1292,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c6b4f7d72bd3_13":{"__typename":"Paragraph","id":"c6b4f7d72bd3_13","name":"f732","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*RStFf_pd8PYA64WmSqpCow.png"},"text":"Pearce D9 Salvage Ship","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_14":{"__typename":"Paragraph","id":"c6b4f7d72bd3_14","name":"f2db","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs: This is quite a prestigious event for the guild. How long have you been apart of Star Atlas Italia?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":6,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_15":{"__typename":"Paragraph","id":"c6b4f7d72bd3_15","name":"8a9f","type":"P","href":null,"layout":null,"metadata":null,"text":"Deadshot: I have been part of Star Atlas Italia (SAI) for over a year and a half. I have found many friends and playmates. Being a player we find ourselves in tournaments with other guilds such as The Club, Bulk, Rome and slowly I have also grown in my guild. Currently I am a squad leader and directed in the last event the organization of 650 ships belonging to guild players. I aspire to become a fleet commander of SAI.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":10,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_16":{"__typename":"Paragraph","id":"c6b4f7d72bd3_16","name":"1072","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs: The D9 is quite a unique ship in that there currently aren’t many available. Do you have any plans for the D9?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":7,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_17":{"__typename":"Paragraph","id":"c6b4f7d72bd3_17","name":"6fb1","type":"P","href":null,"layout":null,"metadata":null,"text":"Deadshot: Currently I do not because it was unexpected, but surely together with my guild and friends we will make the most of it","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":10,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_18":{"__typename":"Paragraph","id":"c6b4f7d72bd3_18","name":"e0c6","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs: Did you share the news with anyone that doesn’t play Star Atlas? Family, relatives, friends? How did they react?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":7,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_19":{"__typename":"Paragraph","id":"c6b4f7d72bd3_19","name":"620a","type":"P","href":null,"layout":null,"metadata":null,"text":"Deadshot: Yes, I shared it with my family and they were amazed and did not believe it. I also showed them the ship which they liked very much. some of my friends convinced them to come and see it as it will be given to me. I will spawn it in the guild server SAI to make the next rally with all ships.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":10,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_20":{"__typename":"Paragraph","id":"c6b4f7d72bd3_20","name":"b507","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs: Is there anything else about yourself you want to tell the community?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":5,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_21":{"__typename":"Paragraph","id":"c6b4f7d72bd3_21","name":"0b0b","type":"P","href":null,"layout":null,"metadata":null,"text":"Deadshot: Yes, the first night I found it I couldn't sleep! The next day I turned on the PC and thought I'm going to check because I still didn't believe it that it was out. I invite the community to never stop trying because yes sometimes something beautiful comes and I hope it's just the beginning for all of us! Viva Star Atlas! You are amazing keep it up and you will always have the support of the community","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":8,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_22":{"__typename":"Paragraph","id":"c6b4f7d72bd3_22","name":"335b","type":"H3","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_23":{"__typename":"Paragraph","id":"c6b4f7d72bd3_23","name":"223e","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs is a pioneer in the world of Star Atlas, having founded The Hologram News Network — an independent meta-news organization that keeps players up to date on all developments regarding Star Atlas. An ardent supporter of emerging technologies, Krigs has been covering this game for over a year and believes passionately in their power to revolutionize our collective gaming experience.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":5,"href":"https:\u002F\u002Fmedium.com\u002Fu\u002F41e0c5b141f1?source=post_page-----4922901fb224--------------------------------","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_24":{"__typename":"Paragraph","id":"c6b4f7d72bd3_24","name":"82bc","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_25":{"__typename":"Paragraph","id":"c6b4f7d72bd3_25","name":"7089","type":"P","href":null,"layout":null,"metadata":null,"text":"Podcast | YouTube | Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Fopen.spotify.com\u002Fshow\u002F2mxndrDW6yPfpS350ijzjt?si=ec7c717f998240d6","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":17,"href":"https:\u002F\u002Fwww.youtube.com\u002Fchannel\u002FUCDa-YxgNG6A9xpH1qyP0OaQ","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":20,"end":27,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":30,"end":39,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":42,"end":45,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_26":{"__typename":"Paragraph","id":"c6b4f7d72bd3_26","name":"57e0","type":"H3","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_27":{"__typename":"Paragraph","id":"c6b4f7d72bd3_27","name":"4cf3","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c6b4f7d72bd3_28":{"__typename":"Paragraph","id":"c6b4f7d72bd3_28","name":"c062","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed by the Star Atlas team. Any information published by The Hologram or its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":36,"end":46,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_68e90af6673f":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_68e90af6673f","isEditor":false},"Membership:4bbb830162b9":{"__typename":"Membership","tier":"MEMBER","id":"4bbb830162b9"},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"Tag:community":{"__typename":"Tag","id":"community","displayTitle":"Community","normalizedTagSlug":"community"},"Post:24f2161bb59a":{"__typename":"Post","id":"24f2161bb59a","collection":{"__ref":"Collection:4d89daa6ae31"},"content({\"postMeteringOptions\":{}})":{"__typename":"PostContent","isLockedPreviewOnly":false,"bodyModel":{"__typename":"RichText","sections":[{"__typename":"Section","name":"75c9","startIndex":0,"textLayout":null,"imageLayout":null,"backgroundImage":null,"videoLayout":null,"backgroundVideo":null},{"__typename":"Section","name":"4881","startIndex":22,"textLayout":null,"imageLayout":null,"backgroundImage":null,"videoLayout":null,"backgroundVideo":null}],"paragraphs":[{"__ref":"Paragraph:c6b4f7d72bd3_0"},{"__ref":"Paragraph:c6b4f7d72bd3_1"},{"__ref":"Paragraph:c6b4f7d72bd3_2"},{"__ref":"Paragraph:c6b4f7d72bd3_3"},{"__ref":"Paragraph:c6b4f7d72bd3_4"},{"__ref":"Paragraph:c6b4f7d72bd3_5"},{"__ref":"Paragraph:c6b4f7d72bd3_6"},{"__ref":"Paragraph:c6b4f7d72bd3_7"},{"__ref":"Paragraph:c6b4f7d72bd3_8"},{"__ref":"Paragraph:c6b4f7d72bd3_9"},{"__ref":"Paragraph:c6b4f7d72bd3_10"},{"__ref":"Paragraph:c6b4f7d72bd3_11"},{"__ref":"Paragraph:c6b4f7d72bd3_12"},{"__ref":"Paragraph:c6b4f7d72bd3_13"},{"__ref":"Paragraph:c6b4f7d72bd3_14"},{"__ref":"Paragraph:c6b4f7d72bd3_15"},{"__ref":"Paragraph:c6b4f7d72bd3_16"},{"__ref":"Paragraph:c6b4f7d72bd3_17"},{"__ref":"Paragraph:c6b4f7d72bd3_18"},{"__ref":"Paragraph:c6b4f7d72bd3_19"},{"__ref":"Paragraph:c6b4f7d72bd3_20"},{"__ref":"Paragraph:c6b4f7d72bd3_21"},{"__ref":"Paragraph:c6b4f7d72bd3_22"},{"__ref":"Paragraph:c6b4f7d72bd3_23"},{"__ref":"Paragraph:c6b4f7d72bd3_24"},{"__ref":"Paragraph:c6b4f7d72bd3_25"},{"__ref":"Paragraph:c6b4f7d72bd3_26"},{"__ref":"Paragraph:c6b4f7d72bd3_27"},{"__ref":"Paragraph:c6b4f7d72bd3_28"}]},"validatedShareKey":"","shareKeyCreator":null},"creator":{"__ref":"User:41e0c5b141f1"},"inResponseToEntityType":null,"isLocked":false,"isMarkedPaywallOnly":false,"lockedSource":"LOCKED_POST_SOURCE_NONE","mediumUrl":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fitalian-star-atlas-player-wins-30k-starship-prize-24f2161bb59a","primaryTopic":null,"topics":[{"__typename":"Topic","slug":"gaming"}],"isPublished":true,"latestPublishedVersion":"c6b4f7d72bd3","visibility":"PUBLIC","postResponses":{"__typename":"PostResponses","count":0},"createdAt":1685811082484,"firstPublishedAt":1685812714958,"latestPublishedAt":1685812929123,"clapCount":15,"allowResponses":true,"isLimitedState":false,"title":"Italian Star Atlas Player Wins $30K Starship Prize","isSeries":false,"sequence":null,"uniqueSlug":"italian-star-atlas-player-wins-30k-starship-prize-24f2161bb59a","socialTitle":"","socialDek":"","noIndex":null,"canonicalUrl":"","metaDescription":"","readingTime":3.6858490566037734,"previewContent":{"__typename":"PreviewContent","subtitle":"Italy — A Star Atlas player belonging to the guild Star Atlas Italia is the winner of a $30,000 star ship, the Pearce D9, during the…"},"previewImage":{"__ref":"ImageMetadata:1*Q5m86ifQLPmFjIqI9_TH7w.png"},"isShortform":false,"seoTitle":"","updatedAt":1685852069245,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isSuspended":false,"license":"ALL_RIGHTS_RESERVED","tags":[{"__ref":"Tag:star-atlas"},{"__ref":"Tag:community"}],"pendingCollection":null,"statusForCollection":"APPROVED","detectedLanguage":"en","wordCount":831,"layerCake":0}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"MISS","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.96674e46.js"></script><script src="https://cdn-client.medium.com/lite/static/js/3057.5e22bbb0.js"></script><script src="https://cdn-client.medium.com/lite/static/js/main.aa1bfdc7.js"></script><script src="https://cdn-client.medium.com/lite/static/js/instrumentation.d6d5fe73.chunk.js"></script>

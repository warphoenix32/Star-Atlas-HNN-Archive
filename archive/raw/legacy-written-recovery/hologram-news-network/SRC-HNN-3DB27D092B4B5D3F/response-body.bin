},"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_ddaa7f6fc028":{"__typename":"UserViewerEdge","id":"userId:41e0c5b141f1-viewerId:lo_ddaa7f6fc028","isFollowing":false,"isUser":false},"NewsletterV3:85fc9c436e2e":{"__typename":"NewsletterV3","id":"85fc9c436e2e","type":"NEWSLETTER_TYPE_AUTHOR","slug":"41e0c5b141f1","name":"41e0c5b141f1","collection":null,"user":{"__ref":"User:41e0c5b141f1"},"description":"","promoHeadline":"","promoBody":"","showPromo":false},"Post:bff20fd1e3c":{"__typename":"Post","id":"bff20fd1e3c"},"PostViewerEdge:postId:e76045f906d8-viewerId:lo_ddaa7f6fc028":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:e76045f906d8-viewerId:lo_ddaa7f6fc028"},"Paragraph:f98afc6f63e6_0":{"__typename":"Paragraph","id":"f98afc6f63e6_0","name":"b4ab","type":"H3","href":null,"layout":null,"metadata":null,"text":"ATMTA Insider Spills on Quiroga Departure","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_1":{"__typename":"Paragraph","id":"f98afc6f63e6_1","name":"a4c6","type":"P","href":null,"layout":null,"metadata":null,"text":"The saga continues after ATMTA CEO Michael Wagner released an official statement on former Chief Revenue Officer Pablo Quiroga’s departure from the company at the end of March.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":50,"end":80,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fatmta-employees-speak-on-quiroga-departure-fd8197c23ca1","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*_L3LgppS_8vJagrF.png":{"__typename":"ImageMetadata","id":"0*_L3LgppS_8vJagrF.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f98afc6f63e6_2":{"__typename":"Paragraph","id":"f98afc6f63e6_2","name":"1e93","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*_L3LgppS_8vJagrF.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_3":{"__typename":"Paragraph","id":"f98afc6f63e6_3","name":"969f","type":"H3","href":null,"layout":null,"metadata":null,"text":"ATMTA Insider Reveals Details on Quiroga’s Management Practices","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":63,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_4":{"__typename":"Paragraph","id":"f98afc6f63e6_4","name":"c2ae","type":"P","href":null,"layout":null,"metadata":null,"text":"An insider at ATMTA, the developer behind upcoming space MMO game Star Atlas, has recently come forward to shed new details surrounding the departure of Star Atlas Co-Founder and Chief Revenue Officer Pablo Quiroga.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_5":{"__typename":"Paragraph","id":"f98afc6f63e6_5","name":"9750","type":"P","href":null,"layout":null,"metadata":null,"text":"The insider, whom we’ll call M&M, alleges that Quiroga’s departure stems from a combination of poor management practices, workplace behavior, and creative differences over the direction of Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_6":{"__typename":"Paragraph","id":"f98afc6f63e6_6","name":"ce2d","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram was able to independently verify M&M’s status as an employee of ATMTA.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":83,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_7":{"__typename":"Paragraph","id":"f98afc6f63e6_7","name":"517f","type":"P","href":null,"layout":null,"metadata":null,"text":"In public, Quiroga presented a calm and poised demeanor, often interacting with the Star Atlas community and willing to take pictures with fans at community events. Quiroga often spoke and presented on behalf of Star Atlas; his presentations well received by the general community.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_8":{"__typename":"Paragraph","id":"f98afc6f63e6_8","name":"d099","type":"P","href":null,"layout":null,"metadata":null,"text":"However, behind closed doors, it would appear that Quiroga adopted a different persona.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_9":{"__typename":"Paragraph","id":"f98afc6f63e6_9","name":"8df2","type":"P","href":null,"layout":null,"metadata":null,"text":"“He was extremely disrespectful to team members, sometimes yelling at employees which caused a lot of division within inter-departmental communication. His management style was aggressive and condescending, not the impression he gave to the community”. — M&M, ATMTA Employee","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":274,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_10":{"__typename":"Paragraph","id":"f98afc6f63e6_10","name":"e998","type":"P","href":null,"layout":null,"metadata":null,"text":"M&M also alleges that Quiroga would often berate the Rev Ops team if things did not go his way and that he would regularly yell and get upset.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_11":{"__typename":"Paragraph","id":"f98afc6f63e6_11","name":"4d2d","type":"P","href":null,"layout":null,"metadata":null,"text":"“That’s why everyone on the team is happy he is gone” (When asked to clarify and quantify these comments, M&M did not elaborate).","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":55,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_12":{"__typename":"Paragraph","id":"f98afc6f63e6_12","name":"e22b","type":"H3","href":null,"layout":null,"metadata":null,"text":"Creative Differences Could Have Led to Split","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_13":{"__typename":"Paragraph","id":"f98afc6f63e6_13","name":"51d3","type":"P","href":null,"layout":null,"metadata":null,"text":"Regarding the direction Star Atlas was heading in 2023, M&M noted that difference in vision began to emerge between Quiroga and the other founders, particularly CEO Michael Wagner.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_14":{"__typename":"Paragraph","id":"f98afc6f63e6_14","name":"e1b3","type":"P","href":null,"layout":null,"metadata":null,"text":"“Pablo wanted to be more strict on release dates and put a lot of pressure on the team to stick to those dates”.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":1,"end":112,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_15":{"__typename":"Paragraph","id":"f98afc6f63e6_15","name":"2460","type":"P","href":null,"layout":null,"metadata":null,"text":"While it’s unknown to what degree product delivery timeline’s were planned, Star Atlas has clearly taken a new direction regarding product deliveries in 2023. In multiple public forums, Wagner has stated that while the team has target dates in mind for product releases, the team would not provide firm dates actual deadlines or delivery dates. Presumably, this is to give the team more development flexibility while avoiding overt negative backlash should a deadline be passed. According to M&M, this is not the direction Quiroga wanted.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_16":{"__typename":"Paragraph","id":"f98afc6f63e6_16","name":"08f0","type":"H3","href":null,"layout":null,"metadata":null,"text":"Quiroga A Possible Barrier to Star Atlas Funding Deal","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":53,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_17":{"__typename":"Paragraph","id":"f98afc6f63e6_17","name":"923a","type":"P","href":null,"layout":null,"metadata":null,"text":"M&M additionally alleges that Quiroga was a potential barrier towards any funding deal. Since last November, Star Atlas has needed additional funding to continue development past this year.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_18":{"__typename":"Paragraph","id":"f98afc6f63e6_18","name":"c41e","type":"P","href":null,"layout":null,"metadata":null,"text":"“The lack of transparency regarding Pablo and the capital raise has been causing major concern from the Star Atlas team including top executives responsible for major gameplay and technological developments” M&M continues. “Some of the team member in Rev Ops were ready to quit if Quiroga was not out, Pablo’s salary was dead weight”.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":1,"end":208,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":223,"end":334,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_19":{"__typename":"Paragraph","id":"f98afc6f63e6_19","name":"9200","type":"P","href":null,"layout":null,"metadata":null,"text":"M&M states that there was unacknowledged [negative] sentiment from the general Star Atlas team following the FTX dilemma, and specifically, that Quiroga continued to receive a full salary despite lay offs and pay cuts being taken against team members.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_20":{"__typename":"Paragraph","id":"f98afc6f63e6_20","name":"dcb2","type":"H3","href":null,"layout":null,"metadata":null,"text":"Quiroga Absent From Public Eye","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":30,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_21":{"__typename":"Paragraph","id":"f98afc6f63e6_21","name":"5e9c","type":"P","href":null,"layout":null,"metadata":null,"text":"Since the official announcement of his departure, Quiroga has been absent from the public Star Atlas community eye. His Twitter and LinkedIn, despite having not posted recently, still list him as the current CRO of ATMTA. Quiroga’s main account name, StarSapa, is no longer apart of the Star Atlas Discord.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":251,"end":259,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_22":{"__typename":"Paragraph","id":"f98afc6f63e6_22","name":"67fa","type":"H3","href":null,"layout":null,"metadata":null,"text":"ATMTA’s Response","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_23":{"__typename":"Paragraph","id":"f98afc6f63e6_23","name":"d7e4","type":"P","href":null,"layout":null,"metadata":null,"text":"ATMTA had this to say regarding the insider’s leaks","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_24":{"__typename":"Paragraph","id":"f98afc6f63e6_24","name":"a784","type":"BQ","href":null,"layout":null,"metadata":null,"text":"ATMTA does not comment on the circumstances of an individual team member’s departure out of respect for their privacy. ATMTA cannot verify and does not condone the comments made by the alleged source for the article. The source does not speak for ATMTA.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_25":{"__typename":"Paragraph","id":"f98afc6f63e6_25","name":"c0ea","type":"H3","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_26":{"__typename":"Paragraph","id":"f98afc6f63e6_26","name":"ba4c","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs is a pioneer in the world of Star Atlas, having founded The Hologram News Network — an independent meta-news organization that keeps players up to date on all developments regarding Star Atlas. An ardent supporter of emerging technologies, Krigs has been covering this game for over a year and believes passionately in their power to revolutionize our collective gaming experience.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":5,"href":"https:\u002F\u002Fmedium.com\u002Fu\u002F41e0c5b141f1?source=post_page-----4922901fb224--------------------------------","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_27":{"__typename":"Paragraph","id":"f98afc6f63e6_27","name":"48ce","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_28":{"__typename":"Paragraph","id":"f98afc6f63e6_28","name":"9233","type":"P","href":null,"layout":null,"metadata":null,"text":"Podcast | YouTube | Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Fopen.spotify.com\u002Fshow\u002F2mxndrDW6yPfpS350ijzjt?si=ec7c717f998240d6","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":17,"href":"https:\u002F\u002Fwww.youtube.com\u002Fchannel\u002FUCDa-YxgNG6A9xpH1qyP0OaQ","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":20,"end":27,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":30,"end":39,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":42,"end":45,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_29":{"__typename":"Paragraph","id":"f98afc6f63e6_29","name":"3ae2","type":"H3","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f98afc6f63e6_30":{"__typename":"Paragraph","id":"f98afc6f63e6_30","name":"16b6","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t bee
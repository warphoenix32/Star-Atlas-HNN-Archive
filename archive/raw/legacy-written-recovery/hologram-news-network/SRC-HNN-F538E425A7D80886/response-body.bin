3-.13L12.5 3v7.07a.5.5 0 0 1-.5.5.5.5 0 0 1-.5-.5V3.02l-2 2a.45.45 0 0 1-.57.04h-.02a.4.4 0 0 1-.16-.3.4.4 0 0 1 .1-.32l2.8-2.8a.5.5 0 0 1 .7 0l2.8 2.8a.42.42 0 0 1 .07.5zm-.1.14zm.88 2h1.5a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-11a2 2 0 0 1-2-2v-10a2 2 0 0 1 2-2H8a.5.5 0 0 1 .35.14c.1.1.15.22.15.35a.5.5 0 0 1-.15.35.5.5 0 0 1-.35.15H6.4c-.5 0-.9.4-.9.9v10.2a.9.9 0 0 0 .9.9h11.2c.5 0 .9-.4.9-.9V8.96c0-.5-.4-.9-.9-.9H16a.5.5 0 0 1 0-1z" fill="currentColor"></path></svg><div class="j i d"><p class="be b bf z hb">Share</p></div></button></div></div></div></div></div></div></div></div></div><figure class="le lf lg lh li lj lb lc paragraph-image"><div role="button" tabindex="0" class="lk ll go lm bg ln"><div class="lb lc ld"><picture><source srcSet="https://miro.medium.com/v2/resize:fit:640/format:webp/1*4dBDR2fV81G6V3bIrdos4A.png 640w, https://miro.medium.com/v2/resize:fit:720/format:webp/1*4dBDR2fV81G6V3bIrdos4A.png 720w, https://miro.medium.com/v2/resize:fit:750/format:webp/1*4dBDR2fV81G6V3bIrdos4A.png 750w, https://miro.medium.com/v2/resize:fit:786/format:webp/1*4dBDR2fV81G6V3bIrdos4A.png 786w, https://miro.medium.com/v2/resize:fit:828/format:webp/1*4dBDR2fV81G6V3bIrdos4A.png 828w, https://miro.medium.com/v2/resize:fit:1100/format:webp/1*4dBDR2fV81G6V3bIrdos4A.png 1100w, https://miro.medium.com/v2/resize:fit:1400/format:webp/1*4dBDR2fV81G6V3bIrdos4A.png 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/v2/resize:fit:640/1*4dBDR2fV81G6V3bIrdos4A.png 640w, https://miro.medium.com/v2/resize:fit:720/1*4dBDR2fV81G6V3bIrdos4A.png 720w, https://miro.medium.com/v2/resize:fit:750/1*4dBDR2fV81G6V3bIrdos4A.png 750w, https://miro.medium.com/v2/resize:fit:786/1*4dBDR2fV81G6V3bIrdos4A.png 786w, https://miro.medium.com/v2/resize:fit:828/1*4dBDR2fV81G6V3bIrdos4A.png 828w, https://miro.medium.com/v2/resize:fit:1100/1*4dBDR2fV81G6V3bIrdos4A.png 1100w, https://miro.medium.com/v2/resize:fit:1400/1*4dBDR2fV81G6V3bIrdos4A.png 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px"/><img alt="" class="bg lo lp c" width="700" height="252" loading="eager" role="presentation"/></picture></div></div></figure><p id="c36d" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj"><a class="af mo" href="https://solaris-qtt.com" rel="noopener ugc nofollow" target="_blank"><strong class="ls ew">Website</strong></a><strong class="ls ew"> | </strong><a class="af mo" href="https://twitter.com/SOLARIS_byQtt" rel="noopener ugc nofollow" target="_blank"><strong class="ls ew">Twitter</strong></a><strong class="ls ew"> | </strong><a class="af mo" href="https://discord.gg/XapPCYWYXs" rel="noopener ugc nofollow" target="_blank"><strong class="ls ew">Discord</strong></a><strong class="ls ew"> </strong>| <a class="af mo" href="https://www.youtube.com/@solarisqtt" rel="noopener ugc nofollow" target="_blank"><strong class="ls ew">YouTube</strong></a></p><h1 id="d94f" class="mp mq ev be mr ms mt mu mv mw mx my mz na nb nc nd ne nf ng nh ni nj nk nl nm bj"><strong class="al">Guild Overview</strong></h1><p id="20f2" class="pw-post-body-paragraph lq lr ev ls b lt nn lv lw lx no lz ma mb np md me mf nq mh mi mj nr ml mm mn eo bj">Solaris is an adventure - combining fun and performance.<br/>Its will is to shine through the Star Atlas universe and beyond!</p><h2 id="be6c" class="ns mq ev be mr nt nu nv mv nw nx ny mz mb nz oa ob mf oc od oe mj of og oh oi bj"><strong class="al">Faction</strong></h2><p id="805f" class="pw-post-body-paragraph lq lr ev ls b lt nn lv lw lx no lz ma mb np md me mf nq mh mi mj nr ml mm mn eo bj"><strong class="ls ew">MUD / ONI / USTUR</strong></p><h2 id="802f" class="ns mq ev be mr nt nu nv mv nw nx ny mz mb nz oa ob mf oc od oe mj of og oh oi bj"><strong class="al">Recruiting</strong></h2><p id="27ff" class="pw-post-body-paragraph lq lr ev ls b lt nn lv lw lx no lz ma mb np md me mf nq mh mi mj nr ml mm mn eo bj"><strong class="ls ew">Yes</strong></p><h2 id="76a7" class="ns mq ev be mr nt nu nv mv nw nx ny mz mb nz oa ob mf oc od oe mj of og oh oi bj"><strong class="al">Objectives</strong></h2><p id="34a5" class="pw-post-body-paragraph lq lr ev ls b lt nn lv lw lx no lz ma mb np md me mf nq mh mi mj nr ml mm mn eo bj">We want to create a safe and friendly space to gather the largest French-speaking community, active (24/7) and present on all continents.</p><p id="399e" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">We will continue to organize meetings and participate in real events (IRL), while maintaining a lively, creative and dynamic space on the networks.</p><p id="d60f" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">We offer an adapted and flexible framework to the different profiles of players and investors with the opportunity to integrate an official structure.</p><p id="9d34" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">We want to build a network of partners in Star Atlas and outside.</p><p id="1649" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">We are setting up a research and development department in Web3 as well as a communication pole allowing us to become an essential actor of the French-speaking information.</p><p id="f8d1" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">We are building a Decentralized Autonomous Organization (DAO) based on merit.</p><h2 id="cba3" class="ns mq ev be mr nt nu nv mv nw nx ny mz mb nz oa ob mf oc od oe mj of og oh oi bj"><strong class="al">Security zone</strong></h2><p id="1b17" class="pw-post-body-paragraph lq lr ev ls b lt nn lv lw lx no lz ma mb np md me mf nq mh mi mj nr ml mm mn eo bj">Safe Zone, Medium Risk Zone, High Risk Zone</p><h2 id="369c" class="ns mq ev be mr nt nu nv mv nw nx ny mz mb nz oa ob mf oc od oe mj of og oh oi bj"><strong class="al">Members</strong></h2><p id="27b7" class="pw-post-body-paragraph lq lr ev ls b lt nn lv lw lx no lz ma mb np md me mf nq mh mi mj nr ml mm mn eo bj">50–100</p><h2 id="6e6a" class="ns mq ev be mr nt nu nv mv nw nx ny mz mb nz oa ob mf oc od oe mj of og oh oi bj">Specifications</h2><ul class=""><li id="289e" class="lq lr ev ls b lt nn lv lw lx no lz ma oj np md me ok nq mh mi ol nr ml mm mn om on oo bj">Overcome challenges, staying strong and looking forward.</li><li id="c81f" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Respect our rules, our community and our partners.</li><li id="778b" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Communicate sincerely with the members and act in accordance with the decisions taken.</li><li id="dc5e" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Our team wants to build an ambitious project and wishes to live collectively in this extraordinary human adventure.</li><li id="ea1e" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">We are working to build a serious and sustainable structure where everyone can commit to their ambitions.</li><li id="61c1" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">With us, as everyone knows, great power implies great responsibilities.</li><li id="0965" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Everyone can be a force of proposal, participate in the votes and evolve in the organization.</li><li id="8cc7" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Every decision is made in the interest of the community.</li></ul><h2 id="691c" class="ns mq ev be mr nt nu nv mv nw nx ny mz mb nz oa ob mf oc od oe mj of og oh oi bj"><strong class="al">Founders</strong></h2><p id="3680" class="pw-post-body-paragraph lq lr ev ls b lt nn lv lw lx no lz ma mb np md me mf nq mh mi mj nr ml mm mn eo bj">A united team of 12 people with a first collective experience of one year with a new project.</p><p id="f902" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">Llorca, Intocc, Tortue, Osiris, Amiral Albator, Yebruba, MikelMarcus, Majorbaguette, Asthom, VonCJ, Zombilian and Paytience</p><h2 id="9e59" class="ns mq ev be mr nt nu nv mv nw nx ny mz mb nz oa ob mf oc od oe mj of og oh oi bj"><strong class="al">Established</strong></h2><p id="324e" class="pw-post-body-paragraph lq lr ev ls b lt nn lv lw lx no lz ma mb np md me mf nq mh mi mj nr ml mm mn eo bj">August 1st, 2022</p><h2 id="ce22" class="ns mq ev be mr nt nu nv mv nw nx ny mz mb nz oa ob mf oc od oe mj of og oh oi bj"><strong class="al">Spoken languages</strong></h2><p id="3f29" class="pw-post-body-paragraph lq lr ev ls b lt nn lv lw lx no lz ma mb np md me mf nq mh mi mj nr ml mm mn eo bj">French</p><h2 id="e8e4" class="ns mq ev be mr nt nu nv mv nw nx ny mz mb nz oa ob mf oc od oe mj of og oh oi bj"><strong class="al">Alliances &amp; Partners</strong></h2><p id="f865" class="pw-post-body-paragraph lq lr ev ls b lt nn lv lw lx no lz ma mb np md me mf nq mh mi mj nr ml mm mn eo bj">GGA : Gargantua Industries</p><p id="ffe9" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">Spaces Froggies</p><p id="1f1b" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">French-speaking guilds</p><p id="3559" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">We are open to any request for alliance or cooperation whether it is French or international. The main thing is to prosper and to obtain a mutual benefit from our collaboration.</p><p id="272d" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">All aspects of the economy being considered and anticipated by the Solaris in different time frames.</p><p id="bad2" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj"><strong class="ls ew">Member Benefits</strong></p><p id="bb85" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">· Technology development</p><p id="0d17" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">· Human resources</p><p id="1ec4" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">· Project management</p><p id="8236" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">· Web journalism</p><p id="76be" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">· Investment</p><p id="56ae" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">· Video editing</p><ul class=""><li id="bc0f" class="lq lr ev ls b lt lu lv lw lx ly lz ma oj mc md me ok mg mh mi ol mk ml mm mn om on oo bj">Entrepreneurship</li><li id="e6ad" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Legal</li><li id="9ca9" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Trading</li></ul><p id="e9d9" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj"><strong class="ls ew">A close-knit team of 12 people with a first collective experience of one year with a new project.</strong></p><ul class=""><li id="dd26" class="lq lr ev ls b lt lu lv lw lx ly lz ma oj mc md me ok mg mh mi ol mk ml mm mn om on oo bj">Elaboration of the guild structure</li><li id="0894" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Realization of animations and Lives</li><li id="5690" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Recruiting 500+ members</li><li id="7439" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">UE5 Project development</li><li id="1034" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Development of Web3 tools</li><li id="8656" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Content generation by AI</li><li id="1453" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Creation of websites</li><li id="0df4" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Editor of Lite Paper</li><li id="a89e" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Production of trailers</li></ul><h2 id="4028" class="ns mq ev be mr nt nu nv mv nw nx ny mz mb nz oa ob mf oc od oe mj of og oh oi bj"><strong class="al">Community</strong></h2><ul class=""><li id="43c3" class="lq lr ev ls b lt nn lv lw lx no lz ma oj np md me ok nq mh mi ol nr ml mm mn om on oo bj">Access to the game information in French</li><li id="8798" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">A multi-faction guild strategy with various gameplay</li><li id="4645" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Players of all ages/levels led by experienced leaders</li><li id="8d68" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Pioneers of Star Atlas in France and founders of communities (600 to 5000 members)</li><li id="1567" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Development of optimized and efficient tools</li></ul><h2 id="cbe2" class="ns mq ev be mr nt nu nv mv nw nx ny mz mb nz oa ob mf oc od oe mj of og oh oi bj"><strong class="al">Investors</strong></h2><ul class=""><li id="d04a" class="lq lr ev ls b lt nn lv lw lx no lz ma oj np md me ok nq mh mi ol nr ml mm mn om on oo bj">An organization exclusively dedicated to Star Atlas</li><li id="0d6e" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">An official association securing the management of the assets</li><li id="4221" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">A team gathering many professional skills (finance, programming, networking…)</li><li id="97dc" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Crypto, NFT and metaverse specialists</li><li id="863d" class="lq lr ev ls b lt op lv lw lx oq lz ma oj or md me ok os mh mi ol ot ml mm mn om on oo bj">Optimized profits thanks to the development of industry, trade and various services</li></ul></div></div></div><div class="ab ca ou ov ow ox" role="separator"><span class="oy bx bl oz pa pb"></span><span class="oy bx bl oz pa pb"></span><span class="oy bx bl oz pa"></span></div><div class="eo ep eq er es"><div class="ab ca"><div class="ch bg dx dy dz ea"><h1 id="cf14" class="mp mq ev be mr ms pc mu mv mw pd my mz na pe nc nd ne pf ng nh ni pg nk nl nm bj">About The Hologram</h1><p id="9856" class="pw-post-body-paragraph lq lr ev ls b lt nn lv lw lx no lz ma mb np md me mf nq mh mi mj nr ml mm mn eo bj"><a class="af mo" href="https://medium.com/the-hologram" rel="noopener">The Hologram</a> is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.</p><p id="271d" class="pw-post-body-paragraph lq lr ev ls b lt lu lv lw lx ly lz ma mb mc md me mf mg mh mi mj mk ml mm mn eo bj">The Hologram is not endorsed or paid by the <a class="af mo" href="https://staratlas.com/" rel="noopener ugc nofollow" target="_blank">Star Atlas</a> team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.</p></div></div></div></div></section></div></div></article><div class="ab ca"><div class="ch bg dx dy dz ea"></div></div></div><div class="ab ca"><div class="ch bg dx dy dz ea"><div class="ph pi ab hk"><div class="pj ab"><a class="pk ax am ao" rel="noopener follow" href="/tag/star-atlas?source=post_page-----893f6283a9cd---------------star_atlas-----------------"><div class="pl go cw pm ax pn po be b bf z bj pp">Star Atlas</div></a></div><div class="pj ab"><a class="pk ax am ao" rel="noopener follow" href="/tag/community?source=post_page-----893f6283a9cd---------------community-----------------"><div class="pl go cw pm ax pn po be b bf z bj pp">Community</div></a></div></div></div></div><div class="l"></div><footer class="pq pr ps pt pu pv pw px py ab q pz gs c"><div class="l ae"><div class="ab ca"><div class="ch bg dx dy dz ea"><div class="ab co qa"><div class="ab q jh"><div class="qb l"><span class="l qc qd qe e d"><div class="ab q jh"><div class="pw-multi-vote-icon go ho ji jj jk"><div class=""><div class="jl jm jn jo jp jq jr am js jt ju jk"><svg width="24" height="24" viewBox="0 0 24 24" aria-label="clap"><path fill-rule="evenodd" clip-rule="evenodd" d="M11.37.83L12 3.28l.63-2.45h-1.26zM15.42 1.84l-1.18-.39-.34 2.5 1.52-2.1zM9.76 1.45l-1.19.4 1.53 2.1-.34-2.5zM20.25 11.84l-2.5-4.4a1.42 1.42 0 0 0-.93-.64.96.96 0 0 0-.75.18c-.25.19-.4.42-.45.7l.05.05 2.35 4.13c1.62 2.95 1.1 5.78-1.52 8.4l-.46.41c1-.13 1.93-.6 2.78-1.45 2.7-2.7 2.51-5.59 1.43-7.38zM12.07 9.01c-.13-.69.08-1.3.57-1.77l-2.06-2.07a1.12 1.12 0 0 0-1.56 0c-.15.15-.22.34-.27.53L12.07 9z"></path><path fill-rule="evenodd" clip-rule="evenodd" d="M14.74 8.3a1.13 1.13 0 0 0-.73-.5.67.67 0 0 0-.53.13c-.15.12-.59.46-.2 1.3l1.18 2.5a.45.45 0 0 1-.23.76.44.44 0 0 1-.48-.25L7.6 6.11a.82.82 0 1 0-1.15 1.15l3.64 3.64a.45.45 0 1 1-.63.63L5.83 7.9 4.8 6.86a.82.82 0 0 0-1.33.9c.04.1.1.18.18.26l1.02 1.03 3.65 3.64a.44.44 0 0 1-.15.73.44.44 0 0 1-.48-.1L4.05 9.68a.82.82 0 0 0-1.4.57.81.81 0 0 0 .24.58l1.53 1.54 2.3 2.28a.45.45 0 0 1-.64.63L3.8 13a.81.81 0 0 0-1.39.57c0 .22.09.43.24.58l4.4 4.4c2.8 2.8 5.5 4.12 8.68.94 2.27-2.28 2.71-4.6 1.34-7.1l-2.32-4.08z"></path></svg></div></div></div><div class="pw-multi-vote-count l jv jw jx jy jz ka kb"><p class="be b kc z hb"><span cla
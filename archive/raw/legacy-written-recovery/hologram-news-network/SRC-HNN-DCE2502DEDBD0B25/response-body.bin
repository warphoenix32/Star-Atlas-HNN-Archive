6987e0","name":"HoloReport","description":"Catch up on the latest Star Atlas news that you've missed. ","promoHeadline":"","promoBody":"","type":"NEWSLETTER_TYPE_COLLECTION","user":{"__ref":"User:41e0c5b141f1"},"collection":{"__ref":"Collection:4d89daa6ae31"},"showPromo":true},"ImageMetadata:1*EWK2g3sZ2CUq9HSp-mKvEA.png":{"__typename":"ImageMetadata","id":"1*EWK2g3sZ2CUq9HSp-mKvEA.png","originalWidth":1024},"Post:655f8b7fe5c1":{"__typename":"Post","id":"655f8b7fe5c1"},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","name":"Krigs","username":"krigsfoniks","newsletterV3":{"__ref":"NewsletterV3:85fc9c436e2e"},"atsQualifiedAt":1650725917596},"NewsletterV3:85fc9c436e2e":{"__typename":"NewsletterV3","id":"85fc9c436e2e"},"PostViewerEdge:postId:7b4b191b67b2-viewerId:lo_4a3ed774ada8":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:7b4b191b67b2-viewerId:lo_4a3ed774ada8"},"Paragraph:d1acf2696013_0":{"__typename":"Paragraph","id":"d1acf2696013_0","name":"030b","type":"H3","href":null,"layout":null,"metadata":null,"text":"The Solana FUD: Is There Hope?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_1":{"__typename":"Paragraph","id":"d1acf2696013_1","name":"6e81","type":"P","href":null,"layout":null,"metadata":null,"text":"A rebuttal to those engaged in steering people away from Solana.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":64,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_2":{"__typename":"Paragraph","id":"d1acf2696013_2","name":"0a30","type":"P","href":null,"layout":null,"metadata":null,"text":"A couple days ago Solana had another outage lasting almost an entire day. Many unnamed actors in the space were outraged of course, pointing fingers at the Solana team, the technology, and the community. The truth is, Solana is still considered to be among the most promising modern blockchains of its time, built upon state-of-the-art tech, overcoming the FTX fallout, and having more development happening than any other web3 project. But more importantly, Solana is the blockchain of choice for the project known as Star Atlas — a massive multiplayer space-exploration metaverse — a project that’s revolutionizing the gaming industry as we know it.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":18,"end":24,"href":null,"anchorType":"USER","userId":"af6a22150fa9","linkMetadata":null},{"__typename":"Markup","type":"A","start":519,"end":529,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*UU0JnuoKPjVPA8GwVJ6VBA.png":{"__typename":"ImageMetadata","id":"1*UU0JnuoKPjVPA8GwVJ6VBA.png","originalHeight":1314,"originalWidth":1314,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d1acf2696013_3":{"__typename":"Paragraph","id":"d1acf2696013_3","name":"07fd","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*UU0JnuoKPjVPA8GwVJ6VBA.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_4":{"__typename":"Paragraph","id":"d1acf2696013_4","name":"dac0","type":"P","href":null,"layout":null,"metadata":null,"text":"Designed from the ground up, Solana is able to process transactions faster than any mainstream blockchain with fees only a fraction of a penny. The creator, Anatoly Yakavenko, saw it in the beginning as the NASDAQ for blockchain, but as it began to be developed, it was clear that Solana might become something different altogether. Unlike Ethereum, which was basically like Bitcoin 2.0, Solana uses cutting-edge technology to do what other projects haven’t been able to implement thus far.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_5":{"__typename":"Paragraph","id":"d1acf2696013_5","name":"0f64","type":"H4","href":null,"layout":null,"metadata":null,"text":"Pillars of the Solana Blockchain","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_6":{"__typename":"Paragraph","id":"d1acf2696013_6","name":"8c15","type":"P","href":null,"layout":null,"metadata":null,"text":"Solana uses key innovations, which combine Proof-of-Stake and Proof-of-History to achieve these faster speeds, lower fees, and reduced energy consumption rates. Let’s take a look:","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":12,"end":27,"href":"https:\u002F\u002Fmedium.com\u002Fsolana-labs\u002F7-innovations-that-make-solana-the-first-web-scale-blockchain-ddc50b1defda","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":43,"end":57,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":62,"end":78,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_7":{"__typename":"Paragraph","id":"d1acf2696013_7","name":"fa66","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Proof-of-History — Clock reference to create a common schedule across all participants.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_8":{"__typename":"Paragraph","id":"d1acf2696013_8","name":"877b","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Tower BFT — a PoH-optimized version of PBFT;","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":10,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_9":{"__typename":"Paragraph","id":"d1acf2696013_9","name":"7c73","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Gulf Stream — Defines when and how transactions are exchanged.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":11,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_10":{"__typename":"Paragraph","id":"d1acf2696013_10","name":"3038","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Sealevel — Processing engine to assign execution of transactions.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":9,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_11":{"__typename":"Paragraph","id":"d1acf2696013_11","name":"7cfc","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Turbine — Defines how transactions are verified, sent, and received.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":8,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_12":{"__typename":"Paragraph","id":"d1acf2696013_12","name":"d991","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Cloudbreak — Memory mechanic that follows participant balances.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":10,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_13":{"__typename":"Paragraph","id":"d1acf2696013_13","name":"4d71","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Pipeline — Verify all components of transactions.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":8,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_14":{"__typename":"Paragraph","id":"d1acf2696013_14","name":"7aed","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Archiver — Nodes where data is taken from validators and transferred into storage.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":9,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_15":{"__typename":"Paragraph","id":"d1acf2696013_15","name":"ceb8","type":"P","href":null,"layout":null,"metadata":null,"text":"Let’s focus in on one of these for a moment: Solana’s ability to enable numerous nodes to participate in consensus while maintaining high speeds is primarily achieved through one of its innovations known as Turbine. Any programming student has likely heard of Big O notation, which is often used to determine how fast a program is able to perform. Turbine scales with O(log(n)), which is superior to O(n) or O(n²). In other words, this accelerates the speed of each type of process. When someone complains about Solana being down, it’s important to remember that it’s still significantly faster than other mainstream blockchains.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":207,"end":214,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":259,"end":274,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_16":{"__typename":"Paragraph","id":"d1acf2696013_16","name":"788f","type":"H4","href":null,"layout":null,"metadata":null,"text":"Finding Strength in Reality","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_17":{"__typename":"Paragraph","id":"d1acf2696013_17","name":"e3ea","type":"P","href":null,"layout":null,"metadata":null,"text":"Just like roads need repairs, computer parts need replaced, and Star Atlas spaceships need resupplied, some blockchains will have occasional problems, especially this early on. Every man-made architecture has gone through this process. It’s why renovations need to be made to older homes. It’s why the best multiplayer gaming companies go down for maintenance early Tuesday mornings. To focus on occasional downtime is to fail to understand the benefits Solana offers to Web3.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":64,"end":85,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*Mo6Ans55hJajeaHR.png":{"__typename":"ImageMetadata","id":"0*Mo6Ans55hJajeaHR.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d1acf2696013_18":{"__typename":"Paragraph","id":"d1acf2696013_18","name":"f439","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*Mo6Ans55hJajeaHR.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_19":{"__typename":"Paragraph","id":"d1acf2696013_19","name":"8333","type":"H4","href":null,"layout":null,"metadata":null,"text":"After all, Google invested in it…","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_20":{"__typename":"Paragraph","id":"d1acf2696013_20","name":"86ea","type":"P","href":null,"layout":null,"metadata":null,"text":"Even after Solana’s close relationship with FTX, the platform seems to be doing better than ever after the fallout. When Austin Federa, Head of Strategy at Solana, was asked about the doom and gloom earlier this year regarding FTX, he responded:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_21":{"__typename":"Paragraph","id":"d1acf2696013_21","name":"488c","type":"BQ","href":null,"layout":null,"metadata":null,"text":"“Months after the [FTX] news, more active network addresses are up, more people are using the network…[and] there’s more validators on the network than before FTX collapsed…if you look at active addresses each day, Solana is higher than all other blockchains at this point.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:c9ab9f01f6f6f97cbb73ae12c5763cb9":{"__typename":"MediaResource","id":"c9ab9f01f6f6f97cbb73ae12c5763cb9","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?type=text%2Fhtml&key=a19fcc184b9711e1b4764040d3dc5c07&schema=twitter&url=https%3A\u002F\u002Ftwitter.com\u002FAustin_Federa\u002Fstatus\u002F1613699456939036673%3Fs%3D20&image=https%3A\u002F\u002Fi.embed.ly\u002F1\u002Fimage%3Furl%3Dhttps%253A%252F%252Fabs.twimg.com%252Ferrors%252Flogo46x38.png%26key%3Da19fcc184b9711e1b4764040d3dc5c07","iframeHeight":281,"iframeWidth":500,"title":"Austin Federa on Twitter: \"Thanks for having me on yesterday to talk about Solana, Bloomberg pic.twitter.com\u002F8Y5pjpJdye \u002F Twitter\""},"Paragraph:d1acf2696013_22":{"__typename":"Paragraph","id":"d1acf2696013_22","name":"0166","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:c9ab9f01f6f6f97cbb73ae12c5763cb9"}},"mixtapeMetadata":null},"Paragraph:d1acf2696013_23":{"__typename":"Paragraph","id":"d1acf2696013_23","name":"b87b","type":"P","href":null,"layout":null,"metadata":null,"text":"Yes, Solana had a historic relationship with FTX but so did many other projects and players. Yes, the network currently has an issue when the blockchain goes down, but some of the greatest achievers in history have faced exceeding moments of opposition and have come out on top, many times much stronger. Financially, some individuals admit that Solana could make 5000% gains if it followed a similar trajectory as Ethereum in the last bull cycle (not financial advice). One of the distinctive features of Solana is that its engineering communications are accessible to the general public, specifically to allow for these discussions among individuals mostly considered as “outsiders”. In other words, the company proves to be honest and open about their endeavors. Rather than complaining about downtime, what might be your solution to the team?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":318,"end":334,"href":"https:\u002F\u002Fyoutu.be\u002F93tTlejQCuI","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":766,"end":846,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*RUtEduBk0_E4w8nq.jpeg":{"__typename":"ImageMetadata","id":"0*RUtEduBk0_E4w8nq.jpeg","originalHeight":600,"originalWidth":1200,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d1acf2696013_24":{"__typename":"Paragraph","id":"d1acf2696013_24","name":"e40c","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*RUtEduBk0_E4w8nq.jpeg"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_25":{"__typename":"Paragraph","id":"d1acf2696013_25","name":"0b20","type":"P","href":null,"layout":null,"metadata":null,"text":"As a merchant in Star Atlas, I must occasionally deal with disgruntled customers across the galaxy. The web3 community is no different. Solana has weaknesses just like any other infrastructure created by people. The problem is that a certain percentage of Solana validators need to agree on a solution when the blockchain goes down. Is the problem a difficult one to solve currently? Of course. Do we believe that this type of issue is impossible to solve? Of course not. But it’s fiction to say that Solana is dying because of it. Empires aren’t built in a year. Have patience.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":212,"end":332,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":436,"end":447,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":457,"end":470,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_26":{"__typename":"Paragraph","id":"d1acf2696013_26","name":"c00f","type":"H4","href":null,"layout":null,"metadata":null,"text":"Is There Hope for Solana?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_27":{"__typename":"Paragraph","id":"d1acf2696013_27","name":"cbf0","type":"P","href":null,"layout":null,"metadata":null,"text":"When somebody writes a massive thread smearing the fastest, most high-tech, and competitive Web3 blockchain for a little downtime in its early years, it only makes us wonder if they’re being paid by a competitor. The pillars it builds upon are highly innovative and solve many current problems in the Web3 space. Just like the most high-end cars need oil changes, some blockchains will need their own oil changes from time-to-time. After all, every man-made structure is flawed to some extent. To attack Solana by focusing on one flaw, while ignoring all of its benefits, fails to offer a real solution. Let’s have more hope in this space, seeking for solutions rather than accusations.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":604,"end":686,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:6397c3ef94c2beb10d3b49d7ec31fa4a":{"__typename":"MediaResource","id":"6397c3ef94c2beb10d3b49d7ec31fa4a","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?src=https%3A%2F%2Fwww.youtube.com%2Fembed%2Fzlx64JjXlgQ%3Ffeature%3Doembed&display_name=YouTube&url=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3Dzlx64JjXlgQ&image=https%3A%2F%2Fi.ytimg.com%2Fvi%2Fzlx64JjXlgQ%2Fhqdefault.jpg&key=a19fcc184b9711e1b4764040d3dc5c07&type=text%2Fhtml&schema=youtube","iframeHeight":480,"iframeWidth":854,"title":"157 - Will Solana Make It with Anatoly Yakovenko"},"Paragraph:d1acf2696013_28":{"__typename":"Paragraph","id":"d1acf2696013_28","name":"df64","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"Will Solana Make It?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:6397c3ef94c2beb10d3b49d7ec31fa4a"}},"mixtapeMetadata":null},"Paragraph:d1acf2696013_29":{"__typename":"Paragraph","id":"d1acf2696013_29","name":"d8b0","type":"P","href":null,"layout":null,"metadata":null,"text":"*Do your own research. This article is not financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":23,"end":59,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":0,"end":60,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_30":{"__typename":"Paragraph","id":"d1acf2696013_30","name":"ac55","type":"H4","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_31":{"__typename":"Paragraph","id":"d1acf2696013_31","name":"bdcb","type":"P","href":null,"layout":null,"metadata":null,"text":"Oni Merchant is a writer on The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of Star Atlas. Follow him on Twitter @OniMerchant.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002F@punaab","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":28,"end":53,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":173,"end":184,"href":"https:\u002F\u002Ftwitter.com\u002FOniMerchant","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":13,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_32":{"__typename":"Paragraph","id":"d1acf2696013_32","name":"833f","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow The Hologram on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_33":{"__typename":"Paragraph","id":"d1acf2696013_33","name":"da2e","type":"P","href":null,"layout":null,"metadata":null,"text":"Podcast | YouTube | Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Fopen.spotify.com\u002Fshow\u002F2mxndrDW6yPfpS350ijzjt?si=ec7c717f998240d6","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":17,"href":"https:\u002F\u002Fwww.youtube.com\u002Fchannel\u002FUCDa-YxgNG6A9xpH1qyP0OaQ","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":20,"end":27,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":30,"end":39,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":42,"end":45,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_34":{"__typename":"Paragraph","id":"d1acf2696013_34","name":"2d49","type":"H4","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_35":{"__typename":"Paragraph","id":"d1acf2696013_35","name":"d2e0","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*xMgx7WArAhOrHsOg.png":{"__typename":"ImageMetadata","id":"0*xMgx7WArAhOrHsOg.png","originalHeight":179,"originalWidth":630,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d1acf2696013_36":{"__typename":"Paragraph","id":"d1acf2696013_36","name":"7b6f","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*xMgx7WArAhOrHsOg.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d1acf2696013_37":{"__typename":"Paragraph","id":"d1acf2696013_37","name":"ea99","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_4a3ed774ada8":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_4a3ed774ada8","isEditor":false},"Tag:solana":{"__typename":"Tag","id":"solana","displayTitle":"Solana","normalizedTagSlug":"solanas"},"Tag:solana-network":{"__typename":"Tag","id":"solana-network","displayTitle":"Solana Network","normalizedTagSlug":"solana-network"},"Tag:web3":{"__typename":"Tag","id":"web3","displayTitle":"Web3","normalizedTagSlug":"web3"},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"MISS","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.67459707.js"></script><script src="https://cdn-client.medium.com/lite/static/js/4826.7fe6f01c.js"
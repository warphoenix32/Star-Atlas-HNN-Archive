_1":{"__typename":"Paragraph","id":"83130daa2061_1","name":"8b8a","type":"P","href":null,"layout":null,"metadata":null,"text":"The Unseen is a Pirates Guild with a focus solely on Star Atlas. No Mercy, No Surrender!","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":65,"end":88,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:83130daa2061_2":{"__typename":"Paragraph","id":"83130daa2061_2","name":"5609","type":"P","href":null,"layout":null,"metadata":null,"text":"So you think you are a Pirate?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":30,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:570d043c433102a82e049d35f704495a":{"__typename":"MediaResource","id":"570d043c433102a82e049d35f704495a","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?src=https%3A%2F%2Fwww.youtube.com%2Fembed%2F-OPLcUy7uKI%3Ffeature%3Doembed&display_name=YouTube&url=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D-OPLcUy7uKI&image=https%3A%2F%2Fi.ytimg.com%2Fvi%2F-OPLcUy7uKI%2Fhqdefault.jpg&key=a19fcc184b9711e1b4764040d3dc5c07&type=text%2Fhtml&schema=youtube","iframeHeight":480,"iframeWidth":854,"title":"So you call yourself a pirate?"},"Paragraph:83130daa2061_3":{"__typename":"Paragraph","id":"83130daa2061_3","name":"5c87","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:570d043c433102a82e049d35f704495a"}},"mixtapeMetadata":null},"Paragraph:83130daa2061_4":{"__typename":"Paragraph","id":"83130daa2061_4","name":"02b6","type":"H4","href":null,"layout":null,"metadata":null,"text":"Why choose The Unseen?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":22,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:83130daa2061_5":{"__typename":"Paragraph","id":"83130daa2061_5","name":"11c0","type":"P","href":null,"layout":null,"metadata":null,"text":"The Unseen is a Pirates Guild with a focus solely on Star Atlas. A number of other guilds tend to dabble in several different metaverses, but with us, you will only be focused on growing and profiting in Star Atlas. Finalist in the 1st Annual Joni Awards for Best Small Guild and Best Guild Website!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:83130daa2061_6":{"__typename":"Paragraph","id":"83130daa2061_6","name":"593e","type":"P","href":null,"layout":null,"metadata":null,"text":"We are also the hosts of the Community Initiative project “The Unseen’s Dog Fighting Championship” more information can be found at https:\u002F\u002Funseenguild.com\u002Fdfc. The Unseen offers an exclusive Ranks and Rewards system that will grant members NFTs for promotions and achievements! All information on this can be found on our website.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":132,"end":159,"href":"https:\u002F\u002Funseenguild.com\u002Fdfc","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":59,"end":97,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:83130daa2061_7":{"__typename":"Paragraph","id":"83130daa2061_7","name":"4ace","type":"H4","href":null,"layout":null,"metadata":null,"text":"What we are looking for","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":23,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:83130daa2061_8":{"__typename":"Paragraph","id":"83130daa2061_8","name":"29d0","type":"P","href":null,"layout":null,"metadata":null,"text":"We are looking for members that want to be aggressive, active, and loyal to the crew. Some others look down upon the aggressive nature of a game of this sort, we thrive on it. We will live on combat, and we are looking for Gamers and Pirates! More information on specifics can be had by reaching out to The Unseen leadership team.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":223,"end":229,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":234,"end":241,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:83130daa2061_9":{"__typename":"Paragraph","id":"83130daa2061_9","name":"80b1","type":"H4","href":null,"layout":null,"metadata":null,"text":"Leadership History","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:83130daa2061_10":{"__typename":"Paragraph","id":"83130daa2061_10","name":"0ab8","type":"P","href":null,"layout":null,"metadata":null,"text":"The Unseen is run by twin brothers that have combined MMO, Shooter, and Action-Adventure leadership experience of over 30 years. We have run guilds, clans, companies, and squads in a multitude of games and have always been on the competitive edge. We also have a large number of leadership positions in all our branches that remain unfilled.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:83130daa2061_11":{"__typen
ame":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:9a7913c194d3-viewerId:lo_4c99e0cd13bb"},"Paragraph:a6048ddccc65_0":{"__typename":"Paragraph","id":"a6048ddccc65_0","name":"060a","type":"H3","href":null,"layout":null,"metadata":null,"text":"EVE Online Enters Web3","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_1":{"__typename":"Paragraph","id":"a6048ddccc65_1","name":"7056","type":"P","href":null,"layout":null,"metadata":null,"text":"CCP Games new venture & what that means for Star Atlas","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":9,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":44,"end":54,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":0,"end":54,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_2":{"__typename":"Paragraph","id":"a6048ddccc65_2","name":"702b","type":"P","href":null,"layout":null,"metadata":null,"text":"CCP Games, creator of the famous massive multiplayer EVE Online, recently announced that it’s secured $40 million in financing from external partners to build a new AAA title utilizing blockchain technology, set within the EVE Universe. This news immediately sent ripples through the blockchain community, especially Star Atlas (currently being built on Solana), as it represents a significant competitor in the development of space-based web3 games.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":9,"href":"https:\u002F\u002Fwww.ccpgames.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":53,"end":63,"href":"https:\u002F\u002Fwww.eveonline.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":317,"end":327,"href":"https:\u002F\u002Fplay.staratlas.com\u002F?oid=3&affid=253","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":9,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":53,"end":63,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":102,"end":126,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":316,"end":327,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_3":{"__typename":"Paragraph","id":"a6048ddccc65_3","name":"6bb3","type":"P","href":null,"layout":null,"metadata":null,"text":"CCP Games is currently at the forefront of developing a fun-to-play space-themed game, prioritizing player-driven social systems, in-game economies, and self-organizing corporations. As such, the announcement of its own AAA title has significant implications. One question many have asked is how this announcement might effect web3 startups such as Star Atlas, which are being built from the ground up. How might Star Atlas look to compete against CCP Games’ $40 million traditional financing?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":403,"end":439,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*vA6RvdtcTBx39i6i1wXDAQ.png":{"__typename":"ImageMetadata","id":"1*vA6RvdtcTBx39i6i1wXDAQ.png","originalHeight":441,"originalWidth":1188,"focusPercentX":null,"focusPercentY":null,"alt":"https:\u002F\u002Fwww.eveonline.com\u002F"},"Paragraph:a6048ddccc65_4":{"__typename":"Paragraph","id":"a6048ddccc65_4","name":"ffe6","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*vA6RvdtcTBx39i6i1wXDAQ.png"},"text":"Eve Online","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":10,"href":"https:\u002F\u002Fwww.eveonline.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_5":{"__typename":"Paragraph","id":"a6048ddccc65_5","name":"e609","type":"H4","href":null,"layout":null,"metadata":null,"text":"EVE Online and Web3 Gaming Principles","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_6":{"__typename":"Paragraph","id":"a6048ddccc65_6","name":"16ae","type":"P","href":null,"layout":null,"metadata":null,"text":"Backing up, EVE Online is a sci-fi MMO which has been in development since 2003. It’s set in a vast, open universe that allows players to create their own stories and shape their own path through trading, mining, fighting, and exploration. The game’s economy is entirely player-driven, and players can form their own corporations to compete with others for resources and territory.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_7":{"__typename":"Paragraph","id":"a6048ddccc65_7","name":"5930","type":"P","href":null,"layout":null,"metadata":null,"text":"These principles align closely with the principles of web3 gaming, which aim to create a fun and open gaming experience that prioritizes player agency and “implied ownership”. In some ways, you might say that traditional gaming companies could have an advantage here. They’ve already given out what players want most: The experience. Enabling true player ownership of in-game assets and the creation of decentralized economies has been something they’ve been unable or unwilling to do until now. One great challenge Web3 has going forward is to create a protective barrier between real economy and pay-to-win. After all, pay-to-win is why traditional gamers look at Web3 in such poor taste.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":598,"end":608,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*uZ42oi5lBKF8dVE6xweqiQ.png":{"__typename":"ImageMetadata","id":"1*uZ42oi5lBKF8dVE6xweqiQ.png","originalHeight":506,"originalWidth":1001,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:a6048ddccc65_8":{"__typename":"Paragraph","id":"a6048ddccc65_8","name":"3063","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*uZ42oi5lBKF8dVE6xweqiQ.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_9":{"__typename":"Paragraph","id":"a6048ddccc65_9","name":"0a17","type":"P","href":null,"layout":null,"metadata":null,"text":"But Web3 startup companies like Star Atlas aim to change all of that. They’ve built their core economic principles from the ground up, without the preconceived, centralized mentality that CCP Games will be coming from. It’s still hard to know for sure, but the likelihood of Star Atlas being much more decentralized and equipped to take on Web3’s new frontier seems incredibly promising. Money doesn’t often change a company’s values and principles overnight.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":32,"end":68,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_10":{"__typename":"Paragraph","id":"a6048ddccc65_10","name":"64cf","type":"H4","href":null,"layout":null,"metadata":null,"text":"Collaboration Between Big Players","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_11":{"__typename":"Paragraph","id":"a6048ddccc65_11","name":"9d25","type":"P","href":null,"layout":null,"metadata":null,"text":"Something that also needs to be said in 2023 is that for those projects that do find success in the Web3 space, there’s much more room for collaboration than there had been previously. Instead of two companies feeling the need to compete exclusively against one another, collaborations are much more likely to explode as developers find common grounds in smart contract ecosystems built from code. Therefore, the release of “Project Awakening” (which is what CCP Games is currently calling the project) should be exciting news to Web3 as well as the Star Atlas community. Open source blockchain tools being developed by “Project Awakening” may have massive benefits for Star Atlas and vice versa.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":425,"end":442,"href":"https:\u002F\u002Fwww.projectawakening.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":355,"end":380,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":425,"end":442,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":571,"end":600,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_12":{"__typename":"Paragraph","id":"a6048ddccc65_12","name":"9387","type":"P","href":null,"layout":null,"metadata":null,"text":"CCP Games’ DAOs could likely become unmatched in Web3 space-faring games. Experience with EVE Online gives it a unique perspective in the development of an immersive game. The company has spent years developing player-driven social systems, open economies, and self-organizing corporations, very similar to what DAOs strive to become. As such, it’s well-positioned to build a project that embodies these principles.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*tSOXDXBYBm2FIBZcjdR8MQ.png":{"__typename":"ImageMetadata","id":"1*tSOXDXBYBm2FIBZcjdR8MQ.png","originalHeight":522,"originalWidth":983,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:a6048ddccc65_13":{"__typename":"Paragraph","id":"a6048ddccc65_13","name":"e359","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*tSOXDXBYBm2FIBZcjdR8MQ.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_14":{"__typename":"Paragraph","id":"a6048ddccc65_14","name":"2162","type":"H4","href":null,"layout":null,"metadata":null,"text":"CCP Games Leadership and Finances","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_15":{"__typename":"Paragraph","id":"a6048ddccc65_15","name":"fdfc","type":"P","href":null,"layout":null,"metadata":null,"text":"CCP Games CEO Hilmar Pétursson has been a vocal proponent of blockchain technology since around 2017. He’s spent these last several years advocating for blockchain’s potential to enable “true player ownership” and “open and secure economies.” Pétursson’s experience with web3 gaming and blockchain technology makes him an ideal partner for a16z, the leading venture capital firm that’s invested heavily into “Project Awakening”.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":340,"end":344,"href":"https:\u002F\u002Fa16z.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":340,"end":344,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_16":{"__typename":"Paragraph","id":"a6048ddccc65_16","name":"7e02","type":"P","href":null,"layout":null,"metadata":null,"text":"The collaboration between CCP Games and a16z will also help to accelerate the development of the infant web3 community. It has the potential to establish new standards for the development of web3 gaming principles and open economies.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_17":{"__typename":"Paragraph","id":"a6048ddccc65_17","name":"22c9","type":"BQ","href":null,"layout":null,"metadata":null,"text":"“Together, we share the belief that player ownership and governance within an open platform can be a key source of fun that serves to amplify great gameplay and captivating game design.” (a16z.com)","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":188,"end":196,"href":"https:\u002F\u002Fa16z.com\u002F2023\u002F03\u002F21\u002Finvesting-in-ccp-games\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*Z05NoUkwQH2tFBmx.jpg":{"__typename":"ImageMetadata","id":"0*Z05NoUkwQH2tFBmx.jpg","originalHeight":238,"originalWidth":857,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:a6048ddccc65_18":{"__typename":"Paragraph","id":"a6048ddccc65_18","name":"bd5c","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*Z05NoUkwQH2tFBmx.jpg"},"text":"Eve Online Quantum Cores","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":24,"href":"https:\u002F\u002Fmmos.com\u002Fwp-content\u002Fuploads\u002F2020\u002F09\u002Feve-online-quantum-cores-update-banner.jpg","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_19":{"__typename":"Paragraph","id":"a6048ddccc65_19","name":"e983","type":"H4","href":null,"layout":null,"metadata":null,"text":"The Impact on Star Atlas","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_20":{"__typename":"Paragraph","id":"a6048ddccc65_20","name":"e5a8","type":"P","href":null,"layout":null,"metadata":null,"text":"While CCP Games’ $40 million is undoubtedly a significant investment in this project, it could also have unintended consequences for ground-up web3 ventures like Star Atlas. It could be a benefit by creating a more supportive ecosystem for its own development, but it could also draw players away. Will Project Awakening players start from scratch or will its userbase be able to transfer their current EVE Online accounts to the new title? That would be quite the onboarding achievement as they’re currently sitting at 9.6 million existing accounts as well as approximately 170,000 active players.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":520,"end":531,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":541,"end":549,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":575,"end":597,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*z2KH8u9EVxJZDA6lDn5sPg.png":{"__typename":"ImageMetadata","id":"1*z2KH8u9EVxJZDA6lDn5sPg.png","originalHeight":356,"originalWidth":782,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:a6048ddccc65_21":{"__typename":"Paragraph","id":"a6048ddccc65_21","name":"04fc","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*z2KH8u9EVxJZDA6lDn5sPg.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_22":{"__typename":"Paragraph","id":"a6048ddccc65_22","name":"e604","type":"P","href":null,"layout":null,"metadata":null,"text":"We want to see Star Atlas succeed and believe that competition is healthy for the growth of any sprouting industry. As CCP develops this new AAA title, we will of course be comparing it closely to the current Web3 giant Star Atlas. While the partnership with a16z gives explosive potential to CCP Games’ efforts to create a groundbreaking title, we hope to see them embrace the freeing principles that Star Atlas currently embraces, rather than grasping onto the constraining technologies and greedy mentalities of the past.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":51,"end":73,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_23":{"__typename":"Paragraph","id":"a6048ddccc65_23","name":"7bc7","type":"P","href":null,"layout":null,"metadata":null,"text":"It will be fascinating to see how this project evolves. As space-exploration lovers ourselves, we at Hologram News Network promise to keep you updated with the most significant Star Atlas News available and will also keep you posted as this new project unfolds. Make sure to follow us on social media for more.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":101,"end":122,"href":null,"anchorType":"USER","userId":"ed24b40c4906","linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":275,"end":300,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_24":{"__typename":"Paragraph","id":"a6048ddccc65_24","name":"41b8","type":"H4","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_25":{"__typename":"Paragraph","id":"a6048ddccc65_25","name":"3c9f","type":"P","href":null,"layout":null,"metadata":null,"text":"Oni Merchant is a writer on The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of Star Atlas. Follow him on Twitter @OniMerchant.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002F@punaab","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":28,"end":53,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":173,"end":184,"href":"https:\u002F\u002Ftwitter.com\u002FOniMerchant","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":13,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a6048ddccc65_26":{"__typename":"Paragraph","id":"a6048ddccc65_26","name":"8fcf
h:81660ce1a916_28"},{"__ref":"Paragraph:81660ce1a916_29"},{"__ref":"Paragraph:81660ce1a916_30"},{"__ref":"Paragraph:81660ce1a916_31"},{"__ref":"Paragraph:81660ce1a916_32"}]}},"customStyleSheet":{"__ref":"CustomStyleSheet:8c8103acb783"},"isPublished":true,"isLocked":false,"license":"ALL_RIGHTS_RESERVED","collaborators":[],"isMarkedPaywallOnly":false,"lockedSource":"LOCKED_POST_SOURCE_NONE","mediumUrl":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fwho-is-iris-a-star-atlas-treasure-hunt-part-i-5e5a6fe74f78","primaryTopic":null,"topics":[],"latestPublishedVersion":"81660ce1a916","postResponses":{"__typename":"PostResponses","count":0},"allowResponses":true,"isLimitedState":false,"voterCount":0,"recommenders":[],"isSeries":false,"sequence":null,"uniqueSlug":"who-is-iris-a-star-atlas-treasure-hunt-part-i-5e5a6fe74f78","title":"Who Is Iris? A Star Atlas Treasure Hunt Part I","clapCount":0,"statusForCollection":"APPROVED","pinnedAt":0,"pinnedByCreatorAt":0,"curationEligibleAt":0,"responseDistribution":"NOT_DISTRIBUTED","inResponseToPostResult":null,"inResponseToCatalogResult":null,"pendingCollection":null,"isNewsletter":false,"isAuthorNewsletter":true,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"}],"readingTime":4.063207547169811,"inResponseToEntityType":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1667872577066,"previewContent":{"__typename":"PreviewContent","subtitle":"Adherents to Star Atlas lore know that the legendary planet Iris is central to its mythos. Iris’ collision with seven other planets created…"},"previewImage":{"__ref":"ImageMetadata:1*udvzd-Toc2II99jlVMfb7Q.png"},"isShortform":false,"seoTitle":"","updatedAt":1667872583021,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"isSuspended":false,"responseRootPost":{"__typename":"ResponseRootPost","post":{"__ref":"Post:5e5a6fe74f78"}},"internalLinks({\"paging\":{\"limit\":8}})":{"__typename":"InternalLinksConnection","items":[]},"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}},"ImageMetadata:1*hxVYZ95KJnWw9ECjAegrxA.png":{"__typename":"ImageMetadata","id":"1*hxVYZ95KJnWw9ECjAegrxA.png"},"ImageMetadata:1*O0IVkV_RHxU_4O2EKKCX_Q.png":{"__typename":"ImageMetadata","id":"1*O0IVkV_RHxU_4O2EKKCX_Q.png","originalWidth":1500},"ImageMetadata:1*0BqQiSIkq1FvMJ6gRaJStw.png":{"__typename":"ImageMetadata","id":"1*0BqQiSIkq1FvMJ6gRaJStw.png","originalWidth":1389,"focusPercentX":null,"focusPercentY":null},"ImageMetadata:1*nL3RserBb4-eB-PCFBrtrA.png":{"__typename":"ImageMetadata","id":"1*nL3RserBb4-eB-PCFBrtrA.png","originalHeight":1720,"originalWidth":1290},"Tag:gameplay":{"__typename":"Tag","id":"gameplay","normalizedTagSlug":"gameplay"},"Tag:community":{"__typename":"Tag","id":"community","normalizedTagSlug":"community"},"Tag:spanish":{"__typename":"Tag","id":"spanish","normalizedTagSlug":"spanish"},"Paragraph:81660ce1a916_0":{"__typename":"Paragraph","id":"81660ce1a916_0","name":"9e5f","type":"H3","href":null,"layout":null,"metadata":null,"text":"Who Is Iris? A Star Atlas Treasure Hunt Part I","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_1":{"__typename":"Paragraph","id":"81660ce1a916_1","name":"c8ed","type":"P","href":null,"layout":null,"metadata":null,"text":"Adherents to Star Atlas lore know that the legendary planet Iris is central to its mythos. Iris’ collision with seven other planets created The Cataclysm and sparked a Galactic Expansion and Arms Race between the three Star Atlas factions to claim its valuable resources.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_2":{"__typename":"Paragraph","id":"81660ce1a916_2","name":"07be","type":"P","href":null,"layout":null,"metadata":null,"text":"In Star Atlas: CORE, Star Atlas Head Writer Matt Medney tells the lore behind the metaverse of Star Atlas. CORE is set 100 years before the The Cataclysm and subsequent Convergence War. Throughout the series the story will focus on Gyunn, a MUD protagonist traversing the galaxy after a visit to a planet in the high risk zone ends with a catastrophic blow to his team. It’s a tale of heroism, heartbreak, and epic adventure set in the rich and complex world that is Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":55,"href":"https:\u002F\u002Ftwitter.com\u002Fmatthewmedney","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_3":{"__typename":"Paragraph","id":"81660ce1a916_3","name":"c07d","type":"P","href":null,"layout":null,"metadata":null,"text":"Episode 1 of CORE, written by Tim Mcburnie, introduces the reader to a trio of space explorers scouting a distant planet for valuable resources.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":30,"end":42,"href":"http:\u002F\u002Fwww.timmcburnie.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*udvzd-Toc2II99jlVMfb7Q.png":{"__typename":"ImageMetadata","id":"1*udvzd-Toc2II99jlVMfb7Q.png","originalHeight":892,"originalWidth":645,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:81660ce1a916_4":{"__typename":"Paragraph","id":"81660ce1a916_4","name":"b857","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*udvzd-Toc2II99jlVMfb7Q.png"},"text":"Star Atlas: CORE Gyunn Edition Cover","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_5":{"__typename":"Paragraph","id":"81660ce1a916_5","name":"e4d3","type":"H4","href":null,"layout":null,"metadata":null,"text":"Who is Iris?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":12,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_6":{"__typename":"Paragraph","id":"81660ce1a916_6","name":"2eca","type":"P","href":null,"layout":null,"metadata":null,"text":"Well, in Star Atlas, Iris isn’t a ‘who’ but a ‘what’. As mentioned, Iris is a planet that existed deep in the High Risk Zone. As a planet, Iris is central to the story of Star Atlas in the current timeline. Star Atlas: CORE will explore the 100 years prior to The Cataclysm. Unfortunately, that’s all we know up until this point in the Star Atlas Lore.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_7":{"__typename":"Paragraph","id":"81660ce1a916_7","name":"bf7d","type":"P","href":null,"layout":null,"metadata":null,"text":"However, the fun is only beginning.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_8":{"__typename":"Paragraph","id":"81660ce1a916_8","name":"18ee","type":"H4","href":null,"layout":null,"metadata":null,"text":"Star Atlas Treasure Hunt Begins: Hunt for the Key of Iris","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":57,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_9":{"__typename":"Paragraph","id":"81660ce1a916_9","name":"82cb","type":"P","href":null,"layout":null,"metadata":null,"text":"Readers who purchase the Star Atlas: CORE SFTs will receive clues contained within each episode. Just like Gyunn, readers will embark on a journey to claim a invaluable prize. Being one of the first explorers to crack the cypher may earn them:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_10":{"__typename":"Paragraph","id":"81660ce1a916_10","name":"5545","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Complete Digital Edition of CORE","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_11":{"__typename":"Paragraph","id":"81660ce1a916_11","name":"512c","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Meeting with the writing team","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_12":{"__typename":"Paragraph","id":"81660ce1a916_12","name":"25e5","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Ship skin based off of the graphic novel","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_13":{"__typename":"Paragraph","id":"81660ce1a916_13","name":"e28a","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Extra exclusive content…","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_14":{"__typename":"Paragraph","id":"81660ce1a916_14","name":"a957","type":"H4","href":null,"layout":null,"metadata":null,"text":"So…. Who Is Iris?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":17,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":11,"end":12,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_15":{"__typename":"Paragraph","id":"81660ce1a916_15","name":"ac31","type":"P","href":null,"layout":null,"metadata":null,"text":"We know lore writers often like tying their lore to real life mythologies. J.K. Rowling is famous for lacing allusions to various polytheistic religions and beliefs throughout the Harry Potter series. It’s no doubt that Medney and Mcburnie have done the same.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":180,"end":193,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_16":{"__typename":"Paragraph","id":"81660ce1a916_16","name":"0284","type":"P","href":null,"layout":null,"metadata":null,"text":"In Greek mythology, Iris the personification of the rainbow and messenger of the gods. Her sister Arke betrayed the Olympians and became the messenger of the gods’ enemy, the Titans. She is also known as one of the goddesses of the sea and the sky and links the gods to humanity. Iris is represented either as a rainbow or as a beautiful young maiden with wings on her shoulders. As a goddess, Iris is associated with communication, messages, the rainbow, and new endeavors. In some texts she is depicted wearing a coat of many colors. With this coat she actually creates the rainbows she rides to get from place to place.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":52,"end":60,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":64,"end":74,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":98,"end":103,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":252,"end":278,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":312,"end":320,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":418,"end":431,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":433,"end":441,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":505,"end":534,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_17":{"__typename":"Paragraph","id":"81660ce1a916_17","name":"f582","type":"P","href":null,"layout":null,"metadata":null,"text":"There’s some pretty elegant imagery and symbolism here. What’s even more fascinating is that it all relates to Star Atlas in some way!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_18":{"__typename":"Paragraph","id":"81660ce1a916_18","name":"972d","type":"H4","href":null,"layout":null,"metadata":null,"text":"Arke and Rainbows","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":17,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_19":{"__typename":"Paragraph","id":"81660ce1a916_19","name":"0376","type":"P","href":null,"layout":null,"metadata":null,"text":"Where have we heard that before? If your thought was the Rainbow Arc, you’d be spot on!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*pMrShCwjS5YONobh":{"__typename":"ImageMetadata","id":"0*pMrShCwjS5YONobh","originalHeight":1125,"originalWidth":2000,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:81660ce1a916_20":{"__typename":"Paragraph","id":"81660ce1a916_20","name":"f461","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*pMrShCwjS5YONobh"},"text":"Star Atlas Rainbow Arc","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_21":{"__typename":"Paragraph","id":"81660ce1a916_21","name":"17a2","type":"P","href":null,"layout":null,"metadata":null,"text":"We know that the Rainbow Arc is a ship manufactured by the Photoli, beings revered as Gods, by the MUD who themselves are human descendants in Star Atlas lore. The Rainbow Arc is also capable of some sort of light cloak or armor which gives it protection, much like Iris’ coat of rainbow colors. There’s just too many connections for this to be simply a mere coincidence.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_22":{"__typename":"Paragraph","id":"81660ce1a916_22","name":"a149","type":"H4","href":null,"layout":null,"metadata":null,"text":"Onwards to glory and treasure","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":29,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_23":{"__typename":"Paragraph","id":"81660ce1a916_23","name":"faea","type":"P","href":null,"layout":null,"metadata":null,"text":"The allusions to the Greek goddess don’t end there. The Star Atlas page for Star Atlas: CORE contains what is likely the first clue in what could be a year long treasure hunt.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*dQQinDLDpicfBtI8uJlBtQ.png":{"__typename":"ImageMetadata","id":"1*dQQinDLDpicfBtI8uJlBtQ.png","originalHeight":713,"originalWidth":1026,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:81660ce1a916_24":{"__typename":"Paragraph","id":"81660ce1a916_24","name":"3ab9","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*dQQinDLDpicfBtI8uJlBtQ.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_25":{"__typename":"Paragraph","id":"81660ce1a916_25","name":"e28c","type":"P","href":null,"layout":null,"metadata":null,"text":"Again, we see the reference to Arc. However, what's more is that an Arc Cypher is an actual cryptological encryption method. An Arc Cypher, or a Rivest Cipher 4, also known as ARC4 or ARCFOUR, are stream ciphers. By going to the Star Atlas: CORE page, there appears to be a running stream cypher on the page. By finding the “Key to Iris”, readers and hunters will likely be able to decrypt the Arc Cypher and claim their prize!","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":197,"end":210,"href":"https:\u002F\u002Fen.wikipedia.org\u002Fwiki\u002FStream_cipher","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":176,"end":180,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":184,"end":191,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_26":{"__typename":"Paragraph","id":"81660ce1a916_26","name":"57a2","type":"P","href":null,"layout":null,"metadata":null,"text":"As a last little easter egg, the Star Atlas CORE newsletter is titled, The Voice of Iris. Remember, Iris was the messenger of the Gods, so it’s befitting that the official newsletter is her voice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":71,"end":89,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_27":{"__typename":"Paragraph","id":"81660ce1a916_27","name":"0b75","type":"P","href":null,"layout":null,"metadata":null,"text":"Eager hunters will likely need to collect a copy of each weekly SFT to be able to discover the Key to Iris.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_28":{"__typename":"Paragraph","id":"81660ce1a916_28","name":"fd4d","type":"P","href":null,"layout":null,"metadata":null,"text":"Is the Voice of Iris calling to you? Will you heed her call? And will you find glory at the end of the rainbow?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_29":{"__typename":"Paragraph","id":"81660ce1a916_29","name":"3caf","type":"P","href":null,"layout":null,"metadata":null,"text":"Disclaimer: While The Hologram will be participating in the hunt, this is not an endorsement to purchase the 18 SFTs that will likely be needed (36 in total if you count both Star Atlas and Magic Eden versions). Readers can access all the content of the CORE story for free.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":274,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_30":{"__typename":"Paragraph","id":"81660ce1a916_30","name":"484c","type":"P","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_31":{"__typename":"Paragraph","id":"81660ce1a916_31","name":"516d","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81660ce1a916_32":{"__typename":"Paragraph","id":"81660ce1a916_32","name":"7888","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_ca563b806482":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_ca563b806482","isEditor":false},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas"}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"HIT","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.f6202fc8.js"></script><script src="https://cdn-client.medium.com/lite/static/js/3034.5bf7db30.js"></script><script src="https://cdn-client.medium.com/lite/static/js/main.19c137a3.js"></script><script src="https://cdn-client.medium.com/lite/static/js/instrumentation.c71f0248.chunk.js"></script>

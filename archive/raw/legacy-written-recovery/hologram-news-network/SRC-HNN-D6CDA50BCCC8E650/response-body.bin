:null,"ptsQualifiedAt":0,"description":"The Hologram delivers the latest in Star Atlas citizen news coverage. Set within the Star Atlas metaverse, the Hologram focuses its stories on Star Atlas’s most valuable asset, its citizens.","isAuroraEligible":true,"viewerEdge":{"__ref":"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_8c597c741798"}},"ImageMetadata:1*_QlVG6XBAcbqXVvmi6-8VQ.jpeg":{"id":"1*_QlVG6XBAcbqXVvmi6-8VQ.jpeg","__typename":"ImageMetadata","originalHeight":3873,"originalWidth":3873},"User:41e0c5b141f1":{"id":"41e0c5b141f1","__typename":"User","name":"Krigs","username":"krigsfoniks","newsletterV3":{"__ref":"NewsletterV3:85fc9c436e2e"},"viewerIsUser":false,"isSuspended":false,"customStyleSheet":{"__ref":"CustomStyleSheet:409afeaf1864"},"customDomainState":null,"hasSubdomain":false,"about":"[{\"children\":[{\"text\":\"Editor and Publisher of the Hologram, a news organization set in the Star Atlas metaverse\"}]},{\"children\":[{\"text\":\"I write about things that occur \"},{\"text\":\"in \",\"italic\":true},{\"text\":\"the Star Atlas metaverse with the goal of become Star Atlas primary in game newspaper. \"}]},{\"children\":[{\"text\":\"Star Atlas metacitizen, crypto enthusiast, and military strategist. Like Bilbo, the road goes ever on. \"}]}]","bookAuthor":null,"homepagePostsConnection({\"paging\":{\"limit\":1}})":{"__typename":"PostConnection","posts":[{"__ref":"Post:13647de6add3"}]},"socialStats":{"__typename":"SocialStats","followerCount":7,"followingCount":3,"collectionFollowingCount":2},"imageId":"1*pjXZkCg0Bp_sOdcJxGzkqg.jpeg","mediumMemberAt":1648252998000,"isPartnerProgramEnrolled":false,"viewerEdge":{"__ref":"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_8c597c741798"},"postSubscribeMembershipUpsellShownAt":0,"allowNotes":true,"twitterScreenName":"","referredMembershipCustomHeadline":"","referredMembershipCustomBody":"","bio":"Founder and Chief Editor of The Hologram","isAuroraVisible":true,"atsQualifiedAt":0,"followersUserConnection(
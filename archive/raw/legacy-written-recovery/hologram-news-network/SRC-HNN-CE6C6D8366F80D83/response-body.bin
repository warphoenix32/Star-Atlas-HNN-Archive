anchorType":"USER","userId":"2772803ea4c0","linkMetadata":null},{"__typename":"Markup","type":"A","start":111,"end":121,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a8323f521ca1_2":{"__typename":"Paragraph","id":"a8323f521ca1_2","name":"e352","type":"P","href":null,"layout":null,"metadata":null,"text":"What’s implied is that over a course of a four-stage pre-season and 8 subsequent seasons, the Star Atlas Showroom will be expanded to include additional gameplay features and career progression systems.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*oN-RZb4cgUSFk0IQ89O7nQ.png":{"__typename":"ImageMetadata","id":"1*oN-RZb4cgUSFk0IQ89O7nQ.png","originalHeight":857,"originalWidth":1521,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:a8323f521ca1_3":{"__typename":"Paragraph","id":"a8323f521ca1_3","name":"f843","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*oN-RZb4cgUSFk0IQ89O7nQ.png"},"text":"Star Atlas Season 0 Cover","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a8323f521ca1_4":{"__typename":"Paragraph","id":"a8323f521ca1_4","name":"f8d5","type":"H4","href":null,"layout":null,"metadata":null,"text":"What’s important about Star Atlas Seasons","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a8323f521ca1_5":{"__typename":"Paragraph","id":"a8323f521ca1_5","name":"e1cd","type":"P","href":null,"layout":null,"metadata":null,"text":"According to ATMTA, the company behind Star Atlas, the full version one game is on a 5–7 year production timeline. The pre-alpha version is currently in pre-season Release 1 with Release 2 around the corner. Understanding the season schedule will help you better understand when certain game mechanics and careers will become available in Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":208,"end":350,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a8323f521ca1_6":{"__typename":"Paragraph","id":"a8323f521ca1_6","name":"494b","type":"P","href":null,"layout":null,"metadata":null,"text":"While Star Atlas is using a season model, its important to note that the timeframe for each season is undefined. Typically gaming seasons last from 3–5 months. On a 5–7 year timeline, seasons could go as long as a year between releases. These seasons should expand the current environment of the Star Atlas showroom allowing people to to become more immersed in the Star Atlas metaverse.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a8323f521ca1_7":{"__typename":"Paragraph","id":"a8323f521ca1_7","name":"fe2a","type":"H4","href":null,"layout":null,"metadata":null,"text":"Star Atlas Pre-Season","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":21,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*xxTU7pMLDJEG9yoXi3F0dg.png":{"__typename":"ImageMetadata","id":"1*xxTU7pMLDJEG9yoXi3F0dg.png","originalHeight":854,"originalWidth":1519,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:a8323f521ca1_8":{"__typename":"Paragraph","id":"a8323f521ca1_8","name":"ecc6","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*xxTU7pMLDJEG9yoXi3F0dg.png"},"text":"Unreal Engine Showroom Pre-Season Roadmap","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a8323f521ca1
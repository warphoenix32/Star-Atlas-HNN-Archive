:null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":37,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a8323f521ca1_55":{"__typename":"Paragraph","id":"a8323f521ca1_55","name":"1518","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Rescue, Refueler, and Politician Careers","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a8323f521ca1_56":{"__typename":"Paragraph","id":"a8323f521ca1_56","name":"16ab","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Fully decentralized","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a8323f521ca1_57":{"__typename":"Paragraph","id":"a8323f521ca1_57","name":"2d2b","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Star Atlas v1.0 — Full Game","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a8323f521ca1_58":{"__typename":"Paragraph","id":"a8323f521ca1_58","name":"5331","type":"P","href":null,"layout":null,"metadata":null,"text":"Synopsis","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":8,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a8323f521ca1_59":{"__typename":"Paragraph","id":"a8323f521ca1_59","name":"18f9","type":"P","href":null,"layout":null,"metadata":null,"text":"Based on the roadmap of Star Atlas seasons, its clear that repair and salvage careers will be prioritized last and only available until closer to the games full release. For those interested in combat, mining, and crafting, rejoice! It would seem like those activities will come sooner, likely within 1–2 years.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a8323f521ca1_60":{"__typename":"Paragraph","id":"a8323f521ca1_60","name":"698a","type":"P","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a8323f521ca1_61":{"__typename":"Paragraph","id":"a8323f521ca1_61","name":"0fce","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a8323f521ca1_62":{"__typename":"Paragraph","id":"a8323f521ca1_62","name":"028e","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:41e0c5b141f1":{"
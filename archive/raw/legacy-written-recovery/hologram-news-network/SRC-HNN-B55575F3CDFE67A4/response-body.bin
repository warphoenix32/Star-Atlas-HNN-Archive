es":{"__typename":"PostResponses","count":0},"allowResponses":true,"isLimitedState":false,"voterCount":1,"recommenders":[],"isSeries":false,"sequence":null,"uniqueSlug":"the-plant-market-of-star-atlas-655f8b7fe5c1","title":"The Plant Market of Star Atlas","clapCount":20,"pinnedAt":0,"pinnedByCreatorAt":1675225118424,"curationEligibleAt":0,"responseDistribution":"NOT_DISTRIBUTED","inResponseToPostResult":null,"inResponseToCatalogResult":null,"pendingCollection":null,"isNewsletter":false,"isAuthorNewsletter":false,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"},{"__ref":"Tag:nft"},{"__ref":"Tag:metaverse"}],"readingTime":3.8333333333333335,"inResponseToEntityType":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1675391672150,"previewContent":{"__typename":"PreviewContent","subtitle":"A call to 3D artists to create flora and fauna in the metaverse."},"previewImage":{"__ref":"ImageMetadata:1*8k3fiRkm-JAyNKDKWVPIYA.png"},"isShortform":false,"seoTitle":"","updatedAt":1675391679277,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"isSuspended":false,"responseRootPost":{"__typename":"ResponseRootPost","post":{"__ref":"Post:655f8b7fe5c1"}},"internalLinks({\"paging\":{\"limit\":8}})":{"__typename":"InternalLinksConnection","items":[{"__ref":"Post:ebc84b781592"},{"__ref":"Post:c1d545a6beaf"},{"__ref":"Post:d50c0af969ea"},{"__ref":"Post:a425da35d114"},{"__ref":"Post:b15277dbc34e"},{"__ref":"Post:f09f42e2e27c"},{"__ref":"Post:a3efed5e7dd9"},{"__ref":"Post:efd09f4eeb19"}]},"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}},"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg","originalWidth":2730,"focusPercentX":48.57142857142857,"focusPercentY":45.19230769230769},"NewsletterV3:ac886d6987e0":{"__typename":"NewsletterV3","slug":"holoreport","id":"ac886d6987e0","name":"HoloReport","description":"Catch up on the latest Star Atlas news that you've missed. ","promoHeadline":"","promoBody":"","type":"NEWSLETTER_TYPE_COLLECTION","user":{"__ref":"User:41e0c5b141f1"},"collection":{"__ref":"Collection:4d89daa6ae31"},"showPromo":true},"ImageMetadata:1*EWK2g3sZ2CUq9HSp-mKvEA.png":{"__typename":"ImageMetadata","id":"1*EWK2g3sZ2CUq9HSp-mKvEA.png","originalWidth":1024},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","name":"Krigs","username":"krigsfoniks","newsletterV3":{"__ref":"NewsletterV3:85fc9c436e2e"},"atsQualifiedAt":1650725917596},"NewsletterV3:85fc9c436e2e":{"__typename":"NewsletterV3","id":"85fc9c436e2e"},"PostViewerEdge:postId:655f8b7fe5c1-viewerId:lo_c63755b993b8":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:655f8b7fe5c1-viewerId:lo_c63755b993b8"},"Paragraph:3ca6e7ab9f14_0":{"__typename":"Paragraph","id":"3ca6e7ab9f14_0","name":"bcff","type":"H3","href":null,"layout":null,"metadata":null,"text":"The Plant Market of Star Atlas","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_1":{"__typename":"Paragraph","id":"3ca6e7ab9f14_1","name":"5ea8","type":"P","href":null,"layout":null,"metadata":null,"text":"A call to 3D artists to create flora and fauna in the metaverse.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":64,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_2":{"__typename":"Paragraph","id":"3ca6e7ab9f14_2","name":"e250","type":"P","href":null,"layout":null,"metadata":null,"text":"The discovery of new alien worlds was a momentous occasion for Mud, Oni, and Ustur alike. For centuries, many eager travelers set out to explore the unknown, hoping to discover secrets of the cosmos. Many planets they encountered were lush, verdant worlds, teeming with life. The plant-life was unlike anything they had ever seen before — towering trees with leaves the size of houses, and creatures that seemed to defy the laws of physics.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":62,"end":66,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":68,"end":71,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":77,"end":82,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":235,"end":274,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*8k3fiRkm-JAyNKDKWVPIYA.png":{"__typename":"ImageMetadata","id":"1*8k3fiRkm-JAyNKDKWVPIYA.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:3ca6e7ab9f14_3":{"__typename":"Paragraph","id":"3ca6e7ab9f14_3","name":"e56e","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*8k3fiRkm-JAyNKDKWVPIYA.png"},"text":"Concept Art","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_4":{"__typename":"Paragraph","id":"3ca6e7ab9f14_4","name":"854a","type":"P","href":null,"layout":null,"metadata":null,"text":"As they explored these new worlds, a team of scientists and explorers couldn’t help but feel a sense of awe and wonder at the beauty and diversity of the life they were encountering. They knew that they had to document and preserve this new world, so they sent a transmission to 3D artists in the community to help them create realistic and detailed digital assets of the flora and fauna they were discovering.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":279,"end":289,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":320,"end":337,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":341,"end":364,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":372,"end":387,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_5":{"__typename":"Paragraph","id":"3ca6e7ab9f14_5","name":"8ba7","type":"P","href":null,"layout":null,"metadata":null,"text":"The artists responded eagerly, creating stunning 3D models of the plants and animals they encountered. They used a pre-determined classification system to ensure authenticity, and included detailed descriptions, animations, rarity, lore, special traits, abilities, etc. for each asset.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":189,"end":210,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":212,"end":222,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":224,"end":230,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":232,"end":236,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":238,"end":252,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":254,"end":263,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":265,"end":268,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_6":{"__typename":"Paragraph","id":"3ca6e7ab9f14_6","name":"1936","type":"P","href":null,"layout":null,"metadata":null,"text":"These digital assets were then made available on a decentralized platform, where the community could view and vote on them. Some of the most popular assets would eventually be synthesized and relocated into official landscapes, providing a unique and satisfying experience for those who had created them.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":192,"end":207,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":216,"end":226,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*K-C_beSKvQx0lL_BNjlWaQ.png":{"__typename":"ImageMetadata","id":"1*K-C_beSKvQx0lL_BNjlWaQ.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:3ca6e7ab9f14_7":{"__typename":"Paragraph","id":"3ca6e7ab9f14_7","name":"f8b9","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*K-C_beSKvQx0lL_BNjlWaQ.png"},"text":"Concept Art","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_8":{"__typename":"Paragraph","id":"3ca6e7ab9f14_8","name":"4017","type":"P","href":null,"layout":null,"metadata":null,"text":"As the exploration of new worlds continued, the community of 3D artists began to grow and flourish, creating new and exciting digital assets for the archive. The artists were also able to monetize their work, selling NFTs of their assets on different Solana marketplaces. They even had the possibility to earn royalties through smart contracts when their assets were used on Star Atlas land claims.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":251,"end":257,"href":null,"anchorType":"USER","userId":"af6a22150fa9","linkMetadata":null},{"__typename":"Markup","type":"A","start":375,"end":385,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":188,"end":207,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":305,"end":319,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_9":{"__typename":"Paragraph","id":"3ca6e7ab9f14_9","name":"f957","type":"P","href":null,"layout":null,"metadata":null,"text":"Traditional video games often fail to take plants seriously as a gameplay feature, depicting them as mere decoration or solid obstacles. There are a few games that have implemented regenerative foliage or the ability to destroy trees, and these features are often not utilized to their full potential. It would be interesting if mechanics were eventually incorporated in Star Atlas, such as reducing player speed or making rustling noises, when moving through plants. When Star Atlas has to focus less on the assets themselves, it will give them more time to come up with better gameplay.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":473,"end":483,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":468,"end":587,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_10":{"__typename":"Paragraph","id":"3ca6e7ab9f14_10","name":"1886","type":"P","href":null,"layout":null,"metadata":null,"text":"The discovery of new alien worlds has expanded Galactic understanding of the universe. To all developers out there: We need a decentralized marketplace for 3D flora & fauna with a robust classification system. If accepted into the game by the Star Atlas team, assets could receive a special badge, differentiating them from the rest.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":94,"end":104,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":126,"end":165,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":167,"end":173,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_11":{"__typename":"Paragraph","id":"3ca6e7ab9f14_11","name":"8f98","type":"H4","href":null,"layout":null,"metadata":null,"text":"A Plant I Hope to Sell in the Star Atlas ecosystem:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:b0bb38a5f6db766c1685effb96afe2c1":{"__typename":"MediaResource","id":"b0bb38a5f6db766c1685effb96afe2c1","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?src=https%3A%2F%2Fwww.youtube.com%2Fembed%2Fh7bljJl_eRA%3Ffeature%3Doembed&display_name=YouTube&url=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3Dh7bljJl_eRA&image=https%3A%2F%2Fi.ytimg.com%2Fvi%2Fh7bljJl_eRA%2Fhqdefault.jpg&key=a19fcc184b9711e1b4764040d3dc5c07&type=text%2Fhtml&schema=youtube","iframeHeight":480,"iframeWidth":854,"title":"Crimson Coil - A 3D Asset for Web3"},"Paragraph:3ca6e7ab9f14_12":{"__typename":"Paragraph","id":"3ca6e7ab9f14_12","name":"a4d4","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"Behold, the Crimson Coil","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":12,"end":24,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:b0bb38a5f6db766c1685effb96afe2c1"}},"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_13":{"__typename":"Paragraph","id":"3ca6e7ab9f14_13","name":"d25a","type":"P","href":null,"layout":null,"metadata":null,"text":"Name: Crimson Coil","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_14":{"__typename":"Paragraph","id":"3ca6e7ab9f14_14","name":"7295","type":"P","href":null,"layout":null,"metadata":null,"text":"Rarity: Secret Rare","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":19,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_15":{"__typename":"Paragraph","id":"3ca6e7ab9f14_15","name":"94b7","type":"P","href":null,"layout":null,"metadata":null,"text":"Description: A poisonous Oni flower with bright red petals and a stem that resembles a coil. Its stem is incredibly valuable and is harvested for use in Oni technology. The flower emits a mesmerizing glow that attracts insects and small creatures, killing unwanted visitors not immune.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":285,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_16":{"__typename":"Paragraph","id":"3ca6e7ab9f14_16","name":"96a2","type":"P","href":null,"layout":null,"metadata":null,"text":"Lore: The Crimson Coil is said to have evolved on a planet with high levels of radiation, where it developed its unique abilities for survival. It’s now found on many different planets and is highly sought after for its beauty and abilities. The Oni are immune to its poisonous effects.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":286,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_17":{"__typename":"Paragraph","id":"3ca6e7ab9f14_17","name":"b4cc","type":"P","href":null,"layout":null,"metadata":null,"text":"Special Traits:","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":15,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_18":{"__typename":"Paragraph","id":"3ca6e7ab9f14_18","name":"a082","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Coil Stem: Used for advanced technology.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":40,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_19":{"__typename":"Paragraph","id":"3ca6e7ab9f14_19","name":"986e","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Mesmerizing Glow: It emits a glow that attracts creatures.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":58,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_20":{"__typename":"Paragraph","id":"3ca6e7ab9f14_20","name":"7dd3","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Rare Chemical: The substance secreted from its petals is rare and highly sought after.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":86,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_21":{"__typename":"Paragraph","id":"3ca6e7ab9f14_21","name":"73f4","type":"P","href":null,"layout":null,"metadata":null,"text":"Abilities:","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":10,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_22":{"__typename":"Paragraph","id":"3ca6e7ab9f14_22","name":"9076","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Defense: Its stem can be used as a weapon to defend against predators.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":70,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*0eSqSiDHztMrKrSEkaPqqQ.jpeg":{"__typename":"ImageMetadata","id":"1*0eSqSiDHztMrKrSEkaPqqQ.jpeg","originalHeight":4096,"originalWidth":4096,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:3ca6e7ab9f14_23":{"__typename":"Paragraph","id":"3ca6e7ab9f14_23","name":"8537","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*0eSqSiDHztMrKrSEkaPqqQ.jpeg"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_24":{"__typename":"Paragraph","id":"3ca6e7ab9f14_24","name":"48af","type":"P","href":null,"layout":null,"metadata":null,"text":"See more of my concept art here: ArtStation — Star Atlas Concept Art — Flora and Fauna","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":33,"end":86,"href":"https:\u002F\u002Fwww.artstation.com\u002Fartwork\u002FnEamNe","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*vw-P-sSczBpzOK4y34Y4BQ.png":{"__typename":"ImageMetadata","id":"1*vw-P-sSczBpzOK4y34Y4BQ.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:3ca6e7ab9f14_25":{"__typename":"Paragraph","id":"3ca6e7ab9f14_25","name":"0c95","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*vw-P-sSczBpzOK4y34Y4BQ.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3ca6e7ab9f14_26":{"__typename":"Paragraph","id":"3ca6e7ab9f14_26","name":"7eac","type":"P","href":null,"layout":null,"metadata":nu
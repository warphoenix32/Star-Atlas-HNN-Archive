bx gj gk"><div class="l go"><img alt="Krigs" class="l ec bx dc dd cw" src="https://miro.medium.com/v2/resize:fill:88:88/1*pVxyLAandIa00EX6ZGRERw.png" width="44" height="44" loading="lazy" data-testid="authorPhoto"/><div class="gl bx l dc dd eh n gm gn"></div></div></div></div></div></a><a href="https://medium.com/the-hologram?source=post_page-----711ce770eb20--------------------------------" rel="noopener follow"><div class="gp ab go"><div><div class="bl" aria-hidden="false"><div class="l gq gr bx gj gs"><div class="l go"><img alt="The Hologram" class="l ec bx bq gt cw" src="https://miro.medium.com/v2/resize:fill:48:48/1*7CPIGOfQcS8d3RGFcufiiA.jpeg" width="24" height="24" loading="lazy" data-testid="publicationPhoto"/><div class="gl bx l bq gt eh n gm gn"></div></div></div></div></div></div></a></div></div><div class="bm bg l"><div class="ab"><div style="flex:1"><span class="be b bf z bj"><div class="gu ab q"><div class="ab q gv"><div class="ab q"><div><div class="bl" aria-hidden="false"><p class="be b gw gx bj"><a class="af ag ah ai aj ak al am an ao ap aq ar gy" data-testid="authorName" rel="noopener follow" href="/@krigsfoniks?source=post_page-----711ce770eb20--------------------------------">Krigs</a></p></div></div></div><span class="gz ha" aria-hidden="true"><span class="be b bf z hb">·</span></span><p class="be b gw gx hb"><span><a class="hc hd ah ai aj ak al am an ao ap aq ar he hf hg" rel="noopener follow" href="/m/signin?actionUrl=https%3A%2F%2Fmedium.com%2F_%2Fsubscribe%2Fuser%2F41e0c5b141f1&amp;operation=register&amp;redirect=https%3A%2F%2Fmedium.com%2Fthe-hologram%2Fstar-atlas-golden-ticket-raffle-offers-unique-opportunity-at-1-35-million-in-prizes-711ce770eb20&amp;user=Krigs&amp;userId=41e0c5b141f1&amp;source=post_page-41e0c5b141f1----711ce770eb20---------------------post_header-----------">Follow</a></span></p></div></div></span></div></div><div class="l hh"><span class="be b bf z hb"><div class="ab cm hi hj hk"><div class="hl hm ab"><div class="be b 
geLayout":null,"backgroundImage":null,"videoLayout":null,"backgroundVideo":null}],"paragraphs":[{"__ref":"Paragraph:a1f1867a0943_0"},{"__ref":"Paragraph:a1f1867a0943_1"},{"__ref":"Paragraph:a1f1867a0943_2"},{"__ref":"Paragraph:a1f1867a0943_3"},{"__ref":"Paragraph:a1f1867a0943_4"},{"__ref":"Paragraph:a1f1867a0943_5"},{"__ref":"Paragraph:a1f1867a0943_6"},{"__ref":"Paragraph:a1f1867a0943_7"},{"__ref":"Paragraph:a1f1867a0943_8"},{"__ref":"Paragraph:a1f1867a0943_9"},{"__ref":"Paragraph:a1f1867a0943_10"},{"__ref":"Paragraph:a1f1867a0943_11"},{"__ref":"Paragraph:a1f1867a0943_12"},{"__ref":"Paragraph:a1f1867a0943_13"},{"__ref":"Paragraph:a1f1867a0943_14"},{"__ref":"Paragraph:a1f1867a0943_15"},{"__ref":"Paragraph:a1f1867a0943_16"}]}},"customStyleSheet":null,"isPublished":true,"isLocked":false,"license":"ALL_RIGHTS_RESERVED","collaborators":[],"statusForCollection":"APPROVED","isMarkedPaywallOnly":false,"lockedSource":"LOCKED_POST_SOURCE_NONE","mediumUrl":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fstar-atlas-developer-atmta-begins-staff-reductions-e2edbbda516f","primaryTopic":null,"topics":[],"viewerEdge":{"__ref":"PostViewerEdge:postId:e2edbbda516f-viewerId:lo_ead05a8a592a"},"latestPublishedVersion":"a1f1867a0943","postResponses":{"__typename":"PostResponses","count":0},"allowResponses":true,"isLimitedState":false,"voterCount":0,"recommenders":[],"isSeries":false,"sequence":null,"uniqueSlug":"star-atlas-developer-atmta-begins-staff-reductions-e2edbbda516f","title":"Star Atlas Developer, ATMTA, Begins Staff Reductions","clapCount":0,"pinnedAt":0,"pinnedByCreatorAt":0,"curationEligibleAt":0,"responseDistribution":"NOT_DISTRIBUTED","inResponseToPostResult":null,"inResponseToCatalogResult":null,"pendingCollection":null,"isNewsletter":false,"isAuthorNewsletter":true,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"}],"readingTime":1.9622641509433962,"inResponseToEntityType":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1671422411302,"previewContent":{"__typename":"PreviewContent","subtitle":"Sun, Dec 18th — Automata, the developers of the game Star Atlas, quietly began staff reductions last Friday to include Content Strategist…"},"previewImage":{"__ref":"ImageMetadata:1*7iZ8FMRv--cXeAuSBg6sHg.png"},"isShortform":false,"seoTitle":"","updatedAt":1671422412525,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"isSuspended":false,"responseRootPost":{"__typename":"ResponseRootPost","post":{"__ref":"Post:e2edbbda516f"}},"internalLinks({\"paging\":{\"limit\":8}})":{"__typename":"InternalLinksConnection","items":[]},"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}},"ImageMetadata:1*hxVYZ95KJnWw9ECjAegrxA.png":{"__typename":"ImageMetadata","id":"1*hxVYZ95KJnWw9ECjAegrxA.png"},"ImageMetadata:1*O0IVkV_RHxU_4O2EKKCX_Q.png":{"__typename":"ImageMetadata","id":"1*O0IVkV_RHxU_4O2EKKCX_Q.png","originalWidth":1500,"focusPercentX":53.57142857142857,"focusPercentY":31.182795698924732},"Post:bff20fd1e3c":{"__typename":"Post","id":"bff20fd1e3c"},"PostViewerEdge:postId:e2edbbda516f-viewerId:lo_ead05a8a592a":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:e2edbbda516f-viewerId:lo_ead05a8a592a"},"Paragraph:a1f1867a0943_0":{"__typename":"Paragraph","id":"a1f1867a0943_0","name":"e34f","type":"H3","href":null,"layout":null,"metadata":null,"text":"Star Atlas Developer, ATMTA, Begins Staff Reductions","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_1":{"__typename":"Paragraph","id":"a1f1867a0943_1","name":"6584","type":"P","href":null,"layout":null,"metadata":null,"text":"Sun, Dec 18th — Automata, the developers of the game Star Atlas, quietly began staff reductions last Friday to include Content Strategist Dave Boerger, better known in the Star Atlas Community as DaveyB.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":53,"end":63,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":13,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_2":{"__typename":"Paragraph","id":"a1f1867a0943_2","name":"653f","type":"P","href":null,"layout":null,"metadata":null,"text":"In a LinkedIn post, the Head of Growth at Star Atlas, Estefan Vazquez, announced on the 16th","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_3":{"__typename":"Paragraph","id":"a1f1867a0943_3","name":"0b0c","type":"BQ","href":null,"layout":null,"metadata":null,"text":"“Today marks the end of my journey with Star Atlas. It has been an incredible experience and a true honor to work alongside some of the most talented people I’ve come across.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_4":{"__typename":"Paragraph","id":"a1f1867a0943_4","name":"f6a7","type":"P","href":null,"layout":null,"metadata":null,"text":"The two high profile layoffs are two of at least four known staff reductions at the company. Several sources at the company have confirmed the staff layoffs but were not at liberty to discuss the reasoning behind the staff reductions. Automata spokespersons declined to provide comment on the staff reductions at this time.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*7iZ8FMRv--cXeAuSBg6sHg.png":{"__typename":"ImageMetadata","id":"1*7iZ8FMRv--cXeAuSBg6sHg.png","originalHeight":512,"originalWidth":512,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:a1f1867a0943_5":{"__typename":"Paragraph","id":"a1f1867a0943_5","name":"45a6","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*7iZ8FMRv--cXeAuSBg6sHg.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_6":{"__typename":"Paragraph","id":"a1f1867a0943_6","name":"06b5","type":"H4","href":null,"layout":null,"metadata":null,"text":"Staff Reductions Amidst Runway Shortage","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":39,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_7":{"__typename":"Paragraph","id":"a1f1867a0943_7","name":"5c78","type":"P","href":null,"layout":null,"metadata":null,"text":"It’s officially unclear if the recent downsizing at Automata was driven by their recent fund loss associated with FTX’s collapse. However, given the circumstances of a shortened development runway, it is highly likely that senior executives at the company were forced to make tough cost savings decisions regarding which personnel to retain.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":88,"end":97,"href":"https:\u002F\u002Fmedium.com\u002Fblockchain-biz\u002Fstar-atlas-heavily-affected-by-ftx-catastrophe-ceo-remains-committed-180cf3c2f5a9","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_8":{"__typename":"Paragraph","id":"a1f1867a0943_8","name":"0cbe","type":"P","href":null,"layout":null,"metadata":null,"text":"It is unlikely that staff reductions were implemented due to public community pressure and outrage following the FTX incident. Star Atlas community members were virulent in their calls for immediate staff firings. Rather, this appears to be a pragmatic business decision the company was forced to make.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_9":{"__typename":"Paragraph","id":"a1f1867a0943_9","name":"9c79","type":"P","href":null,"layout":null,"metadata":null,"text":"The question remains as to the size and scope of these initial reductions. Should revenue reports continue to be net negative, it is possible that additional rounds of layoffs might occur in the future. Automata now faces the challenge of ensuring that the reduction in payroll expenses ultimately enable the development and delivery of the Star Atlas game.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_10":{"__typename":"Paragraph","id":"a1f1867a0943_10","name":"8ba6","type":"P","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_11":{"__typename":"Paragraph","id":"a1f1867a0943_11","name":"3e8a","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs is the founder of The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of the Star Atlas game. Krigs has covered Star Atlas for the past year and enjoys writing about the potential that blockchain technology has to revolutionize the gaming industry.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_12":{"__typename":"Paragraph","id":"a1f1867a0943_12","name":"cbaf","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_13":{"__typename":"Paragraph","id":"a1f1867a0943_13","name":"851c","type":"P","href":null,"layout":null,"metadata":null,"text":"Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":19,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":22,"end":25,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_14":{"__typename":"Paragraph","id":"a1f1867a0943_14","name":"7714","type":"P","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_15":{"__typename":"Paragraph","id":"a1f1867a0943_15","name":"4122","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:a1f1867a0943_16":{"__typename":"Paragraph","id":"a1f1867a0943_16","name":"8cfa","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u0
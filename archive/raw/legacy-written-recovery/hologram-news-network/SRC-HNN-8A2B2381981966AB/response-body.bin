agraph:d08f24edcae1_31"},{"__ref":"Paragraph:d08f24edcae1_32"},{"__ref":"Paragraph:d08f24edcae1_33"},{"__ref":"Paragraph:d08f24edcae1_34"},{"__ref":"Paragraph:d08f24edcae1_35"},{"__ref":"Paragraph:d08f24edcae1_36"},{"__ref":"Paragraph:d08f24edcae1_37"},{"__ref":"Paragraph:d08f24edcae1_38"},{"__ref":"Paragraph:d08f24edcae1_39"},{"__ref":"Paragraph:d08f24edcae1_40"},{"__ref":"Paragraph:d08f24edcae1_41"},{"__ref":"Paragraph:d08f24edcae1_42"}]}},"customStyleSheet":null,"isPublished":true,"isLocked":false,"license":"ALL_RIGHTS_RESERVED","collaborators":[],"isMarkedPaywallOnly":false,"lockedSource":"LOCKED_POST_SOURCE_NONE","mediumUrl":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fbest-ships-for-star-atlas-golden-era-sage-99c49aaa7276","primaryTopic":null,"topics":[],"latestPublishedVersion":"d08f24edcae1","postResponses":{"__typename":"PostResponses","count":0},"allowResponses":true,"isLimitedState":false,"voterCount":0,"recommenders":[],"isSeries":false,"sequence":null,"uniqueSlug":"best-ships-for-star-atlas-golden-era-sage-99c49aaa7276","title":"Best Ships for Star Atlas Golden Era (SAGE)","clapCount":0,"statusForCollection":"APPROVED","pinnedAt":0,"pinnedByCreatorAt":0,"curationEligibleAt":0,"responseDistribution":"NOT_DISTRIBUTED","inResponseToPostResult":null,"inResponseToCatalogResult":null,"pendingCollection":null,"isNewsletter":false,"isAuthorNewsletter":true,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"}],"readingTime":3.672641509433962,"inResponseToEntityType":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1668627290544,"previewContent":{"__typename":"PreviewContent","subtitle":"What is the best Star Atlas ship to buy for SAGE?"},"previewImage":{"__ref":"ImageMetadata:0*G2IzAMLhfntm5cde"},"isShortform":false,"seoTitle":"","updatedAt":1668627299643,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"isSuspended":false,"responseRootPost":{"__typename":"ResponseRootPost","post":{"__ref":"Post:99c49aaa7276"}},"internalLinks({\"paging\":{\"limit\":8}})":{"__typename":"InternalLinksConnection","items":[]},"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}},"ImageMetadata:1*hxVYZ95KJnWw9ECjAegrxA.png":{"__typename":"ImageMetadata","id":"1*hxVYZ95KJnWw9ECjAegrxA.png"},"ImageMetadata:1*O0IVkV_RHxU_4O2EKKCX_Q.png":{"__typename":"ImageMetadata","id":"1*O0IVkV_RHxU_4O2EKKCX_Q.png","originalWidth":1500,"focusPercentX":53.57142857142857,"focusPercentY":31.182795698924732},"Paragraph:d08f24edcae1_0":{"__typename":"Paragraph","id":"d08f24edcae1_0","name":"e2e2","type":"H3","href":null,"layout":null,"metadata":null,"text":"Best Ships for Star Atlas Golden Era (SAGE)","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_1":{"__typename":"Paragraph","id":"d08f24edcae1_1","name":"31bc","type":"P","href":null,"layout":null,"metadata":null,"text":"As Star Atlas prepares to release their new mini-game module SAGE, many players wondered, “What is the best Star Atlas ship to buy”? This question is the focus of much debate and there are many factors to consider.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":3,"end":13,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_2":{"__typename":"Paragraph","id":"d08f24edcae1_2","name":"e090","type":"P","href":null,"layout":null,"metadata":null,"text":"Star Atlas ships cover a wide range of sizes and classes. From XX-Small to Commander and Titan sized ships, Star Atlas has a stunning array of ships to chose from. Ships also cover a plethora of functions, including fighters, bombers, transport, and bounty hunting just to name a few.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_3":{"__typename":"Paragraph","id":"d08f24edcae1_3","name":"917c","type":"P","href":null,"layout":null,"metadata":null,"text":"Current Star Atlas Best Ships","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":29,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_4":{"__typename":"Paragraph","id":"d08f24edcae1_4","name":"3091","type":"P","href":null,"layout":null,"metadata":null,"text":"Until now, there has been two schools of thought on which Star Atlas ships to purchase:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_5":{"__typename":"Paragraph","id":"d08f24edcae1_5","name":"60a6","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Buy the ships that fit your play style or budget","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_6":{"__typename":"Paragraph","id":"d08f24edcae1_6","name":"921a","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Buy any ships that return the most APY from the Faction Fleet mini-game.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_7":{"__typename":"Paragraph","id":"d08f24edcae1_7","name":"6ce1","type":"P","href":null,"layout":null,"metadata":null,"text":"The first option is pretty straight forward. Buy what you like and buy what you can afford. The second option requires a little more analysis, but essentially comes down to buying the best valued ship at the time and enlisting it into Faction Fleet to maximize your return yield. However, it’s well known that eventually Faction Fleet will be phased out, thus Option 2 will no longer be a viable model, leaving many to wonder “What’s next”?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_8":{"__typename":"Paragraph","id":"d08f24edcae1_8","name":"6717","type":"P","href":null,"layout":null,"metadata":null,"text":"SAGE Basics","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":11,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_9":{"__typename":"Paragraph","id":"d08f24edcae1_9","name":"99c2","type":"P","href":null,"layout":null,"metadata":null,"text":"Lets cover some basics about SAGE:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_10":{"__typename":"Paragraph","id":"d08f24edcae1_10","name":"0191","type":"ULI","href":null,"layout":null,"metadata":null,"text":"SAGE will be a real time strategy like game","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_11":{"__typename":"Paragraph","id":"d08f24edcae1_11","name":"fbde","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Players will compete for territorial control against other factions","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_12":{"__typename":"Paragraph","id":"d08f24edcae1_12","name":"1a24","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Fleet firepower will be an important metric in combat","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_13":{"__typename":"Paragraph","id":"d08f24edcae1_13","name":"fa50","type":"P","href":null,"layout":null,"metadata":null,"text":"Still, that doesn’t help answer the question of what’s best.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_14":{"__typename":"Paragraph","id":"d08f24edcae1_14","name":"1b41","type":"P","href":null,"layout":null,"metadata":null,"text":"For SAGE, players can certainly still buy what they want and like. All manner of ship types and sizes will be needed in SAGE, especially when it comes to star base construction which is required to claim territorial control of star systems. Bombers will play an important role in taking down star bases and transport ships will haul valuable materials to and from stations.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_15":{"__typename":"Paragraph","id":"d08f24edcae1_15","name":"26f9","type":"P","href":null,"layout":null,"metadata":null,"text":"Today, Game Dev Chip revealed how a ship’s value and components factor into its performance in SAGE.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_16":{"__typename":"Paragraph","id":"d08f24edcae1_16","name":"524c","type":"P","href":null,"layout":null,"metadata":null,"text":"Alpha drop — Courtesy of Game Dev Chip, this little alpha drop should help clarify that answer a bit. Rarity doesn’t matter for SAGE.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":13,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":102,"end":133,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*cZxZtOxh4tsoeEt5IyUIcg.png":{"__typename":"ImageMetadata","id":"1*cZxZtOxh4tsoeEt5IyUIcg.png","originalHeight":116,"originalWidth":990,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d08f24edcae1_17":{"__typename":"Paragraph","id":"d08f24edcae1_17","name":"0be4","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*cZxZtOxh4tsoeEt5IyUIcg.png"},"text":"Foundation Room Comment","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_18":{"__typename":"Paragraph","id":"d08f24edcae1_18","name":"00cd","type":"P","href":null,"layout":null,"metadata":null,"text":"SAGE — Rare Ships Doesn’t Mean Better!","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":38,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_19":{"__typename":"Paragraph","id":"d08f24edcae1_19","name":"6234","type":"P","href":null,"layout":null,"metadata":null,"text":"From a manufacturing standpoint, rare ships may certainly be more difficult to obtain and thus more valuable on the market. However, from an overall SAGE standpoint, it would appear that the best value would be to purchase a ship with the best overall combat stats, regardless of rarity.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":266,"end":277,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_20":{"__typename":"Paragraph","id":"d08f24edcae1_20","name":"fe87","type":"P","href":null,"layout":null,"metadata":null,"text":"If your goal is to buy the best bang for your buck, check out these combat ships below. Remember, depending on current market prices, it might actually be okay to go with a cheaper ship if the more powerful one is overvalued.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_21":{"__typename":"Paragraph","id":"d08f24edcae1_21","name":"5ae0","type":"P","href":null,"layout":null,"metadata":null,"text":"Best Firepower for Value Ships by Size Class","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":44,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_22":{"__typename":"Paragraph","id":"d08f24edcae1_22","name":"c188","type":"P","href":null,"layout":null,"metadata":null,"text":"XX-Small: Pearce X4","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":19,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*yBBH0i25dFiO9I_o":{"__typename":"ImageMetadata","id":"0*yBBH0i25dFiO9I_o","originalHeight":1011,"originalWidth":2000,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d08f24edcae1_23":{"__typename":"Paragraph","id":"d08f24edcae1_23","name":"b0df","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*yBBH0i25dFiO9I_o"},"text":"Pearce X4 Fighter— Star Atlas","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d08f24edcae1_24":{"__typename":"Paragraph","id":"d08f24edcae1_24","name":"6b7a","type":"P","href":null,"layout":null,"metadata":null,"text":"X-Small: Pearce X5","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*dRpN2wvzQKXdUQM0":{"__typename":"ImageMetadata","id":"0*dRpN2wvzQKXdUQM0","originalHeight":1125,"originalWidth":2000,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d0
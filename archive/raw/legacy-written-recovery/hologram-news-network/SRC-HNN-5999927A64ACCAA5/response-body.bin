-2.65v.02zm-3.12 1.06l-.06-.22-.32.1a8 8 0 0 1-2.3.33c-4.03 0-7.3-2.96-7.3-6.59S8.17 4.9 12.2 4.9c4 0 7.1 2.96 7.1 6.6 0 1.8-.6 3.47-2.02 4.72l-.2.16v.26l.02.3a6.74 6.74 0 0 0 .88 2.4 5.27 5.27 0 0 1-2.17-.86c-.28-.17-.72-.38-.94-.59l.01-.02z"></path></svg></button></div></div></div><div class="ab q ip iq ir is it iu iv iw ix iy iz ja jb jc jd"><div class="ki k j i d"></div><div class="h k"></div><div class="ec rr cm"><div class="l ae"><div class="ab ca"><div class="rs rt ru rv rw mk ch bg"><div class="ab"><div class="bl bg" aria-hidden="false"><div><div class="bl" aria-hidden="false"><button class="af jn ah ai aj ak al kj an ao ap he kk kl kh km kn ko kp kq s kr ks kt ku kv kw kx u ky kz la"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M3 12a9 9 0 1 1 18 0 9 9 0 0 1-18 0zm9-10a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm3.38 10.42l-4.6 3.06a.5.5 0 0 1-.78-.41V8.93c0-.4.45-.63.78-.41l4.6 3.06c.3.2.3.64 0 .84z" fill="currentColor"></path></svg><div class="j i d"><p class="be b bf z hb">Listen</p></div></button></div></div></div></div></div></div></div></div><div class="bl" aria-hidden="false" aria-describedby="postFooterSocialMenu" aria-labelledby="postFooterSocialMenu"><div><div class="bl" aria-hidden="false"><button class="af jn ah ai aj ak al kj an ao ap he kk kl kh km kn ko kp kq s kr ks kt ku kv kw kx u ky kz la"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M15.22 4.93a.42.42 0 0 1-.12.13h.01a.45.45 0 0 1-.29.08.52.52 0 0 1-.3-.13L12.5 3v7.07a.5.5 0 0 1-.5.5.5.5 0 0 1-.5-.5V3.02l-2 2a.45.45 0 0 1-.57.04h-.02a.4.4 0 0 1-.16-.3.4.4 0 0 1 .1-.32l2.8-2.8a.5.5 0 0 1 .7 0l2.8 2.8a.42.42 0 0 1 .07.5zm-.1.14zm.88 2h1.5a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-11a2 2 0 0 1-2-2v-10a2 2 0 0 1 2-2H8a.5.5 0 0 1 .35.14c.1.1.15.22.15.35a.5.5 0 0 1-.15.35.5.5 0 0 1-.35.15H6.4c-.5 0-.9.4-.9.9v10.2a.9.9 0 0 0 .9.9h11.2c.5 0 .9-.4.9-.9V8.96c0-.5-.4-.9-.9-.9H16a.5.5 0 0 1 0-1z" fill="currentColor"></path></svg><div class="j i d"><p class="be b bf z hb">Share</p></div></button></div></div></div></div></div></div></div></div></div><p id="5f9a" class="pw-post-body-paragraph lb lc ev ld b le lf lg lh li lj lk ll lm ln lo lp lq lr ls lt lu lv lw lx ly eo bj">In his first official comment since his departure from ATMTA, former <a class="lz hc ma" href="https://medium.com/u/5ed69ff9cfb0?source=post_page-----eb37dc95ff3--------------------------------" rel="noopener" target="_blank">Star Atlas</a> Chief Revenue Officer Pablo Quiroga speaks on his time with the company.</p><figure class="me mf mg mh mi mj mb mc paragraph-image"><div class="mb mc md"><picture><source srcSet="https://miro.medium.com/v2/resize:fit:640/format:webp/0*DwllziljX_Zj_d3E.png 640w, https://miro.medium.com/v2/resize:fit:720/format:webp/0*DwllziljX_Zj_d3E.png 720w, https://miro.medium.com/v2/resize:fit:750/format:webp/0*DwllziljX_Zj_d3E.png 750w, https://miro.medium.com/v2/resize:fit:786/format:webp/0*DwllziljX_Zj_d3E.png 786w, https://miro.medium.com/v2/resize:fit:828/format:webp/0*DwllziljX_Zj_d3E.png 828w, https://miro.medium.com/v2/resize:fit:1100/format:webp/0*DwllziljX_Zj_d3E.png 1100w, https://miro.medium.com/v2/resize:fit:1400/format:webp/0*DwllziljX_Zj_d3E.png 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/v2/resize:fit:640/0*DwllziljX_Zj_d3E.png 640w, https://miro.medium.com/v2/resize:fit:720/0*DwllziljX_Zj_d3E.png 720w, https://miro.medium.com/v2/resize:fit:750/0*DwllziljX_Zj_d3E.png 750w, https://miro.medium.com/v2/resize:fit:786/0*DwllziljX_Zj_d3E.png 786w, https://miro.medium.com/v2/resize:fit:828/0*DwllziljX_Zj_d3E.png 828w, https://miro.medium.com/v2/resize:fit:1100/0*DwllziljX_Zj_d3E.png 1100w, https://miro.medium.com/v2/resize:fit:1400/0*DwllziljX_Zj_d3E.png 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px"/><img alt="" class="bg mk ml c" width="700" height="700" loading="eager" role="presentation"/></picture></div></figure><figure class="me mf mg mh mi mj"><div class="mm hp l go"><div class="mn mo l"></div></div></figure><blockquote class="mp mq mr"><p id="4521" class="lb lc ms ld b le lf lg lh li lj lk ll mt ln lo lp mu lr ls lt mv lv lw lx ly eo bj">Dear Star Atlas Community, I hope this message finds you all in good spirits as we embark on the next chapter of our journey together. It is with mixed emotions that I write to you today, for it is time for me to officially address the departure from my role as CRO at ATMTA.</p><p id="962d" class="lb lc ms ld b le lf lg lh li lj lk ll mt ln lo lp mu lr ls lt mv lv lw lx ly eo bj">This situation was not easy, but it is one that I believe is necessary.</p><p id="a81c" class="lb lc ms ld b le lf lg lh li lj lk ll mt ln lo lp mu lr ls lt mv lv lw lx ly eo bj">First and foremost, I want to express my deepest gratitude to each and every one of you. The passion and dedication you have shown in building Star Atlas into what it is today is truly awe-inspiring.</p><p id="4841" class="lb lc ms ld b le lf lg lh li lj lk ll mt ln lo lp mu lr ls lt mv lv lw lx ly eo bj">Your commitment to the vision of a decentralized metaverse and your tireless efforts to push the boundaries of what is possible have made this project a force to be reckoned with.</p><p id="f606" class="lb lc ms ld b le lf lg lh li lj lk ll mt ln lo lp mu lr ls lt mv lv lw lx ly eo bj">As I reflect on our journey together, I am filled with immense pride. We have come so far, overcoming obstacles and challenges that seemed insurmountable. But true progress is not measured solely by the distance traveled; it is also marked by the willingness to adapt and evolve.</p><p id="2523" class="lb lc ms ld b le lf lg lh li lj lk ll mt ln lo lp mu lr ls lt mv lv lw lx ly eo bj">This is a project that has the opportunity to revolutionize the way we interact, create, and transact within virtual worlds. It is a vision that transcends borders, cultures, and limitations. And it is a vision that will endure, regardless of who is at the helm.</p><p id="176c" class="lb lc ms ld b le lf lg lh li lj lk ll mt ln lo lp mu lr ls lt mv lv lw lx ly eo bj">I have always believed that the true strength of a visionary lies in their ability to inspire others to dream, create, and achieve greatness. And it is my hope that I have been able to ignite that spark within each and every one of you.</p><p id="e669" class="lb lc ms ld b le lf lg lh li lj lk ll mt ln lo lp mu lr ls lt mv lv lw lx ly eo bj">The legacy of Star Atlas is not tied to any one individual; it is a collective endeavor that belongs to all of us. It is a testament to the power of community, collaboration, and shared purpose.</p><p id="3c4c" class="lb lc ms ld b le lf lg lh li lj lk ll mt ln lo lp mu lr ls lt mv lv lw lx ly eo bj">I implore you to continue pushing the boundaries of what is possible. Embrace change, for it is the catalyst for growth and innovation. Cherish the relationships you have built within this community, for they are the foundation upon which Star Atlas stands.</p><p id="c5d4" class="lb lc ms ld b le lf lg lh li lj lk ll mt ln lo lp mu lr ls lt mv lv lw lx ly eo bj">And above all else, never lose sight of the awe-inspiring potential that lies within each and every one of you.</p><p id="fb53" class="lb lc ms ld b le lf lg lh li lj lk ll mt ln lo lp mu lr ls lt mv lv lw lx ly eo bj">Be light, Pablo</p></blockquote><p id="1f8b" class="pw-post-body-paragraph lb lc ev ld b le lf lg lh li lj lk ll lm ln lo lp lq lr ls lt lu lv lw lx ly eo bj">— Pablo Quiroga, former Chief Revenue Officer of ATMTA, Star Atlas game developer</p><h1 id="1dee" class="mw mx ev be my mz na nb nc nd ne nf ng nh ni nj nk nl nm nn no np nq nr ns nt bj">Quiroa Speaks After Departure</h1><p id="7388" class="pw-post-body-paragraph lb lc ev ld b le nu lg lh li nv lk ll lm nw lo lp lq nx ls lt lu ny lw lx ly eo bj">Quiroga’s tenure as the Chief Revnue Officer of ATMTA officially ended on March 31st, 2023. However, the official public <a class="af nz" rel="noopener" href="/the-hologram/atmta-employees-speak-on-quiroga-departure-fd8197c23ca1">announcement</a> was made on April, 7th by CEO Michael Wagner. Quiroga, along with Wagner, was among the four founders of Star Atlas.</p><p id="6689" class="pw-post-body-paragraph lb lc ev ld b le lf lg lh li lj lk ll lm ln lo lp lq lr ls lt lu lv lw lx ly eo bj">Quiroga’s public comments did not address previously reported allegations of workplace grievances or internal creative differences amongst the team. Quiroga’s message was addressed to the Star Atlas community, which have been long supporters of both Quiroga and Star Atlas.</p><p id="3e3b" class="pw-post-body-paragraph lb lc ev ld b le lf lg lh li lj lk ll lm ln lo lp lq lr ls lt lu lv lw lx ly eo bj">His message embraced a harmonic tone and spoke to the testament of the power of the (Star Atlas) community.</p><p id="7ab0" class="pw-post-body-paragraph lb lc ev ld b le lf lg lh li lj lk ll lm ln lo lp lq lr ls lt lu lv lw lx ly eo bj">It remains unclear <a class="af nz" rel="noopener" href="/the-hologram/atmta-insider-spills-on-quiroga-departure-e76045f906d8">the reasoning behind Quiroga’s sudden departure</a> from ATMTA. Other than the official comment by Wagner, ATMTA has declined to comment further on the matter.</p></div></div></div><div class="ab ca oa ob oc od" role="separator"><span class="oe bx bl of og oh"></span><span class="oe bx bl of og oh"></span><span class="oe bx bl of og"></span></div><div class="eo ep eq er es"><div class="ab ca"><div class="ch bg dx dy dz ea"><h1 id="190f" class="mw mx ev be my mz oi nb nc nd oj nf ng nh ok nj nk nl ol nn no np om nr ns nt bj">About the Author</h1><p id="42f7" class="pw-post-body-paragraph lb lc ev ld b le nu lg lh li nv lk ll lm nw lo lp lq nx ls lt lu ny lw lx ly eo bj"><a class="af nz" href="https://medium.com/u/41e0c5b141f1?source=post_page-----4922901fb224--------------------------------" rel="noopener">Krigs</a> is a pioneer in the world of Star Atlas, having founded The Hologram News Network — an independent meta-news organization that keeps players up to date on all developments regarding Star Atlas. An ardent supporter of emerging technologies, Krigs has been covering this game for over a year and believes passionately in their power to revolutionize our collective gaming experience.</p><p id="4ed9" class="pw-post-body-paragraph lb lc ev ld b le lf lg lh li lj lk ll lm ln lo lp lq lr ls lt lu lv lw lx ly eo bj">Follow on Social Media:</p><p id="0068" class="pw-post-body-paragraph lb lc ev ld b le lf lg lh li lj lk ll lm ln lo lp lq lr ls lt lu lv lw lx ly eo bj"><a class="af nz" href="https://open.spotify.com/show/2mxndrDW6yPfpS350ijzjt?si=ec7c717f998240d6" rel="noopener ugc nofollow" target="_blank">Podcast</a> | <a class="af nz" href="https://www.youtube.com/channel/UCDa-YxgNG6A9xpH1qyP0OaQ" rel="noopener ugc nofollow" target="_blank">YouTube</a> | <a class="af nz" href="https://twitter.com/home" rel="noopener ugc nofollow" target="_blank">Twitter</a> | <a class="af nz" href="https://twitter.com/home" rel="noopener ugc nofollow" target="_blank">Instagram</a> | <a class="af nz" href="https://thehologram.io/" rel="noopener ugc nofollow" target="_blank">Web</a></p><h1 id="0f6d" class="mw mx ev be my mz na nb nc nd ne nf ng nh ni nj nk nl nm nn no np nq nr ns nt bj">About The Hologram</h1><p id="37c7" class="pw-post-body-paragraph lb lc ev ld b le nu lg lh li nv lk ll lm nw lo lp lq nx ls lt lu ny lw lx ly eo bj"><a class="af nz" href="https://medium.com/the-hologram" rel="noopener">The Hologram</a> is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.</p><p id="9ef9" class="pw-post-body-paragraph lb lc ev ld b le lf lg lh li lj lk ll lm ln lo lp lq lr ls lt lu lv lw lx ly eo bj">The Hologram is not endorsed or paid by the <a class="af nz" href="https://staratlas.com/" rel="noopener ugc nofollow" target="_blank">Star Atlas</a> team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.</p></div></div></div></div></section></div></div></article><div class="ab ca"><div class="ch bg dx dy dz ea"></div></div></div><div class="ab ca"><div class="ch bg dx dy dz ea"><div class="on oo ab hk"><div class="op ab"><a class="oq ax am ao" rel="noopener follow" href="/tag/star-atlas?source=post_page-----eb37dc95ff3---------------star_atlas-----------------"><div class="or go cw os ot ou be b bf z bj ov">Star Atlas</div></a></div></div></div></div><div class="l"></div><footer class="ow ox oy oz pa pb pc pd pe ab q pf gs c"><div class="l ae"><div class="ab ca"><div class="ch bg dx dy dz ea"><div class="ab co pg"><div class="ab q jh"><div class="p
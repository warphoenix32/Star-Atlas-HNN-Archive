import("https://cdn-client.medium.com/lite/assets/entry.client-DjwnChmdod.js");</script><!--$--><script>window.__reactRouterContext.streamController.enqueue("[{\"_1\":2,\"_3\":-5,\"_4\":-5},\"loaderData\",{\"_5\":6},\"actionData\",\"errors\",\"routes/pages/entity-routes/ShowEntityPost\",{}]\n");</script><!--$--><script>window.__reactRouterContext.streamController.close();</script><!--/$--><!--/$--><script>window.__APOLLO_STATE__ = {"ROOT_QUERY":{"__typename":"Query","viewer":null,"postResult({\"id\":\"2a3f7753e630\"})":{"__ref":"Post:2a3f7753e630"}},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","customDomainState":null,"hasSubdomain":false,"username":"krigsfoniks","name":"Krigs","newsletterV3":{"__ref":"NewsletterV3:85fc9c436e2e"},"linkedAccounts":{"__ref":"LinkedAccounts:41e0c5b141f1"},"isSuspended":false,"verifications":{"__typename":"VerifiedInfo","isBookAuthor":false},"imageId":"1*pVxyLAandIa00EX6ZGRERw.png","socialStats":{"__typename":"SocialStats","followerCount":247,"followingCount":44,"collectionFollowingCount":4},"bio":"Founder | Crypto | Star Atlas |","allowNotes":true,"membership":{"__ref":"Membership:f4e36c93-9f55-4329-8ac8-ff530f7d276d"},"viewerEdge":{"__ref":"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_fce9b6c05e80"},"twitterScreenName":"Hologram_News"},"Collection:4d89daa6ae31":{"__typename":"Collection","id":"4d89daa6ae31","domain":null,"slug":"the-hologram","googleAnalyticsId":null,"name":"The Hologram","avatar":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg"},"description":"Daily Blockchain gaming news by The Hologram. Get the trusted information you need to stay one step ahead of your competition.","subscriberCount":155,"latestPostsConnection({\"paging\":{\"limit\":1}})":{"__typename":"PostConnection","posts":[{"__ref":"Post:68924ca3781d"}]},"compatV3":{"__ref":"Publication:4d89daa6ae31"},"viewerEdge":{"__ref":"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_fce9b6c05e80"},"twitterUsername":"Hologram_News","facebookPageId":null},"Post:68924ca3781d":{"__typename":"Post","id":"68924ca3781d","firstPublishedAt":1719624868272,"creator":{"__ref":"User:41e0c5b141f1"},"collection":{"__ref":"Collection:4d89daa6ae31"},"isSeries":false,"mediumUrl":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fthe-red-moon-gala-recap-68924ca3781d","sequence":null,"uniqueSlug":"the-red-moon-gala-recap-68924ca3781d"},"Publication:4d89daa6ae31":{"__typename":"Publication","id":"4d89daa6ae31","theme":{"__typename":"PublicationTheme","accentColor":{"__typename":"ColorValue","rgb":"#000000"}}},"LinkedAccounts:41e0c5b141f1":{"__typename":"LinkedAccounts","mastodon":null,"id":"41e0c5b141f1"},"NewsletterV3:85fc9c436e2e":{"__typename":"NewsletterV3","id":"85fc9c436e2e","type":"NEWSLETTER_TYPE_AUTHOR","slug":"41e0c5b141f1","name":"41e0c5b141f1","collection":null,"user":{"__ref":"User:41e0c5b141f1"}},"Paragraph:ff5aac1e627c_0":{"__typename":"Paragraph","id":"ff5aac1e627c_0","name":"cd8f","type":"H3","href":null,"layout":null,"metadata":null,"text":"Star Atlas SAGE Labs Sneak Peak","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_1":{"__typename":"Paragraph","id":"ff5aac1e627c_1","name":"d4ee","type":"P","href":null,"layout":null,"metadata":null,"text":"In this article, we recap the latest updates from Star Atlas, specifically gameplay updates on SAGE Labs Mining, Crafting, Scanning and more. Sneak peaks at the SAGE map, resources, and over $1 million in prizes to come!","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":50,"end":60,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_2":{"__typename":"Paragraph","id":"ff5aac1e627c_2","name":"1d84","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__typename":"ImageMetadata","id":"1*X-vzsTiHN7UeLU7WNwW8_g.png","originalHeight":1296,"originalWidth":2559,"focusPercentX":null,"focusPercentY":null,"alt":null},"text":"SAGE Labs — ATMTA Inc","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_3":{"__typename":"Paragraph","id":"ff5aac1e627c_3","name":"a53a","type":"H3","href":null,"layout":null,"metadata":null,"text":"Sage LABS","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_4":{"__typename":"Paragraph","id":"ff5aac1e627c_4","name":"81ec","type":"P","href":null,"layout":null,"metadata":null,"text":"This past Wednesday, the Star Atlas Brew Boys Santi, Dominic, and Jose sat down with Head of Economy Chris Smith and CEO Michael Wagner to discuss “What is Sage LABS?” and to give a little sneak peak at the mechanics behind the upcoming 2D lite game.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_5":{"__typename":"Paragraph","id":"ff5aac1e627c_5","name":"ac67","type":"P","href":null,"layout":null,"metadata":null,"text":"To kick things off, Chris described SAGE Labs as a limited UI version of Star Atlas Starbased, in essence, an extraction and crafting game.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_6":{"__typename":"Paragraph","id":"ff5aac1e627c_6","name":"c334","type":"H4","href":null,"layout":null,"metadata":null,"text":"What Economic features are going to be in SAGE Labs?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_7":{"__typename":"Paragraph","id":"ff5aac1e627c_7","name":"01a1","type":"P","href":null,"layout":null,"metadata":null,"text":"Per the Chris and6 team, players will have access to Central Space Stations and Faction Starbases at which they will be able compile fleets for adventures out onto the SAGE Labs Map.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_8":{"__typename":"Paragraph","id":"ff5aac1e627c_8","name":"9fc3","type":"P","href":null,"layout":null,"metadata":null,"text":"In SAGE Labs, fleets will generally perform functions of crafting, scanning, or mining.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_9":{"__typename":"Paragraph","id":"ff5aac1e627c_9","name":"89cd","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Crafting is conducted at either a Central Space Station or Starbase.51 different systems in SAGE Labs.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":9,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_10":{"__typename":"Paragraph","id":"ff5aac1e627c_10","name":"8b09","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Scanning can be done in any one of the 51 star sectors of the map. Fleets will scan for Survey Data Units (SDUs). More on that later!","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":9,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_11":{"__typename":"Paragraph","id":"ff5aac1e627c_11","name":"9718","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Lastly, Mining will be conducted at asteroid fields within star sectors. Note that not every star sector will have an asteroid field.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":8,"end":15,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_12":{"__typename":"Paragraph","id":"ff5aac1e627c_12","name":"ab22","type":"P","href":null,"layout":null,"metadata":null,"text":"Speaking of the SAGE Labs map, here’s a sneak preview of the map and user interface.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_13":{"__typename":"Paragraph","id":"ff5aac1e627c_13","name":"bd2e","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__typename":"ImageMetadata","id":"1*e_9J_rr0FsxafrcDwXQCzg.jpeg","originalHeight":809,"originalWidth":1216,"focusPercentX":null,"focusPercentY":null,"alt":null},"text":"Source: ATMTA Inc","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_14":{"__typename":"Paragraph","id":"ff5aac1e627c_14","name":"248f","type":"P","href":null,"layout":null,"metadata":null,"text":"As you can see from the map, there are 36 Sectors for the Medium Risk Zone with an additional 15 sectors for the three Faction Zones.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_15":{"__typename":"Paragraph","id":"ff5aac1e627c_15","name":"1ea8","type":"H4","href":null,"layout":null,"metadata":null,"text":"Mining and Travel","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_16":{"__typename":"Paragraph","id":"ff5aac1e627c_16","name":"de26","type":"P","href":null,"layout":null,"metadata":null,"text":"In order to extract the valuable materials needed to craft in SAGE Labs, fleets will need to leave the safety of their star bases to discover asteroids in space.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_17":{"__typename":"Paragraph","id":"ff5aac1e627c_17","name":"3606","type":"P","href":null,"layout":null,"metadata":null,"text":"Players must use good planning when traveling out of a star base as traveling will consume varying levels of fuel and food in transit. However, with risk comes reward. The farther you get away from star base, the better materials you will find in terms of quantity and rarity. (Note that in In SAGE labs, only fuel, food, and ammo will be used. Toolkits will not be used since there are no combat loops.)","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_18":{"__typename":"Paragraph","id":"ff5aac1e627c_18","name":"30df","type":"P","href":null,"layout":null,"metadata":null,"text":"However, should a player fail to plan properly and run out of fuel, the costs could potentially be significant. If a fleet runs out of fuel, players will need to pay an ATLAS fee to “respawn” at a star base (Don’t worry, ships aren’t destroyed in SAGE Labs).","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_19":{"__typename":"Paragraph","id":"ff5aac1e627c_19","name":"56ee","type":"P","href":null,"layout":null,"metadata":null,"text":"But that’s not all! Any loot or resources collected by that fleet will also be dropped from the fleet’s inventory and lost. Plan accordingly!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_20":{"__typename":"Paragraph","id":"ff5aac1e627c_20","name":"7288","type":"P","href":null,"layout":null,"metadata":null,"text":"Mining at an Asteroid","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":21,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_21":{"__typename":"Paragraph","id":"ff5aac1e627c_21","name":"a762","type":"P","href":null,"layout":null,"metadata":null,"text":"Mining is a relatively simple activity in SAGE Labs. Once you find an asteroid, players will be able choose to mine what available resources an asteroid has.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_22":{"__typename":"Paragraph","id":"ff5aac1e627c_22","name":"9a95","type":"P","href":null,"layout":null,"metadata":null,"text":"The team has mentioned several times that there will only be 9 of the raw resources available in SAGE Labs to start.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_23":{"__typename":"Paragraph","id":"ff5aac1e627c_23","name":"6aa3","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__typename":"ImageMetadata","id":"1*JWP-yXMrkReBw7saD0MNwQ.png","originalHeight":1215,"originalWidth":2400,"focusPercentX":null,"focusPercentY":null,"alt":null},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_24":{"__typename":"Paragraph","id":"ff5aac1e627c_24","name":"ad77","type":"P","href":null,"layout":null,"metadata":null,"text":"These resources are:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_25":{"__typename":"Paragraph","id":"ff5aac1e627c_25","name":"8cc8","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Copper","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_26":{"__typename":"Paragraph","id":"ff5aac1e627c_26","name":"21d1","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Iron","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_27":{"__typename":"Paragraph","id":"ff5aac1e627c_27","name":"1cc2","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Arco","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_28":{"__typename":"Paragraph","id":"ff5aac1e627c_28","name":"2aa4","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Rochinol","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_29":{"__typename":"Paragraph","id":"ff5aac1e627c_29","name":"33ff","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Diamond","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_30":{"__typename":"Paragraph","id":"ff5aac1e627c_30","name":"2268","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Lumanite","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_31":{"__typename":"Paragraph","id":"ff5aac1e627c_31","name":"1af9","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Hydrogen","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_32":{"__typename":"Paragraph","id":"ff5aac1e627c_32","name":"b8ea","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Carbon","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_33":{"__typename":"Paragraph","id":"ff5aac1e627c_33","name":"1484","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Biomass","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_34":{"__typename":"Paragraph","id":"ff5aac1e627c_34","name":"623f","type":"P","href":null,"layout":null,"metadata":null,"text":"Mining consumes ammo and food at fixed rates and gathers at fixed rates, all calculated based on the ships that you are using to mine. Some ships, like mining ships and bombing ships are more efficient at mining.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_35":{"__typename":"Paragraph","id":"ff5aac1e627c_35","name":"83e5","type":"P","href":null,"layout":null,"metadata":null,"text":"Additionally, players can be selective as to how they spend their time mining. Cargo capacity will dictate how much a player can haul back to a station, but that doesn't mean a fleet has to fill up its cargo with one asset. Players will have the ability to interrupt the mining processes to change what is being mined.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_36":{"__typename":"Paragraph","id":"ff5aac1e627c_36","name":"51cd","type":"P","href":null,"layout":null,"metadata":null,"text":"Once a fleet’s cargo hold is full, it’s time to head back to a star base to craft or sell your goods!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_37":{"__typename":"Paragraph","id":"ff5aac1e627c_37","name":"5995","type":"H4","href":null,"layout":null,"metadata":null,"text":"Crafting","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":8,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_38":{"__typename":"Paragraph","id":"ff5aac1e627c_38","name":"31df","type":"P","href":null,"layout":null,"metadata":null,"text":"Crafting is, and will be, one of the more complex systems in SAGE Labs and the future robust SAGE version. Even in this first iteration, there are multiple recipes to craft with a 3 layer deep crafting system. In future updates, crafting can have closer to 10 layers before reaching a final product.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_39":{"__typename":"Paragraph","id":"ff5aac1e627c_39","name":"ae89","type":"P","href":null,"layout":null,"metadata":null,"text":"During the Atlas Brews, Chris revealed some of the items that will be craftable in SAGE Labs in addition to the standard R4 of Fuel, Ammo, Toolkits, and Food.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_40":{"__typename":"Paragraph","id":"ff5aac1e627c_40","name":"86ac","type":"P","href":null,"layout":null,"metadata":null,"text":"Such items like radiation absorbers, frameworks, crystal lattice, particle accelerators are but a few of the items available.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_41":{"__typename":"Paragraph","id":"ff5aac1e627c_41","name":"0825","type":"P","href":null,"layout":null,"metadata":null,"text":"Chris also noted that each crafting recipe has a hidden associated value number assigned to it that helps keep the recipes balanced across gameplay.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_42":{"__typename":"Paragraph","id":"ff5aac1e627c_42","name":"d4e7","type":"P","href":null,"layout":null,"metadata":null,"text":"Crafting will also have a small ATLAS fee cost as an economic sink.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_43":{"__typename":"Paragraph","id":"ff5aac1e627c_43","name":"25b8","type":"P","href":null,"layout":null,"metadata":null,"text":"Crafting Mechanic","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":17,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_44":{"__typename":"Paragraph","id":"ff5aac1e627c_44","name":"0ef9","type":"P","href":null,"layout":null,"metadata":null,"text":"During the discussion on Crafting, Michael Wagner went through an explanation of how Crafting will work in SAGE. In the process, they revealed that the conversion of Biomass into Food is a 1:1 ratio. They also revealed that the time to complete a single Food craft is 1 second.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_45":{"__typename":"Paragraph","id":"ff5aac1e627c_45","name":"597c","type":"P","href":null,"layout":null,"metadata":null,"text":"Wagner also revealed that the speed of a crafting job is affected by the number of crew assigned to a job.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":41,"end":54,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_46":{"__typename":"Paragraph","id":"ff5aac1e627c_46","name":"e435","type":"P","href":null,"layout":null,"metadata":null,"text":"For example — 100 Food takes 100 total work seconds. A single crew assigned to the job would take 100 seconds to complete the order. However, if 100 crew were assigned to the job, the order would be completed in 1 second.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_47":{"__typename":"Paragraph","id":"ff5aac1e627c_47","name":"e67c","type":"P","href":null,"layout":null,"metadata":null,"text":"(Crafted Item Quantity \u002F Assigned Crew) x Base Item Craft Time = Total Job Craft Time","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":85,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_48":{"__typename":"Paragraph","id":"ff5aac1e627c_48","name":"510c","type":"P","href":null,"layout":null,"metadata":null,"text":"Note that crafting mechanics could be subject to change in the future.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":70,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_49":{"__typename":"Paragraph","id":"ff5aac1e627c_49","name":"6bcd","type":"H4","href":null,"layout":null,"metadata":null,"text":"Scanning and SDUs","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":17,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_50":{"__typename":"Paragraph","id":"ff5aac1e627c_50","name":"9ad4","type":"P","href":null,"layout":null,"metadata":null,"text":"During the Atlas Brew, it was shared that there would be a scanning function in SAGE Labs similar to Escape Velocity. Like in EV, players will perform scan functions in search of loot — however, this loot now comes in the form of Survey Data Units or SDUs.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_51":{"__typename":"Paragraph","id":"ff5aac1e627c_51","name":"9194","type":"P","href":null,"layout":null,"metadata":null,"text":"But what are SDUS?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_52":{"__typename":"Paragraph","id":"ff5aac1e627c_52","name":"971f","type":"P","href":null,"layout":null,"metadata":null,"text":"First, lets take a quick look at why SDUs were included and implemented. According to Chris, SDUs were conceived as a way to create gameplay balance and mechanics that were accessible to players with smaller fleets. Knowing that players with large mining fleets would eventually dominate the Mining and Crafting game, SDUs are an attempt at creating equity at the lower player levels.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_53":{"__typename":"Paragraph","id":"ff5aac1e627c_53","name":"00cc","type":"P","href":null,"layout":null,"metadata":null,"text":"SDUs are important because they are required to craft Golden Tickets and are required to redeem items from the SAGE Labs loot table.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":132,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_54":{"__typename":"Paragraph","id":"ff5aac1e627c_54","name":"9c31","type":"P","href":null,"layout":null,"metadata":null,"text":"How to get SDUs","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":15,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_55":{"__typename":"Paragraph","id":"ff5aac1e627c_55","name":"893c","type":"P","href":null,"layout":null,"metadata":null,"text":"As previously mentioned, SDUs can be found by scanning sectors of the map. There are some key things to know about your chances on finding these unique items.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_56":{"__typename":"Paragraph","id":"ff5aac1e627c_56","name":"6d2e","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Players have a 25% of finding SDUs on a scan attempt if an SDU has not been found within that sector within the previous 2 minutes.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":34,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":53,"end":56,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_57":{"__typename":"Paragraph","id":"ff5aac1e627c_57","name":"1830","type":"ULI","href":null,"layout":null,"metadata":null,"text":"If a scan is successful, a number of SDUs will be rewarded based on the number and size of Ships used to scan. 1 XX-Small ship yields 1 SDU. 1 X-Small ship yields 2 SDUs. The number of SDUs discovered by Ship size increases linearly.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":25,"end":109,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_58":{"__typename":"Paragraph","id":"ff5aac1e627c_58","name":"f16d","type":"ULI","href":null,"layout":null,"metadata":null,"text":"SDU loot spawns have a cap of 10. This is the gating mechanism that limits large fleet owners from massing SDUs.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":32,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_59":{"__typename":"Paragraph","id":"ff5aac1e627c_59","name":"3af9","type":"P","href":null,"layout":null,"metadata":null,"text":"What are SDUs For?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_60":{"__typename":"Paragraph","id":"ff5aac1e627c_60","name":"7aea","type":"P","href":null,"layout":null,"metadata":null,"text":"SDUs are used in three ways.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_61":{"__typename":"Paragraph","id":"ff5aac1e627c_61","name":"83e6","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Can be traded\u002Fsold on the Galactic Market to other players","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_62":{"__typename":"Paragraph","id":"ff5aac1e627c_62","name":"5ead","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Used in the redemption process when claiming SAGE Labs Loot in exchange for crafted items.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_63":{"__typename":"Paragraph","id":"ff5aac1e627c_63","name":"f956","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Used in the process of crafting Golden Tickets","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_64":{"__typename":"Paragraph","id":"ff5aac1e627c_64","name":"6218","type":"P","href":null,"layout":null,"metadata":null,"text":"As you can see, SDUs have multiple purposes and will likely be quite valuable in game.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_65":{"__typename":"Paragraph","id":"ff5aac1e627c_65","name":"f9af","type":"H3","href":null,"layout":null,"metadata":null,"text":"Golden Tickets and 1.2Mil Giveaway","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":34,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_66":{"__typename":"Paragraph","id":"ff5aac1e627c_66","name":"f1da","type":"P","href":null,"layout":null,"metadata":null,"text":"To create a full cycle economic loop for SAGE Labs, the team has implemented a 8-week prize raffle equating to a total of $1.2 million dollars.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_67":{"__typename":"Paragraph","id":"ff5aac1e627c_67","name":"997d","type":"P","href":null,"layout":null,"metadata":null,"text":"Every week for 8 weeks, $150K worth of prizes will be given away to random winners using the Golden Ticket raffle.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_68":{"__typename":"Paragraph","id":"ff5aac1e627c_68","name":"aad4","type":"P","href":null,"layout":null,"metadata":null,"text":"To enter, players will need to obtain a Golden Ticket, either through crafting or purchase from other players, and enter it into a weekly contest.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_69":{"__typename":"Paragraph","id":"ff5aac1e627c_69","name":"8575","type":"P","href":null,"layout":null,"metadata":null,"text":"Players can enter a weekly prize pool using multiple golden tickets. However, its very important to note that Golden Tickets are used upon entry and do not carry over from week to week.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":79,"end":185,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_70":{"__typename":"Paragraph","id":"ff5aac1e627c_70","name":"326b","type":"P","href":null,"layout":null,"metadata":null,"text":"Each week, multiple prizes will be drawn from that weeks pool of entered Golden Tickets.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_71":{"__typename":"Paragraph","id":"ff5aac1e627c_71","name":"499e","type":"H3","href":null,"layout":null,"metadata":null,"text":"Other SAGE Labs Notables","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_72":{"__typename":"Paragraph","id":"ff5aac1e627c_72","name":"65e0","type":"H4","href":null,"layout":null,"metadata":null,"text":"Pay Solana Fees in Atlas","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":24,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_73":{"__typename":"Paragraph","id":"ff5aac1e627c_73","name":"78b1","type":"P","href":null,"layout":null,"metadata":null,"text":"Players will have the option to pay their in game Solana transaction fees using ATLAS.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_74":{"__typename":"Paragraph","id":"ff5aac1e627c_74","name":"f887","type":"P","href":null,"layout":null,"metadata":null,"text":"Star Atlas has developed a revolutionary system by which they now act as in intermediary for the payment of the transaction fee, essentially paying SOL to the network while collecting ATLAS in return from the player.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_75":{"__typename":"Paragraph","id":"ff5aac1e627c_75","name":"b8a9","type":"H4","href":null,"layout":null,"metadata":null,"text":"Referral System","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_76":{"__typename":"Paragraph","id":"ff5aac1e627c_76","name":"2d10","type":"P","href":null,"layout":null,"metadata":null,"text":"The team also touched upon the newly revamped player referral system","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_77":{"__typename":"Paragraph","id":"ff5aac1e627c_77","name":"c157","type":"ULI","href":null,"layout":null,"metadata":null,"text":"The nws system is now Web 3 based. Any referred player that makes a a primary purchase on the marketplace, 25% of that value is granted to the referring player.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_78":{"__typename":"Paragraph","id":"ff5aac1e627c_78","name":"a0f0","type":"ULI","href":null,"layout":null,"metadata":null,"text":"If a referred player makes a secondary market purchase, 25% of the net fees collected goes to the referring player.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_79":{"__typename":"Paragraph","id":"ff5aac1e627c_79","name":"40c7","type":"P","href":null,"layout":null,"metadata":null,"text":"Every $500 a referee spends in the galactic marketplace will earn the referring player a golden ticket.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_80":{"__typename":"Paragraph","id":"ff5aac1e627c_80","name":"f1b4","type":"H3","href":null,"layout":null,"metadata":null,"text":"*BONUS* Pearce X4 UE5 Skin Update Photos","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":40,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_81":{"__typename":"Paragraph","id":"ff5aac1e627c_81","name":"61ca","type":"P","href":null,"layout":null,"metadata":null,"text":"The team also released a new look at Unreal Engine 5 development of the limited Pearce X4 skins.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_82":{"__typename":"Paragraph","id":"ff5aac1e627c_82","name":"77cc","type":"IMG","href":null,"layout":"OUTSET_ROW","metadata":{"__typename":"ImageMetadata","id":"1*ezcI8izuush-ebnPbo8PWw.jpeg","originalHeight":910,"originalWidth":1304,"focusPercentX":null,"focusPercentY":null,"alt":null},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_83":{"__typename":"Paragraph","id":"ff5aac1e627c_83","name":"f21e","type":"IMG","href":null,"layout":"OUTSET_ROW_CONTINUE","metadata":{"__typename":"ImageMetadata","id":"1*W-pV80JCc8TseD3S3IJVig.jpeg","originalHeight":910,"originalWidth":1304,"focusPercentX":null,"focusPercentY":null,"alt":null},"text":"Pearce X4 Blue Tigu and Nanobyte Skins","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:ff5aac1e627c_84":{"__typename":"Paragraph","id":"ff5aac1e627c_84","name":"39f9","type":"IMG","href":null,"layout":"OUTSET_ROW","metadata":{"__typename":"ImageMetadata","id":"1*OKHppG2amNRFY0wwKystHg.jpeg","originalHeight":910,"originalWidth":1304
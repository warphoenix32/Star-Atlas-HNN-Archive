ologram\u002Fwill-star-atlas-give-power-to-the-people-17547ffcbc21","primaryTopic":null,"topics":[],"viewerEdge":{"__ref":"PostViewerEdge:postId:17547ffcbc21-viewerId:lo_1b6a3adbb2d9"},"latestPublishedVersion":"c5c18107f6a2","postResponses":{"__typename":"PostResponses","count":0},"allowResponses":true,"isLimitedState":false,"voterCount":0,"recommenders":[],"isSeries":false,"sequence":null,"uniqueSlug":"will-star-atlas-give-power-to-the-people-17547ffcbc21","title":"Will Star Atlas give Power to the People?","clapCount":0,"pinnedAt":0,"pinnedByCreatorAt":0,"curationEligibleAt":0,"responseDistribution":"NOT_DISTRIBUTED","inResponseToPostResult":null,"inResponseToCatalogResult":null,"pendingCollection":null,"isNewsletter":false,"isAuthorNewsletter":false,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"},{"__ref":"Tag:decentralization"},{"__ref":"Tag:web3"},{"__ref":"Tag:gaming"}],"readingTime":3.824528301886793,"inResponseToEntityType":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1674091048730,"previewContent":{"__typename":"PreviewContent","subtitle":"A reflective look into the political claim of an ever-growing metaverse."},"previewImage":{"__ref":"ImageMetadata:1*Za96oN0lxraxtLh3rrajmg.png"},"isShortform":false,"seoTitle":"","updatedAt":1674091056018,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"isSuspended":false,"responseRootPost":{"__typename":"ResponseRootPost","post":{"__ref":"Post:17547ffcbc21"}},"internalLinks({\"paging\":{\"limit\":8}})":{"__typename":"InternalLinksConnection","items":[]},"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}},"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg","originalWidth":2730,"focusPercentX":48.57142857142857,"focusPercentY":45.19230769230769},"ImageMetadata:1*EWK2g3sZ2CUq9HSp-mKvEA.png":{"__typename":"ImageMetadata","id":"1*EWK2g3sZ2CUq9HSp-mKvEA.png","originalWidth":1024},"PostViewerEdge:postId:17547ffcbc21-viewerId:lo_1b6a3adbb2d9":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:17547ffcbc21-viewerId:lo_1b6a3adbb2d9"},"Paragraph:c5c18107f6a2_0":{"__typename":"Paragraph","id":"c5c18107f6a2_0","name":"33d2","type":"H3","href":null,"layout":null,"metadata":null,"text":"Will Star Atlas give Power to the People?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_1":{"__typename":"Paragraph","id":"c5c18107f6a2_1","name":"da8e","type":"P","href":null,"layout":null,"metadata":null,"text":"A reflective look into the political claim of an ever-growing metaverse.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":72,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_2":{"__typename":"Paragraph","id":"c5c18107f6a2_2","name":"a98f","type":"P","href":null,"layout":null,"metadata":null,"text":"The developing phenomenon known as Star Atlas is a unique and immersive virtual experience that combines the elements of gaming, space exploration, and cryptocurrency. While the game itself is still being developed, its community has grown to a massive size. When you spend any small period of time with the Star Atlas crew, you’ll get accustomed to hearing one very important phrase: “Power to the People”.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":35,"end":45,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_3":{"__typename":"Paragraph","id":"c5c18107f6a2_3","name":"458f","type":"H4","href":null,"layout":null,"metadata":null,"text":"A Brief Look into the Decentralized Past","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_4":{"__typename":"Paragraph","id":"c5c18107f6a2_4","name":"c0bf","type":"P","href":null,"layout":null,"metadata":null,"text":"Giving power to the people seems to echo the overall theme of modern governments and cryptocurrency itself. After all, Bitcoin was originally invented to do just that: To empower individuals with the ability to transact peer-to-peer, in a digital world. As decentralized technology became more widely adopted however, we saw increased efforts to regulate it. In order to protect consumers and prevent illegal activities, an increased demand for digital and financial control was imminent.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*TQyyE0-Y94ipTp-7.png":{"__typename":"ImageMetadata","id":"0*TQyyE0-Y94ipTp-7.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":"Astronaut with coins"},"Paragraph:c5c18107f6a2_5":{"__typename":"Paragraph","id":"c5c18107f6a2_5","name":"dff8","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*TQyyE0-Y94ipTp-7.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_6":{"__typename":"Paragraph","id":"c5c18107f6a2_6","name":"7382","type":"P","href":null,"layout":null,"metadata":null,"text":"However, it’s important to understand that even while regulation will continue to be pushed into the future, Web3 is more resistant to the attempts at centralized control than traditional systems. The balance between regulation and autonomy is an ongoing debate in the Web3 space (and outside of it), and it remains to be seen how it will evolve over time. Just as the internet and social networks developed differently than anticipated, the choices we make now will shape whether or not we achieve the utopia we desire.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":109,"end":195,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_7":{"__typename":"Paragraph","id":"c5c18107f6a2_7","name":"5550","type":"H4","href":null,"layout":null,"metadata":null,"text":"Early Adopter to Disillusioned User","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_8":{"__typename":"Paragraph","id":"c5c18107f6a2_8","name":"fb8a","type":"P","href":null,"layout":null,"metadata":null,"text":"I recall being among the early adopters of Facebook, as the platform was initially only available to individuals with a .edu email address. At the time, the platform was novel and provided an enjoyable experience, primarily focusing on photos, statuses, and tagging friends. It was fun! However, as the platform evolved and expanded, it became clear that the emphasis shifted towards monetization, advertisements, and business features, rather than fostering a sense of community and engagement for users.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":275,"end":286,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_9":{"__typename":"Paragraph","id":"c5c18107f6a2_9","name":"5021","type":"P","href":null,"layout":null,"metadata":null,"text":"In 2017 sociologist Zeynep Tufekci gave a TED talk called “We’re building a dystopia just to make people click on ads”. Facebook, Google, and a plethora of giant tech companies have pushed the advertising business model to destroy the best parts of their companies: The human connections. In order to connect with family and friends, I decreasingly opened Facebook to see pictures and statuses. I did however revert backwards in time to texting or calling.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":42,"end":50,"href":"https:\u002F\u002Fwww.ted.com\u002Ftalks\u002Fzeynep_tufekci_we_re_building_a_dystopia_just_to_make_people_click_on_ads","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":20,"end":34,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":266,"end":287,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*Za96oN0lxraxtLh3rrajmg.png":{"__typename":"ImageMetadata","id":"1*Za96oN0lxraxtLh3rrajmg.png","originalHeight":722,"originalWidth":998,"focusPercentX":null,"focusPercentY":null,"alt":"Spaceship"},"Paragraph:c5c18107f6a2_10":{"__typename":"Paragraph","id":"c5c18107f6a2_10","name":"9fe3","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*Za96oN0lxraxtLh3rrajmg.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_11":{"__typename":"Paragraph","id":"c5c18107f6a2_11","name":"5a6b","type":"H4","href":null,"layout":null,"metadata":null,"text":"What Does this Have to Do with Star Atlas?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_12":{"__typename":"Paragraph","id":"c5c18107f6a2_12","name":"a81d","type":"P","href":null,"layout":null,"metadata":null,"text":"The answer to empowering the people lies in one small truth: When something good happens, it’s because we did something to make it that way. Remember that big problem with social media and how big business sucked all the fun straight out of it? The biggest asset Star Atlas has going for it, is that it’s going to be fun. The business is peer-to-peer and the people will begin to shape the future of this metaverse giant through something called a Decentralized Autonomous Organization known as the Star Atlas DAO.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":499,"end":513,"href":"https:\u002F\u002Fgovern.staratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":448,"end":485,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":61,"end":140,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":300,"end":320,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_13":{"__typename":"Paragraph","id":"c5c18107f6a2_13","name":"80a9","type":"BQ","href":null,"layout":null,"metadata":null,"text":"“One might say that the Star Atlas DAO is the jewel of the Star Atlas crown. It represents the fundamental ethos of the community: giving power to the people while serving as a very entertaining and essential gameplay feature that provides economic incentives and overall project governance.” (Star Atlas Newsroom)","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":294,"end":313,"href":"https:\u002F\u002Fstaratlas.com\u002Fnewsroom\u002Fstar-atlas-news\u002Fthe-star-atlas-dao-the-game-of-polis","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_14":{"__typename":"Paragraph","id":"c5c18107f6a2_14","name":"3ee4","type":"P","href":null,"layout":null,"metadata":null,"text":"As a decentralized organization, Star Atlas can steer away from the dystopian-level mistakes made by previous tech giants. While advertising will still exist in any truly free system, it’s up to each of us to decide what that might look like. Star Atlas is much more than a space game. It has the potential to onboard billions into the metaverse. Regardless of faction, if the time comes that any of you need a lift, there’s always one mud pilot willing to help out. — NotBitcoinCEO","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":469,"end":482,"href":null,"anchorType":"USER","userId":"ad2a3faef607","linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":436,"end":445,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":44,"end":47,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_15":{"__typename":"Paragraph","id":"c5c18107f6a2_15","name":"8c64","type":"P","href":null,"layout":null,"metadata":null,"text":"Would you like to check out the Star Atlas Economics Paper for yourself? Read it here. Also, if you enjoyed this article or would like to hear about something specific in the future, please leave a comment below.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":73,"end":85,"href":"http:\u002F\u002Feconomics-paper.pdf (staratlas.com)","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":32,"end":59,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":183,"end":211,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*FflShAC7xDsfH-N_-IkbyA.png":{"__typename":"ImageMetadata","id":"1*FflShAC7xDsfH-N_-IkbyA.png","originalHeight":496,"originalWidth":1007,"focusPercentX":null,"focusPercentY":null,"alt":"Fisherman"},"Paragraph:c5c18107f6a2_16":{"__typename":"Paragraph","id":"c5c18107f6a2_16","name":"89c2","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*FflShAC7xDsfH-N_-IkbyA.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_17":{"__typename":"Paragraph","id":"c5c18107f6a2_17","name":"f64a","type":"H3","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_18":{"__typename":"Paragraph","id":"c5c18107f6a2_18","name":"af13","type":"P","href":null,"layout":null,"metadata":null,"text":"NotBitcoinCEO is a mud pilot & writer on The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":13,"href":"https:\u002F\u002Fmedium.com\u002F@mudpilot","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":13,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_19":{"__typename":"Paragraph","id":"c5c18107f6a2_19","name":"f5ad","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_20":{"__typename":"Paragraph","id":"c5c18107f6a2_20","name":"1eeb","type":"P","href":null,"layout":null,"metadata":null,"text":"Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Ftwitter.com\u002FHologram_News","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":19,"href":"https:\u002F\u002Fwww.instagram.com\u002Fhologram_news\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":22,"end":25,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c5c18107f6a2_21":{"__typename":"Paragraph","id":"c5c18107f6a2_21","name":"9c5c","type":"H3","href":null,"layout":null,"metadat
VFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:eb37dc95ff3-viewerId:lo_116abac365e6"},"Paragraph:deaaa90a6621_0":{"__typename":"Paragraph","id":"deaaa90a6621_0","name":"b7f7","type":"H3","href":null,"layout":null,"metadata":null,"text":"Former Star Atlas CRO Speaks on Departure","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_1":{"__typename":"Paragraph","id":"deaaa90a6621_1","name":"5f9a","type":"P","href":null,"layout":null,"metadata":null,"text":"In his first official comment since his departure from ATMTA, former Star Atlas Chief Revenue Officer Pablo Quiroga speaks on his time with the company.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":69,"end":79,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*DwllziljX_Zj_d3E.png":{"__typename":"ImageMetadata","id":"0*DwllziljX_Zj_d3E.png","originalHeight":700,"originalWidth":700,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:deaaa90a6621_2":{"__typename":"Paragraph","id":"deaaa90a6621_2","name":"e5dd","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*DwllziljX_Zj_d3E.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:35c1ed9e503b6620ec766abaec7d8efb":{"__typename":"MediaResource","id":"35c1ed9e503b6620ec766abaec7d8efb","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?type=text%2Fhtml&key=a19fcc184b9711e1b4764040d3dc5c07&schema=twitter&url=https%3A\u002F\u002Ftwitter.com\u002Fpabloiquiroga\u002Fstatus\u002F1658836823596990466%3Fs%3D20&image=https%3A\u002F\u002Fi.embed.ly\u002F1\u002Fimage%3Furl%3Dhttps%253A%252F%252Fabs.twimg.com%252Ferrors%252Flogo46x38.png%26key%3Da19fcc184b9711e1b4764040d3dc5c07","iframeHeight":281,"iframeWidth":500,"title":"IntiMater on Twitter: \"Dear Star Atlas Community,I hope this message finds you all in good spirits as we embark on the next chapter of our journey together. It is with mixed emotions that I write to you today, for it is time for me to officially address the departure from my role as CRO at ATMTA. \u002F Twitter\""},"Paragraph:deaaa90a6621_3":{"__typename":"Paragraph","id":"deaaa90a6621_3","name":"5489","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:35c1ed9e503b6620ec766abaec7d8efb"}},"mixtapeMetadata":null},"Paragraph:deaaa90a6621_4":{"__typename":"Paragraph","id":"deaaa90a6621_4","name":"4521","type":"BQ","href":null,"layout":null,"metadata":null,"text":"Dear Star Atlas Community, I hope this message finds you all in good spirits as we embark on the next chapter of our journey together. It is with mixed emotions that I write to you today, for it is time for me to officially address the departure from my role as CRO at ATMTA.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_5":{"__typename":"Paragraph","id":"deaaa90a6621_5","name":"962d","type":"BQ","href":null,"layout":null,"metadata":null,"text":"This situation was not easy, but it is one that I believe is necessary.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_6":{"__typename":"Paragraph","id":"deaaa90a6621_6","name":"a81c","type":"BQ","href":null,"layout":null,"metadata":null,"text":"First and foremost, I want to express my deepest gratitude to each and every one of you. The passion and dedication you have shown in building Star Atlas into what it is today is truly awe-inspiring.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_7":{"__typename":"Paragraph","id":"deaaa90a6621_7","name":"4841","type":"BQ","href":null,"layout":null,"metadata":null,"text":"Your commitment to the vision of a decentralized metaverse and your tireless efforts to push the boundaries of what is possible have made this project a force to be reckoned with.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_8":{"__typename":"Paragraph","id":"deaaa90a6621_8","name":"f606","type":"BQ","href":null,"layout":null,"metadata":null,"text":"As I reflect on our journey together, I am filled with immense pride. We have come so far, overcoming obstacles and challenges that seemed insurmountable. But true progress is not measured solely by the distance traveled; it is also marked by the willingness to adapt and evolve.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_9":{"__typename":"Paragraph","id":"deaaa90a6621_9","name":"2523","type":"BQ","href":null,"layout":null,"metadata":null,"text":"This is a project that has the opportunity to revolutionize the way we interact, create, and transact within virtual worlds. It is a vision that transcends borders, cultures, and limitations. And it is a vision that will endure, regardless of who is at the helm.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_10":{"__typename":"Paragraph","id":"deaaa90a6621_10","name":"176c","type":"BQ","href":null,"layout":null,"metadata":null,"text":"I have always believed that the true strength of a visionary lies in their ability to inspire others to dream, create, and achieve greatness. And it is my hope that I have been able to ignite that spark within each and every one of you.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_11":{"__typename":"Paragraph","id":"deaaa90a6621_11","name":"e669","type":"BQ","href":null,"layout":null,"metadata":null,"text":"The legacy of Star Atlas is not tied to any one individual; it is a collective endeavor that belongs to all of us. It is a testament to the power of community, collaboration, and shared purpose.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_12":{"__typename":"Paragraph","id":"deaaa90a6621_12","name":"3c4c","type":"BQ","href":null,"layout":null,"metadata":null,"text":"I implore you to continue pushing the boundaries of what is possible. Embrace change, for it is the catalyst for growth and innovation. Cherish the relationships you have built within this community, for they are the foundation upon which Star Atlas stands.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_13":{"__typename":"Paragraph","id":"deaaa90a6621_13","name":"c5d4","type":"BQ","href":null,"layout":null,"metadata":null,"text":"And above all else, never lose sight of the awe-inspiring potential that lies within each and every one of you.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_14":{"__typename":"Paragraph","id":"deaaa90a6621_14","name":"fb53","type":"BQ","href":null,"layout":null,"metadata":null,"text":"Be light, Pablo","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_15":{"__typename":"Paragraph","id":"deaaa90a6621_15","name":"1f8b","type":"P","href":null,"layout":null,"metadata":null,"text":"— Pablo Quiroga, former Chief Revenue Officer of ATMTA, Star Atlas game developer","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_16":{"__typename":"Paragraph","id":"deaaa90a6621_16","name":"1dee","type":"H3","href":null,"layout":null,"metadata":null,"text":"Quiroa Speaks After Departure","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_17":{"__typename":"Paragraph","id":"deaaa90a6621_17","name":"7388","type":"P","href":null,"layout":null,"metadata":null,"text":"Quiroga’s tenure as the Chief Revnue Officer of ATMTA officially ended on March 31st, 2023. However, the official public announcement was made on April, 7th by CEO Michael Wagner. Quiroga, along with Wagner, was among the four founders of Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":121,"end":133,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fatmta-employees-speak-on-quiroga-departure-fd8197c23ca1","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_18":{"__typename":"Paragraph","id":"deaaa90a6621_18","name":"6689","type":"P","href":null,"layout":null,"metadata":null,"text":"Quiroga’s public comments did not address previously reported allegations of workplace grievances or internal creative differences amongst the team. Quiroga’s message was addressed to the Star Atlas community, which have been long supporters of both Quiroga and Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_19":{"__typename":"Paragraph","id":"deaaa90a6621_19","name":"3e3b","type":"P","href":null,"layout":null,"metadata":null,"text":"His message embraced a harmonic tone and spoke to the testament of the power of the (Star Atlas) community.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_20":{"__typename":"Paragraph","id":"deaaa90a6621_20","name":"7ab0","type":"P","href":null,"layout":null,"metadata":null,"text":"It remains unclear the reasoning behind Quiroga’s sudden departure from ATMTA. Other than the official comment by Wagner, ATMTA has declined to comment further on the matter.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":19,"end":66,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fatmta-insider-spills-on-quiroga-departure-e76045f906d8","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_21":{"__typename":"Paragraph","id":"deaaa90a6621_21","name":"190f","type":"H3","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_22":{"__typename":"Paragraph","id":"deaaa90a6621_22","name":"42f7","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs is a pioneer in the world of Star Atlas, having founded The Hologram News Network — an independent meta-news organization that keeps players up to date on all developments regarding Star Atlas. An ardent supporter of emerging technologies, Krigs has been covering this game for over a year and believes passionately in their power to revolutionize our collective gaming experience.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":5,"href":"https:\u002F\u002Fmedium.com\u002Fu\u002F41e0c5b141f1?source=post_page-----4922901fb224--------------------------------","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_23":{"__typename":"Paragraph","id":"deaaa90a6621_23","name":"4ed9","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_24":{"__typename":"Paragraph","id":"deaaa90a6621_24","name":"0068","type":"P","href":null,"layout":null,"metadata":null,"text":"Podcast | YouTube | Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Fopen.spotify.com\u002Fshow\u002F2mxndrDW6yPfpS350ijzjt?si=ec7c717f998240d6","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":17,"href":"https:\u002F\u002Fwww.youtube.com\u002Fchannel\u002FUCDa-YxgNG6A9xpH1qyP0OaQ","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":20,"end":27,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":30,"end":39,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":42,"end":45,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_25":{"__typename":"Paragraph","id":"deaaa90a6621_25","name":"0f6d","type":"H3","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_26":{"__typename":"Paragraph","id":"deaaa90a6621_26","name":"37c7","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:deaaa90a6621_27":{"__typename":"Paragraph","id":"deaaa90a6621_27","name":"9ef9","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_116abac365e6":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_116abac365e6","isEditor":false},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"Post:eb37dc95ff3":{"__typename":"Post","id":"eb37dc95ff3","collection":{"__ref":"Collection:4d89daa6ae31"},"content({\"postMeteringOptions\":{\"forceTruncation\":false}})":{"__typename":"PostContent","isLockedPreviewO
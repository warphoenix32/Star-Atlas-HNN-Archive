name":"ColorPoint","color":"#FFE4E1E0","point":0.9},{"__typename":"ColorPoint","color":"#FFE2DFDE","point":1}]},"defaultBackgroundSpectrum":{"__typename":"ColorSpectrum","backgroundColor":"#FFFFFFFF","colorPoints":[{"__typename":"ColorPoint","color":"#FF868484","point":0},{"__typename":"ColorPoint","color":"#FF7C7B7A","point":0.1},{"__typename":"ColorPoint","color":"#FF737171","point":0.2},{"__typename":"ColorPoint","color":"#FF696867","point":0.3},{"__typename":"ColorPoint","color":"#FF5F5E5E","point":0.4},{"__typename":"ColorPoint","color":"#FF555454","point":0.5},{"__typename":"ColorPoint","color":"#FF4A4949","point":0.6},{"__typename":"ColorPoint","color":"#FF3F3E3E","point":0.7},{"__typename":"ColorPoint","color":"#FF343333","point":0.8},{"__typename":"ColorPoint","color":"#FF272727","point":0.9},{"__typename":"ColorPoint","color":"#FF1A1A1A","point":1}]},"tintBackgroundSpectrum":{"__typename":"ColorSpectrum","backgroundColor":"#FF000000","colorPoints":[{"__typename":"ColorPoint","color":"#FF000000","point":0},{"__typename":"ColorPoint","color":"#FF1E1D1D","point":0.1},{"__typename":"ColorPoint","color":"#FF3C3B3B","point":0.2},{"__typename":"ColorPoint","color":"#FF565555","point":0.3},{"__typename":"ColorPoint","color":"#FF6F6D6D","point":0.4},{"__typename":"ColorPoint","color":"#FF868484","point":0.5},{"__typename":"ColorPoint","color":"#FF9C9A99","point":0.6},{"__typename":"ColorPoint","color":"#FFB1AEAE","point":0.7},{"__typename":"ColorPoint","color":"#FFC5C3C2","point":0.8},{"__typename":"ColorPoint","color":"#FFD9D6D6","point":0.9},{"__typename":"ColorPoint","color":"#FFECE9E9","point":1}]}},"googleAnalyticsId":null,"editors":[{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:41e0c5b141f1"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:b0bf38de9190"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:ab6dbce60d64"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:ed24b40c4906"}}],"name":"The Hologram","avatar":{"__ref":"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg"},"domain":null,"slug":"the-hologram","description":"Daily Star Atlas news by The Hologram. Politics, economics and community coverage. Get the trusted information you need to stay one step ahead of your competition.","subscriberCount":130,"viewerEdge":{"__ref":"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_8dba539d5026"},"twitterUsername":"Hologram_News","facebookPageId":null,"logo":{"__ref":"ImageMetadata:"},"customDomainState":{"__typename":"CustomDomainState","live":null},"creator":{"__ref":"User:41e0c5b141f1"},"ptsQualifiedAt":1650725921201},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","name":"Krigs","username":"krigsfoniks","newsletterV3":{"__ref":"NewsletterV3:85fc9c436e2e"},"linkedAccounts":{"__ref":"LinkedAccounts:41e0c5b141f1"},"isSuspended":false,"imageId":"1*pVxyLAandIa00EX6ZGRERw.png","mediumMemberAt":1667603125000,"verifications":{"__typename":"VerifiedInfo","isBookAuthor":false},"socialStats":{"__typename":"SocialStats","followerCount":195},"customDomainState":null,"hasSubdomain":false,"bio":"Founder and Chief Editor of The Hologram. | Crypto | Star Atlas |","isPartnerProgramEnrolled":true,"viewerEdge":{"__ref":"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_8dba539d5026"},"viewerIsUser":false,"postSubscribeMembershipUpsellShownAt":0,"allowNotes":true,"twitterScreenName":"Hologram_News","atsQualifiedAt":1650725917596},"User:b0bf38de9190":{"__typename":"User","id":"b0bf38de9190"},"User:ab6dbce60d64":{"__typename":"User","id":"ab6dbce60d64"},"User:ed24b40c4906":{"__typename":"User","id":"ed24b40c4906"},"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg"},"LinkedAccounts:41e0c5b141f1":{"__typename":"LinkedAccounts","mastodon":null,"id":"41e0c5b141f1"},"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_8dba539d5026":{"__typename":"UserViewerEdge","id":"userId:41e0c5b141f1-viewerId:lo_8dba539d5026","isFollowing":false,"isUser":false},"NewsletterV3:85fc9c436e2e":{"__typename":"NewsletterV3","id":"85fc9c436e2e","type":"NEWSLETTER_TYPE_AUTHOR","slug":"41e0c5b141f1","name":"41e0c5b141f1","collection":null,"user":{"__ref":"User:41e0c5b141f1"}},"Paragraph:7634c5c88956_0":{"__typename":"Paragraph","id":"7634c5c88956_0","name":"cbb9","type":"H3","href":null,"layout":null,"metadata":null,"text":"S&B Spy Double-Cross Reveals Extensive Recon Operation","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_1":{"__typename":"Paragraph","id":"7634c5c88956_1","name":"aee6","type":"P","href":null,"layout":null,"metadata":null,"text":"High Risk Zone, Galia Sector — In a series of wild and dramatic events, the first double cross in Star Atlas history revealed an extensive reconnaissance operation by MUD pirate guild Skull & Bones targeting several prominent guilds and leaders.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":29,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*kC8-OV2ve_mqsfIZ-JSq1w.png":{"__typename":"ImageMetadata","id":"1*kC8-OV2ve_mqsfIZ-JSq1w.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:7634c5c88956_2":{"__typename":"Paragraph","id":"7634c5c88956_2","name":"0a8f","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*kC8-OV2ve_mqsfIZ-JSq1w.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_3":{"__typename":"Paragraph","id":"7634c5c88956_3","name":"3dc9","type":"H3","href":null,"layout":null,"metadata":null,"text":"Spy Dismissal Leads to Operational Tell-All","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_4":{"__typename":"Paragraph","id":"7634c5c88956_4","name":"5b31","type":"P","href":null,"layout":null,"metadata":null,"text":"The story begins with Gabss, a former member and spy of Skull & Bones [S&B]. During his normal reconnaissance activities, Gabss revealed the public wallet addresses of S&B members to Ghaz Outro, a member of Guardians of the Galaxy [GotG]. According to Gabss, he believed that there was no harm in the sharing of public addresses.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_5":{"__typename":"Paragraph","id":"7634c5c88956_5","name":"85d9","type":"P","href":null,"layout":null,"metadata":null,"text":"Suspicious of the activity, Outro alerted fellow GotG member Signal, who in turn notified Saint-Just, a 1st Mate of S&B, stressing that GotG did not solicit Gabss information (GotG is a declared enemy of S&B). Eventually, the news of wallet disclosures reached the ears of S&B leaders.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_6":{"__typename":"Paragraph","id":"7634c5c88956_6","name":"0f36","type":"P","href":null,"layout":null,"metadata":null,"text":"Strongly disagreeing with Gabss intent and actions, S&B leaders took swift and decisive action. Gabss was disavowed from S&B’s ranks and promptly kicked out.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_7":{"__typename":"Paragraph","id":"7634c5c88956_7","name":"9f28","type":"P","href":null,"layout":null,"metadata":null,"text":"Events took an even more dramatic turn as the dismissal made its way into the Star Atlas server. After a series of verbal altercations in the public general channel, deciding to divulge the extent of his operations, Gabss revealed that he had been assigned to collect wallet addresses of several prominent guilds and their leaders.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":216,"end":331,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*SRGPnv9vSVEJnRFBVshgBA.png":{"__typename":"ImageMetadata","id":"1*SRGPnv9vSVEJnRFBVshgBA.png","originalHeight":296,"originalWidth":654,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:7634c5c88956_8":{"__typename":"Paragraph","id":"7634c5c88956_8","name":"8c43","type":"IMG","href":null,"layout":"OUTSET_ROW","metadata":{"__ref":"ImageMetadata:1*SRGPnv9vSVEJnRFBVshgBA.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*NyYw_qOum7Iyw_0XfQQwDA.png":{"__typename":"ImageMetadata","id":"1*NyYw_qOum7Iyw_0XfQQwDA.png","originalHeight":350,"originalWidth":581,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:7634c5c88956_9":{"__typename":"Paragraph","id":"7634c5c88956_9","name":"ec96","type":"IMG","href":null,"layout":"OUTSET_ROW_CONTINUE","metadata":{"__ref":"ImageMetadata:1*NyYw_qOum7Iyw_0XfQQwDA.png"},"text":"June 4th, 2023 Conversations between Saint-Just and Gabss","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*ZZoRkGug8Fhl-C2okarnPQ.png":{"__typename":"ImageMetadata","id":"1*ZZoRkGug8Fhl-C2okarnPQ.png","originalHeight":362,"originalWidth":642,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:7634c5c88956_10":{"__typename":"Paragraph","id":"7634c5c88956_10","name":"5708","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*ZZoRkGug8Fhl-C2okarnPQ.png"},"text":"June 4th, 2023 Conversation between Saint-Just and Gabss","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_11":{"__typename":"Paragraph","id":"7634c5c88956_11","name":"54a9","type":"H3","href":null,"layout":null,"metadata":null,"text":"A Dare and A Double Cross","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_12":{"__typename":"Paragraph","id":"7634c5c88956_12","name":"74b0","type":"P","href":null,"layout":null,"metadata":null,"text":"During the Hologram’s conversation with Gabss, it was evident that they have been operating in a reconnaissance role prior to being tasked by S&B. At some point after joining S&B, Gabss began limited operations with Saint-Just. After reviewing extensive text conversations between Saint-Just and Gabss, it was clear that several guilds including ROME, NFT Italia, Quimera, Aephia, BULK, Dark Matter, and The Unseen were targets of the intelligence operation.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":346,"end":457,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_13":{"__typename":"Paragraph","id":"7634c5c88956_13","name":"ac2b","type":"P","href":null,"layout":null,"metadata":null,"text":"From the text conversations, its appears that both Saint-Just and Gabss would discuss whom would be a potential intelligence focus from time to time.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_14":{"__typename":"Paragraph","id":"7634c5c88956_14","name":"930c","type":"P","href":null,"layout":null,"metadata":null,"text":"S&B officially denies sanctioning Gabss’ clandestine activities, however, acknowledged that they did not halt or prevent Gabss’ collection efforts. It’s at least clear that S&B leaders were aware of the ongoing activities. S&B declined to comment any further for this article.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":63,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*dYGw8qSzjax4_OXrl_9YAw.png":{"__typename":"ImageMetadata","id":"1*dYGw8qSzjax4_OXrl_9YAw.png","originalHeight":149,"originalWidth":497,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:7634c5c88956_15":{"__typename":"Paragraph","id":"7634c5c88956_15","name":"0def","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*dYGw8qSzjax4_OXrl_9YAw.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_16":{"__typename":"Paragraph","id":"7634c5c88956_16","name":"14be","type":"P","href":null,"layout":null,"metadata":null,"text":"By June 18th, after two weeks of continued operations, Gabss eventually caught the attention of the S&B Founder, 13omb3r.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*x4CmpctSgqrp3mTfIF7FkQ.png":{"__typename":"ImageMetadata","id":"1*x4CmpctSgqrp3mTfIF7FkQ.png","originalHeight":485,"originalWidth":1134,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:7634c5c88956_17":{"__typename":"Paragraph","id":"7634c5c88956_17","name":"0e47","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*x4CmpctSgqrp3mTfIF7FkQ.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_18":{"__typename":"Paragraph","id":"7634c5c88956_18","name":"bad1","type":"P","href":null,"layout":null,"metadata":null,"text":"However, that positive attention would be short lived as less than 48 hours later, Gabss would become the latest persona non grata amongst the S&B pirates. After a bitter falling out with his former guild mates, Gabss ultimately recounted his operational stint in a phone call with the Hologram.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":113,"end":130,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_19":{"__typename":"Paragraph","id":"7634c5c88956_19","name":"6f5b","type":"P","href":null,"layout":null,"metadata":null,"text":"HNN was able to verify the series of events through a video call with Gabss. Events were further corroborated by other Star Atlas community members along with text evidence of the clandestine activities.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":203,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_20":{"__typename":"Paragraph","id":"7634c5c88956_20","name":"30fc","type":"H3","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:7634c5c88956_21":{"__typename":"Paragraph","id":"7634c5c88956_21","name":"a8df","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs is a pioneer in the world of Star Atlas, having founded The Hologram News Network — an independent meta-news organization that keeps players up to date on all developments regarding Star Atlas. An ardent supporter of emerging technologies, Krigs has been covering this game for over a year and believes passionately in their power to revolutionize our collective gaming experience.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":5,"href":"https:\u002F\u002Fmedium.com\u002Fu\u0
730,"focusPercentX":48.57142857142857,"focusPercentY":45.19230769230769},"NewsletterV3:ac886d6987e0":{"__typename":"NewsletterV3","slug":"holoreport","id":"ac886d6987e0","name":"HoloReport","description":"Catch up on the latest Star Atlas news that you've missed. ","promoHeadline":"","promoBody":"","type":"NEWSLETTER_TYPE_COLLECTION","user":{"__ref":"User:41e0c5b141f1"},"collection":{"__ref":"Collection:4d89daa6ae31"},"showPromo":true},"ImageMetadata:1*EWK2g3sZ2CUq9HSp-mKvEA.png":{"__typename":"ImageMetadata","id":"1*EWK2g3sZ2CUq9HSp-mKvEA.png","originalWidth":1024},"Post:655f8b7fe5c1":{"__typename":"Post","id":"655f8b7fe5c1"},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","name":"Krigs","username":"krigsfoniks","newsletterV3":{"__ref":"NewsletterV3:85fc9c436e2e"},"atsQualifiedAt":1650725917596},"NewsletterV3:85fc9c436e2e":{"__typename":"NewsletterV3","id":"85fc9c436e2e"},"PostViewerEdge:postId:274aedf99988-viewerId:lo_1e6f1b9ec454":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:274aedf99988-viewerId:lo_1e6f1b9ec454"},"Paragraph:6e23b06fade0_0":{"__typename":"Paragraph","id":"6e23b06fade0_0","name":"df47","type":"H3","href":null,"layout":null,"metadata":null,"text":"The Rise of the Metaverse","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_1":{"__typename":"Paragraph","id":"6e23b06fade0_1","name":"3bb1","type":"P","href":null,"layout":null,"metadata":null,"text":"How Star Atlas is paving the way for virtual societies","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":54,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_2":{"__typename":"Paragraph","id":"6e23b06fade0_2","name":"58a3","type":"P","href":null,"layout":null,"metadata":null,"text":"The Metaverse is a concept that has been gaining a lot of traction in recent years, with the growth of gaming technology and the increasing interest in decentralized systems. A metaverse refers to a virtual universe where people can interact and engage in activities in a way that feels life-like, ideally enhancing connections to the real world. The idea is that people can create, explore and live in digital spaces, just as they do outside. One of the most exciting new projects in the metaverse space is Star Atlas, a space-exploration game built on Web3.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_3":{"__typename":"Paragraph","id":"6e23b06fade0_3","name":"043a","type":"P","href":null,"layout":null,"metadata":null,"text":"Star Atlas is a decentralized space-exploration game that is currently being developed to facilitate not only crypto enthusiasts, but also businesses and regular gaming plebs. The game offers players a unique experience where they can explore the vast universe, discover new planets, trade goods, and interact with other players in a seamless and immersive environment. The game is built on the Solana blockchain, which provides a secure and decentralized platform for players to transact and interact with each other that is exponentially faster and cheaper than using Ethereum.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":10,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*Y2yPpMWDphUsznTN.png":{"__typename":"ImageMetadata","id":"0*Y2yPpMWDphUsznTN.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:6e23b06fade0_4":{"__typename":"Paragraph","id":"6e23b06fade0_4","name":"a559","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*Y2yPpMWDphUsznTN.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_5":{"__typename":"Paragraph","id":"6e23b06fade0_5","name":"2773","type":"H4","href":null,"layout":null,"metadata":null,"text":"The Creation of a Metaverse","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_6":{"__typename":"Paragraph","id":"6e23b06fade0_6","name":"a5bd","type":"P","href":null,"layout":null,"metadata":null,"text":"One of the key benefits of Star Atlas is that it allows players to own their digital assets in a way that is secure and permanent. In the game, players can earn rewards and accumulate assets, such as spaceships, planets and valuable resources. These assets are stored on the blockchain and are fully owned by the player, meaning that they can be traded, sold or passed down to others. This creates a new economy that is built on trust and transparency, which is a key aspect of web3. A Decentralized Autonomous Organization (DAO) is set up to eventually be in control of the future of this game, allowing DAO stakeholders of the $POLIS cryptocurrency to be in control of development vision.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_7":{"__typename":"Paragraph","id":"6e23b06fade0_7","name":"e2fb","type":"P","href":null,"layout":null,"metadata":null,"text":"Star Atlas also provides players with a sense of community, as it has one of the most engaged communities in all of Web3. In fact, they just won first place at the Web3 Gamers Choice Awards for that exact reason. And the game’s not even past pre-Alpha yet. It’s a community-built project, led by ATMTA (pronounced Automata). Players can form alliances, trade goods, and engage in battles with other players. This creates a social and economic ecosystem that is unique to the metaverse. The game will also allow players to craft and eventually build their own items and ships which will be sellable on the open NFT market.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:d5ac2711c18820031209750a01685504":{"__typename":"MediaResource","id":"d5ac2711c18820031209750a01685504","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?src=https%3A%2F%2Fwww.youtube.com%2Fembed%2FLySQNYwUuqA%3Ffeature%3Doembed&display_name=YouTube&url=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DLySQNYwUuqA&image=https%3A%2F%2Fi.ytimg.com%2Fvi%2FLySQNYwUuqA%2Fhqdefault.jpg&key=a19fcc184b9711e1b4764040d3dc5c07&type=text%2Fhtml&schema=youtube","iframeHeight":480,"iframeWidth":854,"title":"Star Atlas - Fimbul BYOS Packlite Development [WIP]"},"Paragraph:6e23b06fade0_8":{"__typename":"Paragraph","id":"6e23b06fade0_8","name":"870a","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"Fimbul BYOS Packlite Development","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:d5ac2711c18820031209750a01685504"}},"mixtapeMetadata":null},"Paragraph:6e23b06fade0_9":{"__typename":"Paragraph","id":"6e23b06fade0_9","name":"06fb","type":"P","href":null,"layout":null,"metadata":null,"text":"Another key feature of is the graphics and visual design of the game. The game is designed on Unreal Engine 5 using Nanite technology, opening up the possibility for hyper-realistic environments, unreal spaceships, and an entire universe of possibilities. The combination of these cutting-edge technologies will enable the game to offer a truly unforgettable gaming experience, with graphics that are not only visually stunning but also ahead of its time. In this way, the graphics and visual design of Star Atlas serve to enhance the player’s engagement and enjoyment, making it a critical aspect of the game’s overall success.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_10":{"__typename":"Paragraph","id":"6e23b06fade0_10","name":"628e","type":"H4","href":null,"layout":null,"metadata":null,"text":"A Straightforward Vision","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_11":{"__typename":"Paragraph","id":"6e23b06fade0_11","name":"c236","type":"P","href":null,"layout":null,"metadata":null,"text":"Led by Michael Wagner, CFA, Star Atlas has a talented team behind it, with years of experience in business, economics, gaming, blockchain, and more. The team is committed to delivering a high-quality product that offers players a unique and engaging experience. It’s backed by a strong community of supporters and investors, who are bullish on the future of the metaverse and the potential of Star Atlas. While any community-funded startup built on Web3 may have its financial challenges, Michael recently dove head-first into his plan to deal with them during the Townhall last week. We have to start somewhere, and while there are many risks involved in a vision of this magnitude, there’s also the possibility that Star Atlas will pave the way.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":7,"end":26,"href":null,"anchorType":"USER","userId":"2772803ea4c0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*EmSLzYaL57LuEWmY.png":{"__typename":"ImageMetadata","id":"0*EmSLzYaL57LuEWmY.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:6e23b06fade0_12":{"__typename":"Paragraph","id":"6e23b06fade0_12","name":"4d14","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*EmSLzYaL57LuEWmY.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_13":{"__typename":"Paragraph","id":"6e23b06fade0_13","name":"16ae","type":"H4","href":null,"layout":null,"metadata":null,"text":"The Growth of Web3 Gaming","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":25,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_14":{"__typename":"Paragraph","id":"6e23b06fade0_14","name":"b546","type":"P","href":null,"layout":null,"metadata":null,"text":"The growth of gaming and the increasing interest in decentralized systems is driving the demand for new and innovative projects in the Web3 space. Because of this, this initiative is poised to be a major player in the metaverse, offering players a unique and engaging experience that is built on blockchain technology and web3. Space-exploration is almost like a staple for many gamers. But the possibilities aren’t limited to space-exploration alone. There’s been much discussion on crypto Twitter lately about the implication of Esports sprinkled throughout decentralized efforts such as Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_15":{"__typename":"Paragraph","id":"6e23b06fade0_15","name":"6edc","type":"P","href":null,"layout":null,"metadata":null,"text":"Last week, Wagner began the Town Hall with a somber tone, leading the group to a truth many in this space need to understand. While the combination of blockchain technology, web3 gaming, and advanced graphics is certainly exciting, investing in any business, particularly in the metaverse space, comes with a high level of risk and uncertainty. The potential for players to own and trade digital assets is appealing, but it is important to remember that the value of these assets is highly speculative and can be subject to sudden changes. Additionally, the growth of Star Atlas has promising trends, but it’s impossible to predict its future trajectory with certainty. As with any investment, it’s important to thoroughly research the information and understand the risks involved before making a financial decision. While Star Atlas may be a promising venture, Wagner was very clear that there is still a lot of uncertainty going forward.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_16":{"__typename":"Paragraph","id":"6e23b06fade0_16","name":"b370","type":"H4","href":null,"layout":null,"metadata":null,"text":"After all, Web3 is the modern Wild West","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_17":{"__typename":"Paragraph","id":"6e23b06fade0_17","name":"0ef1","type":"P","href":null,"layout":null,"metadata":null,"text":"Like any true expansion, competition is often what drives the pioneers of the future. One such leak from last week’s meetup explored the new and upcoming feature of ship-racing, likely to attract many newcomers. While rudimentary versions of racing currently exist, Wagner and Community Director Santi, broke the news of integrating ground-racing into the next segment of Showroom (the current pre-Alpha in UE5). “It’s multiplayer-style, fight for your position, ground racing,” said Wagner, “Where you can shoot at other ships to disable them. You won’t be able to skip gates…and this is expected to support up to eight people.” Upcoming releases also include a scavenger hunt with the possibility of finding a ship estimated to be worth around $100,000, DAO functionality, and an expanded showroom give plenty to look forward to in the short-term.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*dmf34FPm5W7m38p1.png":{"__typename":"ImageMetadata","id":"0*dmf34FPm5W7m38p1.png","originalHeight":1172,"originalWidth":1706,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:6e23b06fade0_18":{"__typename":"Paragraph","id":"6e23b06fade0_18","name":"6161","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*dmf34FPm5W7m38p1.png"},"text":"Early Leak of Showroom Racecourse","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_19":{"__typename":"Paragraph","id":"6e23b06fade0_19","name":"e6a5","type":"P","href":null,"layout":null,"metadata":null,"text":"To summarize, while this is in no way financial advice, Star Atlas is a project that people might consider being bullish on. Its combination of blockchain technology, web3, and cutting-edge graphics makes it one of the most exciting visions in the space. The potential for players to own and trade digital assets in a secure and permanent way, as well as the sense of community and social interaction, makes Star Atlas a unique and valuable proposition for players. Its growing virtual world, community, and focus on decentralized systems make it an enterprise worth paying close attention to.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*ia706XBGLjre0fuV.gif":{"__typename":"ImageMetadata","id":"0*ia706XBGLjre0fuV.gif","originalHeight":754,"originalWidth":1266,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:6e23b06fade0_20":{"__typename":"Paragraph","id":"6e23b06fade0_20","name":"cae3","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*ia706XBGLjre0fuV.gif"},"text":"Early Calico Render","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_21":{"__typename":"Paragraph","id":"6e23b06fade0_21","name":"93af","type":"H3","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_22":{"__typename":"Paragraph","id":"6e23b06fade0_22","name":"052c","type":"P","href":null,"layout":null,"metadata":null,"text":"Sean Layton is a writer on The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":11,"href":"https:\u002F\u002Fmedium.com\u002F@mudpilot","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":12,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_23":{"__typename":"Paragraph","id":"6e23b06fade0_23","name":"918f","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow us on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_24":{"__typename":"Paragraph","id":"6e23b06fade0_24","name":"ff8e","type":"P","href":null,"layout":null,"metadata":null,"text":"Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Ftwitter.com\u002FHologram_News","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":19,"href":"https:\u002F\u002Fwww.instagram.com\u002Fhologram_news\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":22,"end":25,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_25":{"__typename":"Paragraph","id":"6e23b06fade0_25","name":"46d2","type":"H3","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_26":{"__typename":"Paragraph","id":"6e23b06fade0_26","name":"a9d3","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*0cQYS9cssH5nV3GK.png":{"__typename":"ImageMetadata","id":"0*0cQYS9cssH5nV3GK.png","originalHeight":143,"originalWidth":504,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:6e23b06fade0_27":{"__typename":"Paragraph","id":"6e23b06fade0_27","name":"1ae6","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*0cQYS9cssH5nV3GK.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:6e23b06fade0_28":{"__typename":"Paragraph","id":"6e23b06fade0_28","name":"916f","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_1e6f1b9ec454":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_1e6f1b9ec454","isEditor":false},"Tag:star-atlas":{"__typename":"Tag","i
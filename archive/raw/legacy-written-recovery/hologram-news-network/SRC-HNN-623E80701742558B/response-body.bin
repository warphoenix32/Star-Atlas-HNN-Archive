is their [ATMTA’s] “active” address basically that’s where marketplace fees etc go","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":86,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_34":{"__typename":"Paragraph","id":"77b1fd3692d0_34","name":"137e","type":"P","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_35":{"__typename":"Paragraph","id":"77b1fd3692d0_35","name":"3199","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":5,"href":"https:\u002F\u002Fmedium.com\u002Fu\u002F41e0c5b141f1?source=post_page-----4922901fb224--------------------------------","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_36":{"__typename":"Paragraph","id":"77b1fd3692d0_36","name":"1215","type":"P","href":null,"layout":null,"metadata":null,"text":"is a pioneer in the world of Star Atlas, having founded The Hologram News Network — an independent meta-news organization that keeps players up to date on all developments regarding Star Atlas. An ardent supporter of emerging technologies, Krigs has been covering this game for over a year and believes passionately in their power to revolutionize our collective gaming experience.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:77b1fd3692d0_37":{"__typename":"Paragraph","id":"77b1fd3692d0_37","name":"241b","type":"P","href":null,"layout
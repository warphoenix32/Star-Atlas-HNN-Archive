"isLimitedState":false,"isNewsletter":false,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"},{"__ref":"Tag:guild"},{"__ref":"Tag:community"}],"topics":[],"isSeries":false,"sequence":null,"uniqueSlug":"heimdall-industries-building-viking-longships-to-starships-6b07efc7d08c","primaryTopic":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1650205017375,"readingTime":6.080188679245283,"previewContent":{"__typename":"PreviewContent","subtitle":"Heimdall Industries is a Viking themed guild dedicated to becoming expert ship builders like their early ancestors. Led by Kings…"},"previewImage":{"__ref":"ImageMetadata:1*rJ1pjMQKA2PrIBq4pZv-Lw.png"},"isShortform":false,"isSuspended":false,"responseRootPost":{"__typename":"ResponseRootPost","post":{"__ref":"Post:6b07efc7d08c"}},"lockedSource":"LOCKED_POST_SOURCE_NONE","clapCount":0,"statusForCollection":"APPROVED","pendingCollection":null,"title":"Heimdall Industries: Building Viking longships to starships","inResponseToEntityType":null,"seoTitle":"","updatedAt":1650205024230,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"pinnedAt":0,"internalLinks({\"paging\":{\"limit\":8}})":{"__typename":"InternalLinksConnection","items":[]},"pinnedByCreatorAt":0,"curationEligibleAt":0,"responseDistribution":"NOT_DISTRIBUTED","inResponseToPostResult":null,"inResponseToCatalogResult":null,"latestPublishedVersion":"c6f51864d0b1","isAuthorNewsletter":true,"voterCount":0,"recommenders":[]},"ImageMetadata:1*_QlVG6XBAcbqXVvmi6-8VQ.jpeg":{"id":"1*_QlVG6XBAcbqXVvmi6-8VQ.jpeg","__typename":"ImageMetadata","originalHeight":3873,"originalWidth":3873},"Paragraph:c6f51864d0b1_0":{"id":"c6f51864d0b1_0","__typename":"Paragraph","name":"2d07","text":"Heimdall Industries: Building Viking longships to starships","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_1":{"id":"c6f51864d0b1_1","__typename":"Paragraph","name":"1fde","text":"Heimdall Industries is a Viking themed guild dedicated to becoming expert ship builders like their early ancestors. Led by Kings VikingenBenny, this Ustur guild will be producing the finest starships this side of the quadrant in no time.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_2":{"id":"c6f51864d0b1_2","__typename":"Paragraph","name":"a432","text":"Heimdall Industries Logo","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*rJ1pjMQKA2PrIBq4pZv-Lw.png"},"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_3":{"id":"c6f51864d0b1_3","__typename":"Paragraph","name":"0eab","text":"What is Heimdall Industries?","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":28,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_4":{"id":"c6f51864d0b1_4","__typename":"Paragraph","name":"bd07","text":"Heimdall Industries is a Star Atlas industrial-centric Viking lorified guild. Heimdall Industries belongs to the Ustur faction and is focused on becoming the best ship builders in the Star Atlas metaverse. Like the Vikings of the middle-ages who expertly built the longship, Heimdall Industries applies that Viking heritage to the space faring age. Their goal: to bring prosperity and protection to its community.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_5":{"id":"c6f51864d0b1_5","__typename":"Paragraph","name":"a7f7","text":"Heimdall Industries is heavily steeped in Norse lore and mythology. Named after the Norse god Heimdall, Heimdall Industries lends much of its heritage to the Norse traditions of old. While popular shows like Vikings have glorified the barbaric nature of the Norse clans, Heimdall Industries strives for a more peaceful vision in the Star Atlas metaverse.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_6":{"id":"c6f51864d0b1_6","__typename":"Paragraph","name":"cf8c","text":"Anyone wishing to embark on their Viking adventure with Heimdall Industries can visit their webpage here. Alternatively, join their discord here.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":100,"end":104,"href":"https:\u002F\u002Fheimdall-industries.org\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":140,"end":144,"href":"https:\u002F\u002Fdiscord.com\u002Finvite\u002FcpRvQunmaJ","anchorType":"LINK","userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_7":{"id":"c6f51864d0b1_7","__typename":"Paragraph","name":"8d73","text":"Who is Heimdall?","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_8":{"id":"c6f51864d0b1_8","__typename":"Paragraph","name":"c8ef","text":"Is it this guy?","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":15,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_9":{"id":"c6f51864d0b1_9","__typename":"Paragraph","name":"9ede","text":"Copyright Marvel Studios","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*VHGIE55cRs4acQT5EdeEnQ.png"},"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_10":{"id":"c6f51864d0b1_10","__typename":"Paragraph","name":"25d2","text":"As much as we love Idris Elba, no it’s not. Idris Elba plays a version of the Norse god Heimdall in Marvel’s Thor movie series.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_11":{"id":"c6f51864d0b1_11","__typename":"Paragraph","name":"e845","text":"In Norse mythology, Heimdall is a god who keeps watch for invaders and the onset of Ragnarok. From his perch guarding the rainbow bridge Bifrost, Heimdall possesses foreknowledge and keen senses, particularly eyesight and hearing. Heimdall is seen as the first protector of the home of the Norse pantheon and the citizens of Asgard. In line with its goal of protecting and providing for its citizens, Heimdall was chosen as the patron god for Heimdall Indsutries.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_12":{"id":"c6f51864d0b1_12","__typename":"Paragraph","name":"8089","text":"Heimdall Industries Organizational Structure","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":44,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_13":{"id":"c6f51864d0b1_13","__typename":"Paragraph","name":"9d0d","text":"Heimdall industries is comprised of three distinct sections, each led by a Jarl. Jarl is the Norse term for Chief. Jarls within Heimdall Industries are considered the officers of the guild.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_14":{"id":"c6f51864d0b1_14","__typename":"Paragraph","name":"6d64","text":"Manufacturing and mining (Knarresmedir and Smedir)\nThe backbone of Heimdall Industries’ mission, the Knarresmedir and Smedir of Heimdall Industries seek to continue the long and proud tradition of Viking craftmanship. Each member is dedicated to producing high quality products, whether that be mining resources, refining materials, or completing ships at the highest level. An owner of a Heimdall Industries ship can have peace of mind knowing their ship will not fail them.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":51,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_15":{"id":"c6f51864d0b1_15","__typename":"Paragraph","name":"c4e2","text":"The ancient Norse Vikings were expert builders of the longship. The longships were designed to be graceful, long, narrow and light, with a shallow hull designed for speed. This allowed the Vikings to traverse many shallow waterways that were unreachable by heavier European galleons. The longship was vital to Viking way of life, seeing heavy use for trading, exploration, and combat.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_16":{"id":"c6f51864d0b1_16","__typename":"Paragraph","name":"7128","text":"","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*w6TH2AaJaMG2_l7ffyapcA.png"},"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_17":{"id":"c6f51864d0b1_17","__typename":"Paragraph","name":"aaff","text":"Exploring (Vikingur)\nThe Vikingur, or explorers, of Heimdall Industries are of the adventurous spirit and curious mind. Their goal is to discover new lands, planets, and trade routes for the betterment of The Heimdall Clan. The establishment of trading partners and trade routes is essential to the success of any industrial organization.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":21,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_18":{"id":"c6f51864d0b1_18","__typename":"Paragraph","name":"fbb8","text":"The Vikings of the early Middle Ages were excellent tradesmen and explorers. In their expertly built longboats, the Vikings of Nordic lands explored much of Europe and reached as far as North Africa. Norse travelers and traders would make the journey on foot to places as far away as modern day Russia and Turkey. The most famous Viking explorer of all, Leiv Eiriksson (Leif Erikson), is believed to have been the first European to set foot on the North American continent, almost 500 years before Christopher Columbus.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_19":{"id":"c6f51864d0b1_19","__typename":"Paragraph","name":"3b73","text":"Leif Erikson day is October 9th","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*wXrwOgO6dYz7IitHA4la2Q.jpeg"},"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_20":{"id":"c6f51864d0b1_20","__typename":"Paragraph","name":"b6c7","text":"Security Force (Hird)\nKnown as The Hird, Heimdall Industries Security Force makes up the third section of the guild. The Hird, in Scandinavian history came to mean not only the nucleus of the royal army, but developed into a more formal royal court. The purpose of Heimdall Industries’ Security Force is the protection of Heimdall Industries’ transport ships and space stations. Thus, The Hird can be considered as a protectorate of its people and its allies. Unless provoked, I would not expect to see The Hird of Heimdall Industries conduct provocative actions against its neighbors.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":21,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_21":{"id":"c6f51864d0b1_21","__typename":"Paragraph","name":"d3b7","text":"The Varangian Guard were Vikings that served as protectors to European Emperors","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*HSx5k89UYIwawJk1kbul6g.jpeg"},"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_22":{"id":"c6f51864d0b1_22","__typename":"Paragraph","name":"02a8","text":"Heimdall Industries Ranks","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":25,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_23":{"id":"c6f51864d0b1_23","__typename":"Paragraph","name":"fa11","text":"Heimdall Industries borrows heavily from Norse clan structure. One can expect to make their way up the hierarchal chain to achieve status as a Jarl, or well renowned officer. The full Heimdall Industries rank structure is broken down below:","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_24":{"id":"c6f51864d0b1_24","__typename":"Paragraph","name":"352c","text":"The Kings (Kongur)","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_25":{"id":"c6f51864d0b1_25","__typename":"Paragraph","name":"2f5c","text":"Interestingly, Heimdall Industries has three kings listed. They are VikingenBenny, Ragnar Lothbrook and Heimðall.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_26":{"id":"c6f51864d0b1_26","__typename":"Paragraph","name":"3e57","text":"The Council (Þing)","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_27":{"id":"c6f51864d0b1_27","__typename":"Paragraph","name":"3e3d","text":"The Heimdall Industries council consists of 6 members. These six members are the three elected members from within Heimdall Industries in addition to the three kings. The elected council members are voted on every 3 months. The Heimdal Industries council is designed to balance the power between the leadership of the guild and its members. Already, the kings of Heimdall Industries are more gratuitous than their ancestors.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_28":{"id":"c6f51864d0b1_28","__typename":"Paragraph","name":"ed39","text":"The Jarls (Officers)","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":20,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_29":{"id":"c6f51864d0b1_29","__typename":"Paragraph","name":"c785","text":"Jarls are the officers of Heimdall Industries overseeing or assigned to one of the main branches in the guild. Jarls are the most loyal and active members within the guild and have specialized roles and capabilities that enhance the overall productivity of Heimdall Industries.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_30":{"id":"c6f51864d0b1_30","__typename":"Paragraph","name":"eb55","text":"Huskarl (Senior Members)","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":24,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_31":{"id":"c6f51864d0b1_31","__typename":"Paragraph","name":"a6a0","text":"Huskarls are the members who have supported Heimdall industries for a longer period and do extra voluntary work to help the guild grow and prosper. Karl (Members)","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_32":{"id":"c6f51864d0b1_32","__typename":"Paragraph","name":"fd24","text":"The Karls","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":9,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_33":{"id":"c6f51864d0b1_33","__typename":"Paragraph","name":"8870","text":"Anyone joining Heimdall Industries can expect to begin their journey as a Karl. Karls are all the official members of Heimdall Industries forming the backbone of the workforce.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_34":{"id":"c6f51864d0b1_34","__typename":"Paragraph","name":"725e","text":"Heimdall Industries Tools","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_35":{"id":"c6f51864d0b1_35","__typename":"Paragraph","name":"a629","text":"Market Place Data Analyzer","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":26,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_36":{"id":"c6f51864d0b1_36","__typename":"Paragraph","name":"b7a1","text":"","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*U-nHez5wQ7jLPUL2rM10MQ.png"},"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_37":{"id":"c6f51864d0b1_37","__typename":"Paragraph","name":"f986","text":"Expert traders must know the best value for their goods and Heimdall Industries offers their own starship marketplace data analysis tool. Data columns allow its members to search for the best deals on ships in either $ATLAS or $USDC. Heimdall Industries marketplace data page also displays the current price of all Star Atlas related cryptocurrencies. The Heimdall Industries market data tool can be found here.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":315,"end":325,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null},{"__typename":"Markup","type":"A","start":406,"end":410,"href":"https:\u002F\u002Fheimdall-industries.org\u002Fship-markets\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_38":{"id":"c6f51864d0b1_38","__typename":"Paragraph","name":"b4b0","text":"SCORE Resupply Optimizer","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":24,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_39":{"id":"c6f51864d0b1_39","__typename":"Paragraph","name":"eff2","text":"","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*k1HSPys5BRvB8kkkVHnq8w.jpeg"},"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_40":{"id":"c6f51864d0b1_40","__typename":"Paragraph","name":"a89a","text":"Built on The Club’s open-source SCORE tool, Heimdall Industries enables a one stop shop for restocking one’s ships. The UI design is uniquely simple and doesn’t require mass clicking and scrolling when compared to the Star Atlas SCORE UI. The countdown timer on the right side displays when the next ship will need resupply. A user’s inventory is displayed on the top for easy reference. All-in-all, this optimizer is an efficient way for shipbuilders and ship owners to manage their fleet. The SCORE tool can be found here.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":9,"end":17,"href":null,"anchorType":"USER","userId":"1e2c913fa2a0","linkMetadata":null},{"__typename":"Markup","type":"A","start":519,"end":523,"href":"https:\u002F\u002Fheimdall-industries.org\u002Fscore\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_41":{"id":"c6f51864d0b1_41","__typename":"Paragraph","name":"c870","text":"Disclaimer: The Heimdall Industries SCORE tool is non-audited software built on The Club’s source code for use in Star Atlas.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":70,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":71,"end":125,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_42":{"id":"c6f51864d0b1_42","__typename":"Paragraph","name":"f4e7","text":"Conclusion","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":10,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_43":{"id":"c6f51864d0b1_43","__typename":"Paragraph","name":"0dc5","text":"Heimdall Industries is a small yet powerful, tight-knit community of industrial minded players and protectors. Their goals of prosperity, protection, and peace will make their guild a highly sought after resource for many. Their influence will have a stabilizing effect both on the Star Atlas community and economy. We wish Heimdall Industries much fortune in the future and look forward to future partnerships.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":411,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_44":{"id":"c6f51864d0b1_44","__typename":"Paragraph","name":"6469","text":"Skal!","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":5,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_45":{"id":"c6f51864d0b1_45","__typename":"Paragraph","name":"228b","text":"Krigs","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":5,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_46":{"id":"c6f51864d0b1_46","__typename":"Paragraph","name":"a4b1","text":"This concludes or guild spotlight on Heimdall Industries. If you enjoyed this content, please let us know. Help us by following us on Twitter @hologram_news. We hope to bring you more exciting content to enhance your Star Atlas experience in the near future.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":258,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:c6f51864d0b1_47":{"id":"c6f51864d0b1_47","__typename":"Paragraph","name":"9699","text":"About The Hologram","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_48":{"id":"c6f51864d0b1_48","__typename":"Paragraph","name":"04e5","text":"The Hologram is an independent news organization dedicated to covering the latest Star Atlas content from all sides. The Hologram was founded on the principle of uniting creators from across their diverse fields and showcasing their talent. The Hologram also recognizes the importance of our reader’s time and will always strive to give you what you need, when you need it.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:c6f51864d0b1_49":{"id":"c6f51864d0b1_49","__typename":"Paragraph","name":"ba5d","text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram or its writers should be considered as informational in nature and does not constitute any financial advice.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"ImageMetadata:1*rJ1pjMQKA2PrIBq4pZv-Lw.png":{"id":"1*rJ1pjMQKA2PrIBq4pZv-Lw.png","__typename":"ImageMetadata","originalHeight":500,"originalWidth":500,"focusPercentX":null,"focusPercentY":null,"alt":null},"ImageMetadata:1*VHGIE55cRs4acQT5EdeEnQ.png":{"id":"1*VHGIE55cRs4acQT5EdeEnQ.png","__typename":"ImageMetadata","originalHeight":500,"originalWidth":960,"focusPercentX":null,"focusPercentY":null,"alt":null},"ImageMetadata:1*w6TH2AaJaMG2_l7ffyapcA.png":{"id":"1*w6TH2AaJaMG2_l7ffyapcA.png","__typename":"ImageMetadata","originalHeight":500,"originalWidth":750,"focusPercentX":null,"focusPercentY":null,"alt":null},"ImageMetadata:1*wXrwOgO6dYz7IitHA4la2Q.jpeg":{"id":"1*wXrwOgO6dYz7IitHA4la2Q.jpeg","__typename":"ImageMetadata","originalHeight":798,"originalWidth":674,"focusPercentX":null,"focusPercentY":null,"alt":null},"ImageMetadata:1*HSx5k89UYIwawJk1kbul6g.jpeg":{"id":"1*HSx5k89UYIwawJk1kbul6g.jpeg","__typename":"ImageMetadata","originalHeight":637,"originalWidth":500,"focusPercentX":null,"focusPercentY":null,"alt":null},"ImageMetadata:1*U-nHez5wQ7jLPUL2rM10MQ.png":{"id":"1*U-nHez5wQ7jLPUL2rM10MQ.png","__typename":"ImageMetadata","originalHeight":1236,"originalWidth":1437,"focusPercentX":null,"focusPercentY":null,"alt":null},"ImageMetadata:1*k1HSPys5BRvB8kkkVHnq8w.jpeg":{"id":"1*k1HSPys5BRvB8kkkVHnq8w.jpeg","__typename":"ImageMetadata","originalHeight":798,"originalWidth":1923,"focusPercentX":null,"focusPercentY":null,"alt":null},"Tag:star-atlas":{"id":"star-atlas","__typename":"Tag"},"Tag:guild":{"id":"guild","__typename":"Tag"},"Tag:community":{"id":"community","__typename":"Tag"},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_d2255ca009c4":{"id":"collectionId:4d89d
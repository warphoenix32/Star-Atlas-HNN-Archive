"0 0 24 24" fill="none"><path d="M19.75 5.39v13.22a1.14 1.14 0 0 1-1.14 1.14H5.39a1.14 1.14 0 0 1-1.14-1.14V5.39a1.14 1.14 0 0 1 1.14-1.14h13.22a1.14 1.14 0 0 1 1.14 1.14zM8.81 10.18H6.53v7.3H8.8v-7.3zM9 7.67a1.31 1.31 0 0 0-1.3-1.32h-.04a1.32 1.32 0 0 0 0 2.64A1.31 1.31 0 0 0 9 7.71v-.04zm8.46 5.37c0-2.2-1.4-3.05-2.78-3.05a2.6 2.6 0 0 0-2.3 1.18h-.07v-1h-2.14v7.3h2.28V13.6a1.51 1.51 0 0 1 1.36-1.63h.09c.72 0 1.26.45 1.26 1.6v3.91h2.28l.02-4.43z" fill="#A8A8A8"></path></svg></span></button></div></div></div><div class="l dw"><div><div class="bk" aria-hidden="false"><button class="ae af ag ah ai aj ak al am an ao ap aq ar as"><span class="bk gk gl gm"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M3.57 14.67c0-.57.13-1.11.38-1.6l.02-.02v-.02l.02-.02c0-.02 0-.02.02-.02.12-.26.3-.52.57-.8L7.78 9v-.02l.01-.02c.44-.41.91-.7 1.44-.85a4.87 4.87 0 0 0-1.19 2.36A5.04 5.04 0 0 0 8 11.6L6.04 13.6c-.19.19-.32.4-.38.65a2 2 0 0 0 0 .9c.08.2.2.4.38.57l1.29 1.31c.27.28.62.42 1.03.42.42 0 .78-.14 1.06-.42l1.23-1.25.79-.78 1.15-1.16c.08-.09.19-.22.28-.4.1-.2.15-.42.15-.67 0-.16-.02-.3-.06-.45l-.02-.02v-.02l-.07-.14s0-.03-.04-.06l-.06-.13-.02-.02c0-.02 0-.03-.02-.05a.6.6 0 0 0-.14-.16l-.48-.5c0-.04.02-.1.04-.15l.06-.12 1.17-1.14.09-.09.56.57c.02.04.08.1.16.18l.05.04.03.06.04.05.03.04.04.06.1.14.02.02c0 .02.01.03.03.04l.1.2v.02c.1.16.2.38.3.68a1 1 0 0 1 .04.25 3.2 3.2 0 0 1 .02 1.33 3.49 3.49 0 0 1-.95 1.87l-.66.67-.97.97-1.56 1.57a3.4 3.4 0 0 1-2.47 1.02c-.97 0-1.8-.34-2.49-1.03l-1.3-1.3a3.55 3.55 0 0 1-1-2.51v-.01h-.02v.02zm5.39-3.43c0-.19.02-.4.07-.63.13-.74.44-1.37.95-1.87l.66-.67.97-.98 1.56-1.56c.68-.69 1.5-1.03 2.47-1.03.97 0 1.8.34 2.48 1.02l1.3 1.32a3.48 3.48 0 0 1 1 2.48c0 .58-.11 1.11-.37 1.6l-.02.02v.02l-.02.04c-.14.27-.35.54-.6.8L16.23 15l-.01.02-.01.02c-.44.42-.92.7-1.43.83a4.55 4.55 0 0 0 1.23-3.52L18 10.38c.18-.21.3-.42.35-.65a2.03 2.03 0 0 0-.01-.9 1.96 1.96 0 0 0-.36-.58l-1.3-1.3a1.49 1.49 0 0 0-1.06-.42c-.42 0-.77.14-1.06.4l-1.2 1.27-.8.8-1.16 1.15c-.08.08-.18.21-.29.4a1.66 1.66 0 0 0-.08 1.12l.02.03v.02l.06.14s.01.03.05.06l.06.13.02.02.01.02.01.02c.05.08.1.13.14.16l.47.5c0 .04-.02.09-.04.15l-.06.12-1.15 1.15-.1.08-.56-.56a2.3 2.3 0 0 0-.18-.19c-.02-.01-.02-.03-.02-.04l-.02-.02a.37.37 0 0 1-.1-.12c-.03-.03-.05-.04-.05-.06l-.1-.15-.02-.02-.02-.04-.08-.17v-.02a5.1 5.1 0 0 1-.28-.69 1.03 1.03 0 0 1-.04-.26c-.06-.23-.1-.46-.1-.7v.01z" fill="#A8A8A8"></path></svg></span></button></div></div></div><div class="bl l"><div><div class="bk" aria-hidden="false"></div></div></div></div></header><span class="l"></span><section><div><div class="ds gv gw gx gy gz"></div><div class="ha hb hc hd he"><div class=""><h1 id="43d6" class="pw-post-title hf hg hh bd hi hj hk hl hm hn ho hp hq hr hs ht hu hv hw hx hy hz ia ib ic id bi">Atlas Brew Society — The IRL Meetings of the Star Atlas Community</h1></div><p id="c73d" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi">On March 25th, the first in real life meeting of the Atlas Brew Society took place in Paris, France at the Bar “Le 38 M” between members of the <a class="jc jd ge" href="https://medium.com/u/5ed69ff9cfb0?source=post_page-----85534fef7500--------------------------------" rel="noopener" target="_blank">Star Atlas</a> team and members of the community.</p><p id="26e4" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi"><em class="je">This article is a translation of the original article written in French by author Ju.</em></p><figure class="jg jh ji jj fd jk er es paragraph-image"><div class="er es jf"><picture><source srcSet="https://miro.medium.com/v2/resize:fit:640/format:webp/0*eQ8qRYgX8T12s80U.jpeg 640w, https://miro.medium.com/v2/resize:fit:720/format:webp/0*eQ8qRYgX8T12s80U.jpeg 720w, https://miro.medium.com/v2/resize:fit:750/format:webp/0*eQ8qRYgX8T12s80U.jpeg 750w, https://miro.medium.com/v2/resize:fit:786/format:webp/0*eQ8qRYgX8T12s80U.jpeg 786w, https://miro.medium.com/v2/resize:fit:828/format:webp/0*eQ8qRYgX8T12s80U.jpeg 828w, https://miro.medium.com/v2/resize:fit:1100/format:webp/0*eQ8qRYgX8T12s80U.jpeg 1100w, https://miro.medium.com/v2/resize:fit:1400/format:webp/0*eQ8qRYgX8T12s80U.jpeg 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/v2/resize:fit:640/0*eQ8qRYgX8T12s80U.jpeg 640w, https://miro.medium.com/v2/resize:fit:720/0*eQ8qRYgX8T12s80U.jpeg 720w, https://miro.medium.com/v2/resize:fit:750/0*eQ8qRYgX8T12s80U.jpeg 750w, https://miro.medium.com/v2/resize:fit:786/0*eQ8qRYgX8T12s80U.jpeg 786w, https://miro.medium.com/v2/resize:fit:828/0*eQ8qRYgX8T12s80U.jpeg 828w, https://miro.medium.com/v2/resize:fit:1100/0*eQ8qRYgX8T12s80U.jpeg 1100w, https://miro.medium.com/v2/resize:fit:1400/0*eQ8qRYgX8T12s80U.jpeg 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px"/><img alt="" class="bf jl jm c" width="700" height="377" loading="eager" role="presentation"/></picture></div></figure><p id="77e4" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi">It all started when Santi (Star Atlas Community Director), decided to come and spend a week in Paris, to visit the capital and spend time with Darwiin (Star Atlas Community Support). Together, they had the idea to take the opportunity to organize, at first informally, a meeting with members of the French-speaking community of Star Atlas.</p><p id="87e6" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi">When Darwiin reached out to the French-speaking community to know if anyone knew of a place in Paris to organize the meeting, PACTwo, one of the particularly active members of Gargantua Industries, immediately proposed “Le 38 M”, a place he knew well. He also proposed to take care of the coordination with the owners of the bar. With the place having been chosen, only a date remained to be selected with March 25th ultimaltey beeing selected.</p><figure class="jg jh ji jj fd jk er es paragraph-image"><div class="er es jf"><picture><source srcSet="https://miro.medium.com/v2/resize:fit:640/format:webp/0*du6v81ATE-bTYqu5.jpeg 640w, https://miro.medium.com/v2/resize:fit:720/format:webp/0*du6v81ATE-bTYqu5.jpeg 720w, https://miro.medium.com/v2/resize:fit:750/format:webp/0*du6v81ATE-bTYqu5.jpeg 750w, https://miro.medium.com/v2/resize:fit:786/format:webp/0*du6v81ATE-bTYqu5.jpeg 786w, https://miro.medium.com/v2/resize:fit:828/format:webp/0*du6v81ATE-bTYqu5.jpeg 828w, https://miro.medium.com/v2/resize:fit:1100/format:webp/0*du6v81ATE-bTYqu5.jpeg 1100w, https://miro.medium.com/v2/resize:fit:1400/format:webp/0*du6v81ATE-bTYqu5.jpeg 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/v2/resize:fit:640/0*du6v81ATE-bTYqu5.jpeg 640w, https://miro.medium.com/v2/resize:fit:720/0*du6v81ATE-bTYqu5.jpeg 720w, https://miro.medium.com/v2/resize:fit:750/0*du6v81ATE-bTYqu5.jpeg 750w, https://miro.medium.com/v2/resize:fit:786/0*du6v81ATE-bTYqu5.jpeg 786w, https://miro.medium.com/v2/resize:fit:828/0*du6v81ATE-bTYqu5.jpeg 828w, https://miro.medium.com/v2/resize:fit:1100/0*du6v81ATE-bTYqu5.jpeg 1100w, https://miro.medium.com/v2/resize:fit:1400/0*du6v81ATE-bTYqu5.jpeg 1400w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 700px"/><img alt="" class="bf jl jm c" width="700" height="394" loading="lazy" role="presentation"/></picture></div><figcaption class="jn jo et er es jp jq bd b be z dx">Santi (1st on the left in the last row) and Darwiin (2nd on the left in the first row), in the company of members of the Star Atlas French-speaking community, in front of the bar “Le 38 M”.</figcaption></figure><p id="2423" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi">After internal discussions on the Star Atlas side, the team decided to make this event the first of a series of IRL meetings and to name these events the Atlas Brew Society. Other events will take place in the future, in different cities around the world, according to the availability and the travels of the Star Atlas team and the community members.</p><p id="fcac" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi">On the evening of March 25th, about twenty-five members of the community, mostly members of the <a class="jc jd ge" href="https://medium.com/u/c33b0043eac3?source=post_page-----85534fef7500--------------------------------" rel="noopener" target="_blank">Gargantua Industries</a> huild, but also of Eclypse, had answered the call of Santi and Darwiin.</p><p id="0e01" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi">The only snag was the absence of Gary Sanchez (Artistic Director and Concept Designer), who unfortunately could not make the trip because of the disruptions caused by the demonstrations that are currently taking place throughout France.</p><p id="657b" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi">Our dear Atlassians were able to taste delicious cocktails, with names inspired by the Lore of Star Atlas, such as the <em class="je">Iris Kiss</em>, <em class="je">The Punaab Whisper</em> or the <em class="je">Ustur Mule</em>, while getting acquainted with each other. It was also an opportunity for Darwiin and Santi to put faces to the nicknames they are used to seeing on the official Star Atlas Discord.</p><figure class="jg jh ji jj fd jk er es paragraph-image"><div class="er es jr"><picture><source srcSet="https://miro.medium.com/v2/resize:fit:640/0*PaW_5AIKpqlhvYJn 640w, https://miro.medium.com/v2/resize:fit:720/0*PaW_5AIKpqlhvYJn 720w, https://miro.medium.com/v2/resize:fit:750/0*PaW_5AIKpqlhvYJn 750w, https://miro.medium.com/v2/resize:fit:786/0*PaW_5AIKpqlhvYJn 786w, https://miro.medium.com/v2/resize:fit:828/0*PaW_5AIKpqlhvYJn 828w, https://miro.medium.com/v2/resize:fit:1100/0*PaW_5AIKpqlhvYJn 1100w, https://miro.medium.com/v2/resize:fit:946/0*PaW_5AIKpqlhvYJn 946w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 473px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/v2/resize:fit:640/0*PaW_5AIKpqlhvYJn 640w, https://miro.medium.com/v2/resize:fit:720/0*PaW_5AIKpqlhvYJn 720w, https://miro.medium.com/v2/resize:fit:750/0*PaW_5AIKpqlhvYJn 750w, https://miro.medium.com/v2/resize:fit:786/0*PaW_5AIKpqlhvYJn 786w, https://miro.medium.com/v2/resize:fit:828/0*PaW_5AIKpqlhvYJn 828w, https://miro.medium.com/v2/resize:fit:1100/0*PaW_5AIKpqlhvYJn 1100w, https://miro.medium.com/v2/resize:fit:946/0*PaW_5AIKpqlhvYJn 946w" sizes="(min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 473px"/><img alt="" class="bf jl jm c" width="473" height="679" loading="lazy" role="presentation"/></picture></div></figure><p id="ae43" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi">The event went on until late in the night, in a friendly and relaxed atmosphere and, according to the people present that night, it was a real success. Everyone left delighted, some of them, like Santi and Darwiin, with T-Shirts offered by Gargantua Industries.</p><p id="fd44" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi">The Star Atlas team had also planned goodies for the members of the community, unfortunately the French customs decided otherwise by blocking the parcel and sending it back to the sender. The team promised to send them later to the people present that night, as well as to the people present at a previous event organized by Morpheus.</p></div><div class="ab cl js jt go ju" role="separator"><span class="jv bw bk jw jx jy"></span><span class="jv bw bk jw jx jy"></span><span class="jv bw bk jw jx"></span></div><div class="ha hb hc hd he"><p id="8fcf" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi">This article was <a class="ae jz" rel="noopener" href="/@Gargantua.Industries/atlas-brew-society-les-rencontres-irl-de-la-communauté-de-star-atlas-98ee9c4c721a">originally written</a> in French by Ju for Gargantua Industries and the Star Atlas community. This article was translated by Krigs of the Hologram with permission by the original author.</p></div><div class="ab cl js jt go ju" role="separator"><span class="jv bw bk jw jx jy"></span><span class="jv bw bk jw jx jy"></span><span class="jv bw bk jw jx"></span></div><div class="ha hb hc hd he"><p id="58bd" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi"><strong class="ig hi">About the Author</strong></p><p id="d4a4" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi"><a class="ae jz" href="https://medium.com/u/41e0c5b141f1?source=post_page-----4922901fb224--------------------------------" rel="noopener">Krigs</a></p><p id="69ad" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi">is a pioneer in the world of Star Atlas, having founded The Hologram News Network — an independent meta-news organization that keeps players up to date on all developments regarding Star Atlas. An ardent supporter of emerging technologies, Krigs has been covering this game for over a year and believes passionately in their power to revolutionize our collective gaming experience.</p><p id="1093" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi">Follow on Social Media:</p><p id="5953" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi"><a class="ae jz" href="https://open.spotify.com/show/2mxndrDW6yPfpS350ijzjt?si=ec7c717f998240d6" rel="noopener ugc nofollow" target="_blank">Podcast</a> | <a class="ae jz" href="https://www.youtube.com/channel/UCDa-YxgNG6A9xpH1qyP0OaQ" rel="noopener ugc nofollow" target="_blank">YouTube</a> | <a class="ae jz" href="https://twitter.com/home" rel="noopener ugc nofollow" target="_blank">Twitter</a> | <a class="ae jz" href="https://twitter.com/home" rel="noopener ugc nofollow" target="_blank">Instagram</a> | <a class="ae jz" href="https://thehologram.io/" rel="noopener ugc nofollow" target="_blank">Web</a></p><p id="fcb4" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi"><strong class="ig hi">About The Hologram</strong></p><p id="52d7" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi"><a class="ae jz" href="https://medium.com/the-hologram" rel="noopener">The Hologram</a> is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.</p><p id="1588" class="pw-post-body-paragraph ie if hh ig b ih ii ij ik il im in io ip iq ir is it iu iv iw ix iy iz ja jb ha bi">The Hologram is not endorsed or paid by the <a class="ae jz" href="https://staratlas.com/" rel="noopener ugc nofollow" target="_blank">Star Atlas</a> team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.</p></div></div></section></div></div></article></div></div></div><div class="ab cl"><div class="dk bf dl dm dn do"><div class="ka kb ab gf"><div class="kc ab"><a class="kd aw al ke" rel="noopener follow" href="/tag/star-atlas?source=post_page-----85534fef7500---------------star_atlas-----------------"><div class="kf di du kg kh ki bd b be z bi kj">Star Atlas</div></a></div><div class="kc ab"><a class="kd aw al ke" rel="noopener follow" href="/tag/community?source=post_page-----85534fef7500---------------community-----------------"><div class="kf di du kg kh ki bd b be z bi kj">Community</div></a></div></div></div></div><div class="l"></div><footer class="kk kl km kn ko kp kq kr ks ab q kt ku c"><div class="l ad"><div class="ab cl"><div class="dk bf dl dm dn do"><div class="ab ff kv"><div class="ab q cb"><div class="kw l"><span class="l fm kx ky e d"><div class="ab q cb"><div class="pw-multi-vote-icon di kz la lb lc"><div class=""><div class="ld le lf lg lh li lj al lk ll lm lc"><svg width="24" height="24" viewBox="0 0 24 24" aria-label="clap"><path fill-rule="evenodd" clip-rule="evenodd" d="M11.37.83L12 3.28l.63-2.45h-1.26zM15.42 1.84l-1.18-.39-.34 2.5 1.52-2.1zM9.76 1.45l-1.19.4 1.53 2.1-.34-2.5zM20.25 11.84l-2.5-4.4a1.42 1.42 0 0 0-.93-.64.96.96 0 0 0-.75.18c-.25.19-.4.42-.45.7l.05.05 2.35 4.13c1.62 2.95 1.1 5.78-1.52 8.4l-.46.41c1-.13 1.93-.6 2.78-1.45 2.7-2.7 2.51-5.59 1.43-7.38zM12.07 9.01c-.13-.69.08-1.3.57-1.77l-2.06-2.07a1.12 1.12 0 0 0-1.56 0c-.15.15-.22.34-.27.53L12
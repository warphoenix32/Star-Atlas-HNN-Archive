oTitle":"","updatedAt":1681942144225,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"isSuspended":false,"pinnedAt":0,"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}},"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg","originalWidth":2730,"focusPercentX":48.57142857142857,"focusPercentY":45.19230769230769},"NewsletterV3:ac886d6987e0":{"__typename":"NewsletterV3","slug":"holoreport","id":"ac886d6987e0","name":"HoloReport","description":"Catch up on the latest Star Atlas news that you've missed. ","promoHeadline":"","promoBody":"","type":"NEWSLETTER_TYPE_COLLECTION","user":{"__ref":"User:41e0c5b141f1"},"collection":{"__ref":"Collection:4d89daa6ae31"},"showPromo":true},"LinkedAccounts:41e0c5b141f1":{"__typename":"LinkedAccounts","mastodon":null,"id":"41e0c5b141f1"},"Post:bff20fd1e3c":{"__typename":"Post","id":"bff20fd1e3c"},"PostViewerEdge:postId:a219c8390d5b-viewerId:lo_c3ff197b615e":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:a219c8390d5b-viewerId:lo_c3ff197b615e"},"Paragraph:3da4954478a8_0":{"__typename":"Paragraph","id":"3da4954478a8_0","name":"6498","type":"H3","href":null,"layout":null,"metadata":null,"text":"Have Star Atlas Researchers Discovered the Origins of the Tufa Race?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_1":{"__typename":"Paragraph","id":"3da4954478a8_1","name":"f3b8","type":"P","href":null,"layout":null,"metadata":null,"text":"The Tufa are a mysterious race of sentient organic rock-beings that populate the High-Risk Zone of Galia, the sector that Star Atlas is set in. However, their origins to date have largely been unknown.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_2":{"__typename":"Paragraph","id":"3da4954478a8_2","name":"7101","type":"P","href":null,"layout":null,"metadata":null,"text":"WARNING: This article contains spoilers for Star Atlas CORE Episodes 1 and 6","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":9,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_3":{"__typename":"Paragraph","id":"3da4954478a8_3","name":"8dd7","type":"H4","href":null,"layout":null,"metadata":null,"text":"What we know about the Tufa so far","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":34,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_4":{"__typename":"Paragraph","id":"3da4954478a8_4","name":"fab5","type":"P","href":null,"layout":null,"metadata":null,"text":"For nearly two years of contemporary Star Atlas history, scant details regarding the origins, makeup, and society of the Tufa species. All that we know thus far is that the Tufa are an amalgamation of sentient organic space rock that live in the deepest parts of the High-Risk Zone nearest the center of the Cataclysm and Iris herself.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*vn-XtQs0s08xamd1":{"__typename":"ImageMetadata","id":"0*vn-XtQs0s08xamd1","originalHeight":911,"originalWidth":2000,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:3da4954478a8_5":{"__typename":"Paragraph","id":"3da4954478a8_5","name":"a0bb","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*vn-XtQs0s08xamd1"},"text":"The Tufa Feist Small Fighter","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_6":{"__typename":"Paragraph","id":"3da4954478a8_6","name":"b968","type":"P","href":null,"layout":null,"metadata":null,"text":"Tufa ships themselves being of the same Geo-biological makeup as Tufa beings, space explorers venturing into asteroid belts of the High-Risk Zone often find themselves ambushed by the infamous Tufa Feist.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_7":{"__typename":"Paragraph","id":"3da4954478a8_7","name":"c190","type":"H4","href":null,"layout":null,"metadata":null,"text":"First Documented Interactions of the Tufa","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":41,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_8":{"__typename":"Paragraph","id":"3da4954478a8_8","name":"b604","type":"P","href":null,"layout":null,"metadata":null,"text":"In the first episode of Star Atlas CORE, the main characters are on the search for valuable resources when they encounter a terrifying amorphous being that seemingly erupted from the ground beneath them.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*aJ1Xao0dVnWl2pLe6ysL5w.png":{"__typename":"ImageMetadata","id":"1*aJ1Xao0dVnWl2pLe6ysL5w.png","originalHeight":474,"originalWidth":569,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:3da4954478a8_9":{"__typename":"Paragraph","id":"3da4954478a8_9","name":"563f","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*aJ1Xao0dVnWl2pLe6ysL5w.png"},"text":"Star Atlas CORE Episode 1","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_10":{"__typename":"Paragraph","id":"3da4954478a8_10","name":"8d7d","type":"P","href":null,"layout":null,"metadata":null,"text":"While a clear depiction of the creature is never named or revealed, the unnamed creature exhibits similar behaviors to the Tufa. This creature erupts from earth and stone to attack the story’s heroes.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_11":{"__typename":"Paragraph","id":"3da4954478a8_11","name":"b454","type":"P","href":null,"layout":null,"metadata":null,"text":"At the time, many scientists speculated that this could have been an encounter with the Tufa, but little additional evidence was available to make a firm conclusion.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_12":{"__typename":"Paragraph","id":"3da4954478a8_12","name":"46f4","type":"H4","href":null,"layout":null,"metadata":null,"text":"Timpo’s Journey Through Time and Space","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":38,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_13":{"__typename":"Paragraph","id":"3da4954478a8_13","name":"bb5f","type":"P","href":null,"layout":null,"metadata":null,"text":"It would be several months between CORE Episode 1 and Episode 6, however, Episode 6’s arc finale brings some additional details to light.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_14":{"__typename":"Paragraph","id":"3da4954478a8_14","name":"1a9c","type":"P","href":null,"layout":null,"metadata":null,"text":"During the arc’s finale, the hero’s new found companion Timpo reveals that he was stuck in a space time rift. On the other side of this rift, he encountered rocks laced with Genesium, similar to the ones that the heroes found in Episode 1.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":93,"end":108,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":157,"end":182,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*wmxYwWBoJh2uHUOBODzabg.png":{"__typename":"ImageMetadata","id":"1*wmxYwWBoJh2uHUOBODzabg.png","originalHeight":274,"originalWidth":646,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:3da4954478a8_15":{"__typename":"Paragraph","id":"3da4954478a8_15","name":"a2f4","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*wmxYwWBoJh2uHUOBODzabg.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*vRwUgOtR8kBWPDV2pY2oyA.png":{"__typename":"ImageMetadata","id":"1*vRwUgOtR8kBWPDV2pY2oyA.png","originalHeight":659,"originalWidth":648,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:3da4954478a8_16":{"__typename":"Paragraph","id":"3da4954478a8_16","name":"b2b7","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*vRwUgOtR8kBWPDV2pY2oyA.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_17":{"__typename":"Paragraph","id":"3da4954478a8_17","name":"ee12","type":"P","href":null,"layout":null,"metadata":null,"text":"Genesium, Timpo describes, is a rare resource that can usher in a new dawn of of engineering and space exploration, making its owners the most powerful force in the galaxy.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":9,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_18":{"__typename":"Paragraph","id":"3da4954478a8_18","name":"dab1","type":"H4","href":null,"layout":null,"metadata":null,"text":"Tufa beings from another space-time continuum?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_19":{"__typename":"Paragraph","id":"3da4954478a8_19","name":"bc05","type":"P","href":null,"layout":null,"metadata":null,"text":"Seeing as how the space-time rift, Genesium, and tufa-like beings are all related, its highly likely that either Genesium or the rock-like creatures came from the space-time rift itself. If Timpo could survive the rift, what’s to say that other beings couldn’t? In fact, Timpo states that he intends to traverse the space-time rift again to reach the other side.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_20":{"__typename":"Paragraph","id":"3da4954478a8_20","name":"6c13","type":"P","href":null,"layout":null,"metadata":null,"text":"This would heavily imply that the Tufa are beings from outside the Galia expanse and leads to many other questions to ponder","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":124,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_21":{"__typename":"Paragraph","id":"3da4954478a8_21","name":"1ac8","type":"H4","href":null,"layout":null,"metadata":null,"text":"Are the Photoli Involved?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_22":{"__typename":"Paragraph","id":"3da4954478a8_22","name":"fe37","type":"P","href":null,"layout":null,"metadata":null,"text":"The origins of the space-time rift remain unexplained. However, Timpo leaves another hint as to who or what caused the space rift.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*b3JBinaRErxOc2cXTiH6sw.png":{"__typename":"ImageMetadata","id":"1*b3JBinaRErxOc2cXTiH6sw.png","originalHeight":275,"originalWidth":573,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:3da4954478a8_23":{"__typename":"Paragraph","id":"3da4954478a8_23","name":"d12d","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*b3JBinaRErxOc2cXTiH6sw.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_24":{"__typename":"Paragraph","id":"3da4954478a8_24","name":"c953","type":"P","href":null,"layout":null,"metadata":null,"text":"In the above panel, Timpo reveals a device that acts as a temporal distortion inhibitor is actually a combination of Genesium and Photolic magic.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_25":{"__typename":"Paragraph","id":"3da4954478a8_25","name":"b58d","type":"P","href":null,"layout":null,"metadata":null,"text":"If the combination of Photolic magic and Genesium is capable of stabilizing space-time, what’s to say that it also isn’t capable of disrupting it?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_26":{"__typename":"Paragraph","id":"3da4954478a8_26","name":"b5c9","type":"P","href":null,"layout":null,"metadata":null,"text":"This would also imply that the Photoli are involved in creating the space-time rift and brining Genesium, Tufa, or both to Galia.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":129,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_27":{"__typename":"Paragraph","id":"3da4954478a8_27","name":"6883","type":"P","href":null,"layout":null,"metadata":null,"text":"We know that the Photoli were capable of manipulating the entire human race into leaving Earth. Manipulating a sentient rock like species to move to another galaxy seems a play right from their book.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_28":{"__typename":"Paragraph","id":"3da4954478a8_28","name":"45c9","type":"P","href":null,"layout":null,"metadata":null,"text":"Could the Photoli also be causal in the Cataclysm and Iris herself?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":67,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*91ZIxLy9ZdPshxET0bUXuA.png":{"__typename":"ImageMetadata","id":"1*91ZIxLy9ZdPshxET0bUXuA.png","originalHeight":159,"originalWidth":894,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:3da4954478a8_29":{"__typename":"Paragraph","id":"3da4954478a8_29","name":"f069","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*91ZIxLy9ZdPshxET0bUXuA.png"},"text":"Voice of Iris Episode 6","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_30":{"__typename":"Paragraph","id":"3da4954478a8_30","name":"9854","type":"P","href":null,"layout":null,"metadata":null,"text":"Lastly, this transmission from the Voice of Iris reveals that the High-Risk Zone, Iris, and the Cataclysm all have a reality-distorting effect.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_31":{"__typename":"Paragraph","id":"3da4954478a8_31","name":"7d9b","type":"P","href":null,"layout":null,"metadata":null,"text":"The space-time rift, High-Risk zone, Iris, Photoli, Tufa, and Genesium are all seemingly becoming more and more related.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_32":{"__typename":"Paragraph","id":"3da4954478a8_32","name":"eeb4","type":"H4","href":null,"layout":null,"metadata":null,"text":"Questions Unanswered","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_33":{"__typename":"Paragraph","id":"3da4954478a8_33","name":"b4a6","type":"P","href":null,"layout":null,"metadata":null,"text":"These discoveries, while revealing, lead to a host of more questions unto themselves.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_34":{"__typename":"Paragraph","id":"3da4954478a8_34","name":"cfcf","type":"ULI","href":null,"layout":null,"metadata":null,"text":"What caused the space-time rift?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_35":{"__typename":"Paragraph","id":"3da4954478a8_35","name":"eb1e","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Are the Tufa a race of invaders or simply misfortunate beings caught up in another Photoli plot?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_36":{"__typename":"Paragraph","id":"3da4954478a8_36","name":"b81f","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Is Genesium a naturally occurring Galian resource or was it dumped here from the explosion of the space-time rift?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_37":{"__typename":"Paragraph","id":"3da4954478a8_37","name":"97ce","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Are the Tufa dependent on Genesium to live?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_38":{"__typename":"Paragraph","id":"3da4954478a8_38","name":"ae83","type":"P","href":null,"layout":null,"metadata":null,"text":"For now, these questions will have to remain unanswered. Undoubtedly, our collective journey into Star Atlas will shed light on the darkest corners of the The Cataclysm.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_39":{"__typename":"Paragraph","id":"3da4954478a8_39","name":"6777","type":"P","href":null,"layout":null,"metadata":null,"text":"What are your thoughts?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":23,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_40":{"__typename":"Paragraph","id":"3da4954478a8_40","name":"7a34","type":"P","href":null,"layout":null,"metadata":null,"text":"Leave us a comment below or on Twitter and let’s hear what your theories are!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:23f47235f1179d85e7554410957ac5b9":{"__typename":"MediaResource","id":"23f47235f1179d85e7554410957ac5b9","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?type=text%2Fhtml&key=a19fcc184b9711e1b4764040d3dc5c07&schema=twitter&url=http%3A\u002F\u002Ftwitter.com\u002FHologram_News\u002Fstatus\u002F1648810739510165504&image=","iframeHeight":281,"iframeWidth":500,"title":"The Hologram | HNN on Twitter: \"🔥Have Star Atlas researchers discovered the origins of the Tufa? 💡The release of CORE Episode 6 sheds some light into these mysterious beings. 🚨WARNING: Spoilers below!@staratlas @WeAreStarAtlas @Jojocryptoquest @matthewmedney https:\u002F\u002Ft.co\u002FBlpV6nW5fr \u002F Twitter\""},"Paragraph:3da4954478a8_41":{"__typename":"Paragraph","id":"3da4954478a8_41","name":"5e03","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:23f47235f1179d85e7554410957ac5b9"}},"mixtapeMetadata":null},"Paragraph:3da4954478a8_42":{"__typename":"Paragraph","id":"3da4954478a8_42","name":"eeaa","type":"H4","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_43":{"__typename":"Paragraph","id":"3da4954478a8_43","name":"ab52","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":5,"href":"https:\u002F\u002Fmedium.com\u002Fu\u002F41e0c5b141f1?source=post_page-----4922901fb224--------------------------------","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_44":{"__typename":"Paragraph","id":"3da4954478a8_44","name":"457d","type":"P","href":null,"layout":null,"metadata":null,"text":"is a pioneer in the world of Star Atlas, having founded The Hologram News Network — an independent meta-news organization that keeps players up to date on all developments regarding Star Atlas. An ardent supporter of emerging technologies, Krigs has been covering this game for over a year and believes passionately in their power to revolutionize our collective gaming experience.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_45":{"__typename":"Paragraph","id":"3da4954478a8_45","name":"0553","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_46":{"__typename":"Paragraph","id":"3da4954478a8_46","name":"f5f1","type":"P","href":null,"layout":null,"metadata":null,"text":"Podcast | YouTube | Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Fopen.spotify.com\u002Fshow\u002F2mxndrDW6yPfpS350ijzjt?si=ec7c717f998240d6","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":17,"href":"https:\u002F\u002Fwww.youtube.com\u002Fchannel\u002FUCDa-YxgNG6A9xpH1qyP0OaQ","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":20,"end":27,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":30,"end":39,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":42,"end":45,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_47":{"__typename":"Paragraph","id":"3da4954478a8_47","name":"949d","type":"H4","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_48":{"__typename":"Paragraph","id":"3da4954478a8_48","name":"159d","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:3da4954478a8_49":{"__typename":"Paragraph","id":"3da4954478a8_49","name":"b31c","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_c3ff197b615e":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_c3ff197b615e","isEditor":false},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"Tag:lore":{"__typename":"Tag","id":"lore","displayTitle":"Lore","normalizedTagSlug":"lore"},"Tag:theory":{"__typename":"Tag","id":"theory","displayTitle":"Theory","normalizedTagSlug":"theory"}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"HIT","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.533e66cd.js"></script><script src="https://cdn-client.medium.com/lite/static/js/2637.f87ac379.js"></script><script src="https://cdn-client.medium.com/lite/static/js/main.d7f11cc1.js"></script><script src="https://cdn-client.medium.com/lite/static/js/instrum
:1*KC6bipvqvlo3aV8wdaY50w.png":{"id":"1*KC6bipvqvlo3aV8wdaY50w.png","__typename":"ImageMetadata","alt":null,"focusPercentX":null,"focusPercentY":null},"Post:edfea5979b3e":{"id":"edfea5979b3e","__typename":"Post","title":"An ordinary day in the Metaverse","mediumUrl":"https:\u002F\u002Fmedium.com\u002F@xzanxzacs\u002Fan-ordinary-day-in-the-metaverse-edfea5979b3e","creator":{"__ref":"User:739faa340ed5"},"previewContent":{"__typename":"PreviewContent","subtitle":"Good day, dear readers!\nToday we will dream on about what life will be in our metaverse with you.\nLife in a vast universe, perhaps as big…","isFullContent":false},"collection":null,"previewImage":{"__ref":"ImageMetadata:1*KC6bipvqvlo3aV8wdaY50w.png"},"clapCount":1,"visibility":"PUBLIC","isSeries":false,"sequence":null,"uniqueSlug":"an-ordinary-day-in-the-metaverse-edfea5979b3e"},"User:5c878300e899":{"id":"5c878300e899","__typename":"User","imageId":"1*NKp3uPAenJM0JxsnR7bxCg@2x.jpeg","mediumMemberAt":0,"name":"Andres Sutherland","username":"Sutherland78","customDomainState":null,"hasSubdomain":false,"bio":""},"Collection:6fcc77644ba0":{"id":"6fcc77644ba0","__typename":"Collection","name":"The Club Guild","domain":null,"slug":"the-club-guild"},"ImageMetadata:1*4YDA985DEFHU2drwL8Kdow.jpeg":{"id":"1*4YDA985DEFHU2drwL8Kdow.jpeg","__typename":"ImageMetadata","alt":null,"focusPercentX":null,"focusPercentY":null},"Post:266846bd2d7b":{"id":"266846bd2d7b","__typename":"Post","title":"The Story Behind DAOcaster. Master Communicator Of The Metaverse!","mediumUrl":"https:\u002F\u002Fmedium.com\u002Fthe-club-guild\u002Fthe-story-behind-daocaster-master-communicator-of-the-metaverse-266846bd2d7b","creator":{"__ref":"User:5c878300e899"},"previewContent":{"__typename":"PreviewContent","subtitle":"I would love to be able to communicate well, I still get anxious when I am front and center and all eyes are on me. One thing is to be able…","isFullContent":false},"collection":{"__ref":"Collection:6fcc77644ba0"},"previewImage":{"__ref":"ImageMetadata:1*4YDA985DEFHU2drwL8Kdow.jpeg"},"clapCount":1,"visibility":"PUBLIC","isSeries":false,"sequence":null,"uniqueSlug":"the-story-behind-daocaster-master-communicator-of-the-metaverse-266846bd2d7b"},"ImageMetadata:1*_QlVG6XBAcbqXVvmi6-8VQ.jpeg":{"id":"1*_QlVG6XBAcbqXVvmi6-8VQ.jpeg","__typename":"ImageMetadata","originalHeight":3873,"originalWidth":3873},"Post:3d7f844511f6":{"id":"3d7f844511f6","__typename":"Post"},"Paragraph:790e148b50d5_0":{"id":"790e148b50d5_0","__typename":"Paragraph","name":"846a","text":"Pearce F4 or the Calico ATS Enforcer, A Comparison","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_1":{"id":"790e148b50d5_1","__typename":"Paragraph","name":"d11a","text":"April 21 — Today marks the release of only the second Medium sized fighter in the Star Atlas marketplace. Until today, the Pearce F4 was the only ship of its size and class. With the release of the Calico ATS Enforcer, how do these two ships stack up against one another?","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_2":{"id":"790e148b50d5_2","__typename":"Paragraph","name":"fc79","text":"Pearce F4","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":9,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_3":{"id":"790e148b50d5_3","__typename":"Paragraph","name":"e20f","text":"","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*qqzhJfAqsK-OoSzPDPvYzA.png"},"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_4":{"id":"790e148b50d5_4","__typename":"Paragraph","name":"7868","text":"Calico Air to Space (ATS) Enforcer","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":34,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_5":{"id":"790e148b50d5_5","__typename":"Paragraph","name":"3471","text":"","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*x5vSmdl3VSIMXGRbnlktxg.png"},"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_6":{"id":"790e148b50d5_6","__typename":"Paragraph","name":"38af","text":"With relatively few ships in the Medium Fighter Class category, it becomes important to understand the advantages each ship has when compared to similarly designed ships. The Calico ATS Enforcer is only the second ship in this category to be released to the general public. Additionally, only one more Medium Fighter will be released during the Galactic Asset Offering Phase 2. The Ogrika Tursic, unreleased at this point, will round out the eventual trio of Medium Fighters. In one-on-one combat scenarios, this could turn into a rock-paper-scissor engagement strategy for Medium Fighter fleets.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":382,"end":395,"href":"https:\u002F\u002Fdownloads.ctfassets.net\u002F2kg7h835bpe1\u002F67tpxRVAHfZEg035KwH5HQ\u002Fd1bb7c860fe1c98b2ae27bc49dcc5427\u002FStarAtlas-GAO-2.pdf","anchorType":"LINK","userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_7":{"id":"790e148b50d5_7","__typename":"Paragraph","name":"be49","text":"To better understand the capabilities of each ship, let’s take a look at some of the key differences that set these two ships apart.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_8":{"id":"790e148b50d5_8","__typename":"Paragraph","name":"afe1","text":"Combat","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":6,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_9":{"id":"790e148b50d5_9","__typename":"Paragraph","name":"5f7b","text":"Faction Aligned Company","type":"H4","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_10":{"id":"790e148b50d5_10","__typename":"Paragraph","name":"0266","text":"The F4 is manufactured by the Pearce company. A MUD aligned company, Pearce heavily specializes in producing the best ships for military use. So highly regarded is the F4’s military prowess, it has become the official standard issue Medium Fighter for Council of Peace fleets.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_11":{"id":"790e148b50d5_11","__typename":"Paragraph","name":"68fe","text":"The ATS is a stunning new design from Calico. Calico is a MUD oriented company with a smaller ONI influence within its corporation. Calico does not have an identified production specialization, but its blend of MUD\u002FONI influence should give the ATS an edge in stealthier patrol operations.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_12":{"id":"790e148b50d5_12","__typename":"Paragraph","name":"5ea9","text":"Looking at Faction Aligned Company alone and in a direct head-on fight, the F4 should outclass the ATS a majority of the time.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":44,"end":125,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_13":{"id":"790e148b50d5_13","__typename":"Paragraph","name":"0952","text":"Components and Modules","type":"H4","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":22,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_14":{"id":"790e148b50d5_14","__typename":"Paragraph","name":"2bff","text":"The F4 and ATS are nearly identical when it comes to components and modules. There is, however, one key distinction between the two ships. The F4 comes standard with two large weapon hardpoint slots. These two weapon hardpoints allow the F4 to continuously dominate its opponents with consistent fire.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":77,"end":137,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":139,"end":198,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_15":{"id":"790e148b50d5_15","__typename":"Paragraph","name":"5be7","text":"Surprisingly, instead of two large weapons, the ATS opts for a single capital sized weapon slot supplemented by two medium weapon hardpoints. This oversized weapon on a medium ship allows the ATS to completely devastate any ship in its sights. However, being that it has only one capital weapon which likely requires a significant time to recharge, we suspect that the ATS is incapable of prolonged combat without additional support.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":45,"end":140,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_16":{"id":"790e148b50d5_16","__typename":"Paragraph","name":"d906","text":"Some might compare the ATS Capital Weapon to the A-10s 30mm GAU-8 Avenger Cannon. Is Calico even trying to be original?","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*SHgLjoROfKNCdYv8.jpg"},"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_17":{"id":"790e148b50d5_17","__typename":"Paragraph","name":"abe0","text":"Tactical Application","type":"H4","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":20,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_18":{"id":"790e148b50d5_18","__typename":"Paragraph","name":"c75d","text":"The F4 represents raw, direct, and sustained fleet combat power. A pair or trio of F4s can make short work of many small to medium sized fleets. The F4 is also much smaller in size compared to the ATS. This would ideally give the F4 a maneuvering advantage over the ATS making the F4 much harder to target. Conversely, the ATS would give the F4’s targeting computers a simpler solution for tracking and engagement.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":63,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_19":{"id":"790e148b50d5_19","__typename":"Paragraph","name":"2c9e","text":"There is a scenario, however, that plays to the ATS’s strengths and advantages. Owing to its ONI influence, the ATS posseses a much greater aptitude for stealth application than the F4. While ONI stealth systems still remain a mystery, the stealth systems aboard the ATS could give it enough time to launch a surprise first strike attack against an F4. Coming from its long range capital weapon, a critical hit against an F4 from the ATS main weapon would likely disable the F4 outright. At the very least, it could significantly tilt the next few moments of combat in favor of the F4.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":108,"end":184,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":353,"end":487,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_20":{"id":"790e148b50d5_20","__typename":"Paragraph","name":"aa26","text":"Economics","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":9,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_21":{"id":"790e148b50d5_21","__typename":"Paragraph","name":"f1ab","text":"Pearce F4 Crew Loading","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*PmAn05AiYGeX3QH3ePKong.png"},"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_22":{"id":"790e148b50d5_22","__typename":"Paragraph","name":"cdbb","text":"Calico ATS Tandem Cockpit","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*hOL0HSXCZCMlI6xl_KacgA.png"},"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_23":{"id":"790e148b50d5_23","__typename":"Paragraph","name":"6736","text":"Crew","type":"H4","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":4,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_24":{"id":"790e148b50d5_24","__typename":"Paragraph","name":"5084","text":"Interestingly, the ATS has space for only two crewmembers compared to the F4's five person crew. The ATS cockpit is designed like 21st Century Earth Era Fighter Aircraft. It has a two person tandem cockpit for a single pilot and a single copilot. On the other hand, the F4 is a more traditional spacefaring vessel, crewed by a Captain, pilot, co-pilot, engineer, and gunner. Perhaps the ATS exhibits undisclosed advantages in atmospheric flight as its namesake would imply.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":15,"end":96,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_25":{"id":"790e148b50d5_25","__typename":"Paragraph","name":"af7c","text":"Crew resource management is also a concern for the ATS. A medium sized ship places a significant workload on two people. The pilot and co-pilot must work in perfect unison to complete a variety of shared tasks successfully. The tandem design of the ATS cockpits also appears to leave little room for crew comforts, increasing the fatigue of crewmembers during extended missions.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_26":{"id":"790e148b50d5_26","__typename":"Paragraph","name":"e4a5","text":"Price\nComparing origination prices, the ATS is valued slightly cheaper than the F4. At initial release, the ATS can be acquired for 2,245 $USDC. The F4 was originally listed at 2,500 $USDC, although buyers can find used F4s for approximately 2,000 $USDC.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":6,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":107,"end":143,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":199,"end":253,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_27":{"id":"790e148b50d5_27","__typename":"Paragraph","name":"d62d","text":"SCORE and SCREAM \nFor SCORE, ship owners can expect the F4 to generate slightly better rewards than the ATS. The F4 currently generates just under 119 $ATLAS per day with a moderate food supply of just under four days. The ATS will likely perform similar to the F4, albeit with slightly reduced results.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":27,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":44,"end":108,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_28":{"id":"790e148b50d5_28","__typename":"Paragraph","name":"7a78","text":"However, this could potentially change for SCREAM when it is released later this year. During Atlas Brew #10, SCREAM designer Chypto stated that SCREAM would factor in different ship mechanics like crew size to determine resource burn rates and rewards. This could mean that the ATS may become more efficient than the F4 at SCREAM, outperforming the F4 during particular missions. Additionally, the ATS should carry a minor stealth capability with it that would have a heavier impact during SCREAM. Currently, SCORE does not account for any stealth mechanics or features.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":49,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":87,"end":254,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_29":{"id":"790e148b50d5_29","__typename":"Paragraph","name":"dd5e","text":"Final Comparison","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_30":{"id":"790e148b50d5_30","__typename":"Paragraph","name":"65d0","text":"The decision to either develop a fleet around the F4 or the ATS will have to be determined by fleet captains and guild fleet managers. The F4 and the ATS represent two different and distinct engagement strategies in the plane of combat. The F4, a Council of Peace standard, is designed to bring direct firepower immediately to the fight. The ATS, a capital weapon carrying behemoth, combines elements of surprise strike with devastating firepower to quickly defeat adversaries. For now, the F4 remains at a slight advantage to the ATS. We shall see how the ATS fares when SCREAM flips the script on mission mechanics.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_31":{"id":"790e148b50d5_31","__typename":"Paragraph","name":"f5cd","text":"Bonus","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":5,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}]},"Paragraph:790e148b50d5_32":{"id":"790e148b50d5_32","__typename":"Paragraph","name":"067f","text":"We think the ATS looks oddly similar to the XXXG-01W Wing Gundam. Really Calico?","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*awio4VbJb6oiNbBbTeTGFA.jpeg"},"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_33":{"id":"790e148b50d5_33","__typename":"Paragraph","name":"e9c1","text":"About The Hologram","type":"H3","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_34":{"id":"790e148b50d5_34","__typename":"Paragraph","name":"813c","text":"The Hologram is an independent news organization dedicated to covering the latest Star Atlas content from all sides. The Hologram was founded on the principle of uniting creators from across their diverse fields and showcasing their talent. The Hologram also recognizes the importance of our reader’s time and will always strive to give you what you need, when you need it.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"Paragraph:790e148b50d5_35":{"id":"790e148b50d5_35","__typename":"Paragraph","name":"ab0a","text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram or its writers should be considered as informational in nature and does not constitute any financial advice.","type":"P","href":null,"layout":null,"metadata":null,"hasDropCap":null,"iframe":null,"mixtapeMetadata":null,"dropCapImage":null,"markups":[]},"ImageMetadata:1*qqzhJfAqsK-OoSzPDPvYzA.png":{"id":"1*qqzhJfAqsK-OoSzPDPvYzA.png","__typename":"ImageMetadata","originalHeight":1119,"originalWidth":2154,"focusPerc
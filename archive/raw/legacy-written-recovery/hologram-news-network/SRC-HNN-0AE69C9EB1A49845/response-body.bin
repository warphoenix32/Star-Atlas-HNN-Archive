lver-key-land-mint-details-2dda7fe56b4b"},"Collection:7bfbf7a7ceed":{"__typename":"Collection","id":"7bfbf7a7ceed","slug":"bcmhunt","name":"bcmhunt","domain":"blog.bcmhunt.com"},"User:eb385893b789":{"__typename":"User","id":"eb385893b789","imageId":"1*ovAvjBRNHPyJ7tgqm4K3ew.jpeg","mediumMemberAt":0,"name":"Blockchain Monsters Hunt","username":"quynhhuongngo.ftu","customDomainState":null,"hasSubdomain":false,"bio":""},"ImageMetadata:1*mmi3e9QKd8BwLSr9A2wwAA.jpeg":{"__typename":"ImageMetadata","id":"1*mmi3e9QKd8BwLSr9A2wwAA.jpeg","alt":null,"focusPercentX":null,"focusPercentY":null},"Post:fde2396acb9e":{"__typename":"Post","id":"fde2396acb9e","visibility":"PUBLIC","previewContent":{"__typename":"PreviewContent","isFullContent":false,"subtitle":"Ready for another round of BCMHunt’s low-effort, high-reward game mode?"},"collection":{"__ref":"Collection:7bfbf7a7ceed"},"title":"The 3rd Staking Cycle Is Around The Corner","mediumUrl":"https:\u002F\u002Fblog.bcmhunt.com\u002Fthe-3rd-staking-cycle-is-around-the-corner-fde2396acb9e","creator":{"__ref":"User:eb385893b789"},"previewImage":{"__ref":"ImageMetadata:1*mmi3e9QKd8BwLSr9A2wwAA.jpeg"},"clapCount":2,"isSeries":false,"sequence":null,"uniqueSlug":"the-3rd-staking-cycle-is-around-the-corner-fde2396acb9e"}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"EXPIRED","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.397ffd64.js"></script><script src="https://cdn-client.medium.com/lite/static/js/3555.012b8c42.js"></script><script src="https://cdn-client.medium.com/lite/static/js/main.3b044d3d.js"></script><script src="https://cdn-client.medium.com/lite/static/js/instrumentation.c71f0248.chunk.js"></script>

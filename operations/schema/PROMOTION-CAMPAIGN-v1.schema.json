{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-atlas-archive.local/schemas/promotion-campaign-v1.schema.json",
  "title": "Simplified Promotion Campaign Report v1",
  "type": "object",
  "required": [
    "pipeline_version",
    "campaign_id",
    "current_stage",
    "merge_authority",
    "stages",
    "preservation",
    "candidates",
    "human_review_queue",
    "research_gaps",
    "summary",
    "validation"
  ],
  "properties": {
    "pipeline_version": {"const": "1.0"},
    "campaign_id": {"type": "string", "minLength": 1},
    "current_stage": {"enum": ["PRESERVE", "DRAFT", "REVIEW", "PUBLISH"]},
    "merge_authority": {"const": "HUMAN_OR_BRANCH_PROTECTION"},
    "stages": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["stage", "status"],
        "properties": {
          "stage": {"enum": ["PRESERVE", "DRAFT", "REVIEW", "PUBLISH"]},
          "status": {"enum": ["PENDING", "IN_PROGRESS", "COMPLETE", "BLOCKED"]}
        },
        "additionalProperties": true
      }
    },
    "preservation": {
      "type": "object",
      "required": ["source_ids", "raw_immutable", "provenance_complete", "normalization_deterministic"],
      "properties": {
        "source_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "raw_immutable": {"type": "boolean"},
        "provenance_complete": {"type": "boolean"},
        "normalization_deterministic": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "candidates": {
      "type": "array",
      "items": {"$ref": "#/$defs/candidate"}
    },
    "human_review_queue": {
      "type": "array",
      "items": {"$ref": "#/$defs/humanDecision"}
    },
    "research_gaps": {"type": "array", "items": {"type": "object"}},
    "summary": {
      "type": "object",
      "required": ["candidate_count", "risk_counts", "review_mode_counts", "disposition_counts", "open_human_decisions", "research_gap_count"],
      "properties": {
        "candidate_count": {"type": "integer", "minimum": 0},
        "risk_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "review_mode_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "disposition_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "open_human_decisions": {"type": "integer", "minimum": 0},
        "research_gap_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "validation": {
      "type": "object",
      "required": ["status", "checks"],
      "properties": {
        "status": {"enum": ["PASS", "FAIL", "PARTIAL"]},
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "passed"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "passed": {"type": "boolean"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "properties": {
        "source_id": {"type": ["string", "null"]},
        "repository_path": {"type": ["string", "null"]},
        "evidence_location": {"type": ["string", "null"]}
      },
      "anyOf": [
        {"required": ["source_id"]},
        {"required": ["repository_path"]}
      ],
      "additionalProperties": true
    },
    "claim": {
      "type": "object",
      "required": ["claim_id", "claim_text", "claim_type", "temporal_scope", "source_authority", "contradiction_status", "supporting_evidence"],
      "properties": {
        "claim_id": {"type": "string", "minLength": 1},
        "claim_text": {"type": "string", "minLength": 1},
        "claim_type": {"type": "string", "minLength": 1},
        "temporal_scope": {"type": "string", "minLength": 1},
        "source_authority": {"enum": ["A1", "A2", "A3", "B1", "B2", "C1", "C2"]},
        "contradiction_status": {"enum": ["NONE_IDENTIFIED", "CONFLICTED", "UNRESOLVED"]},
        "current_state": {"type": "boolean"},
        "as_of": {"type": ["string", "null"]},
        "supporting_evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}}
      },
      "additionalProperties": true
    },
    "candidate": {
      "type": "object",
      "required": ["candidate_id", "risk_class", "review_mode", "disposition", "target_paths", "material_claims"],
      "properties": {
        "candidate_id": {"type": "string", "minLength": 1},
        "risk_class": {"enum": ["R1", "R2", "R3", "R4", "R5"]},
        "review_mode": {"enum": ["AUTOMATED", "BATCH", "INDIVIDUAL", "ARCHIVE_ONLY"]},
        "disposition": {"enum": ["PENDING_REVIEW", "AUTO_APPROVED", "APPROVED", "REVISE", "DEFERRED", "REJECTED", "ARCHIVE_ONLY"]},
        "target_paths": {"type": "array", "items": {"type": "string"}},
        "material_claims": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/claim"}},
        "automatic_eligibility": {"type": "object", "additionalProperties": {"type": "boolean"}},
        "human_decision_id": {"type": ["string", "null"]},
        "authorization_id": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "humanDecision": {
      "type": "object",
      "required": ["decision_id", "question", "evidence", "recommendation", "consequences", "allowed_decisions", "status"],
      "properties": {
        "decision_id": {"type": "string", "minLength": 1},
        "question": {"type": "string", "minLength": 1},
        "evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}},
        "recommendation": {"type": "string", "minLength": 1},
        "consequences": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "allowed_decisions": {"type": "array", "contains": {"const": "DEFER"}},
        "status": {"enum": ["OPEN", "RESOLVED"]},
        "decision": {"enum": ["APPROVE", "REVISE", "REJECT", "DEFER"]},
        "decision_authority": {"const": "HUMAN"},
        "decided_by": {"type": "string", "minLength": 1},
        "decided_at": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

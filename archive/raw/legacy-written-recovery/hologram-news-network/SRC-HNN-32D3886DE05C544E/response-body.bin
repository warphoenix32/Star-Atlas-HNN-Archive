:"ab6dbce60d64","collection":null,"user":{"__ref":"User:ab6dbce60d64"},"description":"","promoHeadline":"","promoBody":"","showPromo":false},"Post:79a45a967971":{"__typename":"Post","id":"79a45a967971"},"NewsletterV3:85fc9c436e2e":{"__typename":"NewsletterV3","id":"85fc9c436e2e"},"PostViewerEdge:postId:cf124667f59c-viewerId:lo_971752d63475":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"PROGRAMMING","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Marc-André Giroux","title":"Sr. Software Developer","company":"Netflix","miroId":"1*uSxyStPJhzmIp7PjJLcpiw.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Carlos Arguelles","title":"Sr. Staff Engineer","company":"Google","miroId":"1*CM27oO9pXETXjs2M9_dUFg.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Tony Yiu","title":"Director","company":"Nasdaq","miroId":"2*CSDritfpmHLYxn63arD9sQ.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Brandeis Marshall","title":"CEO","company":"DataedX","miroId":"1*qLWny7soUL4K4lqhX1wQVw.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Cassie Kozyrkov","title":"Chief Decision Scientist","company":"Google","miroId":"1*IL0mnvzNcpG2ZD0JBqo7zQ.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Memo Akten","title":"Asst. Professor","company":"UCSD","miroId":"4*f7EyGRullh3Ih_2tm3k5xw.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Vitali Zaidman","title":"Software Architect","company":"Meta","miroId":"2*gHhbmOgQGWxZrqDIfLps6A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Camille Fournier","title":"Head of Engineering","company":"JPMorgan Chase","miroId":"1*J2fWNTyPbgEhIyvVIjHAXg.jpeg","hideOnSmallScreen":null}]},"id":"postId:cf124667f59c-viewerId:lo_971752d63475"},"Paragraph:67e10a826bdd_0":{"__typename":"Paragraph","id":"67e10a826bdd_0","name":"3eb4","type":"H3","href":null,"layout":null,"metadata":null,"text":"Review: The Club’s bot J33ves is your R4 supplier of last resort","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*cLKG9oELRYyglbBmd3VjAw.jpeg":{"__typename":"ImageMetadata","id":"1*cLKG9oELRYyglbBmd3VjAw.jpeg","originalHeight":1649,"originalWidth":3000,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:67e10a826bdd_1":{"__typename":"Paragraph","id":"67e10a826bdd_1","name":"62d6","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*cLKG9oELRYyglbBmd3VjAw.jpeg"},"text":"Say hello to J33ves","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_2":{"__typename":"Paragraph","id":"67e10a826bdd_2","name":"b6e3","type":"P","href":null,"layout":null,"metadata":null,"text":"How many times have you missed a resupply window for your ships in SCORE? This author has missed many. Not for lack of trying but my IRL duties often conflict with my virtual life duties causing many a SCORE crew member to go hungry or to drift in space with no fuel (sorry fellas). Furthermore, when the ships ain’t grinding, they ain’t earning. This is just an irritating fact of the SCORE gameplay loop.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_3":{"__typename":"Paragraph","id":"67e10a826bdd_3","name":"fba0","type":"P","href":null,"layout":null,"metadata":null,"text":"When Loid from The Club brought my attention to their resupply bot, aka J33ves, I was naturally curious but skeptical. Resource supply is not a new concept. Guilds like HEIM and even The Club’s first iteration (Pitstop) have R4 supply functionality but it’s not automatic, rather “1-click”. [Note: HEIM’s tool is a fork of The Club’s PitStop.] Furthermore, these tools require one to connect a wallet. This was a non-starter for me given all the recent hacks and wallet drains (of which I was a victim). According to Loid, J33ves works differently. You only need to send Atlas to the J33ves wallet and he will handle the rest. No need to connect your wallet.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":5,"end":9,"href":"https:\u002F\u002Ftwitter.com\u002FLoid_Official","anchorType":"LINK","userId":"","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_4":{"__typename":"Paragraph","id":"67e10a826bdd_4","name":"fa7b","type":"P","href":null,"layout":null,"metadata":null,"text":"With the wallet issue removed, I decided to give J33ves a test drive. Initially the sign-up process required verification but The Club has now removed that step. According to Loid:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_5":{"__typename":"Paragraph","id":"67e10a826bdd_5","name":"ca03","type":"BQ","href":null,"layout":null,"metadata":null,"text":"The biggest update to the resupply service is that it’s open to everyone without the need to link your Discord name to a wallet. So completely anonymous and secure. Send ATLAS from the wallet that needs service and J33VES will see which wallet the Atlas came from and create a balance for that address within a few minutes. This can be checked by searching your address on explorer and clicking the J33ves tab. He will start resupplying when there are less than 30 minutes until supplies are empty, using our ‘optimal’ approach. So fully filling the resource with shortest delaying time and ensuring all other resources have that same amount of time remaining also. The caveat with complete anonymity is that there are no refunds!!! So only send what you need. If you want a refund we will have to process this manually which of course means you would have to reveal yourself. There is 0 risk to your ships with this service as there is 0 wallet connectivity. The Atlas you send is the only potential risk and we will endeavour to refund that if something did happen to it.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_6":{"__typename":"Paragraph","id":"67e10a826bdd_6","name":"1308","type":"P","href":null,"layout":null,"metadata":null,"text":"Getting started","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":15,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_7":{"__typename":"Paragraph","id":"67e10a826bdd_7","name":"f318","type":"P","href":null,"layout":null,"metadata":null,"text":"The easiest way to get started is to go to explorer.staratlas.club and click on the J33ves tab on the right. Read and accept the Terms of Service by checking the box and then send ATLAS to the wallet address listed. Be sure to also to scroll down and read the FAQ.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":43,"end":66,"href":"http:\u002F\u002Fexplorer.staratlas.club","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_8":{"__typename":"Paragraph","id":"67e10a826bdd_8","name":"fa5d","type":"P","href":null,"layout":null,"metadata":null,"text":"Once your Atlas is in J33ves, you can sit back and enjoy. Note: I transferred 500 Atlas to start but you may need to transfer more or less depending on the size of your fleet.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":58,"end":63,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_9":{"__typename":"Paragraph","id":"67e10a826bdd_9","name":"7415","type":"P","href":null,"layout":null,"metadata":null,"text":"Important: As of March 13, 2023 there is a 20% fee for using the resupply service. Also, the fee can be raised (or lowered) at anytime.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":11,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*beXaNdGaO8Di9X4Y":{"__typename":"ImageMetadata","id":"0*beXaNdGaO8Di9X4Y","originalHeight":167,"originalWidth":1600,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:67e10a826bdd_10":{"__typename":"Paragraph","id":"67e10a826bdd_10","name":"f412","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*beXaNdGaO8Di9X4Y"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_11":{"__typename":"Paragraph","id":"67e10a826bdd_11","name":"7c4c","type":"P","href":null,"layout":null,"metadata":null,"text":"However, you are only charged if he has to resupply your fleet. You can beat J33ves to the punch and avoid the fees but what’s the fun in that!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_12":{"__typename":"Paragraph","id":"67e10a826bdd_12","name":"8f25","type":"P","href":null,"layout":null,"metadata":null,"text":"To verify or not to verify, that is the question!","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":49,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_13":{"__typename":"Paragraph","id":"67e10a826bdd_13","name":"1ad3","type":"P","href":null,"layout":null,"metadata":null,"text":"Many will opt to remain anonymous but there are some downsides to this approach. For one, you don’t get access to all the cool J33ves commands that grant you further insight into your SCORE fleet. You don’t have to become a Club member to use these commands, but you do need to verify your wallet which would require you to reveal your Discord username. Personally, I verified my wallet because I wanted the added functionality.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_14":{"__typename":"Paragraph","id":"67e10a826bdd_14","name":"81ab","type":"P","href":null,"layout":null,"metadata":null,"text":"Below is the step by step process for getting verified. You can skip this section if you prefer to remain completely anonymous.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_15":{"__typename":"Paragraph","id":"67e10a826bdd_15","name":"4e4a","type":"P","href":null,"layout":null,"metadata":null,"text":"Step 1: You will need to join The Club’s Discord.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":41,"end":48,"href":"http:\u002F\u002Fdiscord.gg\u002Fthe-sa-club","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":8,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_16":{"__typename":"Paragraph","id":"67e10a826bdd_16","name":"6d27","type":"P","href":null,"layout":null,"metadata":null,"text":"Step 2: Head over to “the read this for access” channel, react to become a member (this is to stop bots and works well). After that, the “member-verify'' channel will be visible.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":7,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_17":{"__typename":"Paragraph","id":"67e10a826bdd_17","name":"8c6d","type":"P","href":null,"layout":null,"metadata":null,"text":"Step 3: In the “member-verify” channel, click the https:\u002F\u002Fverify.staratlas.club\u002F link. It’s pretty straight forward from there. If you get confused there is a nice video in the channel that you can watch.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":50,"end":80,"href":"https:\u002F\u002Fverify.staratlas.club\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":8,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_18":{"__typename":"Paragraph","id":"67e10a826bdd_18","name":"4fe0","type":"P","href":null,"layout":null,"metadata":null,"text":"Step 4: Once verified, head over to J33VES commands channel. This is where members interact with J33VES.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":7,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_19":{"__typename":"Paragraph","id":"67e10a826bdd_19","name":"1b3b","type":"P","href":null,"layout":null,"metadata":null,"text":"Using the “\u002F” key in the “J33ves-commands” channel of The Club Discord allows you to tell J33ves to do a lot of things. For this article, let’s focus on the commands that are relevant for resupplying your ships.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*bhahdyv0WUuOOYPw":{"__typename":"ImageMetadata","id":"0*bhahdyv0WUuOOYPw","originalHeight":1023,"originalWidth":1600,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:67e10a826bdd_20":{"__typename":"Paragraph","id":"67e10a826bdd_20","name":"1579","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*bhahdyv0WUuOOYPw"},"text":"List of J33ves commands","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_21":{"__typename":"Paragraph","id":"67e10a826bdd_21","name":"becb","type":"P","href":null,"layout":null,"metadata":null,"text":"Start playing around with the commands. Note: Commands entered in the commands channel are private. In other words, no one else can see them or the output. The three most important to me were:","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":40,"end":46,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_22":{"__typename":"Paragraph","id":"67e10a826bdd_22","name":"8e31","type":"ULI","href":null,"layout":null,"metadata":null,"text":"\u002Fresupply balance: how much Atlas remains in your J33ves account for resupply purposes.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":17,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_23":{"__typename":"Paragraph","id":"67e10a826bdd_23","name":"ff24","type":"ULI","href":null,"layout":null,"metadata":null,"text":"\u002Ffleet-supplies: the amount of resources left before the J33ves bot will kick in. It also gives you the time when J33ves will resupply your ships. Think of this as your early warning system. A way for you to know what’s going on in SCORE without having to connect your wallet to the Galactic Marketplace.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":15,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_24":{"__typename":"Paragraph","id":"67e10a826bdd_24","name":"52c0","type":"ULI","href":null,"layout":null,"metadata":null,"text":"\u002Ffleet-stats: shows your fleet, daily rewards, daily burns and net yield.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":12,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_25":{"__typename":"Paragraph","id":"67e10a826bdd_25","name":"5ac8","type":"P","href":null,"layout":null,"metadata":null,"text":"Final verdict and comments","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":26,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_26":{"__typename":"Paragraph","id":"67e10a826bdd_26","name":"ada8","type":"P","href":null,"layout":null,"metadata":null,"text":"Overall, this author was impressed with J33ves. I’ve been using the resupply tool for about 5 months now and he has kept my SCORE fleet resourced and happy. Mutinous rumblings have quieted significantly!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_27":{"__typename":"Paragraph","id":"67e10a826bdd_27","name":"f27d","type":"P","href":null,"layout":null,"metadata":null,"text":"Given how well the tool works, we were somewhat surprised by the small number of active users.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*D6Y0QPWq08UN4V8l3aMKIg.png":{"__typename":"ImageMetadata","id":"1*D6Y0QPWq08UN4V8l3aMKIg.png","originalHeight":453,"originalWidth":922,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:67e10a826bdd_28":{"__typename":"Paragraph","id":"67e10a826bdd_28","name":"2ac6","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*D6Y0QPWq08UN4V8l3aMKIg.png"},"text":"Active users and total resupplies","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_29":{"__typename":"Paragraph","id":"67e10a826bdd_29","name":"25db","type":"P","href":null,"layout":null,"metadata":null,"text":"When I asked Loid if the tool was generating any revenue for The Club, he said:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_30":{"__typename":"Paragraph","id":"67e10a826bdd_30","name":"a1eb","type":"BQ","href":null,"layout":null,"metadata":null,"text":"With the price of Atlas where it is, this is not making any notable revenue. You can see in the wallet address what is there and how much it’s worth. We are spending a lot more on it development and upkeep than what it brings in. But that is fine. We are helping the community and building up our reputation and the J33VES name.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_31":{"__typename":"Paragraph","id":"67e10a826bdd_31","name":"2f9f","type":"P","href":null,"layout":null,"metadata":null,"text":"Putting something to together like this is no easy task. The Club took on the risk (and expense) to create something of real practical utility and opened it up to the entire Star Atlas community. To our knowledge, few Guilds have acted in a similar fashion. So what’s next for J33ves? We heard a rumor that he’s starting to becoming intimately familiar with Chat GPT. Stay tuned for our exclusive article on that soon(tm).","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_32":{"__typename":"Paragraph","id":"67e10a826bdd_32","name":"3ec3","type":"H3","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_33":{"__typename":"Paragraph","id":"67e10a826bdd_33","name":"b6c1","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:67e10a826bdd_34":{"__typename":"Paragraph","id":"67e10a826bdd_34","name":"33d2","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_971752d63475":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_971752d63475","isEditor":false},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"Tag:web3":{"__typename":"Tag","id":"web3","displayTitle":"Web3","normalizedTagSlug":"web3"},"Tag:crypto":{"__typename":"Tag","id":"crypto","displayTitle":"Crypto","normalizedTagSlug":"crypto"},"Post:cf124667f59c":
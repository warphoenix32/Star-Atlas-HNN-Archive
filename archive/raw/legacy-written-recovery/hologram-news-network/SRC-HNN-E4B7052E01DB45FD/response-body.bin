ups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_1":{"__typename":"Paragraph","id":"cb74407829ae_1","name":"c73d","type":"P","href":null,"layout":null,"metadata":null,"text":"On March 25th, the first in real life meeting of the Atlas Brew Society took place in Paris, France at the Bar “Le 38 M” between members of the Star Atlas team and members of the community.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":144,"end":154,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_2":{"__typename":"Paragraph","id":"cb74407829ae_2","name":"26e4","type":"P","href":null,"layout":null,"metadata":null,"text":"This article is a translation of the original article written in French by author Ju.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":85,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*eQ8qRYgX8T12s80U.jpeg":{"__typename":"ImageMetadata","id":"0*eQ8qRYgX8T12s80U.jpeg","originalHeight":377,"originalWidth":700,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:cb74407829ae_3":{"__typename":"Paragraph","id":"cb74407829ae_3","name":"73cc","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*eQ8qRYgX8T12s80U.jpeg"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_4":{"__typename":"Paragraph","id":"cb74407829ae_4","name":"77e4","type":"P","href":null,"layout":null,"metadata":null,"text":"It all started when Santi (Star Atlas Community Director), decided to come and spend a week in Paris, to visit the capital and spend time with Darwiin (Star Atlas Community Support). Together, they had the idea to take the opportunity to organize, at first informally, a meeting with members of the French-speaking community of Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_5":{"__typename":"Paragraph","id":"cb74407829ae_5","name":"87e6","type":"P","href":null,"layout":null,"metadata":null,"text":"When Darwiin reached out to the French-speaking community to know if anyone knew of a place in Paris to organize the meeting, PACTwo, one of the particularly active members of Gargantua Industries, immediately proposed “Le 38 M”, a place he knew well. He also proposed to take care of the coordination with the owners of the bar. With the place having been chosen, only a date remained to be selected with March 25th ultimaltey beeing selected.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*du6v81ATE-bTYqu5.jpeg":{"__typename":"ImageMetadata","id":"0*du6v81ATE-bTYqu5.jpeg","originalHeight":394,"originalWidth":700,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:cb74407829ae_6":{"__typename":"Paragraph","id":"cb74407829ae_6","name":"8d7a","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*du6v81ATE-bTYqu5.jpeg"},"text":"Santi (1st on the left in the last row) and Darwiin (2nd on the left in the first row), in the company of members of the Star Atlas French-speaking community, in front of the bar “Le 38 M”.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_7":{"__typename":"Paragraph","id":"cb74407829ae_7","name":"2423","type":"P","href":null,"layout":null,"metadata":null,"text":"After internal discussions on the Star Atlas side, the team decided to make this event the first of a series of IRL meetings and to name these events the Atlas Brew Society. Other events will take place in the future, in different cities around the world, according to the availability and the travels of the Star Atlas team and the community members.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_8":{"__typename":"Paragraph","id":"cb74407829ae_8","name":"fcac","type":"P","href":null,"layout":null,"metadata":null,"text":"On the evening of March 25th, about twenty-five members of the community, mostly members of the Gargantua Industries huild, but also of Eclypse, had answered the call of Santi and Darwiin.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":96,"end":116,"href":null,"anchorType":"USER","userId":"c33b0043eac3","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_9":{"__typename":"Paragraph","id":"cb74407829ae_9","name":"0e01","type":"P","href":null,"layout":null,"metadata":null,"text":"The only snag was the absence of Gary Sanchez (Artistic Director and Concept Designer), who unfortunately could not make the trip because of the disruptions caused by the demonstrations that are currently taking place throughout France.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_10":{"__typename":"Paragraph","id":"cb74407829ae_10","name":"657b","type":"P","href":null,"layout":null,"metadata":null,"text":"Our dear Atlassians were able to taste delicious cocktails, with names inspired by the Lore of Star Atlas, such as the Iris Kiss, The Punaab Whisper or the Ustur Mule, while getting acquainted with each other. It was also an opportunity for Darwiin and Santi to put faces to the nicknames they are used to seeing on the official Star Atlas Discord.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":119,"end":128,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":130,"end":148,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":156,"end":166,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*PaW_5AIKpqlhvYJn":{"__typename":"ImageMetadata","id":"0*PaW_5AIKpqlhvYJn","originalHeight":679,"originalWidth":473,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:cb74407829ae_11":{"__typename":"Paragraph","id":"cb74407829ae_11","name":"0159","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*PaW_5AIKpqlhvYJn"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_12":{"__typename":"Paragraph","id":"cb74407829ae_12","name":"ae43","type":"P","href":null,"layout":null,"metadata":null,"text":"The event went on until late in the night, in a friendly and relaxed atmosphere and, according to the people present that night, it was a real success. Everyone left delighted, some of them, like Santi and Darwiin, with T-Shirts offered by Gargantua Industries.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_13":{"__typename":"Paragraph","id":"cb74407829ae_13","name":"fd44","type":"P","href":null,"layout":null,"metadata":null,"text":"The Star Atlas team had also planned goodies for the members of the community, unfortunately the French customs decided otherwise by blocking the parcel and sending it back to the sender. The team promised to send them later to the people present that night, as well as to the people present at a previous event organized by Morpheus.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_14":{"__typename":"Paragraph","id":"cb74407829ae_14","name":"8fcf","type":"P","href":null,"layout":null,"metadata":null,"text":"This article was originally written in French by Ju for Gargantua Industries and the Star Atlas community. This article was translated by Krigs of the Hologram with permission by the original author.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":17,"end":35,"href":"https:\u002F\u002Fmedium.com\u002F@Gargantua.Industries\u002Fatlas-brew-society-les-rencontres-irl-de-la-communaut%C3%A9-de-star-atlas-98ee9c4c721a","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_15":{"__typename":"Paragraph","id":"cb74407829ae_15","name":"58bd","type":"P","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_16":{"__typename":"Paragraph","id":"cb74407829ae_16","name":"d4a4","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":5,"href":"https:\u002F\u002Fmedium.com\u002Fu\u002F41e0c5b141f1?source=post_page-----4922901fb224--------------------------------","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_17":{"__typename":"Paragraph","id":"cb74407829ae_17","name":"69ad","type":"P","href":null,"layout":null,"metadata":null,"text":"is a pioneer in the world of Star Atlas, having founded The Hologram News Network — an independent meta-news organization that keeps players up to date on all developments regarding Star Atlas. An ardent supporter of emerging technologies, Krigs has been covering this game for over a year and believes passionately in their power to revolutionize our collective gaming experience.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_18":{"__typename":"Paragraph","id":"cb74407829ae_18","name":"1093","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_19":{"__typename":"Paragraph","id":"cb74407829ae_19","name":"5953","type":"P","href":null,"layout":null,"metadata":null,"text":"Podcast | YouTube | Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Fopen.spotify.com\u002Fshow\u002F2mxndrDW6yPfpS350ijzjt?si=ec7c717f998240d6","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":17,"href":"https:\u002F\u002Fwww.youtube.com\u002Fchannel\u002FUCDa-YxgNG6A9xpH1qyP0OaQ","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":20,"end":27,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":30,"end":39,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":42,"end":45,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_20":{"__typename":"Paragraph","id":"cb74407829ae_20","name":"fcb4","type":"P","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_21":{"__typename":"Paragraph","id":"cb74407829ae_21","name":"52d7","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:cb74407829ae_22":{"__typename":"Paragraph","id":"cb74407829ae_22","name":"1588","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_f0d54e343954":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_f0d54e343954","isEditor":false},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"Tag:community":{"__typename":"Tag","id":"community","displayTitle":"Community","normalizedTagSlug":"community"},"Post:85534fef7500":{"__typename":"Post","id":"85534fef7500","canonicalUrl":"","collection":{"__ref":"Collection:4d89daa6ae31"},"content({\"postMeteringOptions\":{\"forceTruncation\":false}})":{"__typename":"PostContent","isLockedPreviewOnly":false,"validatedShareKey":"","bodyModel":{"__typename":"RichText","sections":[{"__typename":"Section","name":"6476","startIndex":0,"textLayout":null,"imageLayout":null,"backgroundImage":null,"videoLayout":null,"backgroundVideo":null},{"__typename":"Section","name":"11fe","startIndex":14,"textLayout":null,"imageLayout":null,"backgroundImage":null,"videoLayout":null,"backgroundVideo":null},{"__typename":"Section","name":"1fef","startIndex":15,"textLayout":null,"imageLayout":null,"backgroundImage":null,"videoLayout":null,"backgroundVideo":null}],"paragraphs":[{"__ref":"Paragraph:cb74407829ae_0"},{"__ref":"Paragraph:cb74407829ae_1"},{"__ref":"Paragraph:cb74407829ae_2"},{"__ref":"Paragraph:cb74407829ae_3"},{"__ref":"Paragraph:cb74407829ae_4"},{"__ref":"Paragraph:cb74407829ae_5"},{"__ref":"Paragraph:cb74407829ae_6"},{"__ref":"Paragraph:cb74407829ae_7"},{"__ref":"Paragraph:cb74407829ae_8"},{"__ref":"Paragraph:cb74407829ae_9"},{"__ref":"Paragraph:cb74407829ae_10"},{"__ref":"Paragraph:cb74407829ae_11"},{"__ref":"Paragraph:cb74407829ae_12"},{"__ref":"Paragraph:cb74407829ae_13"},{"__ref":"Paragraph:cb74407829ae_14"},{"__ref":"Paragraph:cb74407829ae_15"},{"__ref":"Paragraph:cb74407829ae_16"},{"__ref":"Paragraph:cb74407829ae_17"},{"__ref":"Paragraph:cb74407829ae_18"},{"__ref":"Paragraph:cb74407829ae_19"},{"__ref":"Paragraph:cb74407829ae_20"},{"__ref":"Paragraph:cb74407829ae_21"},{"__ref":"Paragraph:cb74407829ae_22"}]}},"creator":{"__ref":"User:41e0c5b141f1"},"customStyleSheet":null,"isPublished":true,"isLocked":false,"license":"ALL_RIGHTS_RESERVED","collaborators":[],"statusForCollection":"APPROVED","isMarkedPaywallOnly":false,"lockedSource":"LOCKED_POST_SOURCE_NONE","mediumUrl":"https:\u002F\u002Fmedium.co
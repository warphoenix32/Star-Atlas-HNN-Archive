,"point":0.7},{"__typename":"ColorPoint","color":"#FFC5C3C2","point":0.8},{"__typename":"ColorPoint","color":"#FFD9D6D6","point":0.9},{"__typename":"ColorPoint","color":"#FFECE9E9","point":1}]}},"googleAnalyticsId":null,"editors":[{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:41e0c5b141f1"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:b0bf38de9190"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:ed24b40c4906"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:35ffdccaa5dc"}},{"__typename":"CollectionMastheadUserItem","user":{"__ref":"User:ab6dbce60d64"}}],"name":"The Hologram","avatar":{"__ref":"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg"},"domain":null,"slug":"the-hologram","description":"Daily Star Atlas news by The Hologram. Politics, economics and community coverage. Get the trusted information you need to stay one step ahead of your competition.","subscriberCount":148,"viewerEdge":{"__ref":"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_a7a415255005"},"twitterUsername":"Hologram_News","facebookPageId":null,"logo":{"__ref":"ImageMetadata:"}},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","name":"Krigs","username":"krigsfoniks","newsletterV3":{"__ref":"NewsletterV3:85fc9c436e2e"},"linkedAccounts":{"__ref":"LinkedAccounts:41e0c5b141f1"},"isSuspended":false,"imageId":"1*pVxyLAandIa00EX6ZGRERw.png","mediumMemberAt":1667603125000,"verifications":{"__typename":"VerifiedInfo","isBookAuthor":false},"socialStats":{"__typename":"SocialStats","followerCount":232},"customDomainState":null,"hasSubdomain":false,"bio":"Founder | Crypto | Star Atlas |","isPartnerProgramEnrolled":true,"viewerEdge":{"__ref":"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_a7a415255005"},"viewerIsUser":false,"postSubscribeMembershipUpsellShownAt":0,"allowNotes":true,"membership":{"__ref":"Membership:4bbb830162b9"},"twitterScreenName":"Hologram_News"},"User:b0bf38de9190":{"__typename":"User","id":"b0bf38de9190"},"User:ed24b40c4906":{"__typename":"User","id":"ed24b40c4906"},"User:35ffdccaa5dc":{"__typename":"User","id":"35ffdccaa5dc"},"User:ab6dbce60d64":{"__typename":"User","id":"ab6dbce60d64"},"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg"},"LinkedAccounts:41e0c5b141f1":{"__typename":"LinkedAccounts","mastodon":null,"id":"41e0c5b141f1"},"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_a7a415255005":{"__typename":"UserViewerEdge","id":"userId:41e0c5b141f1-viewerId:lo_a7a415255005","isFollowing":false,"isUser":false},"NewsletterV3:85fc9c436e2e":{"__typename":"NewsletterV3","id":"85fc9c436e2e","type":"NEWSLETTER_TYPE_AUTHOR","slug":"41e0c5b141f1","name":"41e0c5b141f1","collection":null,"user":{"__ref":"User:41e0c5b141f1"}},"Paragraph:0d3c5ed07274_0":{"__typename":"Paragraph","id":"0d3c5ed07274_0","name":"b9a1","type":"H3","href":null,"layout":null,"metadata":null,"text":"Star Atlas Golden Ticket Raffle Offers Unique Opportunity at $1.35 Million In Prizes","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_1":{"__typename":"Paragraph","id":"0d3c5ed07274_1","name":"0230","type":"P","href":null,"layout":null,"metadata":null,"text":"Here are the best weeks to play Star Atlas over the next few months and how to enter the $1.35 million dollar prize raffle.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":123,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*1g3MSw4sEgOoH92w.png":{"__typename":"ImageMetadata","id":"0*1g3MSw4sEgOoH92w.png","originalHeight":2160,"originalWidth":2160,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:0d3c5ed07274_2":{"__typename":"Paragraph","id":"0d3c5ed07274_2","name":"62d2","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*1g3MSw4sEgOoH92w.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_3":{"__typename":"Paragraph","id":"0d3c5ed07274_3","name":"5ca0","type":"H4","href":null,"layout":null,"metadata":null,"text":"Star Atlas Gives Away 1.35 Million in Prizes","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_4":{"__typename":"Paragraph","id":"0d3c5ed07274_4","name":"55f3","type":"P","href":null,"layout":null,"metadata":null,"text":"Over the next 8 weeks, Star Atlas will hold 8 separate raffles to participants of their Golden Ticket Raffle Event.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":23,"end":33,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_5":{"__typename":"Paragraph","id":"0d3c5ed07274_5","name":"ceef","type":"P","href":null,"layout":null,"metadata":null,"text":"Each week will feature a unique pool of prizes, with some prizes valued at over $100K each.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_6":{"__typename":"Paragraph","id":"0d3c5ed07274_6","name":"e9af","type":"H4","href":null,"layout":null,"metadata":null,"text":"How To Get Golden Tickets","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_7":{"__typename":"Paragraph","id":"0d3c5ed07274_7","name":"0e14","type":"P","href":null,"layout":null,"metadata":null,"text":"To enter, contestants must submit Golden Tickets into that week’s drawing to be eligible. The current drawing begins on Oct 27th and ends on Nov 3rd.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_8":{"__typename":"Paragraph","id":"0d3c5ed07274_8","name":"310d","type":"P","href":null,"layout":null,"metadata":null,"text":"If you want to participate, but don’t have Golden Tickets, you can acquire them in one of two ways.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_9":{"__typename":"Paragraph","id":"0d3c5ed07274_9","name":"04b3","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Golden Tickets can be purchased on the Star Atlas marketplace.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":39,"end":61,"href":"https:\u002F\u002Fplay.staratlas.com\u002F?r=1njph1m5xrtdv1xa","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_10":{"__typename":"Paragraph","id":"0d3c5ed07274_10","name":"b102","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Alternatively, contestants can participate in Star Atlas SAGE Labs where players can earn materials and components through gameplay and craft Golden Tickets themselves. Star Atlas SAGE Labs requires Star Atlas assets to play.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":46,"end":66,"href":"https:\u002F\u002Flabs.staratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_11":{"__typename":"Paragraph","id":"0d3c5ed07274_11","name":"526e","type":"H4","href":null,"layout":null,"metadata":null,"text":"How and Where to Enter Golden Tickets For Weekly Drawings","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_12":{"__typename":"Paragraph","id":"0d3c5ed07274_12","name":"4110","type":"P","href":null,"layout":null,"metadata":null,"text":"Once you’ve acquired some Golden Tickets, you must then head over to Hedgehog Markets’ Star Atlas Contest Page found here: https:\u002F\u002Fhedgehog.markets\u002Fstar-atlas","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":69,"end":85,"href":null,"anchorType":"USER","userId":"6cd4a82154a0","linkMetadata":null},{"__typename":"Markup","type":"A","start":123,"end":158,"href":"https:\u002F\u002Fhedgehog.markets\u002Fstar-atlas","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_13":{"__typename":"Paragraph","id":"0d3c5ed07274_13","name":"b0e6","type":"P","href":null,"layout":null,"metadata":null,"text":"Alternatively, you can navigate to the website using Star Atlas guide.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":53,"end":69,"href":"https:\u002F\u002Fmedium.com\u002Fstar-atlas\u002Fgolden-tickets-star-atlas-giving-million-loot-revolutionary-game-solana-b3d01930e9dc","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_14":{"__typename":"Paragraph","id":"0d3c5ed07274_14","name":"2258","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Connect your wallet","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_15":{"__typename":"Paragraph","id":"0d3c5ed07274_15","name":"62e5","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Select the number of tickets you want to enter and hit submit.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_16":{"__typename":"Paragraph","id":"0d3c5ed07274_16","name":"e153","type":"P","href":null,"layout":null,"metadata":null,"text":"At time of writing, over 107,000 Golden Tickets have been entered into the first week’s drawing.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":96,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_17":{"__typename":"Paragraph","id":"0d3c5ed07274_17","name":"30fa","type":"H3","href":null,"layout":null,"metadata":null,"text":"Best Weeks To Play and Enter","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_18":{"__typename":"Paragraph","id":"0d3c5ed07274_18","name":"fb34","type":"P","href":null,"layout":null,"metadata":null,"text":"From the chart below, you can see that there are differences in the prizes offered by Star Atlas each week. Some players may choose to spread out their entries every week while some may find specific weeks to enter. Keep reading below to find out some of the best weeks to enter into the drawing.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*rFCnfv1xHeoApVoX.png":{"__typename":"ImageMetadata","id":"0*rFCnfv1xHeoApVoX.png","originalHeight":1129,"originalWidth":1000,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:0d3c5ed07274_19":{"__typename":"Paragraph","id":"0d3c5ed07274_19","name":"966c","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*rFCnfv1xHeoApVoX.png"},"text":"Star Atlas Golden Ticket Raffle Prize Table","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_20":{"__typename":"Paragraph","id":"0d3c5ed07274_20","name":"6159","type":"H4","href":null,"layout":null,"metadata":null,"text":"Best Overall Week — Week 1","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_21":{"__typename":"Paragraph","id":"0d3c5ed07274_21","name":"b4e8","type":"P","href":null,"layout":null,"metadata":null,"text":"Notably, Week 1 offers the largest prize pool in terms of dollar value. At the top of the prize pool for this week are 2 Fimbul BYOS Tankships which are some of the biggest and toughest ships in Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_22":{"__typename":"Paragraph","id":"0d3c5ed07274_22","name":"80d6","type":"P","href":null,"layout":null,"metadata":null,"text":"Week 1 also offers a chance at a Capital Vzus Ballad and a number of other prizes for contestants to claim.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_23":{"__typename":"Paragraph","id":"0d3c5ed07274_23","name":"e653","type":"H4","href":null,"layout":null,"metadata":null,"text":"Best Week For Housing — Week 3","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_24":{"__typename":"Paragraph","id":"0d3c5ed07274_24","name":"665b","type":"P","href":null,"layout":null,"metadata":null,"text":"Player housing is a highly sought after gameplay loop in many MMOs and Star Atlas is no exception. Especially if you consider that player housing on Central Space Stations is also limited in number.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_25":{"__typename":"Paragraph","id":"0d3c5ed07274_25","name":"3439","type":"P","href":null,"layout":null,"metadata":null,"text":"Players looking to possibly win varying levels of player houses in Star Atlas should take a good look at what Week 3 has to offer.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_26":{"__typename":"Paragraph","id":"0d3c5ed07274_26","name":"1eb5","type":"H4","href":null,"layout":null,"metadata":null,"text":"Best Week For New Players — Week 5","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_27":{"__typename":"Paragraph","id":"0d3c5ed07274_27","name":"e5dd","type":"P","href":null,"layout":null,"metadata":null,"text":"By the initial looks of it, Week 5 doesn't seem to offer much variety for contestants. However, this exact reason is why Week 5 might offer the best opportunity for smaller or newer players to win prizes.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_28":{"__typename":"Paragraph","id":"0d3c5ed07274_28","name":"867a","type":"P","href":null,"layout":null,"metadata":null,"text":"Players with larger ticket pools will likely have focused their entries elsewhere making the overall potential odds for Week 5 appealing for some.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_29":{"__typename":"Paragraph","id":"0d3c5ed07274_29","name":"f5d8","type":"H4","href":null,"layout":null,"metadata":null,"text":"Wildcard — Week 8","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_30":{"__typename":"Paragraph","id":"0d3c5ed07274_30","name":"53e5","type":"P","href":null,"layout":null,"metadata":null,"text":"There is little information about what prizes will rollout for Week 8, but knowing the Star Atlas community, it sure could be a good one.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_31":{"__typename":"Paragraph","id":"0d3c5ed07274_31","name":"3083","type":"P","href":null,"layout":null,"metadata":null,"text":"Currently, transport and data runner ships are in high demand — this could turn into a ship drop of those types.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_32":{"__typename":"Paragraph","id":"0d3c5ed07274_32","name":"8b09","type":"P","href":null,"layout":null,"metadata":null,"text":"Alternatively, Star Atlas may include some never before released assets to cap off two months of prize giveaways.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_33":{"__typename":"Paragraph","id":"0d3c5ed07274_33","name":"a778","type":"H3","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_34":{"__typename":"Paragraph","id":"0d3c5ed07274_34","name":"e498","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":5,"href":"https:\u002F\u002Fmedium.com\u002Fu\u002F41e0c5b141f1","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":5,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_35":{"__typename":"Paragraph","id":"0d3c5ed07274_35","name":"4523","type":"P","href":null,"layout":null,"metadata":null,"text":"An ardent supporter of emerging technologies, Krigs has been covering blockchain games for over two years and believes passionately in their power to revolutionize our collective gaming experience.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_36":{"__typename":"Paragraph","id":"0d3c5ed07274_36","name":"2940","type":"H3","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_37":{"__typename":"Paragraph","id":"0d3c5ed07274_37","name":"6998","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:0d3c5ed07274_38":{"__typename":"Paragraph","id":"0d3c5ed07274_38","name":"1419","type":"P","href":null,"layout":null,"metadata":null,"text":"Any information published by The Hologram or its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_a7a415255005":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_a7a415255005","isEditor":false},"Membership:4bbb830162b9":{"__typename":"Membership","tier":"MEMBER","id":"4bbb830162b9"},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"Tag:blockchain":{"__typename":"Tag","id":"block
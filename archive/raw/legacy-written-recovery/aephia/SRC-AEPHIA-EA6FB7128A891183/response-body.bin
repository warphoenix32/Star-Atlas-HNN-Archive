t\t\tslides: [{\"src\":\"https:\\\/\\\/aephia.com\\\/wp-content\\\/uploads\\\/2022\\\/06\\\/fimbul-mamba-star-atlas-ship-02.jpg\"},{\"src\":\"https:\\\/\\\/aephia.com\\\/wp-content\\\/uploads\\\/2021\\\/10\\\/ogrika-thripid-star-atlas-ship-01.jpg\"},{\"src\":\"https:\\\/\\\/aephia.com\\\/wp-content\\\/uploads\\\/2022\\\/05\\\/calico-ats-enforcer-star-atlas-ship-03.jpg\"}],\n\t\t\t\ttransition: 'fade',\n\t\t\t\tanimation: 'kenburns',\n\t\t\t\toverlay: 'https:\/\/aephia.com\/wp-content\/plugins\/addon-elements-for-elementor-page-builder\/\/assets\/lib\/vegas\/overlays\/01.png',\n\t\t\t\tcover: true,\n\t\t\t\tdelay: 7500,\n\t\t\t\ttimer: false\t\t\t});\n\t\t\t\n\n\t\t\t\/\/ Clear the overlay if custom overlay switcher is set to 'yes'\n\t\t\tif ('' === 'yes') {\n\t\t\t\t$element.find('.vegas-overlay').css('background-image', '');\n\t\t\t}\n\t\t});\n\t<\/script>\n\t\t\t\t<section class=\"has_eae_slider elementor-section elementor-top-section elementor-element elementor-element-53386bea elementor-section-height-min-height elementor-section-content-middle elementor-hidden-mobile elementor-section-boxed elementor-section-height-default elementor-section-items-middle\" data-eae-slider=\"48803\" data-id=\"53386bea\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t\t\t\t\t\t<div class=\"elementor-background-overlay\"><\/div>\n\t\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-no\">\n\t\t\t\t\t<div class=\"has_eae_slider elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-40961272\" data-eae-slider=\"45788\" data-id=\"40961272\" data-element_type=\"column\" data-e-type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-fef0d81 elementor-widget elementor-widget-heading\" data-id=\"fef0d81\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">*Updated with the latest stats from the Sage Manual<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/section>\n\t\t\t\t<section class=\"has_eae_slider elementor-section elementor-top-section elementor-element elementor-element-b79df4f elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-eae-slider=\"34687\" data-id=\"b79df4f\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;background_background&quot;:&quot;gradient&quot;}\">\n\t\t\t\t\t\t\t<div class=\"elementor-background-overlay\"><\/div>\n\t\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-default\">\n\t\t\t\t\t<div class=\"has_eae_slider elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-f6f0344\" data-eae-slider=\"62006\" data-id=\"f6f0344\" data-element_type=\"column\" data-e-type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-7d7ec67 elementor-widget elementor-widget-html\" data-id=\"7d7ec67\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"html.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<header class=\"header\">\n\t\t<div class=\"radio-toolbar\">\n\t\t\t<input type=\"radio\" id=\"hideBombBays\" name=\"toggleBombBays\" value=\"off\">\n\t\t\t<label for=\"hideBombBays\">Exclude Bomb Bays<\/label>\n\t\n\t\t\t<input type=\"radio\" id=\"showBombBays\" name=\"toggleBombBays\" value=\"on\">\n\t\t\t<label for=\"showBombBays\">Include Bomb Bays<\/label>\n\t\t<\/div>\n\t<\/header>\n\t<table id=\"ship-table\" class=\"bombbays-off\">\n\t\t<thead>\n\t\t\t<tr>\n\t\t\t\t<th colspan=\"2\">SHIP<\/th>\n\t\t\t\t<th>WEAPON HARDPOINTS & MISSILE BAYS<\/th>\n\t\t\t\t<th>FIREPOWER<\/th>\n\t\t\t<\/tr>\n\t\t<\/thead>\n\t\t<tbody>\n\t\t\t<tr class=\"loading\">\n\t\t\t\t<td colspan=\"4\" >\n\t\t\t\t\t<div class=\"loading-ripple\"><\/div>\n\t\t\t\t<\/td>\n\t\t\t<\/tr>\n\t\t<\/tbody>\n\t<\/table>\n\t<template id=\"ship\">\n\t\t<tr>\n\t\t\t<td class=\"image\">\n\t\t\t<\/td>\n\t\t\t<td class=\"designation\">\n\t\t\t\t<div class=\"name\"><\/div>\n\t\t\t\t<div class=\"type\"><\/div>\n\t\t\t<\/td>\n\t\t\t<td class=\"loadout\"><\/td>\n\t\t\t<td class=\"score\">\n\t\t\t\t<div class=\"firepower without-bb\"><\/div>\n\t\t\t\t<div class=\"firepower with-bb\"><\/div>\n\t\t\t\t<div class=\"per-vwap without-bb\"><\/div>\n\t\t\t\t<div class=\"per-vwap with-bb\"><\/div>\n\t\t\t<\/td>\n\t\t<\/tr>\n\t<\/template>\n\t<style>\n\t\t.header {\n\t\t\ttext-align: left;\n\t\t}\n\t\t.radio-toolbar {\n\t\t\tmargin: 0px 25px 10px;\n\t\t\tdisplay: inline-flex;\n\t\t\tborder: 2px solid var( --e-global-color-accent );\n\t\t\tborder-radius: 10px;\n\t\t\ttext-transform: uppercase;\n\t\t\tfont-weight: bold;\n\t\t}\n\n\t\t.radio-toolbar input[type=\"radio\"] {\n\t\t\topacity: 0;\n\t\t\tposition: fixed;\n\t\t\twidth: 0;\n\t\t}\n\n\t\t.radio-toolbar label {\n\t\t\tdisplay: inline-block;\n\t\t\tpadding: 12px 24px;\n\t\t\tfont-family: sans-serif, Arial;\n\t\t\tfont-size: 0.875em;\n\t\t\tline-height: 1.25em;\n\t\t\tcolor: var( --e-global-color-accent );\n\t\t\tbackground-color: transparent;\n\t\t\tbackground-image: linear-gradient(0deg, var( --e-global-color-c1310f0 ) 0%, var( --e-global-color-03359ba ) 100%);\n\t\t}\n\n\t\t.radio-toolbar label:first-of-type {\n\t\t\tborder-bottom-left-radius: 8px;\n\t\t\tborder-top-left-radius: 8px;\n\t\t}\n\n\t\t.radio-toolbar label:last-of-type {\n\t\t\tborder-bottom-right-radius: 8px;\n\t\t\tborder-top-right-radius: 8px;\n\t\t}\n\n\t\t.radio-toolbar label:hover,\n\t\t.radio-toolbar input[type=\"radio\"]:checked + label:not(:hover) {\n\t\t\tcolor: var( --e-global-color-03359ba );\n\t\t\tbackground-color: transparent;\n\t\t\tbackground-image: linear-gradient(0deg, var( --e-global-color-primary ) 0%, var( --e-global-color-accent ) 100%);\n\t\t}\n\n\t\t.radio-toolbar input[type=\"radio\"]:not(:checked) + label:hover {\n\t\t\tbox-shadow: inset 0px 0px 40px 5px rgba(255,255,255,0.8);\n\t\t\tcursor: pointer;\n\t\t}\n\n\t\t.radio-toolbar input[type=\"radio\"]:not(:checked) + label:not(:hover) {\n\t\t\tbox-shadow: inset 0px 0px 20px -1px rgba(0,0,0,0.85);\n\t\t}\n\n\t\t.radio-toolbar input[type=\"radio\"]:not(:checked):focus + label:not(:hover),\n\t\t.radio-toolbar input[type=\"radio\"]:checked:focus + label:not(:hover) {\n\t\t\tbox-shadow: inset 0px 0px 1px 1px rgba(255,255,255,0.85), 0px 0px 8px 0px rgba(255,255,255,0.65);\n\t\t}\n\n\t\t.radio-toolbar input[type=\"radio\"]:checked + label::before {\n\t\t\tdisplay: inline-block;\n\t\t\tcontent: '\u2771';\n\t\t\twidth: 0.6em;\n\t\t\tmargin-left: -0.6em;\n\t\t\tline-height: 1rem;\n\t\t\tfont-family: monospace;\n\t\t\tfont-size: 1.5em;\n\t\t\tvertical-align: top;\n\t\t\tpadding-right: 0.675em;\n\t\t}\n\t\t\n\t\ttable {\n\t\t\tfont-size: clamp(12px, 1.5vw, 16px);\n\t\t\tfont-family: \"Oswald\", Sans-Serif;\n\t\t\tbackground-color: rgba(0, 0, 0, 0.7);\n\t\t\tborder-spacing: 0;\n\t\t\tborder-collapse: collapse;\n\t\t}\n\n\t\tthead {\n\t\t\tbackground-color: transparent;\n    \t\tbackground-image: linear-gradient(270deg, #92DDFF 0%, var(--e-global-color-primary ) 100%);\n\t\t}\n\n\t\ttbody > tr > td {\n\t\t\tcursor: pointer;\n\t\t\tfont-weight: 500;\n\t\t}\n\n\t\ttbody > tr > td.image {\n\t\t\tpadding: 0;\n\t\t}\n\n\t\ttbody > tr > td:not(.image) {\n\t\t\ttext-transform: capitalize;\n\t\t\tpadding: 1em;\n\t\t\tvertical-align: middle;\n\t\t}\n\n\t\ttbody > tr:nth-child(odd) {\n\t\t\tbackground-color: #033247;\n\t\t}\n\t\ttbody > tr:nth-child(even) {\n\t\t\tbackground-color: #025072;\n\t\t}\n\n\t\tthead > tr > th {\n\t\t\tpadding: 1em;\n\t\t\tfont-size: 1.125em;\n\t\t\tcolor: rgb(3, 50, 71);\n\t\t\tline-height: 2em;\n\t\t\tfont-weight: 500;\n\t\t}\n\n\t\tth,\n\t\ttd {\n\t\t\ttext-align: left;\n\t\t}\n\n\t\ttr,\n\t\ttd {\n\t\t\tborder: 2px solid rgb(200, 237, 252) !important;\n\t\t}\n\n\t\tth {\n\t\t\tbackground-repeat: no-repeat;\n\t\t\tbackground-position: center right;\n\t\t\ttext-transform: uppercase;\n\t\t\tpadding-left: 6px;\n\t\t\tborder: none !important;\n\t\t}\n\n\t\t.image {\n\t\t\tmin-height: 94px;\n\t\t\tmin-width: clamp(100px, 20vw, 300px);\n\t\t\tbackground-size: cover;\n\t\t\tbackground-position: center;\n\t\t}\n\n\t\t.designation > .name {\n\t\t\tcolor: var(--e-global-color-45c5f93);\n    \t\tfont-size: 1.375em;\n\t\t\ttext-transform: uppercase;\n\t\t}\n\n\t\t.designation > .type {\n\t\t\tcolor: var(--e-global-color-accent);\n    \t\tfont-size: 1em;\n\t\t}\n\n\t\t.loadout {\n\t\t\tcolor: var(--e-global-color-45c5f93);\n\t\t}\n\n\t\t.score {\n\t\t\tmin-width: 11.25em;\n\t\t\tbackground-color: transparent;\n    \t\tbackground-image: linear-gradient(180deg, var(--e-global-color-secondary ) 0%, #7C004E 100%);\n\t\t\tcolor: #FFF;\n\t\t\ttext-align: center;\n\t\t}\n\n\t\t.bombbays-on .without-bb {\n\t\t\tdisplay: none;\n\t\t}\n\t\t.bombbays-off .with-bb {\n\t\t\tdisplay: none;\n\t\t}\n\n\t\t.score > .firepower {\n\t\t\tcolor: #E7F8FF;\n    \t\tfont-size: 2.625em;\n\t\t\t\/* font-size: 1.625em; *\/\n\t\t\tline-height: 1em;\n    \t\tfont-weight: 900;\n\t\t}\n\n\t\t.score > .per-vwap {\n\t\t\tcolor: #92E0FF;\n    \t\tfont-size: 1.25em;\n    \t\tfont-weight: 400;\n\t\t}\n\n\t\ttr.loading>td:not(.name):not(.vwap) {\n\t\t\ttext-align: center;\n\t\t}\n\n\t\t\/*Remove WordPress table styling*\/\n\t\ttable tbody>tr:nth-child(odd)>td,\n\t\ttable tbody>tr:nth-child(even)>td {\n\t\t\tbackground-color: transparent;\n\t\t}\n\n\t\t.loading-ripple {\n\t\t\tdisplay: inline-block;\n\t\t\tposition: relative;\n\t\t\twidth: 36px;\n\t\t\theight: 36px;\n\t\t}\n\n\t\t.loading-ripple::before,\n\t\t.loading-ripple::after {\n\t\t\tcontent: '';\n\t\t\tdisplay: block;\n\t\t\tposition: absolute;\n\t\t\tborder: 2px solid #fff;\n\t\t\tbox-sizing: content-box;\n\t\t\topacity: 1;\n\t\t\tborder-radius: 50%;\n\t\t\tanimation: loading-ripple 1.4s cubic-bezier(0, 0.2, 0.8, 1) infinite;\n\t\t}\n\n\t\t.loading-ripple::after {\n\t\t\tanimation-delay: -0.7s;\n\t\t}\n\n\t\t@keyframes loading-ripple {\n\t\t\t0% {\n\t\t\t\ttop: 16px;\n\t\t\t\tleft: 16px;\n\t\t\t\twidth: 0;\n\t\t\t\theight: 0;\n\t\t\t\topacity: 1;\n\t\t\t}\n\n\t\t\t100% {\n\t\t\t\ttop: 0px;\n\t\t\t\tleft: 0px;\n\t\t\t\twidth: 32px;\n\t\t\t\theight: 32px;\n\t\t\t\topacity: 0;\n\t\t\t}\n\t\t}\n\t<\/style>\n\t<script>\n\t\tconst DATA_URI = 'https:\/\/data.aephia.com\/assets.json';\n\n\t\tconst FIREPOWER_CREW_SLOTS = [\n\t\t\t'Weapons Operator',\n\t\t];\n\n\t\tconst FIREPOWER_COMPONENT_SLOTS = [\n\t\t\t'Fixed Hardpoint',\n\t\t\t'Turret Hardpoint',\n\t\t\t'Missile Bay',\n\t\t\t'Bomb Bay',\n\t\t\t\/\/ 'Drone Port',\n\t\t];\n\n\t\tconst FIREPOWER_MODULE_SLOTS = [\n\t\t\t'Ammo'\n\t\t];\n\n\t\tconst bombBays = {\n\t\t\tEXCLUDE: 0,\n\t\t\tINCLUDE: 1,\n\t\t};\n\n\t\tconst tableBodyEl = document.querySelector('#ship-table > tbody');\n\t\tconst shipTemplate = document.getElementById('ship');\n\n\t\tlet includeBombBays = false;\n\n\t\tfunction getData() {\n\t\t\treturn fetch(DATA_URI)\n\t\t\t\t.then(async (response) => {\n\t\t\t\t\tif (response.status >= 400) {\n\t\t\t\t\t\tconst text = await response.text();\n\t\t\t\t\t\treturn Promise.reject(new Error(`[${response.status}] ${response.statusText}: ${text}`));\n\t\t\t\t\t}\n\t\t\t\t\treturn response.json();\n\t\t\t\t})\n\t\t\t\t.then(showShipData);\n\t\t}\n\n\t\tfunction getRelevantShipData(data) {\n\t\t\tconst ships = data.ship;\n\t\t\t\n\t\t\treturn Object.keys(ships).map((mintId) => {\n\t\t\t\tconst ship = ships[mintId];\n\t\t\t\tconst { totalSupply, vwap, originationPrice } = calculateVwapAndTotalSupply(\n\t\t\t\t\tship.primarySales,\n\t\t\t\t\tship.airdrops || [],\n\t\t\t\t\tship.totalSupply\n\t\t\t\t);\n\n\t\t\t\tconst { firepowerWithBombBays, firepowerWithoutBombBays } = getFirePower(ship); \/\/ship.aepData?.firepower ?? 0,\n\n\t\t\t\treturn {\n\t\t\t\t\timage: ship.image,\n\t\t\t\t\tname: ship.name,\n\t\t\t\t\tattributes: ship.attributes,\n\t\t\t\t\tloadout: getLoadout(ship, 'firepower'),\n\t\t\t\t\tfirepower: firepowerWithoutBombBays,\n\t\t\t\t\tfirepowerWithBB: firepowerWithBombBays,\n\t\t\t\t\tslots: ship.slots,\n\t\t\t\t\toriginationPrice,\n\t\t\t\t\tvwap,\n\t\t\t\t\ttotalSupply\n\t\t\t\t}\n\t\t\t});\n\t\t}\n\n\t\tfunction getLoadout(ship, type) {\n\t\t\tconst components = ship.slots.componentSlots\n\t\t\t\t.filter((slot) => FIREPOWER_COMPONENT_SLOTS.includes(slot.type))\n\t\t\t\t.map((slot) => {\n\t\t\t\t\treturn `${ slot.quantity } ${ size(slot.size) } ${ plural(slot.type, slot.quantity > 1) }`;\n\t\t\t\t});\n\n\t\t\t\/\/ const modules = ship.slots.moduleSlots\n\t\t\t\/\/ \t.filter((slot) => FIREPOWER_MODULE_SLOTS.includes(slot.type))\n\t\t\t\/\/ \t.map((slot) => {\n\t\t\t\/\/ \t\treturn `${slot.quantity} ${size(slot.size)} ${slot.type} ${plural('Module', slot.quantity > 1)}`;\n\t\t\t\/\/ \t});\n\n\t\t\t\/\/ const crew = ship.slots.crewSlots\n\t\t\t\/\/ \t.filter((slot) => FIREPOWER_CREW_SLOTS.includes(slot.type))\n\t\t\t\/\/ \t.map((slot) => {\n\t\t\t\/\/ \t\treturn `${slot.quantity} ${size(slot.size)} ${plural(slot.type, slot.quantity > 1)}`;\n\t\t\t\/\/ \t});\n\n\n\t\t\treturn [...components \/**, ...modules, ...crew**\/].join(' | ');\n\t\t}\n\n\t\tfunction size(size) {\n\t\t\tconst parts = size.split('-');\n\t\t\tif (parts.length === 1) {\n\t\t\t\treturn capitalize(size);\n\t\t\t}\n\t\t\treturn `${ parts[0].toUpperCase() }-${ capitalize(parts[1]) }`\n\t\t}\n\n\t\tfunction plural(term, plural) {\n\t\t\tif (!plural) {\n\t\t\t\treturn term;\n\t\t\t}\n\n\t\t\treturn term + 's';\n\t\t}\n\n\t\tfunction getPrettyType(ship) {\n\t\t\treturn `${capitalize(ship.attributes.rarity)} ${ size(ship.attributes.class) } ${ capitalize(ship.attributes.spec) }`;\n\t\t}\n\n\t\tfunction capitalize(str) {\n\t\t\treturn str[0].toUpperCase() + str.slice(1);\n\t\t}\n\n\t\tfunction showShipData(data) {\n\t\t\tconst fragment = new DocumentFragment();\n\t\t\tconst shipData = getRelevantShipData(data);\n\t\t\tconst sortedShips = shipData.sort((shipA, shipB) => shipB.firepower - shipA.firepower );\n\t\t\tconst shipRowEls = sortedShips.map(createShipRow);\n\n\t\t\ttableBodyEl.innerHTML = '';\n\t\t\tfragment.append(...shipRowEls);\n\t\t\ttableBodyEl.appendChild(fragment);\n\t\t}\n\n\t\tfunction createShipRow(ship) {\n\t\t\tconst newShipRowEl = shipTemplate.content.cloneNode(true);\n\t\t\tconst fp = Math.round(ship.firepower * 10) \/ 10;\n\t\t\tconst fpBB = Math.round(ship.firepowerWithBB * 10) \/ 10;\n\t\t\tconst fpPerVWAP = Math.round(1000 * ship.firepower \/ ship.vwap) \/ 1000;\n\t\t\tconst fpBBPerVWAP = Math.round(1000 * ship.firepowerWithBB \/ ship.vwap) \/ 1000;\n\n\t\t\tnewShipRowEl.children[0].setAttribute('data-firepower', fp);\n\t\t\tnewShipRowEl.children[0].setAttribute('data-firepower-bomb', fpBB);\n\n\n\t\t\tlet td = newShipRowEl.querySelectorAll('td');\n\t\t\ttd[0].style = `background-image: url(${ship.image});`;\n\t\t\ttd[1].children[0].textContent = ship.name;\n\t\t\ttd[1].children[1].textContent = getPrettyType(ship);\n\t\t\ttd[2].textContent = ship.loadout;\n\t\t\ttd[3].children[0].textContent = fp;\n\t\t\ttd[3].children[1].textContent = fpBB;\n\t\t\ttd[3].children[2].textContent = `${fpPerVWAP !== Infinity ? fpPerVWAP : '--'} FP\/$`;\n\t\t\ttd[3].children[3].textContent = `${fpBBPerVWAP !== Infinity ? fpBBPerVWAP : '--'} FP\/$`;\n\t\t\t\/\/ td[3].children[1].textContent = `prev: ${Math.round(ship.firepower * 10) \/ 10}`;\n\t\t\treturn newShipRowEl;\n\t\t}\n\n\t\tfunction connectToggles() {\n\t\t\tconst bombBaysEls = document.getElementsByName('toggleBombBays');\n\n\t\t\tfor (var i = 0; i < bombBaysEls.length; i++) {\n\t\t\t\tif (bombBaysEls[i].value === 'on' && includeBombBays) {\n\t\t\t\t\tbombBaysEls[i].checked = true;\n\t\t\t\t}\n\t\t\t\tif (bombBaysEls[i].value === 'off' && !includeBombBays) {\n\t\t\t\t\tbombBaysEls[i].checked = true;\n\t\t\t\t}\n\t\t\t\tbombBaysEls[i].onchange = function (evt) {\n\t\t\t\t\ttoggleBombBays(this.value === 'on');\n\t\t\t\t};\n\t\t\t}\n\t\t}\n\n\t\tfunction toggleBombBays(show) {\n\t\t\tconst shipTable = document.getElementById('ship-table');\n\t\t\tshipTable.classList.remove('bombbays-on', 'bombbays-off');\n\t\t\tshipTable.classList.add(`bombbays-${show ? 'on' : 'off'}`);\n\t\t\tif (show) {\n\t\t\t\tsortTable(shipTable, 'firepowerBomb');\n\t\t\t} else {\n\t\t\t\tsortTable(shipTable, 'firepower');\n\t\t\t}\n\t\t}\n\n\t\tfunction sortTable(table, dataKey) {\n\t\t\tconst tbody = table.querySelector('tbody');\n\t\t\tconst getValue = (tr, dataKey) => tr.dataset[dataKey];\n\n\t\t\tconst comparer = (dataKey, asc) => (a, b) => ((v1, v2) =>\n\t\t\t\tv1 !== '' && v2 !== '' && !isNaN(v1) && !isNaN(v2) ? v1 - v2 : v1.toString().localeCompare(v2)\n\t\t\t)(getValue(asc ? a : b, dataKey), getValue(asc ? b : a, dataKey));\n\t\t\t\n\t\t\tArray.from(tbody.querySelectorAll('tr:nth-child(n+1)'))\n\t\t\t\t.sort(comparer(dataKey, false))\n\t\t\t\t.forEach(tr => tbody.appendChild(tr));\n\t\t}\n\n\t\tfunction calculateVwapAndTotalSupply(salesWaves, airdrops, officialTotalSupply = 0) {\n\t\t\tlet totalSupply = 0;\n\t\t\tlet totalShipValue = 0;\n\t\t\tlet originationPrice = 0;\n\t\t\tlet vwap = 0;\n\n\t\t\tfor (const salesWave of salesWaves) {\n\t\t\t\ttotalSupply += salesWave.supply;\n\t\t\t\ttotalShipValue += salesWave.supply * salesWave.price;\n\t\t\t}\n\n\t\t\tif (totalSupply) {\n\t\t\t\toriginationPrice = salesWaves[0].price;\n\t\t\t\tvwap = Math.round((totalShipValue \/ totalSupply) * 100) \/ 100;\n\t\t\t}\n\n\t\t\tfor (const airdrop of airdrops) {\n\t\t\t\ttotalSupply += airdrop.supply;\n\t\t\t}\n\n\t\t\ttotalSupply = Math.max(totalSupply, officialTotalSupply);\n\n\t\t\treturn {\n\t\t\t\tvwap,\n\t\t\t\ttotalSupply,\n\t\t\t\toriginationPrice\n\t\t\t};\n\t\t}\n\n\t\tconst TYPE_MODIFIERS = {\n\t\t\t'Fixed Hardpoint': 1,\n\t\t\t'Turret Hardpoint': 0.9,\n\t\t\t'Missile Bay': 1,\n\t\t\t\/\/'Bomb Bay': 4\n\t\t};\n\n\t\tconst BOMB_BAY_MODIFIER = {\n\t\t\t'Bomb Bay': 4\n\t\t};\n\n\t\tconst SIZE_CLASS = {\n\t\t\t'xxx-small': 0,\n\t\t\t'xx-small': 1,\n\t\t\t'x-small': 2,\n\t\t\t'small': 3,\n\t\t\t'medium': 4,\n\t\t\t'large': 5,\n\t\t\t'capital': 6,\n\t\t\t'commander': 7,\n\t\t\t'titan': 9,\n\t\t};\n\n\t \tconst MAKE_HARDPOINT_MODIFIERS = {\n\t\t\t'Pearce': 6,\n\t\t\t'Busan': 4,\n\t\t\t'VZUS': 5,\n\t\t\t'Calico': 5.5,\n\t\t\t'Ogrika': 3.75,\n\t\t\t'Opal': 5.25,\n\t\t\t'Armstrong': 3.75,\n\t\t\t'Fimbul': 4.5,\n\t\t\t'Fimbul BYOS': 6.25,\n\t\t\t'Fimbul ECOS': 5.75,\n\t\t\t'Tufa': 4.75,\n\t\t\t'Rainbow': 6.5,\n\t\t\t'FloydLine': 5,\n\t\t};\n\n\t\tconst MAKE_BAY_MODIFIERS = {\n\t\t\t'Pearce': 4,\n\t\t\t'Busan': 5,\n\t\t\t'VZUS': 6,\n\t\t\t'Calico': 3.75,\n\t\t\t'Ogrika': 5.5,\n\t\t\t'Opal': 5,\n\t\t\t'Armstrong Industries': 3.75,\n\t\t\t'Fimbul': 4.5,\n\t\t\t'Fimbul BYOS': 5,\n\t\t\t'Fimbul ECOS': 6.5,\n\t\t\t'Tufa': 5.75,\n\t\t\t'Rainbow': 4.75,\n\t\t\t'FloydLine': 5.25,\n\t\t};\n\n\t\tconst SPEC_HARDPOINT_MODIFIERS = {\n\t\t\t'fighter': 4,\n\t\t\t'bomber': 3,\n\t\t\t'bounty hunter': 2,\n\t\t\t'smuggler': 2,\n\t\t\t'freight': 1,\n\t\t\t'refuel': 1,\n\t\t\t'refuel\/repair': 2,\n\t\t\t'repair': 2,\n\t\t\t'salvage': 1,\n\t\t\t'rescue': 2,\n\t\t\t'transport': 2,\n\t\t\t'racer': 2,\n\t\t\t'data runner': 2,\n\t\t\t'multi-role': 2,\n\t\t\t'miner': 1,\n\t\t\t'tow': 1,\n\t\t};\n\n\t\tconst SPEC_BAY_MODIFIERS = {\n\t\t\t'fighter': 2,\n\t\t\t'bomber': 4,\n\t\t\t'bounty hunter': 2,\n\t\t\t'smuggler': 2,\n\t\t\t'freight': 1,\n\t\t\t'refuel': 1,\n\t\t\t'refuel\/repair': 1,\n\t\t\t'repair': 1,\n\t\t\t'salvage': 1,\n\t\t\t'rescue': 1,\n\t\t\t'transport': 2,\n\t\t\t'racer': 1,\n\t\t\t'data runner': 2,\n\t\t\t'multi-role': 2,\n\t\t\t'miner': 1,\n\t\t\t'tow': 1,\n\t\t};\n\n\t\tfunction getSizeModifier(size) {\n\t\t\treturn Math.pow(2, SIZE_CLASS[size]);\n\t\t}\n\n\t\tfunction getFirePower(ship) {\n\t\t\tconst make = ship.attributes.make;\n\t\t\tconst spec = ship.attributes.spec;\n\t\t\tconst compSlots = ship.slots.componentSlots;\n\n\t\t\tlet fpScore = 0;\n\t\t\tlet fpBBScore = 0;\n\t\t\tcompSlots.forEach((slot) => {\n\t\t\t\tlet score = TYPE_MODIFIERS[slot.type];\n\t\t\t\tif (score) {\n\t\t\t\t\tconst slotScore = getSlotScore(score, slot, make, spec);\n\t\t\t\t\tfpScore += slotScore;\n\t\t\t\t\tfpBBScore += slotScore;\n\t\t\t\t\treturn;\n\t\t\t\t}\n\n\t\t\t\tscore = BOMB_BAY_MODIFIER[slot.type];\n\t\t\t\tif (score) {\n\t\t\t\t\tfpBBScore += getSlotScore(score, slot, make, spec);\n\t\t\t\t}\n\t\t\t});\n\n\t\t\treturn { firepowerWithBombBays: fpBBScore, firepowerWithoutBombBays: fpScore };\n\t\t}\n\n\t\tfunction getSlotScore(score, slot, make, spec) {\n\t\t\tconst quantity = slot.size === 'large' && slot.type === 'Turret Hardpoint' && ship.name === 'Busan Maiden Heart' ? 2 : slot.quantity;\n\t\t\tconst slotBaseType = slot.type.split(' ')[1];\n\t\t\tconst baseScore = score * quantity * getSizeModifier(slot.size);\n\n\t\t\tif (slotBaseType === 'Hardpoint') {\n\t\t\t\treturn baseScore * (\n\t\t\t\t\t(MAKE_HARDPOINT_MODIFIERS[make] \/ 10) +\n\t\t\t\t\t(SPEC_HARDPOINT_MODIFIERS[spec] \/ 10) +\n\t\t\t\t\t1\n\t\t\t\t);\n\t\t\t} else if (slotBaseType === 'Bay') {\n\t\t\t\treturn baseScore * (\n\t\t\t\t\t(MAKE_BAY_MODIFIERS[make] \/ 10) +\n\t\t\t\t\t(SPEC_BAY_MODIFIERS[spec] \/ 10) +\n\t\t\t\t\t1\n\t\t\t\t);\n\t\t\t}\n\t\t}\n\n\t\tgetData();\n\t\tconnectToggles();\n\t<\/script>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/section>\n\t\t\t\t<section class=\"has_eae_slider elementor-section elementor-top-section elementor-element elementor-element-64f29c74 elementor-hidden-desktop elementor-hidden-tablet elementor-hidden-mobile elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-eae-slider=\"72258\" data-id=\"64f29c74\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;background_background&quot;:&quot;gradient&quo
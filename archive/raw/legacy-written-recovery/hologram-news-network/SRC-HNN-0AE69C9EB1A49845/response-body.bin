reen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:98a33632a88b-viewerId:lo_f50ca61fc249"},"Paragraph:b886128f3f08_0":{"__typename":"Paragraph","id":"b886128f3f08_0","name":"8731","type":"H3","href":null,"layout":null,"metadata":null,"text":"Star Atlas SAGE Crafting: The Best Way to Get Crews Cheaply","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_1":{"__typename":"Paragraph","id":"b886128f3f08_1","name":"7887","type":"P","href":null,"layout":null,"metadata":null,"text":"Dec 16th, 2022 — Back in August, we published an article theory crafting what would be the best and most efficient way to gain crew members for crafting in Star Atlas SAGE. Today, with the release of the draft SAGE game manual, we finally have some more clarity.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":49,"end":56,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fwhat-will-be-the-first-star-atlas-crafting-meta-5c7a3833d176","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":156,"end":166,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null},{"__typename":"Markup","type":"A","start":220,"end":226,"href":"https:\u002F\u002Fstaratlas.com\u002Fnewsroom\u002Fgame-manuals\u002Fsage-game-manual-part-2-game-structure","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_2":{"__typename":"Paragraph","id":"b886128f3f08_2","name":"5b57","type":"P","href":null,"layout":null,"metadata":null,"text":"Disclaimer: Information in this guide is subject to change and without warning by Star Atlas. The information below comes from the Star Atlas SAGE manual with additional amplifying Q&A from the Star Atlas Devs.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":10,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":0,"end":210,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*fKEtNDANRPIsbPEqmS_Phw.png":{"__typename":"ImageMetadata","id":"1*fKEtNDANRPIsbPEqmS_Phw.png","originalHeight":512,"originalWidth":512,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:b886128f3f08_3":{"__typename":"Paragraph","id":"b886128f3f08_3","name":"1fc0","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*fKEtNDANRPIsbPEqmS_Phw.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_4":{"__typename":"Paragraph","id":"b886128f3f08_4","name":"81fb","type":"H4","href":null,"layout":null,"metadata":null,"text":"Basic Crew Mechanics","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_5":{"__typename":"Paragraph","id":"b886128f3f08_5","name":"73d1","type":"OLI","href":null,"layout":null,"metadata":null,"text":"To begin, we establish the premise that Crafting capacity in SAGE will be determined by amount of Crew Members docked in a Central Space Station or Star Base.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":40,"end":158,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":111,"end":118,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_6":{"__typename":"Paragraph","id":"b886128f3f08_6","name":"29ed","type":"P","href":null,"layout":null,"metadata":null,"text":"2. Second, total crafting capacity management is determined by the number of privilege points a player has invested into that skill. A player can only earn 142 total privilege points on one account","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":3,"end":135,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*QffTGoFnfaR-kgKo2GksSw.png":{"__typename":"ImageMetadata","id":"1*QffTGoFnfaR-kgKo2GksSw.png","originalHeight":57,"originalWidth":902,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:b886128f3f08_7":{"__typename":"Paragraph","id":"b886128f3f08_7","name":"f830","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*QffTGoFnfaR-kgKo2GksSw.png"},"text":"Crafting Capacity Privilege","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_8":{"__typename":"Paragraph","id":"b886128f3f08_8","name":"f15a","type":"P","href":null,"layout":null,"metadata":null,"text":"Theoretically, a player could invest all 142 points into Crafting Capacity, but that would leave no room for other important privileges like fleet size. We’ll cover a potential side option a bit later.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_9":{"__typename":"Paragraph","id":"b886128f3f08_9","name":"a2f1","type":"P","href":null,"layout":null,"metadata":null,"text":"3. SAGE is no longer using a hangar gating mechanism and players are free to deposit ships into SAGE (This was a recent change and may change before the release of SAGE). These ships, theoretically, should not count against a players fleet size or command limits so long as they remain docked. However, the benefit here is that these ships will count towards your Crew available to craft.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":3,"end":100,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_10":{"__typename":"Paragraph","id":"b886128f3f08_10","name":"f574","type":"H4","href":null,"layout":null,"metadata":null,"text":"So What is the Cheapest Way to Get Crews?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":41,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*vxMh53AuJenfVOLy":{"__typename":"ImageMetadata","id":"0*vxMh53AuJenfVOLy","originalHeight":1354,"originalWidth":2560,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:b886128f3f08_11":{"__typename":"Paragraph","id":"b886128f3f08_11","name":"0ee4","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*vxMh53AuJenfVOLy"},"text":"FIMBUL Airbike complete with a crafter!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_12":{"__typename":"Paragraph","id":"b886128f3f08_12","name":"d286","type":"P","href":null,"layout":null,"metadata":null,"text":"That’s right, the FIMBUL Airbike is currently the cheapest and easiest way to accumulate a large crew staff for any crafting mogul.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_13":{"__typename":"Paragraph","id":"b886128f3f08_13","name":"2d77","type":"P","href":null,"layout":null,"metadata":null,"text":"Compared to a single Commander ship or even Titan, the crew cost per ship ratio for the Airbike is 1\u002F1000th the price of any larger ship.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_14":{"__typename":"Paragraph","id":"b886128f3f08_14","name":"2980","type":"H4","href":null,"layout":null,"metadata":null,"text":"So how many should you have?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":28,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_15":{"__typename":"Paragraph","id":"b886128f3f08_15","name":"3fdf","type":"P","href":null,"layout":null,"metadata":null,"text":"First, its important to understand that these mechanics could change in the future. However, given the current cost and understanding of future SAGE gameplay, we recommend no more than 50 Airbikes depending on the amount of crafting you plan on partaking in during SAGE.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_16":{"__typename":"Paragraph","id":"b886128f3f08_16","name":"eb08","type":"P","href":null,"layout":null,"metadata":null,"text":"To fully utilize 50 Airbikes, you will need 50 points in the Crafting Capacity privilege. 50 points in Crafting Capacity governs the amount of active crafting crew you can have across the entire SAGE map at one time, not a single Star Base. Don’t think you can have 50 crew at each Star Base crafting simultaneously in your little empire.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":217,"end":241,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":217,"end":241,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_17":{"__typename":"Paragraph","id":"b886128f3f08_17","name":"6159","type":"P","href":null,"layout":null,"metadata":null,"text":"Alternatively, you could increase your Crafting Capacity Privilege to a lesser amount and then split your Airbike crews across multiple Star Bases depending on factors like proximity to resources and faction allies.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_18":{"__typename":"Paragraph","id":"b886128f3f08_18","name":"038b","type":"P","href":null,"layout":null,"metadata":null,"text":"Say a privilege score of 25, you would have two star bases with 25 crews each. Or 5 Star Bases with 10 crews each. Its all up to your playstyle.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_19":{"__typename":"Paragraph","id":"b886128f3f08_19","name":"5862","type":"H4","href":null,"layout":null,"metadata":null,"text":"Maximizing Crew Capacity","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":24,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_20":{"__typename":"Paragraph","id":"b886128f3f08_20","name":"86d3","type":"P","href":null,"layout":null,"metadata":null,"text":"Again, the Crew Capacity Privilege maxes out at 142, meaning you can at most have 142 active crew at once. This is due to the Privilege Point cap on a single account.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_21":{"__typename":"Paragraph","id":"b886128f3f08_21","name":"8a49","type":"P","href":null,"layout":null,"metadata":null,"text":"Here is where we get into a little grey area. If you begin to find that having a large crafting privilege is preventing you from strengthening one of your other player areas, you could theoretically create a second account specifically for crafting.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_22":{"__typename":"Paragraph","id":"b886128f3f08_22","name":"3272","type":"P","href":null,"layout":null,"metadata":null,"text":"However, that’s not something we can universally recommend at this time as its unclear what the disadvantages of doing so are; there will likely be some. While we’re not talking TOS violations, your main account could be missing out on applicable career progression bonuses.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_23":{"__typename":"Paragraph","id":"b886128f3f08_23","name":"6fe0","type":"P","href":null,"layout":null,"metadata":null,"text":"If anything changes, we’ll continue to update this article or publish a completely new one if the changes are significant. Make sure you follow and subscribe to get the latest info direct to your inbox","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":201,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_24":{"__typename":"Paragraph","id":"b886128f3f08_24","name":"c904","type":"P","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_25":{"__typename":"Paragraph","id":"b886128f3f08_25","name":"5c46","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs is the founder of The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of the Star Atlas game. Krigs has covered Star Atlas for the past year and enjoys writing about the potential that blockchain technology has to revolutionize the gaming industry.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_26":{"__typename":"Paragraph","id":"b886128f3f08_26","name":"55f6","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_27":{"__typename":"Paragraph","id":"b886128f3f08_27","name":"67a8","type":"P","href":null,"layout":null,"metadata":null,"text":"Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":19,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":22,"end":25,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_28":{"__typename":"Paragraph","id":"b886128f3f08_28","name":"f117","type":"P","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_29":{"__typename":"Paragraph","id":"b886128f3f08_29","name":"3273","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:b886128f3f08_30":{"__typename":"Paragraph","id":"b886128f3f08_30","name":"d8e4","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_f50ca61fc249":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_f50ca61fc249","isEditor":false},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"User:7d1512646bf9":{"__typename":"User","id":"7d1512646bf9","imageId":"0*AjlCF7UqhOpmOQ7v","mediumMemberAt":0,"name":"LotusLovesLotus","username":"lotusloveslotus","customDomainState":{"__typename":"CustomDomainState","live":{"__typename":"CustomDomain","domain":"lotusloveslotus.medium.com"}},"hasSubdomain":true,"bio":"Latina lesbian who writes, games, and streams. linktr.ee\u002Flotusloveslotus"},"Post:69d9bdc8c866":{"__typename":"Post","id":"69d9bdc8c866","visibility":"PUBLIC","previewContent":{"__typename":"PreviewContent","isFullContent":false,"subtitle":"There’s a tendency to equate game length with quality, or to measure a game’s worth by its hours of game time… I completely disagree."},"collection":null,"title":"Games Are Too Fucking Long","mediumUrl":"https:\u002F\u002Flotusloveslotus.medium.com\u002Fgames-are-too-fucking-long-69d9bdc8c866","creator":{"__ref":"User:7d1512646bf9"},"previewImage":{"__ref":"ImageMetadata:"},"clapCount":0,"isSeries":false,"sequence":null,"uniqueSlug":"games-are-too-fucking-long-69d9bdc8c866"},"User:c0dbee17ac81":{"__typename":"User","id":"c0dbee17ac81","imageId":"1*lNUr-6jjy3LGMe0MN-n2gA.png","mediumMemberAt":0,"name":"MacSources","username":"macsources","customDomainState":{"__typename":"CustomDomainState","live":{"__typename":"CustomDomain","domain":"macsources.medium.com"}},"hasSubdomain":true,"bio":"Mac Sources is an Information and Technology Company. We review all things technology-related. Our team also reports on tech news happening in the world. "},"ImageMetadata:0*SabG9gk6Ic5_55xP":{"__typename":"ImageMetadata","id":"0*SabG9gk6Ic5_55xP","alt":null,"focusPercentX":null,"focusPercentY":null},"Post:4afd2464d243":{"__typename":"Post","id":"4afd2464d243","visibility":"PUBLIC","previewContent":{"__typename":"PreviewContent","isFullContent":false,"subtitle":"VIOTEK SUW49C 49 Inch Ultrawide Curved HDR Gaming Monitor"},"collection":null,"title":"VIOTEK SUW49C 49 Inch Super Ultrawide Curved HDR Gaming Monitor REVIEW | Mac Sources","mediumUrl":"https:\u002F\u002Fmacsources.medium.com\u002Fviotek-suw49c-49-inch-super-ultrawide-curved-hdr-gaming-monitor-review-mac-sources-4afd2464d243","creator":{"__ref":"User:c0dbee17ac81"},"previewImage":{"__ref":"ImageMetadata:0*SabG9gk6Ic5_55xP"},"clapCount":0,"isSeries":false,"sequence":null,"uniqueSlug":"viotek-suw49c-49-inch-super-ultrawide-curved-hdr-gaming-monitor-review-mac-sources-4afd2464d243"},"User:405c6d7ec1e9":{"__typename":"User","id":"405c6d7ec1e9","imageId":"1*0ghDVj6rTIJS_1vBPB9QEg.png","mediumMemberAt":0,"name":"Spork","username":"guanmao","customDomainState":{"__typename":"CustomDomainState","live":{"__typename":"CustomDomain","domain":"guanmao.medium.com"}},"hasSubdomain":true,"bio":"Just want to liberate people from the evils of capitalism and build something better."},"Post:99e6deddc86b":{"__typename":"Post","id":"99e6deddc86b","visibility":"PUBLIC","previewContent":{"__typename":"PreviewContent","isFullContent":false,"subtitle":"One of the great misrepresentations of reality in the video game industry is the railroad management game. Most deal solely with trains…"},"collection":null,"title":"The Train ‘Empire’ Game That Will Never Be Made","mediumUrl":"https:\u002F\u002Fguanmao.medium.com\u002Fthe-train-empire-game-that-will-never-be-made-99e6deddc86b","creator":{"__ref":"User:405c6d7ec1e9"},"previewImage":{"__ref":"ImageMetadata:"},"clapCount":0,"isSeries":false,"sequence":null,"uniqueSlug":"the-train-empire-game-that-will-never-be-made-99e6deddc86b"},"Collection:d1ab18a7abb8":{"__typename":"Collection","id":"d1ab18a7abb8","slug":"lootnft","name":"lootnft","domain":null},"User:73a6db355c43":{"__typename":"User","id":"73a6db355c43","imageId":"1*dli_xfPMwkhbF_eZJ24Mbg.jpeg","mediumMemberAt":0,"name":"Melanie kondo","username":"melaniekondo98","customDomainState":{"__typename":"CustomDomainState","live":{"__typename":"CustomDomain","domain":"melaniekondo98.medium.com"}},"hasSubdomain":true,"bio":""},"ImageMetadata:1*ZQGsTnGV4ia0xhBgawehvA.png":{"__typename":"ImageMetadata","id":"1*ZQGsTnGV4ia0xhBgawehvA.png","alt":null,"focusPercentX":null,"focusPercentY":null},"Post:7685adc34cd1":{"__typename":"Post","id":"7685adc34cd1","visibility":"PUBLIC","previewContent":{"__typename":"PreviewContent","isFullContent":false,"subtitle":"Less than a week ago, Loot NFT announced the commencement of its very first auctions. After great anticipation surrounding these auctions…"},"collection":{"__ref":"Collection:d1ab18a7abb8"},"title":"The Genesis NFT","mediumUrl":"https:\u002F\u002Fmedium.com\u002Flootnft\u002Fthe-genesis-nft-7685adc34cd1","creator":{"__ref":"User:73a6db355c43"},"previewImage":{"__ref":"ImageMetadata:1*ZQGsTnGV4ia0xhBgawehvA.png"},"clapCount":95,"isSeries":false,"sequence":null,"uniqueSlug":"the-genesis-nft-7685adc34cd1"},"User:8f549a791104":{"__typename":"User","id":"8f549a791104","imageId":"1*C7fcJyln0mTuY6esUqu8uw.png","mediumMemberAt":0,"name":"Kyle M. Matos","username":"kyle.matos14","customDomainState":null,"hasSubdomain":false,"bio":"An aspiring game designer who wants to tell great stories."},"ImageMetadata:1*VEgYMgH2vAfiDx22uMMx-w.jpeg":{"__typename":"ImageMetadata","id":"1*VEgYMgH2vAfiDx22uMMx-w.jpeg","alt":null,"focusPercentX":null,"focusPercentY":null},"Post:c32b06a7e7f4":{"__typename":"Post","id":"c32b06a7e7f4","visibility":"PUBLIC","previewContent":{"__typename":"PreviewContent","isFullContent":false,"subtitle":"Grand Archive is a newly emerging trading card game from Weebs of the Shore — genuinely love the company name btw — that debuted on…"},"collection":null,"title":"Grand Archive: Redesigning Spirit Cards","mediumUrl":"https:\u002F\u002Fmedium.com\u002F@kyle.matos14\u002Fgrand-archive-redesigning-spirit-cards-c32b06a7e7f4","creator":{"__ref":"User:8f549a791104"},"previewImage":{"__ref":"I
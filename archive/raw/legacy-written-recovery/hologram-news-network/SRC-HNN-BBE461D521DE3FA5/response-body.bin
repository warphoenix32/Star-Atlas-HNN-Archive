r":false,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"},{"__ref":"Tag:scifi"}],"readingTime":4.10503144654088,"inResponseToEntityType":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1674407816190,"previewContent":{"__typename":"PreviewContent","subtitle":"“Secure your seat, save your feet, docking safety can’t be beat!”"},"previewImage":{"__ref":"ImageMetadata:1*vs_fCJXuvlkDdVWmyVqQxw.png"},"isShortform":false,"seoTitle":"","updatedAt":1674407820539,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"isSuspended":false,"responseRootPost":{"__typename":"ResponseRootPost","post":{"__ref":"Post:9651b51a0695"}},"internalLinks({\"paging\":{\"limit\":8}})":{"__typename":"InternalLinksConnection","items":[]},"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}},"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg","originalWidth":2730,"focusPercentX":48.57142857142857,"focusPercentY":45.19230769230769},"ImageMetadata:1*EWK2g3sZ2CUq9HSp-mKvEA.png":{"__typename":"ImageMetadata","id":"1*EWK2g3sZ2CUq9HSp-mKvEA.png","originalWidth":1024},"PostViewerEdge:postId:9651b51a0695-viewerId:lo_56d17bea3789":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:9651b51a0695-viewerId:lo_56d17bea3789"},"Paragraph:81fdbdab8892_0":{"__typename":"Paragraph","id":"81fdbdab8892_0","name":"8725","type":"H3","href":null,"layout":null,"metadata":null,"text":"Galactic Regulations of Space Station Docking in Star Atlas","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_1":{"__typename":"Paragraph","id":"81fdbdab8892_1","name":"18d6","type":"P","href":null,"layout":null,"metadata":null,"text":"“Secure your seat, save your feet, docking safety can’t be beat!”","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":65,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_2":{"__typename":"Paragraph","id":"81fdbdab8892_2","name":"f01c","type":"P","href":null,"layout":null,"metadata":null,"text":"The developing Star Atlas world is a unique and immersive metaverse experience that combines the elements of gaming, space exploration, and cryptocurrency. While the game itself is already becoming a captivating experience, it’s important for any new or veteran pilot to review these important precautions while docking or undocking to Galactic Space Stations.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":15,"end":25,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":58,"end":67,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":270,"end":293,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":294,"end":311,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":312,"end":359,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*vs_fCJXuvlkDdVWmyVqQxw.png":{"__typename":"ImageMetadata","id":"1*vs_fCJXuvlkDdVWmyVqQxw.png","originalHeight":678,"originalWidth":999,"focusPercentX":null,"focusPercentY":null,"alt":"NotBitcoinCEO Space Station"},"Paragraph:81fdbdab8892_3":{"__typename":"Paragraph","id":"81fdbdab8892_3","name":"47b5","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*vs_fCJXuvlkDdVWmyVqQxw.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_4":{"__typename":"Paragraph","id":"81fdbdab8892_4","name":"adb8","type":"H4","href":null,"layout":null,"metadata":null,"text":"Space Stations Can Be a Tricky Place for a New Pilot","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_5":{"__typename":"Paragraph","id":"81fdbdab8892_5","name":"c5d1","type":"P","href":null,"layout":null,"metadata":null,"text":"Since the Treaty of Peace was established by the Galactic Council, space travel has become an exciting and rapidly advancing field, offering new opportunities for exploration and discovery. However, with this progress comes the need for increased safety measures. Docking and undocking procedures, in particular, are critical moments during space travel that require the utmost attention and care. Protocols and procedures must be followed to ensure the safety of all crew members and passengers. Here are ten safety protocols to keep in mind:","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":140,"end":188,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":264,"end":296,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":497,"end":543,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*kFJwongHgj02xW5K.png":{"__typename":"ImageMetadata","id":"0*kFJwongHgj02xW5K.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":"NotBitcoinCEO Space Seats"},"Paragraph:81fdbdab8892_6":{"__typename":"Paragraph","id":"81fdbdab8892_6","name":"59bc","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*kFJwongHgj02xW5K.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_7":{"__typename":"Paragraph","id":"81fdbdab8892_7","name":"a305","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Stay seated. As a primary safety measure, all individuals on board are required to be seated and properly secured during any sudden changes in velocity. This includes both embarking and disembarking. It’s acknowledged that extended space travel will consist of long moments of relaxation among crew members. Activities, such as resting in a bed, enjoying time in the crew quarters, or providing maintenance on ship mechanics, must take a backseat when approaching or leaving Space Stations. The importance of adhering to proper docking protocols cannot be emphasized enough.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":11,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_8":{"__typename":"Paragraph","id":"81fdbdab8892_8","name":"10c6","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Inspections\u002FRepairs. Before undocking, inspecting the spacecraft for damages or malfunctioning equipment may prove a useful tool before embarking on long adventures to distant locations.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":21,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_9":{"__typename":"Paragraph","id":"81fdbdab8892_9","name":"abd4","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Enable Q-LINK. Initiating the Quantum Entanglement Link is vital in meeting Galactic regulations and docking without fines. In most space stations, a quantum entanglement link must be established between ship and station, allowing for instant communication and navigation.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":13,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_10":{"__typename":"Paragraph","id":"81fdbdab8892_10","name":"365a","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Disengage Energy Shields. This is a requirement for all pilots in order to allow for proper docking procedures to take place within protocol distance. Space Stations are regularly enforced and don’t hold the same dangers as Deep Space.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":26,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_11":{"__typename":"Paragraph","id":"81fdbdab8892_11","name":"50c8","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Synchronize Time Dilation Field. Synchronizing with Space Stations will help avoid many temporal discrepancies during the docking process. While collisions are an unlikely occurrence, this simple step greatly reduces miscommunication between different technologies. Most ships will automatically do this for you, however it’s good to be aware of.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":32,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_12":{"__typename":"Paragraph","id":"81fdbdab8892_12","name":"84cb","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Activate Teleportation Systems. While normally automatic, many Space Stations in The Outskirt Regions maintain power-efficient teleportation that must be powered on once docked. The pilot may need to activate these systems after docking if they haven’t been automatically configured.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":30,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":81,"end":101,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":111,"end":140,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":146,"end":176,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_13":{"__typename":"Paragraph","id":"81fdbdab8892_13","name":"9624","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Pressurization. Equalizing the pressure between the spacecraft and the space station is key in preventing damage to docking equipment or injury to the crew. When pressure systems have malfunctioned, do not open the hatch under any circumstances until help has arrived.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":14,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_14":{"__typename":"Paragraph","id":"81fdbdab8892_14","name":"fd6a","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Decontamination. Some space stations or colonies may require decontamination in order to gain entry. These are done in order to prevent the spread of contaminants in closed systems. This could possibly involve going through an airlock or some other form of decontamination procedure.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":227,"end":234,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":235,"end":282,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_15":{"__typename":"Paragraph","id":"81fdbdab8892_15","name":"c0fe","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Open Hangar Doors. Depending on what station you’re at, clearing the spacecraft for departure by verifying hangar doors are open before liftoff is vital.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":17,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":128,"end":135,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":143,"end":144,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_16":{"__typename":"Paragraph","id":"81fdbdab8892_16","name":"853c","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Side-Docking Precautions. Pilots with side-docking capabilities should slowly pull into any given station aligning themselves with the received coordinates. Magnetic docking clamps will automatically attach to your ship as soon as your alignment parameters are correctly set up. Only until attachment is complete is it safe for the crew to maneuver around the ship and for the doors to be opened.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":26,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*AHYuIR3fbUsAJ-gE.png":{"__typename":"ImageMetadata","id":"0*AHYuIR3fbUsAJ-gE.png","originalHeight":1024,"originalWidth":1024,"focusPercentX":null,"focusPercentY":null,"alt":"NotBitcoinCEO Space Friends"},"Paragraph:81fdbdab8892_17":{"__typename":"Paragraph","id":"81fdbdab8892_17","name":"76fa","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*AHYuIR3fbUsAJ-gE.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_18":{"__typename":"Paragraph","id":"81fdbdab8892_18","name":"f43d","type":"P","href":null,"layout":null,"metadata":null,"text":"In conclusion, proper adherence to docking safety protocols is essential for the well-being of all individuals on board. Crew members must prioritize their safety by being seated and properly secured during all docking events. By following these protocols, we can improve the safety of all Galactic Citizens and avoid serious injury or death. Failure to adhere to these protocols may result in revocation of station privilege.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":343,"end":426,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_19":{"__typename":"Paragraph","id":"81fdbdab8892_19","name":"5fe7","type":"P","href":null,"layout":null,"metadata":null,"text":"**This document is theoretical and is intended for safety purposes only.**","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":74,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_20":{"__typename":"Paragraph","id":"81fdbdab8892_20","name":"52cc","type":"P","href":null,"layout":null,"metadata":null,"text":"Would you like to check out Star Atlas for yourself? Join today! Also, if you enjoyed this article or would like to hear about something specific in the future, please leave a comment below.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":53,"end":63,"href":"https:\u002F\u002Fplay.staratlas.com\u002F?oid=3&affid=253","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":28,"end":39,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":161,"end":189,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*Mk8sSW1jBVD5F69uDWOf6A.png":{"__typename":"ImageMetadata","id":"1*Mk8sSW1jBVD5F69uDWOf6A.png","originalHeight":472,"originalWidth":1001,"focusPercentX":null,"focusPercentY":null,"alt":"NotBitcoinCEO Space Motorcycle"},"Paragraph:81fdbdab8892_21":{"__typename":"Paragraph","id":"81fdbdab8892_21","name":"0c16","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*Mk8sSW1jBVD5F69uDWOf6A.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_22":{"__typename":"Paragraph","id":"81fdbdab8892_22","name":"6ed0","type":"H3","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_23":{"__typename":"Paragraph","id":"81fdbdab8892_23","name":"1884","type":"P","href":null,"layout":null,"metadata":null,"text":"NotBitcoinCEO is a mud pilot & writer on The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":13,"href":"https:\u002F\u002Fmedium.com\u002F@mudpilot","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":13,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_24":{"__typename":"Paragraph","id":"81fdbdab8892_24","name":"09e2","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_25":{"__typename":"Paragraph","id":"81fdbdab8892_25","name":"901d","type":"P","href":null,"layout":null,"metadata":null,"text":"Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Ftwitter.com\u002FHologram_News","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":19,"href":"https:\u002F\u002Fwww.instagram.com\u002Fhologram_news\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":22,"end":25,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_26":{"__typename":"Paragraph","id":"81fdbdab8892_26","name":"aae4","type":"H3","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_27":{"__typename":"Paragraph","id":"81fdbdab8892_27","name":"c00e","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*i9Q0zOxjxBPA_-9n.png":{"__typename":"ImageMetadata","id":"0*i9Q0zOxjxBPA_-9n.png","originalHeight":199,"originalWidth":700,"focusPercentX":null,"focusPercentY":null,"alt":"NotBitcoinCEO — The Hologram"},"Paragraph:81fdbdab8892_28":{"__typename":"Paragraph","id":"81fdbdab8892_28","name":"d69b","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*i9Q0zOxjxBPA_-9n.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:81fdbdab8892_29":{"__typename":"Paragraph","id":"81fdbdab8892_29","name":"d0d1","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_56d17bea3789":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_56d17bea3789","isEditor":false},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","atsQualifiedAt":1650725917596},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"Tag:scifi":{"__typename":"Tag","id":"scifi","displayTitle":"SciFi","normalizedTagSlug":"scifi"}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"HIT","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.56d6982e.js"></script><script src="https://cdn-client.medium.com/lite/static/js/7505.62df2c9c.js"></script><script src="https://cdn-client.medium.com/lite/static/js/main.a649148b.js"></script><script src="https://cdn-client.medium.com/lite/static/js/instrumentation.c71f0248.chunk.js"></script>

tSubscribeMembershipUpsellShownAt":0,"mediumMemberAt":0,"homepagePostsConnection:{\"paging\":{\"limit\":1}}":{"__typename":"PostConnection","posts":[{"__ref":"Post:2d105621d288"}]},"isSuspended":false,"allowNotes":true,"isAuroraVisible":true,"twitterScreenName":"","atsQualifiedAt":0},"Post:45c58d55c237":{"__typename":"Post","id":"45c58d55c237","firstPublishedAt":1675726675891,"visibility":"PUBLIC","creator":{"__ref":"User:b3ca146a7a78"},"canonicalUrl":"","collection":{"__ref":"Collection:4d89daa6ae31"},"content({\"postMeteringOptions\":{\"forceTruncation\":false}})":{"__typename":"PostContent","isLockedPreviewOnly":false,"validatedShareKey":"","bodyModel":{"__typename":"RichText","sections":[{"__typename":"Section","name":"3b24","startIndex":0,"textLayout":null,"imageLayout":null,"backgroundImage":null,"videoLayout":null,"backgroundVideo":null},{"__typename":"Section","name":"7fcc","startIndex":21,"textLayout":null,"imageLayout":null,"backgroundImage":null,"videoLayout":null,"backgroundVideo":null}],"paragraphs":[{"__ref":"Paragraph:5950b63ec187_0"},{"__ref":"Paragraph:5950b63ec187_1"},{"__ref":"Paragraph:5950b63ec187_2"},{"__ref":"Paragraph:5950b63ec187_3"},{"__ref":"Paragraph:5950b63ec187_4"},{"__ref":"Paragraph:5950b63ec187_5"},{"__ref":"Paragraph:5950b63ec187_6"},{"__ref":"Paragraph:5950b63ec187_7"},{"__ref":"Paragraph:5950b63ec187_8"},{"__ref":"Paragraph:5950b63ec187_9"},{"__ref":"Paragraph:5950b63ec187_10"},{"__ref":"Paragraph:5950b63ec187_11"},{"__ref":"Paragraph:5950b63ec187_12"},{"__ref":"Paragraph:5950b63ec187_13"},{"__ref":"Paragraph:5950b63ec187_14"},{"__ref":"Paragraph:5950b63ec187_15"},{"__ref":"Paragraph:5950b63ec187_16"},{"__ref":"Paragraph:5950b63ec187_17"},{"__ref":"Paragraph:5950b63ec187_18"},{"__ref":"Paragraph:5950b63ec187_19"},{"__ref":"Paragraph:5950b63ec187_20"},{"__ref":"Paragraph:5950b63ec187_21"},{"__ref":"Paragraph:5950b63ec187_22"},{"__ref":"Paragraph:5950b63ec187_23"}]}},"customStyleSheet":null,"isPublished":true,"isLocked":false,"license":"ALL_RIGHTS_RESERVED","collaborators":[],"statusForCollection":"APPROVED","isMarkedPaywallOnly":false,"lockedSource":"LOCKED_POST_SOURCE_NONE","mediumUrl":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fthe-road-to-sage-a-guide-to-the-tech-demo-part-2-45c58d55c237","primaryTopic":null,"topics":[{"__typename":"Topic","slug":"gaming","name":"Gaming"}],"viewerEdge":{"__ref":"PostViewerEdge:postId:45c58d55c237-viewerId:lo_fda07d1cc886"},"latestPublishedVersion":"5950b63ec187","postResponses":{"__typename":"PostResponses","count":0},"allowResponses":true,"isLimitedState":false,"voterCount":1,"recommenders":[],"isSeries":false,"sequence":null,"uniqueSlug":"the-road-to-sage-a-guide-to-the-tech-demo-part-2-45c58d55c237","title":"The Road to SAGE: A Guide to the Tech Demo (Part 2)","clapCount":50,"pinnedAt":0,"pinnedByCreatorAt":0,"curationEligibleAt":0,"responseDistribution":"NOT_DISTRIBUTED","inResponseToPostResult":null,"inResponseToCatalogResult":null,"pendingCollection":null,"isNewsletter":false,"isAuthorNewsletter":false,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"},{"__ref":"Tag:guides-and-tutorials"}],"readingTime":4.029245283018868,"inResponseToEntityType":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1675828634583,"previewContent":{"__typename":"PreviewContent","subtitle":"Hello dreamers of the metaverse. Today I bring you the second part of the guide for the first stage of the Roadmap in the phase known as…"},"previewImage":{"__ref":"ImageMetadata:1*2YBNW9EPuVevLCrUwSRvpA.png"},"isShortform":false,"seoTitle":"","updatedAt":1675828638907,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"isSuspended":false,"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}},"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg","originalWidth":2730,"focusPercentX":48.57142857142857,"focusPercentY":45.19230769230769},"NewsletterV3:ac886d6987e0":{"__typename":"NewsletterV3","slug":"holoreport","id":"ac886d6987e0","name":"HoloReport","description":"Catch up on the latest Star Atlas news that you've missed. ","promoHeadline":"","promoBody":"","type":"NEWSLETTER_TYPE_COLLECTION","user":{"__ref":"User:41e0c5b141f1"},"collection":{"__ref":"Collection:4d89daa6ae31"},"showPromo":true},"Post:2d105621d288":{"__typename":"Post","id":"2d105621d288"},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","name":"Krigs","username":"krigsfoniks","newsletterV3":{"__ref":"NewsletterV3:85fc9c436e2e"},"atsQualifiedAt":1650725917596},"NewsletterV3:85fc9c436e2e":{"__typename":"NewsletterV3","id":"85fc9c436e2e"},"PostViewerEdge:postId:45c58d55c237-viewerId:lo_fda07d1cc886":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:45c58d55c237-viewerId:lo_fda07d1cc886"},"Paragraph:5950b63ec187_0":{"__typename":"Paragraph","id":"5950b63ec187_0","name":"6856","type":"H3","href":null,"layout":null,"metadata":null,"text":"The Road to SAGE: A Guide to the Tech Demo (Part 2)","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_1":{"__typename":"Paragraph","id":"5950b63ec187_1","name":"91e2","type":"P","href":null,"layout":null,"metadata":null,"text":"Hello dreamers of the metaverse. Today I bring you the second part of the guide for the first stage of the Roadmap in the phase known as the Tech Demo. We will describe each of the necessary steps to reach a complete launch of this first phase and we will discuss some extra details that you cannot miss.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":141,"end":150,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fventuring-down-the-paths-of-sage-guide-to-the-first-stage-roadmap-tech-demo-part-1-4e1df64bf935","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_2":{"__typename":"Paragraph","id":"5950b63ec187_2","name":"efb9","type":"H3","href":null,"layout":null,"metadata":null,"text":"Star Path Network","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*2YBNW9EPuVevLCrUwSRvpA.png":{"__typename":"ImageMetadata","id":"1*2YBNW9EPuVevLCrUwSRvpA.png","originalHeight":653,"originalWidth":1293,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:5950b63ec187_3":{"__typename":"Paragraph","id":"5950b63ec187_3","name":"62ac","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*2YBNW9EPuVevLCrUwSRvpA.png"},"text":"Star Gate","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_4":{"__typename":"Paragraph","id":"5950b63ec187_4","name":"2447","type":"P","href":null,"layout":null,"metadata":null,"text":"The movement of ships within the Galia map is not just dependent on their impulse engines or their warping engines. The Star Path is a network formed by all systems belonging to the faction, a safe and fast route for transportation through known territory at the cost of a small commission of ATLAS and fuel.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":293,"end":298,"href":"https:\u002F\u002Fcoinmarketcap.com\u002Fcurrencies\u002Fstar-atlas\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":303,"end":307,"href":"https:\u002F\u002Fplay.staratlas.com\u002Fmarket\u002FfueL3hBZjLLLJHiFH9cqZoozTG3XQZ53diwFPwbzNim\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_5":{"__typename":"Paragraph","id":"5950b63ec187_5","name":"e315","type":"P","href":null,"layout":null,"metadata":null,"text":"The cost in ATLAS depends on the level of the Star Base within the system from where we want to leave and the amount of privilege points we have deposited in reducing these fees. This mechanism facilitates transportation and allows smaller ships to participate in different faction tasks in a more balanced way. We will see in the future if this route will always be the most used or if many will prefer to use their own engines, this may vary depending on the cost of fuel in the market, the urgency of the trip and the safety of adjacent sectors.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_6":{"__typename":"Paragraph","id":"5950b63ec187_6","name":"d861","type":"H3","href":null,"layout":null,"metadata":null,"text":"R20","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*lB5nDb25bxkKZr4OwMPe7g.png":{"__typename":"ImageMetadata","id":"1*lB5nDb25bxkKZr4OwMPe7g.png","originalHeight":1597,"originalWidth":1600,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:5950b63ec187_7":{"__typename":"Paragraph","id":"5950b63ec187_7","name":"990e","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*lB5nDb25bxkKZr4OwMPe7g.png"},"text":"Resources and Materials found in the Middle Zone","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_8":{"__typename":"Paragraph","id":"5950b63ec187_8","name":"ab16","type":"P","href":null,"layout":null,"metadata":null,"text":"Mining and resource gathering are the foundation of the economy within Star Atlas. R20 will allow for the creation of a wide range of consumables for both Star Bases and ships, as well as future upgrades.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_9":{"__typename":"Paragraph","id":"5950b63ec187_9","name":"dee3","type":"P","href":null,"layout":null,"metadata":null,"text":"The extraction difficulty varies depending on the hardness of each resource, which affects the mining or collection time. The amount of resources or wealth level is determined by the type of planet or distance from the safe zone. We usually find the rarest resources as we venture further into the medium-risk zone, this is an extra incentive for explorers and fortune seekers.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_10":{"__typename":"Paragraph","id":"5950b63ec187_10","name":"fecf","type":"H3","href":null,"layout":null,"metadata":null,"text":"R4 Crafting","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*p5Exc0VgxMtEWd9QZOfUpg.jpeg":{"__typename":"ImageMetadata","id":"1*p5Exc0VgxMtEWd9QZOfUpg.jpeg","originalHeight":417,"originalWidth":883,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:5950b63ec187_11":{"__typename":"Paragraph","id":"5950b63ec187_11","name":"fc78","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*p5Exc0VgxMtEWd9QZOfUpg.jpeg"},"text":"R4","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_12":{"__typename":"Paragraph","id":"5950b63ec187_12","name":"c4c5","type":"P","href":null,"layout":null,"metadata":null,"text":"The R4 resources are the most well-known, and we currently need them to make our ships produce ATLAS within SCORE, the current minigame-staking that is the center of the utility of ships as NFTs. If you want to learn more about these, you can find them in the Star Atlas marketplace.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":271,"end":282,"href":"https:\u002F\u002Fplay.staratlas.com\u002Fmarket\u002F?category=resource&itemClass=consumable","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_13":{"__typename":"Paragraph","id":"5950b63ec187_13","name":"70d7","type":"P","href":null,"layout":null,"metadata":null,"text":"With the launch of SAGE, these resources will no longer be sold directly by the DAO and will be entirely processed by the players. Keep in mind that the Tech Demo will be within the Solana Devnet, so in this first phase it does not affect its supply in the Marketplace, but in the future when the game’s economy is released.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_14":{"__typename":"Paragraph","id":"5950b63ec187_14","name":"78fd","type":"P","href":null,"layout":null,"metadata":null,"text":"These resources are essential for the operation of ships and even Star Bases. Each one fulfills a function, ammunition allows for battles and direct resource gathering from asteroids, food allows the crew to operate at their maximum level without penalties, tool kits are essential for repairing damage received by our ships in battle once they are refueled at a Star Base or at the Central Space Station, as well as fuel, which allows us to move around the map. Refueling is a condition for reloading ammunition, fuel and tool kits until the mechanics that allow specialized ships to fulfill their functions are released.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_15":{"__typename":"Paragraph","id":"5950b63ec187_15","name":"9880","type":"H3","href":null,"layout":null,"metadata":null,"text":"Galactic Map with 51 Star Systems","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_16":{"__typename":"Paragraph","id":"5950b63ec187_16","name":"7db4","type":"P","href":null,"layout":null,"metadata":null,"text":"Exploring the Galia map is one of the player’s main objectives in SAGE. This is the first experience we will have within the game thanks to the information provided by the team, a delivery called The Treasure Hunt, the first truly play-to-earn interaction where there will be high-value loot, even a Fimbul BYOS Tankship, a legendary rarity Commander-sized ship valued at over 90,000 USDC, whoever finds this rarity will truly carry the envy of the entire community:).","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_17":{"__typename":"Paragraph","id":"5950b63ec187_17","name":"cecc","type":"P","href":null,"layout":null,"metadata":null,"text":"Initially, we do not know if we will have all the Star Systems from the Tech Demo to explore, but we will be able to discover how the resources are distributed and the different ways to explore this Universe. Each movement between sectors is recorded on the blockchain, so once we start playing many can create maps of all the explored places and their resources through the interaction of their ships with the game, at the start it’s a race to be the first to arrive and find the hidden secrets.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_18":{"__typename":"Paragraph","id":"5950b63ec187_18","name":"864e","type":"H3","href":null,"layout":null,"metadata":null,"text":"End of Part 2","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_19":{"__typename":"Paragraph","id":"5950b63ec187_19","name":"908c","type":"P","href":null,"layout":null,"metadata":null,"text":"To finish this second part of the guide, I must highlight that everything discussed corresponds to information revealed by the team through talks and some written sources, in addition to the Manual. Everything revealed in the SAGE manual is prone to changes and should be taken into account when making any decisions.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":191,"end":197,"href":"https:\u002F\u002Fstaratlas.com\u002Fnewsroom\u002Fgame-manuals","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_20":{"__typename":"Paragraph","id":"5950b63ec187_20","name":"babe","type":"P","href":null,"layout":null,"metadata":null,"text":"For now, I bid farewell friends of the metaverse, I hope that soon we will be exploring Galia in search of that Tankship, in the meantime, we will be attentive to all the important news from the team.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_21":{"__typename":"Paragraph","id":"5950b63ec187_21","name":"c19b","type":"H3","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_22":{"__typename":"Paragraph","id":"5950b63ec187_22","name":"b7ee","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:5950b63ec187_23":{"__typename":"Paragraph","id":"5950b63ec187_23","name":"d9b2","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_fda07d1cc886":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_fda07d1cc886","isEditor":false},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"Tag:guides-and-tutorials":{"__typename":"Tag","id":"guides-and-tutorials","displayTitle":"Guides And Tutorials","normalizedTagSlug":"guides-and-tutorials"}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"HIT","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.228d6d4a.js"></script><script src="https://cdn-client.medium.com/lite/static/js/7505.62df2c9c.js"></script><script src="https://cdn-client.medium.com/lite/static/js/main.78850a8a.js"></script><script src="https://cdn-client.medium.com/lite/static/js/instrumentation.c71f0248.chunk.js"></script>

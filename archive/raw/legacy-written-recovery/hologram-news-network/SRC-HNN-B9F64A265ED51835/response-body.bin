F@krigsfoniks\u002Fstar-atlas-player-quick-start-guide-bff20fd1e3c","primaryTopic":null,"topics":[],"latestPublishedVersion":"f9be2e400b9c","postResponses":{"__typename":"PostResponses","count":0},"allowResponses":true,"isLimitedState":false,"voterCount":0,"recommenders":[],"isSeries":false,"sequence":null,"uniqueSlug":"star-atlas-player-quick-start-guide-bff20fd1e3c","title":"Star Atlas Player Quick Start Guide","clapCount":0,"statusForCollection":"PENDING","pinnedAt":0,"pinnedByCreatorAt":0,"curationEligibleAt":0,"responseDistribution":"NOT_DISTRIBUTED","inResponseToPostResult":null,"inResponseToCatalogResult":null,"pendingCollection":{"__ref":"Collection:c7e66e764104"},"isNewsletter":false,"isAuthorNewsletter":true,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"}],"readingTime":8.816037735849056,"inResponseToEntityType":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1668788563333,"previewContent":{"__typename":"PreviewContent","subtitle":"Start playing Star Atlas in under 15 minutes. This guide will quickly walk you through how to add a crypto wallet, buy a ship, and start…"},"previewImage":{"__ref":"ImageMetadata:0*5AA6fNTHMH-Ffd4w.jpg"},"isShortform":false,"seoTitle":"","updatedAt":1668788598952,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"isSuspended":false,"responseRootPost":{"__typename":"ResponseRootPost","post":{"__ref":"Post:bff20fd1e3c"}},"internalLinks({\"paging\":{\"limit\":8}})":{"__typename":"InternalLinksConnection","items":[]},"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}},"Paragraph:f9be2e400b9c_0":{"__typename":"Paragraph","id":"f9be2e400b9c_0","name":"c6e4","type":"H3","href":null,"layout":null,"metadata":null,"text":"Star Atlas Player Quick Start Guide","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_1":{"__typename":"Paragraph","id":"f9be2e400b9c_1","name":"7241","type":"P","href":null,"layout":null,"metadata":null,"text":"Start playing Star Atlas in under 15 minutes. This guide will quickly walk you through how to add a crypto wallet, buy a ship, and start Star Atlas Faction Fleet.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_2":{"__typename":"Paragraph","id":"f9be2e400b9c_2","name":"bfa3","type":"H3","href":null,"layout":null,"metadata":null,"text":"Table of Contents","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_3":{"__typename":"Paragraph","id":"f9be2e400b9c_3","name":"d00b","type":"P","href":null,"layout":null,"metadata":null,"text":"Overview\n1. Downloading A Wallet\n2. Accessing the Game\n3. Buying a Ship\n4. Choosing A Faction\n5. Playing Faction Fleet","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_4":{"__typename":"Paragraph","id":"f9be2e400b9c_4","name":"e235","type":"H3","href":null,"layout":null,"metadata":null,"text":"Star Atlas Overview","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_5":{"__typename":"Paragraph","id":"f9be2e400b9c_5","name":"bf5d","type":"P","href":null,"layout":null,"metadata":null,"text":"To start, Star Atlas is a grand-strategy, space exploration, massively multiplayer online role playing game built in Unreal Engine 5 and backed by the Solana Blockchain. The first Star Atlas mini-game, Faction Fleet, is available in web bowser. SAGE will also be playable in a web-browser mini-game by the end of 2022. Currently, the UE5 virtual environment of ships you own is available on the Epic Games store. Eventually, the full game will be released as a downloadable client from the Epic Games store.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*5AA6fNTHMH-Ffd4w.jpg":{"__typename":"ImageMetadata","id":"0*5AA6fNTHMH-Ffd4w.jpg","originalHeight":466,"originalWidth":840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_6":{"__typename":"Paragraph","id":"f9be2e400b9c_6","name":"a515","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*5AA6fNTHMH-Ffd4w.jpg"},"text":"Star Atlas SCREAM work in progress design","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_7":{"__typename":"Paragraph","id":"f9be2e400b9c_7","name":"e43e","type":"P","href":null,"layout":null,"metadata":null,"text":"Major breakthroughs in recent technology created an opportunity for a futuristic science fiction experience that is entirely new and groundbreaking. Real-time graphics technology using Unreal Engine 5’s Nanite allows for cinematic quality video game visuals. Blockchain technology using the Solana protocol established a largely serverless and secured gameplay experience. Non-fungible tokens obtained and traded within Star Atlas creates an economy that replicates the tangibility of real world assets and ownership. That’s the basics about the new video game, Star Atlas, and what you need to know before playing.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_8":{"__typename":"Paragraph","id":"f9be2e400b9c_8","name":"785e","type":"H4","href":null,"layout":null,"metadata":null,"text":"1. Downloading A Wallet","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_9":{"__typename":"Paragraph","id":"f9be2e400b9c_9","name":"5caa","type":"P","href":null,"layout":null,"metadata":null,"text":"Since Star Atlas is a blockchain game, it requires a cryptocurrency wallet to store your digital tokens and in-game currency.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_10":{"__typename":"Paragraph","id":"f9be2e400b9c_10","name":"53bc","type":"P","href":null,"layout":null,"metadata":null,"text":"Step 1 — In any web browser download and install a Solana wallet that is compatible with Star Atlas. We recommend Phantom — How to add a Phantom Wallet","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":124,"end":151,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fhow-to-add-a-phantom-wallet-f34ae14bea9a","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":0,"end":9,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*qcxK6gWPHWeYiIwQk3Q7Fw.png":{"__typename":"ImageMetadata","id":"1*qcxK6gWPHWeYiIwQk3Q7Fw.png","originalHeight":403,"originalWidth":653,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_11":{"__typename":"Paragraph","id":"f9be2e400b9c_11","name":"7d37","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*qcxK6gWPHWeYiIwQk3Q7Fw.png"},"text":"Wallets That Are Fully Supported by Phantom","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_12":{"__typename":"Paragraph","id":"f9be2e400b9c_12","name":"98ad","type":"P","href":null,"layout":null,"metadata":null,"text":"Optional — Hardware Wallet\nWe strongly recommend taking the extra step in security and using a hardware wallet in conjunction with your Phantom wallet. This acts like two factor authentication and can help prevent your funds from accidentally being drained.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":27,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_13":{"__typename":"Paragraph","id":"f9be2e400b9c_13","name":"1b9a","type":"P","href":null,"layout":null,"metadata":null,"text":"Step 2 — Add Funds to You Wallet","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":32,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_14":{"__typename":"Paragraph","id":"f9be2e400b9c_14","name":"13e0","type":"P","href":null,"layout":null,"metadata":null,"text":"Star Atlas is built on the Solana ecosystem, hence you will need to add the Solana ($SOL) cryptocurrency to your wallet. This can be accomplished one of two ways.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_15":{"__typename":"Paragraph","id":"f9be2e400b9c_15","name":"4d4e","type":"P","href":null,"layout":null,"metadata":null,"text":"Shorter Method: You can buy Solana or USDC directly in your Phantom Wallet.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_16":{"__typename":"Paragraph","id":"f9be2e400b9c_16","name":"c4f8","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Open your Phantom Wallet and hit Buy","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":33,"end":36,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_17":{"__typename":"Paragraph","id":"f9be2e400b9c_17","name":"196f","type":"OLI","href":null,"layout":null,"metadata":null,"text":"From there, select either Solana or USDC","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_18":{"__typename":"Paragraph","id":"f9be2e400b9c_18","name":"df5c","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Select how much you want to deposit","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_19":{"__typename":"Paragraph","id":"f9be2e400b9c_19","name":"d30b","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Select your provider","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_20":{"__typename":"Paragraph","id":"f9be2e400b9c_20","name":"2cd1","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Coinbase Pay links to your Coinbase account.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_21":{"__typename":"Paragraph","id":"f9be2e400b9c_21","name":"9848","type":"ULI","href":null,"layout":null,"metadata":null,"text":"If you don’t already have a Coinbase account, we recommend MoonPay","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_22":{"__typename":"Paragraph","id":"f9be2e400b9c_22","name":"b096","type":"ULI","href":null,"layout":null,"metadata":null,"text":"DO NOT use FTX Pay. FTX is now bankrupt.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":20,"end":40,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_23":{"__typename":"Paragraph","id":"f9be2e400b9c_23","name":"6e9c","type":"P","href":null,"layout":null,"metadata":null,"text":"5. You should see your funds in your account now!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_24":{"__typename":"Paragraph","id":"f9be2e400b9c_24","name":"b020","type":"P","href":null,"layout":null,"metadata":null,"text":"Note — Star Atlas Ships are bought in ATLAS or USDC. If you already know what ship you want to buy, we recommend getting USDC directly.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":135,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_25":{"__typename":"Paragraph","id":"f9be2e400b9c_25","name":"21de","type":"P","href":null,"layout":null,"metadata":null,"text":"Longer Method: First, you can purchase Solana from a Centralized Exchange (CEX) like Coinbase or Binance. You can then send Solana tokens from your CEX account directly to your Phantom Wallet. You will need your Phantom Wallet public address or wallet address and it looks something like this:","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":15,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*kL84Em_oTKGa-ME7CkL-vA.png":{"__typename":"ImageMetadata","id":"1*kL84Em_oTKGa-ME7CkL-vA.png","originalHeight":118,"originalWidth":422,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_26":{"__typename":"Paragraph","id":"f9be2e400b9c_26","name":"eb0c","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*kL84Em_oTKGa-ME7CkL-vA.png"},"text":"Hit Copy to quickly copy your address","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_27":{"__typename":"Paragraph","id":"f9be2e400b9c_27","name":"9efb","type":"P","href":null,"layout":null,"metadata":null,"text":"6XFpQc7H4MRjTDLmEW5q41gsQ8VwV5QNKUohqTjdTrxu","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_28":{"__typename":"Paragraph","id":"f9be2e400b9c_28","name":"4098","type":"P","href":null,"layout":null,"metadata":null,"text":"From your CEX account, select how much you want to transfer to your wallet and hit send. Make sure that you input your own wallet address, not the one above!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_29":{"__typename":"Paragraph","id":"f9be2e400b9c_29","name":"3f52","type":"P","href":null,"layout":null,"metadata":null,"text":"Note — Depending on your CEX and how long you’ve have funds with them, it may take 1–2 weeks before you’re authorized to transfer your funds out of the CEX","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":155,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_30":{"__typename":"Paragraph","id":"f9be2e400b9c_30","name":"e1db","type":"H4","href":null,"layout":null,"metadata":null,"text":"2. Accessing the Game","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_31":{"__typename":"Paragraph","id":"f9be2e400b9c_31","name":"a363","type":"P","href":null,"layout":null,"metadata":null,"text":"As of now, Star Atlas exists in two different formats. Faction Fleet, and eventually SAGE, are web browser based mini-games. The Star Atlas Showroom is an Unreal Engine 5 (UE5) client from in the Epic Games store.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_32":{"__typename":"Paragraph","id":"f9be2e400b9c_32","name":"fc83","type":"H4","href":null,"layout":null,"metadata":null,"text":"Faction Fleet and SAGE","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_33":{"__typename":"Paragraph","id":"f9be2e400b9c_33","name":"73da","type":"P","href":null,"layout":null,"metadata":null,"text":"Faction Fleet, and eventually SAGE, can be accessed at play.staratlas.com. This will take you to the main page where you will be asked to connect you Phantom Wallet. If you aren’t automatically asked, there is a connect wallet button in the left menu at the bottom.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":55,"end":74,"href":"https:\u002F\u002Fplay.staratlas.com\u002F?oid=3&affid=203","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":212,"end":226,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_34":{"__typename":"Paragraph","id":"f9be2e400b9c_34","name":"10d2","type":"P","href":null,"layout":null,"metadata":null,"text":"Congratulations! You’ve just officially taken your first steps into the Star Atlas metaverse!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_35":{"__typename":"Paragraph","id":"f9be2e400b9c_35","name":"e01e","type":"P","href":null,"layout":null,"metadata":null,"text":"Note: The link above is a referral link for the game. If you do end up purchasing a ship from Star Atlas, we receive a small recruiter bonus. There is no obligation to do so and if you’d rather use the normal link, you can do so here, play.startlas.com.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":235,"end":252,"href":"http:\u002F\u002Fplay.startlas.com","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"EM","start":0,"end":253,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*OpxziVcv-q8WRq3svMyHNA.png":{"__typename":"ImageMetadata","id":"1*OpxziVcv-q8WRq3svMyHNA.png","originalHeight":868,"originalWidth":1489,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_36":{"__typename":"Paragraph","id":"f9be2e400b9c_36","name":"2333","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*OpxziVcv-q8WRq3svMyHNA.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_37":{"__typename":"Paragraph","id":"f9be2e400b9c_37","name":"6078","type":"H4","href":null,"layout":null,"metadata":null,"text":"3. Buying A Ship","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_38":{"__typename":"Paragraph","id":"f9be2e400b9c_38","name":"a001","type":"P","href":null,"layout":null,"metadata":null,"text":"If you’ve played any kind of MMO game before, then the Star Atlas Marketplace will look pretty familiar to you.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":55,"end":77,"href":"https:\u002F\u002Fplay.staratlas.com\u002Fmarket","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*TCE0ugYW7Fv1mQZeQLuMKA.png":{"__typename":"ImageMetadata","id":"1*TCE0ugYW7Fv1mQZeQLuMKA.png","originalHeight":841,"originalWidth":1843,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_39":{"__typename":"Paragraph","id":"f9be2e400b9c_39","name":"722c","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*TCE0ugYW7Fv1mQZeQLuMKA.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_40":{"__typename":"Paragraph","id":"f9be2e400b9c_40","name":"3b95","type":"P","href":null,"layout":null,"metadata":null,"text":"If you already know what you want, don’t let us stop you. But if you’re not quite sure what to buy, we recommend starting out with a ship available in the XX-Small category.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":155,"end":172,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*joLEVwT27MVswBFQIHo_MQ.png":{"__typename":"ImageMetadata","id":"1*joLEVwT27MVswBFQIHo_MQ.png","originalHeight":854,"originalWidth":1854,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_41":{"__typename":"Paragraph","id":"f9be2e400b9c_41","name":"5c3c","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*joLEVwT27MVswBFQIHo_MQ.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_42":{"__typename":"Paragraph","id":"f9be2e400b9c_42","name":"529c","type":"P","href":null,"layout":null,"metadata":null,"text":"As you can see, there are several to choose from. Click through each one to find out more about it. For this example, we’ll go through the newest ship in this category — the VZUS solos racer.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":174,"end":184,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*ZTMq_G2yJVMJbtkzgf1EDw.png":{"__typename":"ImageMetadata","id":"1*ZTMq_G2yJVMJbtkzgf1EDw.png","originalHeight":868,"originalWidth":1841,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_43":{"__typename":"Paragraph","id":"f9be2e400b9c_43","name":"9485","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*ZTMq_G2yJVMJbtkzgf1EDw.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_44":{"__typename":"Paragraph","id":"f9be2e400b9c_44","name":"653b","type":"P","href":null,"layout":null,"metadata":null,"text":"Clicking the VSUZ will take you to a page where you can see all available buy and sell orders. At the top you can see a list of available sellers. At the bottom is a list of buyers. The market works just like a regular buy\u002Fsell order market. You can also swap between USDC and ATLAS denominations depending on what currency you have available.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_45":{"__typename":"Paragraph","id":"f9be2e400b9c_45","name":"3b6a","type":"P","href":null,"layout":null,"metadata":null,"text":"The teal Star Atlas name denotes ships being sold by the company itself. Eventually, player IDs will replace the random wallet address you see.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*l4ugNebL38O45TfLfYlcnQ.png":{"__typename":"ImageMetadata","id":"1*l4ugNebL38O45TfLfYlcnQ.png","originalHeight":864,"originalWidth":1851,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_46":{"__typename":"Paragraph","id":"f9be2e400b9c_46","name":"10bc","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*l4ugNebL38O45TfLfYlcnQ.png"},"text":"Overpriced Ship","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_47":{"__typename":"Paragraph","id":"f9be2e400b9c_47","name":"0bce","type":"P","href":null,"layout":null,"metadata":null,"text":"Once you find the ship you want, click it and a new window will pop up. If the ship you’re trying to buy is greatly overpriced for current market value, several warnings will pop up. The game actually will prevent you from buying an overpriced ship unless you acknowledge the price.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*KarYrl1Pq7laCKjwze-yBA.png":{"__typename":"ImageMetadata","id":"1*KarYrl1Pq7laCKjwze-yBA.png","originalHeight":874,"originalWidth":1885,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_48":{"__typename":"Paragraph","id":"f9be2e400b9c_48","name":"096e","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*KarYrl1Pq7laCKjwze-yBA.png"},"text":"Ship at fair market value","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_49":{"__typename":"Paragraph","id":"f9be2e400b9c_49","name":"352a","type":"P","href":null,"layout":null,"metadata":null,"text":"Once you hit buy, you’ll be asked to confirm your purchase in your Phantom wallet. Hit approve and voila, you are now the proud owner of a brand new ship!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_50":{"__typename":"Paragraph","id":"f9be2e400b9c_50","name":"78d7","type":"P","href":null,"layout":null,"metadata":null,"text":"Where’s my ship?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_51":{"__typename":"Paragraph","id":"f9be2e400b9c_51","name":"676b","type":"P","href":null,"layout":null,"metadata":null,"text":"Your ship is technically stored on the blockchain with a visible representation of its status in your inventory.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*xQiz7mS-AaAnED-ewrQyzg.png":{"__typename":"ImageMetadata","id":"1*xQiz7mS-AaAnED-ewrQyzg.png","originalHeight":841,"originalWidth":1864,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_52":{"__typename":"Paragraph","id":"f9be2e400b9c_52","name":"2dc2","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*xQiz7mS-AaAnED-ewrQyzg.png"},"text":"Player Inventory","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_53":{"__typename":"Paragraph","id":"f9be2e400b9c_53","name":"5d61","type":"P","href":null,"layout":null,"metadata":null,"text":"You can also find any of your other Star Atlas game items in your inventory. This will be important when it comes time to buy resources to stock your ships with.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_54":{"__typename":"Paragraph","id":"f9be2e400b9c_54","name":"cf4b","type":"H4","href":null,"layout":null,"metadata":null,"text":"4. Choosing A Star Atlas Faction","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_55":{"__typename":"Paragraph","id":"f9be2e400b9c_55","name":"3b01","type":"P","href":null,"layout":null,"metadata":null,"text":"Before you can enlist your ships in Faction Fleet, you will first have to choose a Star Atlas faction.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_56":{"__typename":"Paragraph","id":"f9be2e400b9c_56","name":"bd77","type":"P","href":null,"layout":null,"metadata":null,"text":"There are three Star Atlas factions and they are:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_57":{"__typename":"Paragraph","id":"f9be2e400b9c_57","name":"41cb","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Oni\nThe ONI faction is a harmonious consortium of diverse species. The people of the Om sector, Segal, Akenat, and Neuno systems collectively set aside their differences in the hopes of a more bountiful life in space.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":4,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_58":{"__typename":"Paragraph","id":"f9be2e400b9c_58","name":"6ceb","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Mud\nManus Ultimus Divinum, The Last Divine Hand, is a spacefaring faction of humans originating from their home planet of Earth. After uniting under a common cause inspired by a benevolent Photoli scout, humans harnessed Earth’s resources to set off for the stars.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":4,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_59":{"__typename":"Paragraph","id":"f9be2e400b9c_59","name":"1a77","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Ustur\nUstur cybernetic sentient beings have an origin shrouded in complex mystery. One legend tells of a Dyson sphere-powered supercomputer harnessing the energy of a magnetar class neutron star. The energy throughput allowed the installed AI to advance beyond its physical location and withdrew from the parent machine without a trace.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":6,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*eTxmduf3bOF2yexpFETmgw.png":{"__typename":"ImageMetadata","id":"1*eTxmduf3bOF2yexpFETmgw.png","originalHeight":867,"originalWidth":1723,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_60":{"__typename":"Paragraph","id":"f9be2e400b9c_60","name":"c82c","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*eTxmduf3bOF2yexpFETmgw.png"},"text":"Star Atlas Factions","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_61":{"__typename":"Paragraph","id":"f9be2e400b9c_61","name":"0640","type":"P","href":null,"layout":null,"metadata":null,"text":"Important: Your faction selection is tied to your wallet! You cannot change it later.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":85,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_62":{"__typename":"Paragraph","id":"f9be2e400b9c_62","name":"a2f0","type":"P","href":null,"layout":null,"metadata":null,"text":"Think of your wallet as an account. The only way to change your faction is to create a new wallet (account) and go through the selection process again.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_63":{"__typename":"Paragraph","id":"f9be2e400b9c_63","name":"cccc","type":"P","href":null,"layout":null,"metadata":null,"text":"If you do decide to change factions later, you can always transfer assets from your old wallet to your new wallet. However, any perks associated with your account will not be transferred.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_64":{"__typename":"Paragraph","id":"f9be2e400b9c_64","name":"3936","type":"H4","href":null,"layout":null,"metadata":null,"text":"Selecting a Faction","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_65":{"__typename":"Paragraph","id":"f9be2e400b9c_65","name":"9f61","type":"P","href":null,"layout":null,"metadata":null,"text":"As of writing, there are no gameplay advantages to any faction. The faction selection process will show you where each faction gains certain bonuses, but the extent of those bonuses are currently unknown. Some known bonuses have been stated by the developers but are currently not implemented in the game.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_66":{"__typename":"Paragraph","id":"f9be2e400b9c_66","name":"6f1f","type":"P","href":null,"layout":null,"metadata":null,"text":"Known Bonus:","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":12,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_67":{"__typename":"Paragraph","id":"f9be2e400b9c_67","name":"1191","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Factions should gain loyalty points quicker with their Faction Aligned Companies (FACs)","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":55,"end":80,"href":"https:\u002F\u002Fstaratlas.notion.site\u002FFaction-Aligned-Companies-Public-003dffe8c5c64fe88cce59793dd6ceb5","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_68":{"__typename":"Paragraph","id":"f9be2e400b9c_68","name":"6e7a","type":"P","href":null,"layout":null,"metadata":null,"text":"At present, selecting one faction over another can come down to personal preference or guild preference. If you’ve already joined a Star Atlas guild, or are considering joining one, they may have faction restrictions in place.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_69":{"__typename":"Paragraph","id":"f9be2e400b9c_69","name":"1f8a","type":"P","href":null,"layout":null,"metadata":null,"text":"When it comes to flying ships, factions do not restrict your ability to pilot a ship.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_70":{"__typename":"Paragraph","id":"f9be2e400b9c_70","name":"ca2c","type":"H4","href":null,"layout":null,"metadata":null,"text":"5. Playing Star Atlas Faction Fleet","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_71":{"__typename":"Paragraph","id":"f9be2e400b9c_71","name":"c964","type":"P","href":null,"layout":null,"metadata":null,"text":"Once you’ve selected a faction, you’re ready to enlist your ships in support of your faction’s cause.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*TfjzxJXgJNgtDT8xX2pAmw.png":{"__typename":"ImageMetadata","id":"1*TfjzxJXgJNgtDT8xX2pAmw.png","originalHeight":871,"originalWidth":1845,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_72":{"__typename":"Paragraph","id":"f9be2e400b9c_72","name":"d291","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*TfjzxJXgJNgtDT8xX2pAmw.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_73":{"__typename":"Paragraph","id":"f9be2e400b9c_73","name":"28a3","type":"P","href":null,"layout":null,"metadata":null,"text":"Before you can enlist your ships, you’ll need to make sure you have enough Food, Fuel, and Ammo in your inventory. Eventually, you’ll need Toolkits for repairs when your ships run out of health.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_74":{"__typename":"Paragraph","id":"f9be2e400b9c_74","name":"143c","type":"P","href":null,"layout":null,"metadata":null,"text":"If you click on the Enlist Ship button, you’ll see:","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":20,"end":32,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*yWehG0rEsTPC7AyI2AHiMw.png":{"__typename":"ImageMetadata","id":"1*yWehG0rEsTPC7AyI2AHiMw.png","originalHeight":845,"originalWidth":1861,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_75":{"__typename":"Paragraph","id":"f9be2e400b9c_75","name":"0dcb","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*yWehG0rEsTPC7AyI2AHiMw.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_76":{"__typename":"Paragraph","id":"f9be2e400b9c_76","name":"74b9","type":"P","href":null,"layout":null,"metadata":null,"text":"If you don’t already have resources in your inventory, go back to the Star Atlas marketplace buy the resources you need. Make sure to remember how much you need.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*0BEn3C6f9C6pWL8q8hDPWA.png":{"__typename":"ImageMetadata","id":"1*0BEn3C6f9C6pWL8q8hDPWA.png","originalHeight":859,"originalWidth":1889,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_77":{"__typename":"Paragraph","id":"f9be2e400b9c_77","name":"d568","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*0BEn3C6f9C6pWL8q8hDPWA.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_78":{"__typename":"Paragraph","id":"f9be2e400b9c_78","name":"bf54","type":"P","href":null,"layout":null,"metadata":null,"text":"Resources are generally sold in ATLAS, the game’s in game currency. You’ll need to pickup some ATLAS, or ask someone to give you a small amount to be able to buy your resources.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*cTKvGmDf1UMkU6C5sWsM4Q.png":{"__typename":"ImageMetadata","id":"1*cTKvGmDf1UMkU6C5sWsM4Q.png","originalHeight":878,"originalWidth":1862,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_79":{"__typename":"Paragraph","id":"f9be2e400b9c_79","name":"8ce5","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*cTKvGmDf1UMkU6C5sWsM4Q.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_80":{"__typename":"Paragraph","id":"f9be2e400b9c_80","name":"e873","type":"P","href":null,"layout":null,"metadata":null,"text":"Generally, the Star Atlas DAO seller will have the lowest prices. Buy enough, Food, Fuel, and Ammo for your ship. We also recommend picking up toolkits if you have enough ATLAS as well.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_81":{"__typename":"Paragraph","id":"f9be2e400b9c_81","name":"8242","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*yWehG0rEsTPC7AyI2AHiMw.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_82":{"__typename":"Paragraph","id":"f9be2e400b9c_82","name":"5282","type":"P","href":null,"layout":null,"metadata":null,"text":"Back on the Enlist Ship page, once you hit Enlist Feet your ships will be sent on their mission. Depending on the ship, you will have to continually supply it with resources. As a reward, your ship will earn you an income of daily ATLAS so long as its supplied.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":12,"end":24,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":43,"end":55,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_83":{"__typename":"Paragraph","id":"f9be2e400b9c_83","name":"7699","type":"P","href":null,"layout":null,"metadata":null,"text":"Once your ship is enlisted you should see something like this:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*AZbNLDjjQMTlvobfx6_6Ig.png":{"__typename":"ImageMetadata","id":"1*AZbNLDjjQMTlvobfx6_6Ig.png","originalHeight":864,"originalWidth":1851,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_84":{"__typename":"Paragraph","id":"f9be2e400b9c_84","name":"57ba","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*AZbNLDjjQMTlvobfx6_6Ig.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_85":{"__typename":"Paragraph","id":"f9be2e400b9c_85","name":"2b7c","type":"P","href":null,"layout":null,"metadata":null,"text":"Resupplying Ships","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":17,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_86":{"__typename":"Paragraph","id":"f9be2e400b9c_86","name":"7b5b","type":"P","href":null,"layout":null,"metadata":null,"text":"Once it come time to resupply your ships, hit the Manage Fleet button.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":50,"end":63,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*8YASXltuBmx7chRIYZxrGA.png":{"__typename":"ImageMetadata","id":"1*8YASXltuBmx7chRIYZxrGA.png","originalHeight":859,"originalWidth":1812,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:f9be2e400b9c_87":{"__typename":"Paragraph","id":"f9be2e400b9c_87","name":"48e6","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*8YASXltuBmx7chRIYZxrGA.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_88":{"__typename":"Paragraph","id":"f9be2e400b9c_88","name":"f3f5","type":"P","href":null,"layout":null,"metadata":null,"text":"That will bring up a page like this. From here you can choose to either resupply each ship individually or resupply everything at once. Remember to have enough resources in your inventory beforehand.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_89":{"__typename":"Paragraph","id":"f9be2e400b9c_89","name":"43df","type":"H4","href":null,"layout":null,"metadata":null,"text":"Conclusion","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":10,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_90":{"__typename":"Paragraph","id":"f9be2e400b9c_90","name":"2cd6","type":"P","href":null,"layout":null,"metadata":null,"text":"Again, congratulations! You are now a veteran space explorer within the Star Atlas metaverse. By 2022, Star Atlas intends to release their next mini-game, SAGE, where players will compete for territory on behalf of their chosen faction. Players will eventually be able to craft, mine, and create ships of their own. Additionally, Star Atlas will continue to expand upon their Unreal Engine 5 Client for fully immersive gameplay.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_91":{"__typename":"Paragraph","id":"f9be2e400b9c_91","name":"d218","type":"P","href":null,"layout":null,"metadata":null,"text":"If you found this guide helpful, leave a comment below. Also don’t forget to hit follow and subscribe to get notified when we release our future Star Atlas SAGE guides!","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_92":{"__typename":"Paragraph","id":"f9be2e400b9c_92","name":"7647","type":"P","href":null,"layout":null,"metadata":null,"text":"If you need additional help, hop into the Star Atlas Discord.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":53,"end":60,"href":"https:\u002F\u002Fdiscord.gg\u002Fstaratlas","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_93":{"__typename":"Paragraph","id":"f9be2e400b9c_93","name":"f76d","type":"P","href":null,"layout":null,"metadata":null,"text":"Disclaimers:\nThe author holds assets in the game of Star Atlas.\n\nCurrent market conditions present significant risk in the crypto environment. This article is in no way an endorsement of any investment proposals by the reader.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":226,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_94":{"__typename":"Paragraph","id":"f9be2e400b9c_94","name":"5255","type":"P","href":null,"layout":null,"metadata":null,"text":"This article is in no way endorsed by Star Atlas or ATMTA, Inc.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":63,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_95":{"__typename":"Paragraph","id":"f9be2e400b9c_95","name":"b1f0","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs is the founder of The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of the Star Atlas game. Krigs has covered Star Atlas for the past year and enjoys writing about the potential that blockchain technology has to revolutionize the gaming industry.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_96":{"__typename":"Paragraph","id":"f9be2e400b9c_96","name":"d982","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:f9be2e400b9c_97":{"__typename":"Paragraph","id":"f9be2e400b9c_97","name":"fd48","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs: https:\u002F\u002Ftwitter.com\u002FKrigsfoniks\nThe Hologram: https:\u002F\u002Ftwitter.com\u002FHologram_News","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":7,"end":38,"href":"https:\u002F\u002Ftwitter.com\u002FKrigsfoniks","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":53,"end":86,"href":"https:\u002F\u002Ftwitter.com\u002FHologram_News","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"User:71d85907ce46":{"__typename":"User","id":"71d85907ce46"},"ImageMetadata:1*QbugCgA243udwPJUtJizbg.jpeg":{"__typename":"ImageMetadata","id":"1*QbugCgA243udwPJUtJizbg.jpeg"},"Collection:c7e66e764104":{"__typename":"Collection","id":"c7e66e764104","name":"Blockchain Biz","creator":{"__ref":"User:71d85907ce46"},"avatar":{"__ref":"ImageMetadata:1*QbugCgA243udwPJUtJizbg.jpeg"},"domain":null,"slug":"blockchain-biz"},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas"}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"HIT","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.e469c197.js"></script><script src="https://cdn-client.medium.com/lite/static/js/3034.5bf7db30.js"></script><script src="https://cdn-client.medium.com/lite/static/js/main.2dc81224.js"></script><script src="https://cdn-client.medium.com/lite/static/js/instrumentation.c71f0248.chunk.js"></script>

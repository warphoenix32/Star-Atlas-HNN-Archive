er Launches 3D Printed Ships For Sale","clapCount":0,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"},{"__ref":"Tag:community"}],"readingTime":2.147169811320755,"pendingCollection":null,"inResponseToEntityType":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1680144123180,"previewContent":{"__typename":"PreviewContent","subtitle":"Wed Mar 19th — During the 56th Star Atlas brew, a community member under the name of Enigma 42 unveiled the official launch of a new…"},"previewImage":{"__ref":"ImageMetadata:0*UlW9EiTPnA3SfbfZ.jpg"},"isShortform":false,"seoTitle":"","updatedAt":1680144132314,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"isSuspended":false,"pinnedAt":0,"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}},"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg","originalWidth":2730,"focusPercentX":48.57142857142857,"focusPercentY":45.19230769230769},"NewsletterV3:ac886d6987e0":{"__typename":"NewsletterV3","slug":"holoreport","id":"ac886d6987e0","name":"HoloReport","description":"Catch up on the latest Star Atlas news that you've missed. ","promoHeadline":"","promoBody":"","type":"NEWSLETTER_TYPE_COLLECTION","user":{"__ref":"User:41e0c5b141f1"},"collection":{"__ref":"Collection:4d89daa6ae31"},"showPromo":true},"Post:bff20fd1e3c":{"__typename":"Post","id":"bff20fd1e3c"},"PostViewerEdge:postId:495399bfef22-viewerId:lo_2922f165c108":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:495399bfef22-viewerId:lo_2922f165c108"},"Paragraph:2f9c842aaeb3_0":{"__typename":"Paragraph","id":"2f9c842aaeb3_0","name":"3e8c","type":"H3","href":null,"layout":null,"metadata":null,"text":"Star Atlas Community Member Launches 3D Printed Ships For Sale","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_1":{"__typename":"Paragraph","id":"2f9c842aaeb3_1","name":"4974","type":"P","href":null,"layout":null,"metadata":null,"text":"Wed Mar 19th — During the 56th Star Atlas brew, a community member under the name of Enigma 42 unveiled the official launch of a new product line of 3D printed Star Atlas ships for purchase.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:ab3d8f1a2142c49bf7978a42b3f695f0":{"__typename":"MediaResource","id":"ab3d8f1a2142c49bf7978a42b3f695f0","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?src=https%3A%2F%2Fwww.youtube.com%2Fembed%2FFwOYwFK-Zdg%3Fstart%3D9%26feature%3Doembed%26start%3D9&display_name=YouTube&url=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DFwOYwFK-Zdg&image=https%3A%2F%2Fi.ytimg.com%2Fvi%2FFwOYwFK-Zdg%2Fhqdefault.jpg&key=a19fcc184b9711e1b4764040d3dc5c07&type=text%2Fhtml&schema=youtube","iframeHeight":480,"iframeWidth":854,"title":"3D printed Star Atlas VZUS AMBWE"},"Paragraph:2f9c842aaeb3_2":{"__typename":"Paragraph","id":"2f9c842aaeb3_2","name":"cccf","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:ab3d8f1a2142c49bf7978a42b3f695f0"}},"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_3":{"__typename":"Paragraph","id":"2f9c842aaeb3_3","name":"cea4","type":"P","href":null,"layout":null,"metadata":null,"text":"A product description for the VZUS Ambwe shup reads:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_4":{"__typename":"Paragraph","id":"2f9c842aaeb3_4","name":"8634","type":"BQ","href":null,"layout":null,"metadata":null,"text":"This 3D print is inspired by Star Atlas. Star Atlas is a trademark or registered trademark of ATMTA, Inc. in the United States of America and elsewhere. This 3D print is manufactured and supplied by Enigma-42 in Australia. This is a physical 3D print in Resin.\nItem is ‘as printed’ and NOT sanded or painted.\nSupports have been removed however minor marks may remain.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_5":{"__typename":"Paragraph","id":"2f9c842aaeb3_5","name":"936a","type":"BQ","href":null,"layout":null,"metadata":null,"text":"Dimensions: 110mm long x 101mm wide x 55mm high","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_6":{"__typename":"Paragraph","id":"2f9c842aaeb3_6","name":"83b5","type":"P","href":null,"layout":null,"metadata":null,"text":"The VZUS ambwe is a popular Bounty Hunting Ship in the game of Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":63,"end":73,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_7":{"__typename":"Paragraph","id":"2f9c842aaeb3_7","name":"24b1","type":"P","href":null,"layout":null,"metadata":null,"text":"The VZUS ambwe model can be bought for $30 at Star Atlassian, the website run by Enigma 42. Enigma 42 also offers 4other physical models including the FIMBUL Packlite, the Fimbul Mamba, Pearce X4, and Tufa Feist.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":46,"end":60,"href":"https:\u002F\u002Fstaratlassian.com\u002Fproduct-category\u002Fphysical-products\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*UlW9EiTPnA3SfbfZ.jpg":{"__typename":"ImageMetadata","id":"0*UlW9EiTPnA3SfbfZ.jpg","originalHeight":324,"originalWidth":500,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:2f9c842aaeb3_8":{"__typename":"Paragraph","id":"2f9c842aaeb3_8","name":"7707","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*UlW9EiTPnA3SfbfZ.jpg"},"text":"Tufa Feist 3D Resin Model","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_9":{"__typename":"Paragraph","id":"2f9c842aaeb3_9","name":"8236","type":"P","href":null,"layout":null,"metadata":null,"text":"Star Atlassian also offers STL files that include the above 5 ships plus the Calico Compakt Hero and the Rainbow Om for $10 each.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_10":{"__typename":"Paragraph","id":"2f9c842aaeb3_10","name":"c181","type":"H3","href":null,"layout":null,"metadata":null,"text":"Products First of Many Under Star Atlas IP Program","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_11":{"__typename":"Paragraph","id":"2f9c842aaeb3_11","name":"0cc3","type":"P","href":null,"layout":null,"metadata":null,"text":"The launch of the 3D Star Atlas ship models marks the first official community run project under the new Star Atlas IP program.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_12":{"__typename":"Paragraph","id":"2f9c842aaeb3_12","name":"70f2","type":"P","href":null,"layout":null,"metadata":null,"text":"In February, ATMTA announced that it would open up licensing of its Star Atlas IP to the community. While official details regarding the terms of the Star Atlas IP program have not been released, it was previously disclosed that community projects could leverage Star Atlas IP for up to $1 Million in sales before a full licensing agreement would be required.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_13":{"__typename":"Paragraph","id":"2f9c842aaeb3_13","name":"2193","type":"P","href":null,"layout":null,"metadata":null,"text":"The launch of Enigma 42’s product line opens the doors for other community started projects featuring the Star Atlas brand.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_14":{"__typename":"Paragraph","id":"2f9c842aaeb3_14","name":"6da8","type":"P","href":null,"layout":null,"metadata":null,"text":"Other projects that could potentially leverage Star Atlas IP rights include Aephia’s upcoming Project Cataclysm Battle Card Game.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_15":{"__typename":"Paragraph","id":"2f9c842aaeb3_15","name":"01af","type":"P","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_16":{"__typename":"Paragraph","id":"2f9c842aaeb3_16","name":"0e0b","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":5,"href":"https:\u002F\u002Fmedium.com\u002Fu\u002F41e0c5b141f1?source=post_page-----4922901fb224--------------------------------","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_17":{"__typename":"Paragraph","id":"2f9c842aaeb3_17","name":"c731","type":"P","href":null,"layout":null,"metadata":null,"text":"is a pioneer in the world of Star Atlas, having founded The Hologram News Network — an independent meta-news organization that keeps players up to date on all developments regarding Star Atlas. An ardent supporter of emerging technologies, Krigs has been covering this game for over a year and believes passionately in their power to revolutionize our collective gaming experience.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_18":{"__typename":"Paragraph","id":"2f9c842aaeb3_18","name":"f064","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_19":{"__typename":"Paragraph","id":"2f9c842aaeb3_19","name":"fec3","type":"P","href":null,"layout":null,"metadata":null,"text":"Podcast | YouTube | Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Fopen.spotify.com\u002Fshow\u002F2mxndrDW6yPfpS350ijzjt?si=ec7c717f998240d6","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":17,"href":"https:\u002F\u002Fwww.youtube.com\u002Fchannel\u002FUCDa-YxgNG6A9xpH1qyP0OaQ","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":20,"end":27,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":30,"end":39,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":42,"end":45,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_20":{"__typename":"Paragraph","id":"2f9c842aaeb3_20","name":"ac43","type":"P","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_21":{"__typename":"Paragraph","id":"2f9c842aaeb3_21","name":"4e4e","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2f9c842aaeb3_22":{"__typename":"Paragraph","id":"2f9c842aaeb3_22","name":"8ca6","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_2922f165c108":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_2922f165c108","isEditor":false},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"Tag:community":{"__typename":"Tag","id":"community","displayTitle":"Community","normalizedTagSlug":"community"}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"MISS","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.8a4af149.js"></script><script src="https://cdn-clien
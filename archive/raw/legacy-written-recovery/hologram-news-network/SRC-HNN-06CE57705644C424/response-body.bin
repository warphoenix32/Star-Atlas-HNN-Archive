SmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:9dab579ff1fb-viewerId:lo_c2d4eb299b81"},"Paragraph:c89e47cb2b7b_0":{"__typename":"Paragraph","id":"c89e47cb2b7b_0","name":"7b40","type":"H3","href":null,"layout":null,"metadata":null,"text":"2022 Star Atlas Joni Award Predictions: Our Picks in Every Category","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_1":{"__typename":"Paragraph","id":"c89e47cb2b7b_1","name":"cfc8","type":"P","href":null,"layout":null,"metadata":null,"text":"The first annual Star Atlas Joni Awards are just around the corner and with them comes The Hologram’s first ever prediction list for the event.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":17,"end":27,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_2":{"__typename":"Paragraph","id":"c89e47cb2b7b_2","name":"683d","type":"P","href":null,"layout":null,"metadata":null,"text":"If you haven't voted yet, you can do so here. Read and vote before Dec 14th.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":40,"end":44,"href":"https:\u002F\u002Fwww.surveymonkey.com\u002Fr\u002Fjoni-awards-voting-2022","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_3":{"__typename":"Paragraph","id":"c89e47cb2b7b_3","name":"7f4f","type":"P","href":null,"layout":null,"metadata":null,"text":"Let’s get started.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*_vv55099j8bNQmVk":{"__typename":"ImageMetadata","id":"0*_vv55099j8bNQmVk","originalHeight":894,"originalWidth":1590,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c89e47cb2b7b_4":{"__typename":"Paragraph","id":"c89e47cb2b7b_4","name":"573d","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*_vv55099j8bNQmVk"},"text":"Star Atlas Joni Awards","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_5":{"__typename":"Paragraph","id":"c89e47cb2b7b_5","name":"8170","type":"H4","href":null,"layout":null,"metadata":null,"text":"1. Community Member of the Year: Funcracker","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":43,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*QIq4ZJkNmcfSP4Iy.jpg":{"__typename":"ImageMetadata","id":"0*QIq4ZJkNmcfSP4Iy.jpg","originalHeight":400,"originalWidth":400,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c89e47cb2b7b_6":{"__typename":"Paragraph","id":"c89e47cb2b7b_6","name":"19d3","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*QIq4ZJkNmcfSP4Iy.jpg"},"text":"Twitter","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_7":{"__typename":"Paragraph","id":"c89e47cb2b7b_7","name":"18d1","type":"P","href":null,"layout":null,"metadata":null,"text":"Funcracker has been, undoubtedly, a pillar of the Star Atlas community. As a co-founder of Aephia Industries, Funcracker has helped guide many Star Atlassians along their journey.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_8":{"__typename":"Paragraph","id":"c89e47cb2b7b_8","name":"3a7a","type":"H4","href":null,"layout":null,"metadata":null,"text":"2. Most Knowledgeable Community Member: Funcracker","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_9":{"__typename":"Paragraph","id":"c89e47cb2b7b_9","name":"0723","type":"P","href":null,"layout":null,"metadata":null,"text":"Funcracker isn’t just well liked by the community for his personality. His knowledge of many of Star Atlas’s undocumented mechanics is almost second to none. Whether its town halls, Atlas Brews, or Twitter Spaces, Funcracker is always tuned in to the Star Atlas know how.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_10":{"__typename":"Paragraph","id":"c89e47cb2b7b_10","name":"f568","type":"P","href":null,"layout":null,"metadata":null,"text":"While there are many in the community who could give Funcracker a run for his money, of the nominees, he takes the cake.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_11":{"__typename":"Paragraph","id":"c89e47cb2b7b_11","name":"c8c2","type":"H4","href":null,"layout":null,"metadata":null,"text":"3. Community Helper of the Year: Odvb","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_12":{"__typename":"Paragraph","id":"c89e47cb2b7b_12","name":"ddea","type":"P","href":null,"layout":null,"metadata":null,"text":"As a Star Atlas Discord Community Mod, it’s no surprise that Odvb is a final contended. A constant presence in the server, Odvb can always be found tirelessly point new members in the right direction.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:8cc0bd9ac7eb505fdb33bf0dc01e15dd":{"__typename":"MediaResource","id":"8cc0bd9ac7eb505fdb33bf0dc01e15dd","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?src=https%3A%2F%2Fwww.youtube.com%2Fembed%2F3b4Pl0tHb7E%3Ffeature%3Doembed&display_name=YouTube&url=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D3b4Pl0tHb7E&image=https%3A%2F%2Fi.ytimg.com%2Fvi%2F3b4Pl0tHb7E%2Fhqdefault.jpg&key=a19fcc184b9711e1b4764040d3dc5c07&type=text%2Fhtml&schema=youtube","iframeHeight":480,"iframeWidth":854,"title":"JONI teaser"},"Paragraph:c89e47cb2b7b_13":{"__typename":"Paragraph","id":"c89e47cb2b7b_13","name":"c00f","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:8cc0bd9ac7eb505fdb33bf0dc01e15dd"}},"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_14":{"__typename":"Paragraph","id":"c89e47cb2b7b_14","name":"a377","type":"H4","href":null,"layout":null,"metadata":null,"text":"4. Small Guild of the Year: Scythe","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_15":{"__typename":"Paragraph","id":"c89e47cb2b7b_15","name":"9b91","type":"P","href":null,"layout":null,"metadata":null,"text":"Of the small guild nominees, there’s only one true distinct winner and that is Scythe Guild. Over the past 6 months, Scythe has managed to raise $1,200 in donations from the Star Atlas community towards noble causes like cancer research. One of the few charitable guilds in the community, Scythe brings philanthropy to Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*NqVRpCghp5SUgyjV":{"__typename":"ImageMetadata","id":"0*NqVRpCghp5SUgyjV","originalHeight":500,"originalWidth":1500,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c89e47cb2b7b_16":{"__typename":"Paragraph","id":"c89e47cb2b7b_16","name":"17c1","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*NqVRpCghp5SUgyjV"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_17":{"__typename":"Paragraph","id":"c89e47cb2b7b_17","name":"6f18","type":"H4","href":null,"layout":null,"metadata":null,"text":"5. Medium Guild of the Year: Rome","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_18":{"__typename":"Paragraph","id":"c89e47cb2b7b_18","name":"5d0f","type":"P","href":null,"layout":null,"metadata":null,"text":"Rome guild has managed to build one of the most robust presences in the metaverse to date. Rome guild members are veterans of the crypto and metaverse space, with key members hosting a virtual talk show every Sunday to discuss the latest metaverse news.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*4T4PSXdsq2q5L-Wf":{"__typename":"ImageMetadata","id":"0*4T4PSXdsq2q5L-Wf","originalHeight":500,"originalWidth":1500,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c89e47cb2b7b_19":{"__typename":"Paragraph","id":"c89e47cb2b7b_19","name":"7f59","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*4T4PSXdsq2q5L-Wf"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_20":{"__typename":"Paragraph","id":"c89e47cb2b7b_20","name":"d6d0","type":"H4","href":null,"layout":null,"metadata":null,"text":"6. Large Guild of the Year: Quimera","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_21":{"__typename":"Paragraph","id":"c89e47cb2b7b_21","name":"285f","type":"P","href":null,"layout":null,"metadata":null,"text":"If there’s one defining force of Star Atlas, it’s Quimera. Hosting their own Quimercon in-person event, Quimera is one of the largest guilds in Star Atlas. While they may appear absent in the English section of the Star Atlas discord, Quimera is a mainstay of the Spanish channels. While the English community remains split across various guilds, Quimera has managed to unite a vast majority of the Spanish community under one banner.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*6yOuGdxDNaLomcUF":{"__typename":"ImageMetadata","id":"0*6yOuGdxDNaLomcUF","originalHeight":500,"originalWidth":1500,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c89e47cb2b7b_22":{"__typename":"Paragraph","id":"c89e47cb2b7b_22","name":"af1c","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*6yOuGdxDNaLomcUF"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_23":{"__typename":"Paragraph","id":"c89e47cb2b7b_23","name":"618d","type":"H4","href":null,"layout":null,"metadata":null,"text":"7. Best Guild Website: Aephia.com","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":33,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_24":{"__typename":"Paragraph","id":"c89e47cb2b7b_24","name":"a534","type":"P","href":null,"layout":null,"metadata":null,"text":"Replete with a repository of information, Aephia.com has a robust array of Star Atlas information in a simple, easy to read format. The various tools on the website help new Aephia members find the information they need quickly.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_25":{"__typename":"Paragraph","id":"c89e47cb2b7b_25","name":"ae63","type":"H4","href":null,"layout":null,"metadata":null,"text":"8. Best Content Creator: Morpheus","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":33,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_26":{"__typename":"Paragraph","id":"c89e47cb2b7b_26","name":"a5cd","type":"P","href":null,"layout":null,"metadata":null,"text":"A leader in the French Star Atlas community, Morpheus produces some of the most creative Star Atlas content in any language. Despite being a French speaking content creator, the name Morpheus is recognized far and wide.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*Se2Jn0PQDMJg2oNqdlwMYg.png":{"__typename":"ImageMetadata","id":"1*Se2Jn0PQDMJg2oNqdlwMYg.png","originalHeight":449,"originalWidth":608,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c89e47cb2b7b_27":{"__typename":"Paragraph","id":"c89e47cb2b7b_27","name":"881b","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*Se2Jn0PQDMJg2oNqdlwMYg.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_28":{"__typename":"Paragraph","id":"c89e47cb2b7b_28","name":"23b2","type":"H4","href":null,"layout":null,"metadata":null,"text":"9. Best Video: How to Play Star Atlas by DAOCaster","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_29":{"__typename":"Paragraph","id":"c89e47cb2b7b_29","name":"97d5","type":"P","href":null,"layout":null,"metadata":null,"text":"DAOCaster was one of the original content creators for Star Atlas and was critical in onboarding likely thousands of new members, including this writer. His coverage of the emerging metaverse that is Star Atlas inspired many to take their first steps into blockchain gaming.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"MediaResource:8cdb883125418dfe78a8fe6f8d3fde8f":{"__typename":"MediaResource","id":"8cdb883125418dfe78a8fe6f8d3fde8f","iframeSrc":"https:\u002F\u002Fcdn.embedly.com\u002Fwidgets\u002Fmedia.html?src=https%3A%2F%2Fwww.youtube.com%2Fembed%2FPVF8b5FAyrI%3Ffeature%3Doembed&display_name=YouTube&url=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DPVF8b5FAyrI&image=https%3A%2F%2Fi.ytimg.com%2Fvi%2FPVF8b5FAyrI%2Fhqdefault.jpg&key=a19fcc184b9711e1b4764040d3dc5c07&type=text%2Fhtml&schema=youtube","iframeHeight":480,"iframeWidth":854,"title":"How to Play Star Atlas | FULL WALKTHROUGH | Buying SOL, Buying ATLAS, Buying Ships & Staking Ships"},"Paragraph:c89e47cb2b7b_30":{"__typename":"Paragraph","id":"c89e47cb2b7b_30","name":"7d97","type":"IFRAME","href":null,"layout":"INSET_CENTER","metadata":null,"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":{"__typename":"Iframe","mediaResource":{"__ref":"MediaResource:8cdb883125418dfe78a8fe6f8d3fde8f"}},"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_31":{"__typename":"Paragraph","id":"c89e47cb2b7b_31","name":"a5c8","type":"H4","href":null,"layout":null,"metadata":null,"text":"10. Best Meme: Santi Action Figure","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*tKN6O1D4_RvHf5rS.jpg":{"__typename":"ImageMetadata","id":"0*tKN6O1D4_RvHf5rS.jpg","originalHeight":2048,"originalWidth":2560,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c89e47cb2b7b_32":{"__typename":"Paragraph","id":"c89e47cb2b7b_32","name":"ef8f","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*tKN6O1D4_RvHf5rS.jpg"},"text":"By Arktype","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_33":{"__typename":"Paragraph","id":"c89e47cb2b7b_33","name":"c49c","type":"P","href":null,"layout":null,"metadata":null,"text":"Everyone loves a good jab at our fearless community relations leader.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_34":{"__typename":"Paragraph","id":"c89e47cb2b7b_34","name":"1dc3","type":"H4","href":null,"layout":null,"metadata":null,"text":"11. Community Created Project of the Year: Redspatula","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_35":{"__typename":"Paragraph","id":"c89e47cb2b7b_35","name":"e5b5","type":"P","href":null,"layout":null,"metadata":null,"text":"One of the most visited websites for Star Atlas ship market data, Redspatula is a critical piece of information for ship buyers and market watchers. Their site has helped countless players find the best deals on ships at the right price.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*o1S9Ha22bHZZApPqNIRC8w.png":{"__typename":"ImageMetadata","id":"1*o1S9Ha22bHZZApPqNIRC8w.png","originalHeight":944,"originalWidth":1856,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c89e47cb2b7b_36":{"__typename":"Paragraph","id":"c89e47cb2b7b_36","name":"2e78","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*o1S9Ha22bHZZApPqNIRC8w.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_37":{"__typename":"Paragraph","id":"c89e47cb2b7b_37","name":"e1a4","type":"H4","href":null,"layout":null,"metadata":null,"text":"12. Favorite Solana Project: Phantom","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_38":{"__typename":"Paragraph","id":"c89e47cb2b7b_38","name":"c74d","type":"P","href":null,"layout":null,"metadata":null,"text":"Phantom is one of the most visible projects on the Solana ecosystem and key to decentralized finance management. As a key integrator to Star Atlas, Phantom will undoubtedly see huge potential and growth alongside Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*JKGgEg4SFNts7HaT.png":{"__typename":"ImageMetadata","id":"0*JKGgEg4SFNts7HaT.png","originalHeight":1080,"originalWidth":1920,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:c89e47cb2b7b_39":{"__typename":"Paragraph","id":"c89e47cb2b7b_39","name":"cac1","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*JKGgEg4SFNts7HaT.png"},"text":"Phantom Wallet","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_40":{"__typename":"Paragraph","id":"c89e47cb2b7b_40","name":"d7dd","type":"P","href":null,"layout":null,"metadata":null,"text":"And there you have it, our first full list of the Star Atlas 2022 Joni Award Predictions. Don’t forget to vote by Dec 14th and catch the awards show live on Dec 16th to see if your favorite winners will take home a Joni.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_41":{"__typename":"Paragraph","id":"c89e47cb2b7b_41","name":"35fb","type":"P","href":null,"layout":null,"metadata":null,"text":"Agree or disagree with our predictions? Leave a comment and let us know what you think.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_42":{"__typename":"Paragraph","id":"c89e47cb2b7b_42","name":"30de","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs is the founder of The Hologram News Network, an independent blockchain gaming meta-news organization devoted to the coverage of the Star Atlas game. Krigs has covered Star Atlas for the past year and enjoys writing about the potential that blockchain technology has to revolutionize the gaming industry.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_43":{"__typename":"Paragraph","id":"c89e47cb2b7b_43","name":"cd7b","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_44":{"__typename":"Paragraph","id":"c89e47cb2b7b_44","name":"84dc","type":"P","href":null,"layout":null,"metadata":null,"text":"Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":19,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":22,"end":25,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_45":{"__typename":"Paragraph","id":"c89e47cb2b7b_45","name":"224b","type":"P","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_46":{"__typename":"Paragraph","id":"c89e47cb2b7b_46","name":"8cea","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:c89e47cb2b7b_47":{"__typename":"Paragraph","id":"c89e47cb2b7b_47","name":"6b5a","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_c2d4eb299b81":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_c2d4e
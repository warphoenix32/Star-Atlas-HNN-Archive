to Exploring the Halls of the Star Atlas Showroom","clapCount":0,"pinnedAt":0,"pinnedByCreatorAt":0,"curationEligibleAt":0,"responseDistribution":"NOT_DISTRIBUTED","inResponseToPostResult":null,"inResponseToCatalogResult":null,"pendingCollection":null,"isNewsletter":false,"isAuthorNewsletter":false,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"}],"readingTime":5.695283018867925,"inResponseToEntityType":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1674266855595,"previewContent":{"__typename":"PreviewContent","subtitle":"Hello, metaverse enthusiasts, this is explorer USTUR, also known as Jall.doer. The year 2022 has been truly memorable for all of us in the…"},"previewImage":{"__ref":"ImageMetadata:1*nFKpsp4ySGUImm-0fV6obQ.jpeg"},"isShortform":false,"seoTitle":"","updatedAt":1674266863703,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"isSuspended":false,"responseRootPost":{"__typename":"ResponseRootPost","post":{"__ref":"Post:766876ece8d1"}},"internalLinks({\"paging\":{\"limit\":8}})":{"__typename":"InternalLinksConnection","items":[{"__ref":"Post:31e26c8a3da7"},{"__ref":"Post:6f3ea0350c9d"},{"__ref":"Post:a964d79be148"},{"__ref":"Post:8f9453e2318b"},{"__ref":"Post:7461bbb02f8d"},{"__ref":"Post:5fb5975dde3d"},{"__ref":"Post:46d589921c2c"},{"__ref":"Post:37dd264584a6"}]},"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}},"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg","originalWidth":2730,"focusPercentX":48.57142857142857,"focusPercentY":45.19230769230769},"Post:4c6803eab23f":{"__typename":"Post","id":"4c6803eab23f"},"PostViewerEdge:postId:766876ece8d1-viewerId:lo_08131fec0771":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:766876ece8d1-viewerId:lo_08131fec0771"},"Paragraph:8898c7c5f81e_0":{"__typename":"Paragraph","id":"8898c7c5f81e_0","name":"eea8","type":"H3","href":null,"layout":null,"metadata":null,"text":"Navigating the Cosmos: A Guide to Exploring the Halls of the Star Atlas Showroom","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_1":{"__typename":"Paragraph","id":"8898c7c5f81e_1","name":"ac30","type":"P","href":null,"layout":null,"metadata":null,"text":"Hello, metaverse enthusiasts, this is explorer USTUR, also known as Jall.doer. The year 2022 has been truly memorable for all of us in the Star Atlas community, filled with a variety of experiences and emotions. Throughout this time, the team has released multiple proposals that have gradually expanded the ecosystem, but without a doubt, the one that has garnered the most interest so far is the first module created in Unreal Engine 5, a demo of what the final game of Star Atlas could be. The Showroom or Volant Station, as it is known by those who walk its corridors, is the seed of the universe that ATMTA intends to build for us. If you want to delve a little deeper into this new universe and start your journey among the stars, follow me and you will not be disappointed.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":139,"end":149,"href":"https:\u002F\u002Fmedium.com\u002F@staratlasgame","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":422,"end":437,"href":"https:\u002F\u002Fwww.unrealengine.com\u002Fen-US\u002Funreal-engine-5?sessionInvalidated=true","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*nFKpsp4ySGUImm-0fV6obQ.jpeg":{"__typename":"ImageMetadata","id":"1*nFKpsp4ySGUImm-0fV6obQ.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:8898c7c5f81e_2":{"__typename":"Paragraph","id":"8898c7c5f81e_2","name":"9ccc","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*nFKpsp4ySGUImm-0fV6obQ.jpeg"},"text":"Entrance to Volant Station","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_3":{"__typename":"Paragraph","id":"8898c7c5f81e_3","name":"84cf","type":"H3","href":null,"layout":null,"metadata":null,"text":"Entering a New Universe","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_4":{"__typename":"Paragraph","id":"8898c7c5f81e_4","name":"8a67","type":"P","href":null,"layout":null,"metadata":null,"text":"The primary characteristic of an explorer is curiosity, often what really matters can be found in the details. Anyone lucky enough to find the keys to enter these facilities will come face to face with this relatively simple design structure with a MUD style, but with truly curious and well-worked details. The first thing that catches our attention are these statues in the form of hands trying to reach a world that remains in constant change, so close but so far at the same time. We are captivated by the beauty of this place as we begin to delve deeper. At the entrance, we see these screens on each wall where we can display our posters in pure SANDBOX style.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":652,"end":659,"href":"https:\u002F\u002Fregister.sandbox.game\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_5":{"__typename":"Paragraph","id":"8898c7c5f81e_5","name":"e5eb","type":"H3","href":null,"layout":null,"metadata":null,"text":"The Hall of History","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*7Zvg0477W9a2HyezKXHWlg.jpeg":{"__typename":"ImageMetadata","id":"1*7Zvg0477W9a2HyezKXHWlg.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:8898c7c5f81e_6":{"__typename":"Paragraph","id":"8898c7c5f81e_6","name":"02ef","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*7Zvg0477W9a2HyezKXHWlg.jpeg"},"text":"Panels for Posters","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_7":{"__typename":"Paragraph","id":"8898c7c5f81e_7","name":"f2b3","type":"P","href":null,"layout":null,"metadata":null,"text":"The story that each of these posters holds transports us to important moments within Star Atlas, related to the War of Convergence or witness of the expansion of the known universe. Observing every detail of these works can be a whole experience from this new perspective. It is precisely when curiosity calls at your door that you realize there was something else behind you, something you had overlooked. A transport is located right at this entrance, as if waiting for its next passenger.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_8":{"__typename":"Paragraph","id":"8898c7c5f81e_8","name":"a389","type":"H3","href":null,"layout":null,"metadata":null,"text":"An Unexpected Transport","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*1YPLg-dC-odrN-MWpXuZFQ.jpeg":{"__typename":"ImageMetadata","id":"1*1YPLg-dC-odrN-MWpXuZFQ.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:8898c7c5f81e_9":{"__typename":"Paragraph","id":"8898c7c5f81e_9","name":"1719","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*1YPLg-dC-odrN-MWpXuZFQ.jpeg"},"text":"Unexpected Transportation","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_10":{"__typename":"Paragraph","id":"8898c7c5f81e_10","name":"fac0","type":"P","href":null,"layout":null,"metadata":null,"text":"This is perhaps the most striking clue to understand that we are in an expanding environment. Who knows what remote places we will be able to visit in the future. Meanwhile, this arch in the distance seems to be a testimony of how small this place is compared to the world where we find ourselves. As we delve deeper into the structure, we begin to realize the splendid interior design and the continuation of this exhibition hall where we can see our badges.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_11":{"__typename":"Paragraph","id":"8898c7c5f81e_11","name":"b5c9","type":"H3","href":null,"layout":null,"metadata":null,"text":"An amazing view","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*auQzrwVPd87_M4kwN3lQWg.jpeg":{"__typename":"ImageMetadata","id":"1*auQzrwVPd87_M4kwN3lQWg.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:8898c7c5f81e_12":{"__typename":"Paragraph","id":"8898c7c5f81e_12","name":"dd56","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*auQzrwVPd87_M4kwN3lQWg.jpeg"},"text":"Showroom","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_13":{"__typename":"Paragraph","id":"8898c7c5f81e_13","name":"0204","type":"P","href":null,"layout":null,"metadata":null,"text":"Each detail within this corridor is incredible, we can exhibit our collectibles and achievements within the metaverse, this results in a very curious contrast after walking through an entrance filled with the history of the developing universe. You continue on your way and come across this artifact that displays a screen when you approach it.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_14":{"__typename":"Paragraph","id":"8898c7c5f81e_14","name":"29c6","type":"H3","href":null,"layout":null,"metadata":null,"text":"First Interaction with our most important assets, the Ships","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*CludQZmx-F3FkT1hn1IbwA.jpeg":{"__typename":"ImageMetadata","id":"1*CludQZmx-F3FkT1hn1IbwA.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:8898c7c5f81e_15":{"__typename":"Paragraph","id":"8898c7c5f81e_15","name":"44a8","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*CludQZmx-F3FkT1hn1IbwA.jpeg"},"text":"Invocation of Ships inside the Showroom","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_16":{"__typename":"Paragraph","id":"8898c7c5f81e_16","name":"0688","type":"P","href":null,"layout":null,"metadata":null,"text":"This panel allows you to access all the ships that have currently been designed to explore the metaverse. Observing each of these beautiful ships, you will realize that you can only teleport to those that you have purchased, this is where one of the first game-blockchain interactions comes into play. The Foundation Kit technology developed by ATMTA, which interacts directly with your wallet from the game in Unreal 5, allows for creating many mechanics that will make Star Atlas a very interesting metaverse to experience through natural metaverse-blockchain interaction. For now, this is the only way we really use assets within the Showroom.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*HUxlFDta-VFHZmU3HbgCNA.jpeg":{"__typename":"ImageMetadata","id":"1*HUxlFDta-VFHZmU3HbgCNA.jpeg","originalHeight":1080,"originalWidth":1920,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:8898c7c5f81e_17":{"__typename":"Paragraph","id":"8898c7c5f81e_17","name":"2adc","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*HUxlFDta-VFHZmU3HbgCNA.jpeg"},"text":"Ship selection panel","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_18":{"__typename":"Paragraph","id":"8898c7c5f81e_18","name":"bcb0","type":"P","href":null,"layout":null,"metadata":null,"text":"In the R2 update, this panel shows us the development status of the ships within the Showroom, for example, we will find ships that we can only see in a faded form and in design work, but others we can see in great detail, such as the case of the Floyd, this is the only free ship that also allows experiencing the first flight simulation experience within Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*cqiH0uQ6Fa_3FvVTB9kUQA.jpeg":{"__typename":"ImageMetadata","id":"1*cqiH0uQ6Fa_3FvVTB9kUQA.jpeg","originalHeight":1080,"originalWidth":1920,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:8898c7c5f81e_19":{"__typename":"Paragraph","id":"8898c7c5f81e_19","name":"180c","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*cqiH0uQ6Fa_3FvVTB9kUQA.jpeg"},"text":"First flight experience with the Floyd spacecraft","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_20":{"__typename":"Paragraph","id":"8898c7c5f81e_20","name":"dbeb","type":"P","href":null,"layout":null,"metadata":null,"text":"As you use your ship for the first time, thoughts of what could be come to mind and you wonder more than ever how many secrets are hidden in this developing world, if only you could leave this bubble and explore beyond, but rest easy my fellow explorers, the time has not yet come, there is still much to be built with what we have within this small remnant of planet Earth.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_21":{"__typename":"Paragraph","id":"8898c7c5f81e_21","name":"de99","type":"H3","href":null,"layout":null,"metadata":null,"text":"The Garden of Hope","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*kLkEbD-_Uawla8ToSw_V_Q.jpeg":{"__typename":"ImageMetadata","id":"1*kLkEbD-_Uawla8ToSw_V_Q.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:8898c7c5f81e_22":{"__typename":"Paragraph","id":"8898c7c5f81e_22","name":"d64d","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*kLkEbD-_Uawla8ToSw_V_Q.jpeg"},"text":"Second entrance to Volant Station through the garden","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_23":{"__typename":"Paragraph","id":"8898c7c5f81e_23","name":"da15","type":"P","href":null,"layout":null,"metadata":null,"text":"As we delve deeper into the perimeter of the central structure, this time from the garden, we will come across one of the most beautiful views. In the center, just above us are these three statues that stand out like an altar to the most sacred. They represent the supreme leaders of each faction that brought peace to the universe, and that small beam of light that seems to have no end to the top of the sky, seems to be a testament to hope for a better future. With the intention of discovering new secrets, we delve deeper into the structure, finding a place that seems to be reserved for parties or events among friends.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_24":{"__typename":"Paragraph","id":"8898c7c5f81e_24","name":"b7e2","type":"H3","href":null,"layout":null,"metadata":null,"text":"A place to relax with friends","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*UGHBbJBlBfcAyo-6JTQC7w.jpeg":{"__typename":"ImageMetadata","id":"1*UGHBbJBlBfcAyo-6JTQC7w.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:8898c7c5f81e_25":{"__typename":"Paragraph","id":"8898c7c5f81e_25","name":"a1b8","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*UGHBbJBlBfcAyo-6JTQC7w.jpeg"},"text":"Bar inside the Showroom","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_26":{"__typename":"Paragraph","id":"8898c7c5f81e_26","name":"79a3","type":"P","href":null,"layout":null,"metadata":null,"text":"We often forget the social aspect that defines a metaverse. A bar in a video game might be unnecessary or just a place to get new missions, but in the metaverse of Star Atlas, it will surely be a very visited place by all. These places are meant to be part of the central experience, where we will find customers, contractors, bounty hunters, friends, and maybe relationships beyond the digital. It may be difficult to visualize now within a seemingly empty place, but we are not far from seeing it with our own eyes, once the metaverse takes shape.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_27":{"__typename":"Paragraph","id":"8898c7c5f81e_27","name":"3a5e","type":"H3","href":null,"layout":null,"metadata":null,"text":"First excursion inside the Showroom","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*VCp_NMekqJvw6EiTmgUIRg.jpeg":{"__typename":"ImageMetadata","id":"1*VCp_NMekqJvw6EiTmgUIRg.jpeg","originalHeight":2160,"originalWidth":3840,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:8898c7c5f81e_28":{"__typename":"Paragraph","id":"8898c7c5f81e_28","name":"8429","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*VCp_NMekqJvw6EiTmgUIRg.jpeg"},"text":"Star Map Room","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_29":{"__typename":"Paragraph","id":"8898c7c5f81e_29","name":"5e7e","type":"P","href":null,"layout":null,"metadata":null,"text":"It is becoming time to process all the information found so far and to evaluate the immensity of possibilities that open up before us, perhaps we will see each other on my next excursion through the Star Atlas Showroom, many secrets are waiting to be found and stories that await to be told. Take care of yourself, my fellow explorers, I hope this little journey has served you to obtain valuable information about this expanding metaverse, may peace be with you.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_30":{"__typename":"Paragraph","id":"8898c7c5f81e_30","name":"a4e8","type":"P","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_31":{"__typename":"Paragraph","id":"8898c7c5f81e_31","name":"0d7e","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:8898c7c5f81e_32":{"__typename":"Paragraph","id":"8898c7c5f81e_32","name":"2eb7","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_08131fec0771":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_08131fec0771","isEditor":false},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","atsQualifiedAt":1650725917596},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"User:7437ac77bdda":{"__typename":"User","id":"7437ac77bdda","imageId":"1*C_AQcr5MIYG6M7-6bsQkBg.jpeg","mediumMemberAt":0,"name":"Laura Wolf","username":"Chiroptera","customDomainState":null,"hasSubdomain":false,"bio":"","verifications":{"__typename":"VerifiedInfo","isBookAuthor":false}},"ImageMetadata:1*kl1SPuznei2K0ORLj4FcVA.jpeg":{"__typename":"ImageMetadata","id":"1*kl1SPuznei2K0ORLj4FcVA.jpeg","alt":null,"focusPercentX":null,"focusPercentY":null},"Post:31e26c8a3da7":{"__typename":"Post","id":"31e26c8a3da7","visibility":"PUBLIC","previewContent":{"__typename":"PreviewContent","isFullContent":false,"subtitle":"First of all: I am a Fan of the or
3B3B","point":0.2},{"__typename":"ColorPoint","color":"#FF565555","point":0.3},{"__typename":"ColorPoint","color":"#FF6F6D6D","point":0.4},{"__typename":"ColorPoint","color":"#FF868484","point":0.5},{"__typename":"ColorPoint","color":"#FF9C9A99","point":0.6},{"__typename":"ColorPoint","color":"#FFB1AEAE","point":0.7},{"__typename":"ColorPoint","color":"#FFC5C3C2","point":0.8},{"__typename":"ColorPoint","color":"#FFD9D6D6","point":0.9},{"__typename":"ColorPoint","color":"#FFECE9E9","point":1}]}},"googleAnalyticsId":null,"domain":null,"name":"The Hologram","slug":"the-hologram","avatar":{"__ref":"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg"},"isAuroraVisible":false,"legacyHeaderBackgroundImage":{"__ref":"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg"},"logo":{"__ref":"ImageMetadata:"},"subscriberCount":90,"newsletterV3":null,"navItems":[{"__typename":"NavItem","tagSlug":null,"title":"SAGE","url":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fsage\u002Fhome"},{"__typename":"NavItem","tagSlug":null,"title":"Guides","url":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fguides\u002Fhome"},{"__typename":"NavItem","tagSlug":null,"title":"Star Atlas Community","url":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fcommunity\u002Fhome"},{"__typename":"NavItem","tagSlug":null,"title":"Spanish","url":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fspanish\u002Fhome"},{"__typename":"NavItem","tagSlug":null,"title":"About Us","url":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fabout"}],"viewerEdge":{"__ref":"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_2a1d2071eacd"},"creator":{"__ref":"User:41e0c5b141f1"},"isAuroraEligible":true,"twitterUsername":"Hologram_News","facebookPageId":null,"customDomainState":null,"ptsQualifiedAt":1650725921201,"description":"The Hologram delivers the latest in Star Atlas news, politics, economics and community coverage."},"ImageMetadata:1*7CPIGOfQcS8d3RGFcufiiA.jpeg":{"__typename":"ImageMetadata","id":"1*7CPIGOfQcS8d3RGFcufiiA.jpeg","originalWidth":2730,"focusPercentX":48.57142857142857,"focusPercentY":45.19230769230769},"CustomStyleSheet:1b0e58ee5395":{"__typename":"CustomStyleSheet","id":"1b0e58ee5395","global":{"__typename":"GlobalStyles","colorPalette":{"__typename":"StyleSheetColorPalette","background":null}},"header":{"__typename":"HeaderStyles","headerScale":"HEADER_SCALE_SMALL","backgroundImageDisplayMode":"IMAGE_DISPLAY_MODE_FILL","backgroundImageVerticalAlignment":"START","backgroundColorDisplayMode":"COLOR_DISPLAY_MODE_SOLID","backgroundColor":null,"secondaryBackgroundColor":null,"postBackgroundColor":null,"backgroundImage":null,"logoImage":null,"appNameColor":null,"appNameTreatment":"NAME_TREATMENT_TEXT","nameTreatment":"NAME_TREATMENT_TEXT"},"navigation":null,"blogroll":{"__typename":"BlogrollConfiguration","visibility":"BLOGROLL_VISIBILITY_SIDEBAR"}},"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_2a1d2071eacd":{"__typename":"UserViewerEdge","id":"userId:41e0c5b141f1-viewerId:lo_2a1d2071eacd","isFollowing":false,"isUser":false},"NewsletterV3:85fc9c436e2e":{"__typename":"NewsletterV3","id":"85fc9c436e2e","type":"NEWSLETTER_TYPE_AUTHOR","slug":"41e0c5b141f1","name":"41e0c5b141f1","collection":null,"user":{"__ref":"User:41e0c5b141f1"},"description":"","promoHeadline":"","promoBody":"","showPromo":false,"subscribersCount":6},"User:41e0c5b141f1":{"__typename":"User","id":"41e0c5b141f1","name":"Krigs","username":"krigsfoniks","newsletterV3":{"__ref":"NewsletterV3:85fc9c436e2e"},"imageId":"1*pVxyLAandIa00EX6ZGRERw.png","customStyleSheet":{"__ref":"CustomStyleSheet:1b0e58ee5395"},"customDomainState":null,"hasSubdomain":false,"mediumMemberAt":1667603125000,"verifications":{"__typename":"VerifiedInfo","isBookAuthor":false},"socialStats":{"__typename":"SocialStats","followerCount":116,"followingCount":24,"collectionFollowingCount":3},"isPartnerProgramEnrolled":true,"viewerEdge":{"__ref":"UserViewerEdge:userId:41e0c5b141f1-viewerId:lo_2a1d2071eacd"},"viewerIsUser":false,"postSubscribeMembershipUpsellShownAt":0,"about":"[{\"children\":[{\"text\":\"Editor and Publisher of the Hologram, a news organization set in the Star Atlas metaverse\"}]},{\"children\":[{\"text\":\"I write about things that occur \"},{\"text\":\"in \",\"italic\":true},{\"text\":\"the Star Atlas metaverse with the goal of become Star Atlas primary in game newspaper. \"}]},{\"children\":[{\"text\":\"Star Atlas metacitizen, crypto enthusiast, and military strategist. Like Bilbo, the road goes ever on. \"}]}]","homepagePostsConnection:{\"paging\":{\"limit\":1}}":{"__typename":"PostConnection","posts":[{"__ref":"Post:bff20fd1e3c"}]},"isSuspended":false,"allowNotes":true,"isAuroraVisible":true,"twitterScreenName":"Hologram_News","atsQualifiedAt":1650725917596,"bio":"Founder and Chief Editor of The Hologram. | Crypto | Star Atlas |"},"Post:bff20fd1e3c":{"__typename":"Post","id":"bff20fd1e3c"},"PostViewerEdge:postId:946af14901cf-viewerId:lo_2a1d2071eacd":{"__typename":"PostViewerEdge","paywall":{"__typename":"PostPaywall","type":"ASPIRATIONAL","creatorSpotlights":[{"__typename":"CreatorSpotlight","name":"Jonathan Lethem","title":"New York Times Best-Selling Author","company":null,"miroId":"1*iudmnb-vrHQeHKc34ETv_A.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Susan Orlean","title":"Staff Writer","company":"The New Yorker","miroId":"1*3trmKoIWsT_2kL9U-UU6GQ@2x.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Dr. Tom Frieden","title":"Former CDC Director","company":null,"miroId":"1*oTq5RWcSwzoDiuAO_OBhaw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Savala Nolan","title":"Professor, UC Berkeley School of Law","company":null,"miroId":"1*Cf_qSwN5neVTzDdJW-koRw.jpeg","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Roger Martin","title":"Professor, Strategy Advisor, Former Dean","company":null,"miroId":"1*T6e_YKc1VwcB0oDPFJFijA.png","hideOnSmallScreen":null},{"__typename":"CreatorSpotlight","name":"Julie Zhuo","title":"Former VP of Product Design, Facebook","company":null,"miroId":"0*bOVFN2_iLTHM5m2c.jpeg","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Ryan Holiday","title":"Best-Selling Author and Entrepreneur","company":null,"miroId":"0*oxw8NBp_Td0n3l4_.png","hideOnSmallScreen":true},{"__typename":"CreatorSpotlight","name":"Laura Vanderkam","title":"Best-Selling Author, TED Speaker","company":null,"miroId":"0*F-96hvvSXAzZvkqn","hideOnSmallScreen":null}]},"id":"postId:946af14901cf-viewerId:lo_2a1d2071eacd"},"Paragraph:2cb2788d7d1b_0":{"__typename":"Paragraph","id":"2cb2788d7d1b_0","name":"e3e1","type":"H3","href":null,"layout":null,"metadata":null,"text":"The Guild-State: A Framework for Understanding Guild Behavior in Star Atlas","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_1":{"__typename":"Paragraph","id":"2cb2788d7d1b_1","name":"af03","type":"H3","href":null,"layout":null,"metadata":null,"text":"Star Atlas — The next evolution of governance?","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":46,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_2":{"__typename":"Paragraph","id":"2cb2788d7d1b_2","name":"bd37","type":"P","href":null,"layout":null,"metadata":null,"text":"For many, Star Atlas is a grand-strategy MMORPG filled with space battles and galactic conquest. But to others, Star Atlas represents the next evolution in societal governance enabled mainly by Web3 technology.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":10,"end":20,"href":null,"anchorType":"USER","userId":"5ed69ff9cfb0","linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_3":{"__typename":"Paragraph","id":"2cb2788d7d1b_3","name":"f58b","type":"P","href":null,"layout":null,"metadata":null,"text":"By some definition, the metaverse is a shared social space that exists in the digital realm. This space operates in parallel to everyday society. As a shared metaverse, Star Atlas will serve as one of the next iterations of meta-social constructs that have been established by games like Second Life, Entropia Online, and EVE Online. As a metaverse, Star Atlas will have its own economics, politics, and cultural customs.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_4":{"__typename":"Paragraph","id":"2cb2788d7d1b_4","name":"b538","type":"P","href":null,"layout":null,"metadata":null,"text":"It has been stated that Star Atlas will be an evolution in governance; decentralized governance models replacing centralized democracy at some point in the far future. In the Star Atlas metaverse, states built around national identity will not exist. Even pre-defined game factions will be transcended at some point for constructs that people will self-determine and coalesce around.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":273,"end":281,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fthe-factions-of-star-atlas-7fe57e3f8575","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*bIlWBY4rplFyIOZZyGJ9jw.png":{"__typename":"ImageMetadata","id":"1*bIlWBY4rplFyIOZZyGJ9jw.png","originalHeight":512,"originalWidth":512,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:2cb2788d7d1b_5":{"__typename":"Paragraph","id":"2cb2788d7d1b_5","name":"725b","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*bIlWBY4rplFyIOZZyGJ9jw.png"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_6":{"__typename":"Paragraph","id":"2cb2788d7d1b_6","name":"4f53","type":"P","href":null,"layout":null,"metadata":null,"text":"If Star Atlas is to be a grand experiment in decentralized governance, then who will act as the main players in this new galactic hegemony? In the current global system, nation-states act as the main players in international political relations.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":139,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_7":{"__typename":"Paragraph","id":"2cb2788d7d1b_7","name":"2893","type":"P","href":null,"layout":null,"metadata":null,"text":"Since Star Atlas seeks to transcend the current geographically defined nation-state system, it is only natural that nation-states be supplanted by a new form of centralized societal organization.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_8":{"__typename":"Paragraph","id":"2cb2788d7d1b_8","name":"e14c","type":"P","href":null,"layout":null,"metadata":null,"text":"In Star Atlas, guilds or guild-states will become the new hegemonic power.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":74,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_9":{"__typename":"Paragraph","id":"2cb2788d7d1b_9","name":"6603","type":"P","href":null,"layout":null,"metadata":null,"text":"And while Star Atlas and Web3 offers an opportunity at a more open, equitable, and decentralized society, the tools and governance systems to enable such an ideal are still nascent. Furthermore, human psychology and societal behavior has yet to adapt to these new ideological norms as well.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_10":{"__typename":"Paragraph","id":"2cb2788d7d1b_10","name":"9cae","type":"P","href":null,"layout":null,"metadata":null,"text":"Thus, without definitive evidence that Web3 technology will dramatically shift governance behavior, we must rely on well-established international relations concepts, modified slightly for the Star Atlas metaverse.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*feJFT5sw_Ed5JPjZ.jpg":{"__typename":"ImageMetadata","id":"0*feJFT5sw_Ed5JPjZ.jpg","originalHeight":479,"originalWidth":638,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:2cb2788d7d1b_11":{"__typename":"Paragraph","id":"2cb2788d7d1b_11","name":"84d9","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*feJFT5sw_Ed5JPjZ.jpg"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_12":{"__typename":"Paragraph","id":"2cb2788d7d1b_12","name":"a84c","type":"H4","href":null,"layout":null,"metadata":null,"text":"Defining Interstellar Relations","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":31,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_13":{"__typename":"Paragraph","id":"2cb2788d7d1b_13","name":"ec8d","type":"P","href":null,"layout":null,"metadata":null,"text":"In Star Atlas, the term international relations can be used interchangeably with the term interstellar relations. Additionally, nation-states can be replaced by guild-states. By establishing these two base terms, we can further dissect guild-state behavior.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":90,"end":112,"href":null,"anchorType":null,"userId":null,"linkMetadata":null},{"__typename":"Markup","type":"STRONG","start":161,"end":173,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_14":{"__typename":"Paragraph","id":"2cb2788d7d1b_14","name":"a95f","type":"H4","href":null,"layout":null,"metadata":null,"text":"Where defines a Guild-State?","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_15":{"__typename":"Paragraph","id":"2cb2788d7d1b_15","name":"de99","type":"P","href":null,"layout":null,"metadata":null,"text":"With a base framework in place, we can now begin assessing Star Atlas guild behavior. First, we must establish what is a guild-state.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_16":{"__typename":"Paragraph","id":"2cb2788d7d1b_16","name":"9e4c","type":"P","href":null,"layout":null,"metadata":null,"text":"While scholars have many overarching criteria for what defines a state, the common characteristics of states are:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_17":{"__typename":"Paragraph","id":"2cb2788d7d1b_17","name":"0dc9","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Definable and defendable borders recognized by other states","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":1,"end":59,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_18":{"__typename":"Paragraph","id":"2cb2788d7d1b_18","name":"e3ee","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Interstellar systems of government (hierarchies)","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":48,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_19":{"__typename":"Paragraph","id":"2cb2788d7d1b_19","name":"2b75","type":"ULI","href":null,"layout":null,"metadata":null,"text":"Sovereignty over territory (legitimate use of force, rule of law)","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":65,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_20":{"__typename":"Paragraph","id":"2cb2788d7d1b_20","name":"b333","type":"P","href":null,"layout":null,"metadata":null,"text":"If a Star Atlas guild meets, or seeks to meet, these criteria now or in the future, then they can be considered as a guild-state.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_21":{"__typename":"Paragraph","id":"2cb2788d7d1b_21","name":"9cb5","type":"H4","href":null,"layout":null,"metadata":null,"text":"Interstellar Relations — Idealism vs Realism","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":44,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_22":{"__typename":"Paragraph","id":"2cb2788d7d1b_22","name":"9bb3","type":"P","href":null,"layout":null,"metadata":null,"text":"In sum, the concepts of Interstellar Relations draw heavily upon the theories of Earth’s international relations. The two major paradigms of Liberalism and Realism remain largely intact until evidence suggests either these models prove non-applicable or the influence of Web3 technology evolves upon existing models.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_23":{"__typename":"Paragraph","id":"2cb2788d7d1b_23","name":"cd2b","type":"H4","href":null,"layout":null,"metadata":null,"text":"Liberalism","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":10,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_24":{"__typename":"Paragraph","id":"2cb2788d7d1b_24","name":"36c5","type":"P","href":null,"layout":null,"metadata":null,"text":"Liberalism is one of the two major theories in interstellar relations. Liberalism argues that all guild-states do not have the same goals based on selfish interests but that a guild-state will relate with another guild-state based on its internal norms and culture. Liberalist believe that human nature is not inherently bad, and that guild-states are capable of cooperating to the extent of forgoing their interests to achieve a collective goal.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_25":{"__typename":"Paragraph","id":"2cb2788d7d1b_25","name":"b170","type":"P","href":null,"layout":null,"metadata":null,"text":"Liberalism suggests, in fact, that guild-states can peacefully co-exist, and that guild-states aren’t always on the brink of war. Liberal scholars point to the fact that despite the persistence of armed conflict, most guild-states are not at war most of the time. Liberalism argues that relations between nations are not always a zero-sum game. A zero-sum game is one in which any gain by one player is automatically a loss by another player. One’s gains in security, for example, doesn’t make someone else worse off, and vice versa. Liberal theory also points to the fact that despite the condition of anarchy in the galaxy, most guild-states are not at war, most of the time. So, the idea that interstellar relations must be conducted as though one were always under the threat of attack isn’t necessarily indicative of reality.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":264,"end":344,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_26":{"__typename":"Paragraph","id":"2cb2788d7d1b_26","name":"7de0","type":"P","href":null,"layout":null,"metadata":null,"text":"Liberalists think that interactions between guild-states should be based on international law and morality, not just on power. Liberalists want to create a democratic and peaceful galaxy where everyone can have a say.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_27":{"__typename":"Paragraph","id":"2cb2788d7d1b_27","name":"09f7","type":"H4","href":null,"layout":null,"metadata":null,"text":"Realism","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":7,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_28":{"__typename":"Paragraph","id":"2cb2788d7d1b_28","name":"5f70","type":"P","href":null,"layout":null,"metadata":null,"text":"Realism is the other dominant schools of thought in interstellar relations theory, theoretically formalizing the Realpolitik statesmanship of early modern Earth. Although a highly diverse body of thought, it is unified by the belief that interstellar politics is always and necessarily a field of conflict among guild-states pursuing wealth and power. Realists think that individuals and society are not inherently benevolent but rather self-centered and competitive. This perspective, views humanoid nature as egocentric (not necessarily selfish) and conflictual unless there exist conditions under which beings may coexist. It is also disposed of the notion that an individual’s intuitive nature is made up of anarchy. In regard to self-interest, individuals and guild-states are self-reliant and are motivated in seeking more power.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_29":{"__typename":"Paragraph","id":"2cb2788d7d1b_29","name":"fd61","type":"P","href":null,"layout":null,"metadata":null,"text":"Realism suggests that guild-states should and do look out for their own interests first. Realism presumes that guild-states are out for themselves first and foremost. The galaxy is therefore a dangerous place; a guild-state has look out for themselves and prepare for the worst. What matters, then, is how much economic and especially military power a guild-state has. When your neighbor misbehaves, you can’t call the Council of Peace.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":89,"end":166,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_30":{"__typename":"Paragraph","id":"2cb2788d7d1b_30","name":"9957","type":"P","href":null,"layout":null,"metadata":null,"text":"Classical realists say this is just nature. By nature, individuals are at some level greedy and insecure and behave accordingly. So even if you’re not greedy and insecure, you have to behave that way, because that’s the game. Structural realists say it’s more about how the galaxy is organized — an anarchic system creates the Hobbesian state of nature, referring to the 16th century Earth philosopher who justified the existence of the guild-state by comparing it to a somewhat hypothetical “state of nature,” a war of all against all. So, guild-states should seek peace, but prepare for war.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_31":{"__typename":"Paragraph","id":"2cb2788d7d1b_31","name":"b99a","type":"H3","href":null,"layout":null,"metadata":null,"text":"Star Atlas Guild-States and Interstellar Relations","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_32":{"__typename":"Paragraph","id":"2cb2788d7d1b_32","name":"b41b","type":"P","href":null,"layout":null,"metadata":null,"text":"Through qualitative analysis of Star Atlas guild-state’s policies, actions, and public statements — particularly as they pertain towards other guild-states.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_33":{"__typename":"Paragraph","id":"2cb2788d7d1b_33","name":"4fc0","type":"P","href":null,"layout":null,"metadata":null,"text":"It’s important to note that ideologies of Guild-States can change over time. Further, a Guild-States outward interstellar relations behavior may or may not be indicative of Guild-State leader’s personnel beliefs. Guild-States that are more democratic in nature are likely to have policies that are reflective of the interests of the broader populous as opposed to a single individual or group.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_34":{"__typename":"Paragraph","id":"2cb2788d7d1b_34","name":"7b29","type":"P","href":null,"layout":null,"metadata":null,"text":"At the onset of 2023, a general analysis of the Star Atlas Interstellar Relations spectrum is thus:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*Nq_kLBq-yu6yTiAd1hbI2Q.png":{"__typename":"ImageMetadata","id":"1*Nq_kLBq-yu6yTiAd1hbI2Q.png","originalHeight":1383,"originalWidth":2524,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:2cb2788d7d1b_35":{"__typename":"Paragraph","id":"2cb2788d7d1b_35","name":"c62e","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*Nq_kLBq-yu6yTiAd1hbI2Q.png"},"text":"Star Atlas Interstellar Relations Spectrum","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_36":{"__typename":"Paragraph","id":"2cb2788d7d1b_36","name":"c2c9","type":"P","href":null,"layout":null,"metadata":null,"text":"Note: Guild-States denoted with an asterisk are confirmed Pirate Guilds. Should pirate guilds, or any other guild for that matter, not meet the criteria for a Guild-State then Interstellar Relations theory would prove inapplicable.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":0,"end":231,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_37":{"__typename":"Paragraph","id":"2cb2788d7d1b_37","name":"f159","type":"P","href":null,"layout":null,"metadata":null,"text":"As we can see from initial guild-state behavior, the scope of Star Atlas guilds covers nearly the entire Interstellar Relations spectrum, much like in international relations.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":175,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_38":{"__typename":"Paragraph","id":"2cb2788d7d1b_38","name":"05d3","type":"P","href":null,"layout":null,"metadata":null,"text":"Its important to note that Liberalism and Realism are not measures of whether a guild-state will initiate conflict. Instead, they are measures of how a guild-state is likely to perceive the Star Atlas metaverse and enact diplomatic policies.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"EM","start":50,"end":116,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_39":{"__typename":"Paragraph","id":"2cb2788d7d1b_39","name":"84ae","type":"P","href":null,"layout":null,"metadata":null,"text":"Guild-states that lean towards Realism view the Star Atlas system as anarchic, and thus view other guild-state security posturing with relative concern.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_40":{"__typename":"Paragraph","id":"2cb2788d7d1b_40","name":"7c32","type":"P","href":null,"layout":null,"metadata":null,"text":"Guild-states that lean towards idealism, believe that shared values and strong interstellar laws and customs will prevent increasing conflict.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_41":{"__typename":"Paragraph","id":"2cb2788d7d1b_41","name":"d7fc","type":"P","href":null,"layout":null,"metadata":null,"text":"Again, its important to note that Guild-state ideation is not reflective of any one individual within the guild-state, but rather a summation of an entire Guild-state’s governance and bureaucratic systems and policies. Guild-State behavior will certainly change over time, this is to be expected. Certain macro-governance effects may even skew the entire spectrum either towards Liberalism or Realism. In either case, by using the Guild-State framework, Interstellar Relations scientists and analysts can now begin to study, analyze, and discuss Guild-State behavior in Star Atlas.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_42":{"__typename":"Paragraph","id":"2cb2788d7d1b_42","name":"36b9","type":"P","href":null,"layout":null,"metadata":null,"text":"About the Author","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":16,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_43":{"__typename":"Paragraph","id":"2cb2788d7d1b_43","name":"11ea","type":"P","href":null,"layout":null,"metadata":null,"text":"Krigs is a pioneer in the world of Star Atlas, having founded The Hologram News Network — an independent meta-news organization that keeps players up to date on all developments regarding Star Atlas. An ardent supporter of emerging technologies, Krigs has been covering this game for over a year and believes passionately in their power to revolutionize our collective gaming experience.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_44":{"__typename":"Paragraph","id":"2cb2788d7d1b_44","name":"ba6e","type":"P","href":null,"layout":null,"metadata":null,"text":"Follow on Social Media:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_45":{"__typename":"Paragraph","id":"2cb2788d7d1b_45","name":"77e3","type":"P","href":null,"layout":null,"metadata":null,"text":"YouTube | Twitter | Instagram | Web","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":7,"href":"https:\u002F\u002Fwww.youtube.com\u002Fchannel\u002FUCDa-YxgNG6A9xpH1qyP0OaQ","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":10,"end":17,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":20,"end":29,"href":"https:\u002F\u002Ftwitter.com\u002Fhome","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":32,"end":35,"href":"https:\u002F\u002Fthehologram.io\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_46":{"__typename":"Paragraph","id":"2cb2788d7d1b_46","name":"6ba7","type":"P","href":null,"layout":null,"metadata":null,"text":"About The Hologram","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":18,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_47":{"__typename":"Paragraph","id":"2cb2788d7d1b_47","name":"97b1","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is Star Atlas’ first and only independent news network. Our vision is to become the most trusted source of information about Star Atlas and a voice for the whole community. Readers can expect a high standard from our reporting and staff. Our promise to you: we will not publish anything that hasn’t been thoroughly researched and based on the best facts available.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":12,"href":"https:\u002F\u002Fmedium.com\u002Fthe-hologram","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:2cb2788d7d1b_48":{"__typename":"Paragraph","id":"2cb2788d7d1b_48","name":"852e","type":"P","href":null,"layout":null,"metadata":null,"text":"The Hologram is not endorsed or paid by the Star Atlas team. Any information published by The Hologram nor its writers should be considered as informational in nature and does not constitute any financial advice.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":44,"end":54,"href":"https:\u002F\u002Fstaratlas.com\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:4d89daa6ae31-viewerId:lo_2a1d2071eacd":{"__typename":"CollectionViewerEdge","id":"collectionId:4d89daa6ae31-viewerId:lo_2a1d2071eacd","isEditor":false},"Tag:star-atlas":{"__typename":"Tag","id":"star-atlas","displayTitle":"Star Atlas","normalizedTagSlug":"star-atlas"},"Tag:politics":{"__typename":"Tag","id":"politics","displayTitle":"Politics","normalizedTagSlug":"politics"},"Post:946af14901cf":{"__typename":"Post","id":"946af14901cf","canonicalUrl":"","collection":{"__ref":"Collection:4d89daa6ae31"},"content({\"postMeteringOptions\":{\"forceTruncation\":false}})":{"__typename":"PostContent","isLockedPreviewOnly":false,"validatedShareKey":"","bodyModel":{"__typename":"RichText","sections":[{"__typename":"Section","name":"3dac","startIndex":0,"textLayout":null,"imageLayout":null,"backgroundImage":null,"videoLayout":null,"backgroundVideo":null},{"__typename":"Section","name":"893a","startIndex":42,"textLayout":null,"imageLayout":null,"backgroundImage":null,"videoLayout":null,"backgroundVideo":null}],"paragraphs":[{"__ref":"Paragraph:2cb2788d7d1b_0"},{"__ref":"Paragraph:2cb2788d7d1b_1"},{"__ref":"Paragraph:2cb2788d7d1b_2"},{"__ref":"Paragraph:2cb2788d7d1b_3"},{"__ref":"Paragraph:2cb2788d7d1b_4"},{"__ref":"Paragraph:2cb2788d7d1b_5"},{"__ref":"Paragraph:2cb2788d7d1b_6"},{"__ref":"Paragraph:2cb2788d7d1b_7"},{"__ref":"Paragraph:2cb2788d7d1b_8"},{"__ref":"Paragraph:2cb2788d7d1b_9"},{"__ref":"Paragraph:2cb2788d7d1b_10"},{"__ref":"Paragraph:2cb2788d7d1b_11"},{"__ref":"Paragraph:2cb2788d7d1b_12"},{"__ref":"Paragraph:2cb2788d7d1b_13"},{"__ref":"Paragraph:2cb2788d7d1b_14"},{"__ref":"Paragraph:2cb2788d7d1b_15"},{"__ref":"Paragraph:2cb2788d7d1b_16"},{"__ref":"Paragraph:2cb2788d7d1b_17"},{"__ref":"Paragraph:2cb2788d7d1b_18"},{"__ref":"Paragraph:2cb2788d7d1b_19"},{"__ref":"Paragraph:2cb2788d7d1b_20"},{"__ref":"Paragraph:2cb2788d7d1b_21"},{"__ref":"Paragraph:2cb2788d7d1b_22"},{"__ref":"Paragraph:2cb2788d7d1b_23"},{"__ref":"Paragraph:2cb2788d7d1b_24"},{"__ref":"Paragraph:2cb2788d7d1b_25"},{"__ref":"Paragraph:2cb2788d7d1b_26"},{"__ref":"Paragraph:2cb2788d7d1b_27"},{"__ref":"Paragraph:2cb2788d7d1b_28"},{"__ref":"Paragraph:2cb2788d7d1b_29"},{"__ref":"Paragraph:2cb2788d7d1b_30"},{"__ref":"Paragraph:2cb2788d7d1b_31"},{"__ref":"Paragraph:2cb2788d7d1b_32"},{"__ref":"Paragraph:2cb2788d7d1b_33"},{"__ref":"Paragraph:2cb2788d7d1b_34"},{"__ref":"Paragraph:2cb2788d7d1b_35"},{"__ref":"Paragraph:2cb2788d7d1b_36"},{"__ref":"Paragraph:2cb2788d7d1b_37"},{"__ref":"Paragraph:2cb2788d7d1b_38"},{"__ref":"Paragraph:2cb2788d7d1b_39"},{"__ref":"Paragraph:2cb2788d7d1b_40"},{"__ref":"Paragraph:2cb2788d7d1b_41"},{"__ref":"Paragraph:2cb2788d7d1b_42"},{"__ref":"Paragraph:2cb2788d7d1b_43"},{"__ref":"Paragraph:2cb2788d7d1b_44"},{"__ref":"Paragraph:2cb2788d7d1b_45"},{"__ref":"Paragraph:2cb2788d7d1b_46"},{"__ref":"Paragraph:2cb2788d7d1b_47"},{"__ref":"Paragraph:2cb2788d7d1b_48"}]}},"creator":{"__ref":"User:41e0c5b141f1"},"customStyleSheet":null,"isPublished":true,"isLocked":false,"license":"ALL_RIGHTS_RESERVED","collaborators":[],"statusForCollection":"APPROVED","isMarkedPaywallOnly":false,"lockedSource":"LOCKED_POST_SOURCE_NONE","mediumUrl":"https:\u002F\u002Fmedium.com\u002Fthe-hologram\u002Fthe-guild-state-a-framework-for-understanding-guild-behavior-in-star-atlas-946af14901cf","primaryTopic":null,"topics":[],"viewerEdge":{"__ref":"PostViewerEdge:postId:946af14901cf-viewerId:lo_2a1d2071eacd"},"latestPublishedVersion":"2cb2788d7d1b","visibility":"PUBLIC","postResponses":{"__typename":"PostResponses","count":0},"allowResponses":true,"isLimitedState":false,"voterCount":0,"recommenders":[],"isSeries":false,"sequence":null,"uniqueSlug":"the-guild-state-a-framework-for-understanding-guild-behavior-in-star-atlas-946af14901cf","title":"The Guild-State: A Framework for Understanding Guild Behavior in Star Atlas","clapCount":0,"pinnedAt":0,"pinnedByCreatorAt":0,"curationEligibleAt":0,"responseDistribution":"NOT_DISTRIBUTED","inResponseToPostResult":null,"inResponseToCatalogResult":null,"pendingCollection":null,"isNewsletter":false,"isAuthorNewsletter":true,"firstPublishedAt":1674326238853,"layerCake":0,"tags":[{"__ref":"Tag:star-atlas"},{"__ref":"Tag:politics"}],"readingTime":6.621698113207547,"inResponseToEntityType":null,"socialTitle":"","socialDek":"","noIndex":null,"curationStatus":"CURATION_STATUS_DISABLED","metaDescription":"","latestPublishedAt":1674326238853,"previewContent":{"__typename":"PreviewContent","subtitle":"For many, Star Atlas is a grand-strategy MMORPG filled with space battles and galactic conquest. But to others, Star Atlas represents…"},"previewImage":{"__ref":"ImageMetadata:1*bIlWBY4rplFyIOZZyGJ9jw.png"},"isShortform":false,"seoTitle":"","updatedAt":1674326245182,"shortformType":"SHORTFORM_TYPE_LINK","seoDescription":"","isIndexable":true,"isSuspended":false,"responseRootPost":{"__typename":"ResponseRootPost","post":{"__ref":"Post:946af14901cf"}},"internalLinks({\"paging\":{\"limit\":8}})":{"__typename":"InternalLinksConnection","items":[]},"awards:countToShowAwardBadge(type:STAFF_PICK,limit:1)":{"__typename":"AwardConnection","totalCount":0,"awards":[]}}}</script><script>window.__MIDDLEWARE_STATE__={"session":{"xsrf":""},"cache":{"cacheStatus":"HIT","inDisabledExperiment":false}}</script><script src="https://cdn-client.medium.com/lite/static/js/manifest.56d6982e.js"></script><script src="https://cdn-client.medium.com/lite/static/js/7505.62df2c9c.js"></script><script src="https://cdn-client.medium.com/lite/static/js/main.a649148b.js"></script><script src="https://cdn-client.medium.com/lite/static/js/instrumentation.c71f0248.chunk.js"></script>
